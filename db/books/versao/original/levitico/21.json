        { "hebraico": "יְהוָ֖ה", "transliteral": "YHWH", "traducao_palavra": "YHWH" },
        { "hebraico": "מְקַדִּשְׁכֶֽם׃", "transliteral": "mə-qad-diš-ḵem", "traducao_palavra": "que vos santifico" }
