{
  "livro": "Levítico - וַיִּקְרָא - Vayikra",
  "capítulo": 21,
  "titulos": {},
  "versiculos": {
    "1": {
      "traducao_completa": "Depois disse YHWH a Moisés: Fala aos sacerdotes, filhos de Arão, e dize-lhes: O sacerdote não se contaminará por causa de um morto entre o seu povo,",
      "palavras": [
        { "hebraico": "וַיֹּ֤אמֶר", "transliteral": "way-yō-mer", "traducao_palavra": "e disse" },
        { "hebraico": "יְהוָה֙", "transliteral": "YHWH", "traducao_palavra": "YHWH" },
        { "hebraico": "אֶל־מֹשֶׁ֔ה", "transliteral": "ʾel-mō-šeh", "traducao_palavra": "a Moisés" },
        { "hebraico": "אֱמֹ֥ר", "transliteral": "ʾĕ-mōr", "traducao_palavra": "fala" },
        { "hebraico": "אֶל־הַכֹּהֲנִ֖ים", "transliteral": "ʾel-hak-kō-hă-nîm", "traducao_palavra": "aos sacerdotes" },
        { "hebraico": "בְּנֵ֣י", "transliteral": "bə-nê", "traducao_palavra": "filhos de" },
        { "hebraico": "אַהֲרֹ֑ן", "transliteral": "ʾa-hă-rōn", "traducao_palavra": "Arão" },
        { "hebraico": "וְאָמַרְתָּ֣", "transliteral": "wə-ʾā-mar-tā", "traducao_palavra": "e dize" },
        { "hebraico": "אֲלֵיהֶ֔ם", "transliteral": "ʾă-lê-hem", "traducao_palavra": "a eles" },
        { "hebraico": "לְנֶ֥פֶשׁ", "transliteral": "lə-ne-p̄eš", "traducao_palavra": "por uma alma [morto]" },
        { "hebraico": "לֹֽא־יִטַּמָּ֖א", "transliteral": "lō-yiṭ-ṭam-mā", "traducao_palavra": "não se contaminará" },
        { "hebraico": "בְּעַמָּֽיו׃", "transliteral": "bə-ʿam-māyw", "traducao_palavra": "entre o seu povo" }
      ]
    },
    "2": {
      "traducao_completa": "Salvo por seu parente mais próximo: por sua mãe, e por seu pai, e por seu filho, e por sua filha, e por seu irmão.",
      "palavras": [
        { "hebraico": "כִּ֚י", "transliteral": "kî", "traducao_palavra": "exceto" },
        { "hebraico": "אִם־לִשְׁאֵרֹ֔ו", "transliteral": "ʾim-liš-ʾê-rô", "traducao_palavra": "por seu parente" },
        { "hebraico": "הַקָּרֹ֖ב", "transliteral": "ha-qā-rōḇ", "traducao_palavra": "o próximo" },
        { "hebraico": "אֵלָ֑יו", "transliteral": "ʾê-lāyw", "traducao_palavra": "a ele" },
        { "hebraico": "לְאִמֹּ֣ו", "transliteral": "lə-ʾim-mô", "traducao_palavra": "por sua mãe" },
        { "hebraico": "וּלְאָבִ֔יו", "transliteral": "ū-lə-ʾā-ḇîw", "traducao_palavra": "e por seu pai" },
        { "hebraico": "וּלְבְנֹ֥ו", "transliteral": "ū-lə-ḇə-nô", "traducao_palavra": "e por seu filho" },
        { "hebraico": "וּלְבִתֹּ֖ו", "transliteral": "ū-lə-ḇit-tô", "traducao_palavra": "e por sua filha" },
        { "hebraico": "וּלְאָחִֽיו׃", "transliteral": "ū-lə-ʾā-ḥîw", "traducao_palavra": "e por seu irmão" }
      ]
    },
    "3": {
      "traducao_completa": "E por sua irmã virgem, que lhe é próxima, que ainda não teve marido; por ela se pode contaminar.",
      "palavras": [
        { "hebraico": "וּלְאֲחֹתֹ֣ו", "transliteral": "ū-lə-ʾă-ḥō-ṯô", "traducao_palavra": "e por sua irmã" },
        { "hebraico": "הַבְּתוּלָה֮", "transliteral": "hab-bə-ṯû-lā", "traducao_palavra": "a virgem" },
        { "hebraico": "הַקְּרוֹבָ֣ה", "transliteral": "haq-qə-rō-ḇā", "traducao_palavra": "a próxima" },
        { "hebraico": "אֵלָיו֒", "transliteral": "ʾê-lāyw", "traducao_palavra": "a ele" },
        { "hebraico": "אֲשֶׁ֥ר", "transliteral": "ʾă-šer", "traducao_palavra": "que" },
        { "hebraico": "לֹא־הָיְתָ֥ה", "transliteral": "lō-hā-yə-ṯā", "traducao_palavra": "não foi/teve" },
        { "hebraico": "לְאִ֑ישׁ", "transliteral": "lə-ʾîš", "traducao_palavra": "marido" },
        { "hebraico": "לָ֖הּ", "transliteral": "lāh", "traducao_palavra": "por ela" },
        { "hebraico": "יִטַּמָּֽא׃", "transliteral": "yiṭ-ṭam-mā", "traducao_palavra": "ele se contaminará" }
      ]
    },
    "4": {
      "traducao_completa": "Ele, sendo principal entre o seu povo, não se contaminará, para se profanar.",
      "palavras": [
        { "hebraico": "לֹ֥א", "transliteral": "lō", "traducao_palavra": "não" },
        { "hebraico": "יִטַּמָּ֖א", "transliteral": "yiṭ-ṭam-mā", "traducao_palavra": "se contaminará" },
