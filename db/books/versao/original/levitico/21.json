        { "hebraico": "אֱלֹהֶ֖יךָ", "transliteral": "ʾĕ-lō-he-ḵā", "traducao_palavra": "teu Deus" },
        { "hebraico": "ה֣וּא", "transliteral": "hû", "traducao_palavra": "ele" },
        { "hebraico": "מַקְרִ֑יב", "transliteral": "maq-rîḇ", "traducao_palavra": "oferece" },
        { "hebraico": "קָדֹושׁ֙", "transliteral": "qā-ḏôš", "traducao_palavra": "santo" },
        { "hebraico": "יִֽהְיֶה־לָּ֔ךְ", "transliteral": "yih-yeh-lāḵ", "traducao_palavra": "será para ti" },
        { "hebraico": "כִּ֣י", "transliteral": "kî", "traducao_palavra": "porque" },
        { "hebraico": "קָדֹ֔ושׁ", "transliteral": "qā-ḏôš", "traducao_palavra": "santo [sou]" },
