        { "hebraico": "זֹנָ֧ה", "transliteral": "zō-nā", "traducao_palavra": "prostituta" },
        { "hebraico": "וַחֲלָלָ֛ה", "transliteral": "wa-ḥă-lā-lā", "traducao_palavra": "ou profanada/desonrada" },
        { "hebraico": "לֹ֥א", "transliteral": "lō", "traducao_palavra": "não" },
        { "hebraico": "יִקָּ֑חוּ", "transliteral": "yiq-qā-ḥû", "traducao_palavra": "tomarão" },
        { "hebraico": "וְאִשָּׁ֛ה", "transliteral": "wə-ʾiš-šā", "traducao_palavra": "e mulher" },
