    "8": {
      "traducao_completa": "Portanto o santificarás, porquanto oferece o pão do teu Deus; santo será para ti, pois eu, YHWH que vos santifico, sou santo.",
      "palavras": [
        { "hebraico": "וְקִדַּשְׁתֹּו֙", "transliteral": "wə-qid-daš-tô", "traducao_palavra": "e o santificarás" },
