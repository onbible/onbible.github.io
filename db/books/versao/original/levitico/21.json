        { "hebraico": "קָרְחָה֙", "transliteral": "qār-ḥā", "traducao_palavra": "calva" },
        { "hebraico": "בְּרֹאשָׁ֔ם", "transliteral": "bə-rō-šām", "traducao_palavra": "em sua cabeça" },
        { "hebraico": "וּפְאַ֥ת", "transliteral": "ū-p̄ə-ʾaṯ", "traducao_palavra": "e o canto de" },
        { "hebraico": "זְקָנָ֖ם", "transliteral": "zə-qā-nām", "traducao_palavra": "sua barba" },
        { "hebraico": "לֹ֣א", "transliteral": "lō", "traducao_palavra": "não" },
        { "hebraico": "יְגַלֵּ֑חוּ", "transliteral": "yə-ḡal-lê-ḥû", "traducao_palavra": "raparão" },
        { "hebraico": "וּבִבְשָׂרָ֔ם", "transliteral": "ū-ḇiḇ-śā-rām", "traducao_palavra": "e em sua carne" },
        { "hebraico": "לֹ֥א", "transliteral": "lō", "traducao_palavra": "não" },
        { "hebraico": "יִשְׂרְט֖וּ", "transliteral": "yiś-rə-ṭû", "traducao_palavra": "farão cortes/lacerações" },
