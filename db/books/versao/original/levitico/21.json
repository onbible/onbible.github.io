        { "hebraico": "מֵ֖ת", "transliteral": "mêṯ", "traducao_palavra": "mortas" },
        { "hebraico": "לֹ֣א", "transliteral": "lō", "traducao_palavra": "não" },
        { "hebraico": "יָבֹ֑א", "transliteral": "yā-ḇō", "traducao_palavra": "chegará" },
        { "hebraico": "לְאָבִ֥יו", "transliteral": "lə-ʾā-ḇîw", "traducao_palavra": "por seu pai" },
