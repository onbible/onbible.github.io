        { "hebraico": "מֵאֶחָ֜יו", "transliteral": "mê-ʾe-ḥāyw", "traducao_palavra": "entre seus irmãos" },
        { "hebraico": "אֲשֶׁר־יוּצַ֨ק", "transliteral": "ʾă-šer-yû-ṣaq", "traducao_palavra": "sobre o qual foi derramado" },
        { "hebraico": "עַל־רֹאשֹׁ֜ו", "transliteral": "ʿal-rō-šô", "traducao_palavra": "sobre sua cabeça" },
        { "hebraico": "שֶׁ֣מֶן", "transliteral": "še-men", "traducao_palavra": "azeite de" },
        { "hebraico": "הַמִּשְׁחָ֗ה", "transliteral": "ham-miš-ḥā", "traducao_palavra": "unção" },
        { "hebraico": "וּמִלֵּא֙", "transliteral": "ū-mil-lē", "traducao_palavra": "e foi consagrado [encheu]" },
        { "hebraico": "אֶת־יָדֹ֔ו", "transliteral": "ʾeṯ yā-ḏô", "traducao_palavra": "sua mão" },
        { "hebraico": "לִלְבֹּ֖שׁ", "transliteral": "lil-bōš", "traducao_palavra": "para vestir" },
        { "hebraico": "אֶת־הַבְּגָדִ֑ים", "transliteral": "ʾeṯ hab-bə-ḡā-ḏîm", "traducao_palavra": "as vestes" },
        { "hebraico": "אֶת־רֹאשֹׁו֙", "transliteral": "ʾeṯ rō-šô", "traducao_palavra": "sua cabeça" },
        { "hebraico": "לֹ֣א", "transliteral": "lō", "traducao_palavra": "não" },
