        { "hebraico": "כִּ֥י", "transliteral": "kî", "traducao_palavra": "quando" },
        { "hebraico": "תֵחֵ֖ל", "transliteral": "ṯê-ḥêl", "traducao_palavra": "começar" },
        { "hebraico": "לִזְנֹ֑ות", "transliteral": "liz-nôṯ", "traducao_palavra": "a prostituir-se" },
        { "hebraico": "אֶת־אָבִ֙יהָ֙", "transliteral": "ʾeṯ-ʾā-ḇî-hā", "traducao_palavra": "a seu pai" },
        { "hebraico": "הִ֣יא", "transliteral": "hî", "traducao_palavra": "ela" },
        { "hebraico": "מְחַלֶּ֔לֶת", "transliteral": "mə-ḥal-le-leṯ", "traducao_palavra": "profana" },
        { "hebraico": "בָּאֵ֖שׁ", "transliteral": "bā-ʾēš", "traducao_palavra": "no fogo" },
        { "hebraico": "תִּשָּׂרֵֽף׃", "transliteral": "tiś-śā-rēp̄", "traducao_palavra": "será queimada" }
      ]
    },
    "10": {
      "traducao_completa": "E o sumo sacerdote entre seus irmãos, sobre cuja cabeça foi derramado o azeite da unção, e que for consagrado para vestir as vestes, não descobrirá a sua cabeça nem rasgará as suas vestes;",
      "palavras": [
        { "hebraico": "וְהַכֹּהֵן֩", "transliteral": "wə-hak-kō-hên", "traducao_palavra": "e o sacerdote" },
