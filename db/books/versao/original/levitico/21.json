        { "hebraico": "אֱלֹהֵיהֶ֑ם", "transliteral": "ʾĕ-lō-hê-hem", "traducao_palavra": "seu Deus" },
        { "hebraico": "כִּי֩", "transliteral": "kî", "traducao_palavra": "porque" },
        { "hebraico": "אֶת־אִשֵּׁ֨י", "transliteral": "ʾeṯ-ʾiš-šê", "traducao_palavra": "as ofertas queimadas de" },
        { "hebraico": "יְהוָ֜ה", "transliteral": "YHWH", "traducao_palavra": "YHWH" },
        { "hebraico": "לֶ֧חֶם", "transliteral": "le-ḥem", "traducao_palavra": "[o] pão de" },
        { "hebraico": "אֱלֹהֵיהֶ֛ם", "transliteral": "ʾĕ-lō-hê-hem", "traducao_palavra": "seu Deus" },
        { "hebraico": "הֵ֥ם", "transliteral": "hêm", "traducao_palavra": "eles" },
