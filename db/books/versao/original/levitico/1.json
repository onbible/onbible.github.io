{
  "livro": "Levítico - וַיִּקְרָא - Vayikra",
  "capítulo": 1,
  "titulos": {},
  "versiculos": {
    "1": {
      "traducao_completa": "E chamou a Moisés, e falou YHWH a ele da tenda da congregação, dizendo:",
      "palavras": [
        { "hebraico": "וַיִּקְרָא", "transliteral": "way-yiq-rā", "traducao_palavra": "e chamou" },
        { "hebraico": "אֶל־מֹשֶׁה", "transliteral": "ʾel-mō-šeh", "traducao_palavra": "a Moisés" },
        { "hebraico": "וַיְדַבֵּר", "transliteral": "way-yə-ḏab-bēr", "traducao_palavra": "e falou" },
        { "hebraico": "יְהוָה", "transliteral": "YHWH", "traducao_palavra": "YHWH" },
        { "hebraico": "אֵלָיו", "transliteral": "ʾē-lāyw", "traducao_palavra": "a ele" },
        { "hebraico": "מֵאֹהֶל", "transliteral": "mē-ʾō-hel", "traducao_palavra": "da tenda de" },
        { "hebraico": "מוֹעֵד", "transliteral": "mô-ʿēḏ", "traducao_palavra": "congregação" },
        { "hebraico": "לֵּאמֹר׃", "transliteral": "lē-mōr", "traducao_palavra": "dizendo" }
      ]
    },
    "2": {
      "traducao_completa": "Fala aos filhos de Israel e dize-lhes: Quando um homem entre vós trouxer uma oferta a YHWH, do gado, [isto é], do boi ou do rebanho, trareis a vossa oferta.",
      "palavras": [
        { "hebraico": "דַּבֵּר", "transliteral": "dab-bēr", "traducao_palavra": "fala" },
        { "hebraico": "אֶל־בְּנֵי", "transliteral": "ʾel-bə-nê", "traducao_palavra": "aos filhos de" },
        { "hebraico": "יִשְׂרָאֵל", "transliteral": "yiś-rā-ʾēl", "traducao_palavra": "Israel" },
        { "hebraico": "וְאָמַרְתָּ", "transliteral": "wə-ʾā-mar-tā", "traducao_palavra": "e dirás" },
        { "hebraico": "אֲלֵהֶם", "transliteral": "ʾă-lê-hem", "traducao_palavra": "a eles" },
        { "hebraico": "אָדָם", "transliteral": "ʾā-ḏām", "traducao_palavra": "[um] homem" },
        { "hebraico": "כִּי־יַקְרִיב", "transliteral": "kî-yaq-rîḇ", "traducao_palavra": "quando trouxer/oferecer" },
        { "hebraico": "מִכֶּם", "transliteral": "mik-kem", "traducao_palavra": "de vós" },
        { "hebraico": "קָרְבָּן", "transliteral": "qā-rə-bān", "traducao_palavra": "oferta" },
        { "hebraico": "לַיהוָה", "transliteral": "la-YHWH", "traducao_palavra": "a YHWH" }
      ]
    },
    "3": {
      "traducao_completa": "Se a sua oferta for holocausto de gado, oferecerá macho sem defeito; à porta da tenda da congregação o oferecerá, para que seja aceito perante YHWH.",
      "palavras": [
        { "hebraico": "אִם־עֹלָה", "transliteral": "ʾim-ʿō-lā", "traducao_palavra": "se holocausto" },
        { "hebraico": "קָרְבָּנוֹ", "transliteral": "qā-rə-bā-nô", "traducao_palavra": "[for] sua oferta" },
        { "hebraico": "מִן־הַבָּקָר", "transliteral": "min-hab-bā-qār", "traducao_palavra": "do gado" },
        { "hebraico": "זָכָר", "transliteral": "zā-ḵār", "traducao_palavra": "macho" },
        { "hebraico": "תָּמִים", "transliteral": "tā-mîm", "traducao_palavra": "perfeito/íntegro" },
        { "hebraico": "יַקְרִיבֶנּוּ", "transliteral": "yaq-rî-ḇen-nû", "traducao_palavra": "ele o oferecerá" }
      ]
    },
    "4": {
      "traducao_completa": "E porá a sua mão sobre a cabeça do holocausto, para que seja aceito a favor dele, para fazer expiação por ele.",
      "palavras": [
        { "hebraico": "וְסָמַךְ", "transliteral": "wə-sā-maḵ", "traducao_palavra": "e apoiará/porá" },
        { "hebraico": "יָדוֹ", "transliteral": "yā-ḏô", "traducao_palavra": "sua mão" },
        { "hebraico": "עַל", "transliteral": "ʿal", "traducao_palavra": "sobre" },
        { "hebraico": "רֹאשׁ", "transliteral": "rōš", "traducao_palavra": "cabeça de" },
        { "hebraico": "הָעֹלָה", "transliteral": "hā-ʿō-lā", "traducao_palavra": "o holocausto" },
        { "hebraico": "וְנִרְצָה", "transliteral": "wə-nir-ṣā", "traducao_palavra": "e será aceito" },
        { "hebraico": "לּוֹ", "transliteral": "lô", "traducao_palavra": "para ele" },
        { "hebraico": "לְכַפֵּר", "transliteral": "lə-ḵap-pēr", "traducao_palavra": "para expiar" },
        { "hebraico": "עָלָיו׃", "transliteral": "ʿā-lāyw", "traducao_palavra": "sobre ele" }
      ]
    },
    "5": {
      "traducao_completa": "Depois degolará o bezerro perante YHWH; e os filhos de Arão, os sacerdotes, oferecerão o sangue, e aspergirão o sangue ao redor sobre o altar que está diante da porta da tenda da congregação.",
      "palavras": [
        { "hebraico": "וְשָׁחַט", "transliteral": "wə-šā-ḥaṭ", "traducao_palavra": "e degolará" },
        { "hebraico": "אֶת־בֶּן", "transliteral": "ʾeṯ-ben", "traducao_palavra": "[o] filho de" },
        { "hebraico": "הַבָּקָר", "transliteral": "hab-bā-qār", "traducao_palavra": "o gado" },
        { "hebraico": "לִפְנֵי", "transliteral": "lip̄-nê", "traducao_palavra": "diante de" },
        { "hebraico": "יְהוָה", "transliteral": "YHWH", "traducao_palavra": "YHWH" }
      ]
    },
    "6": {
      "traducao_completa": "Então esfolará o holocausto, e o partirá nos seus pedaços.",
      "palavras": [
        { "hebraico": "וְהִפְשִׁיט", "transliteral": "wə-hip̄-šîṭ", "traducao_palavra": "e esfolará" },
        { "hebraico": "אֶת־הָעֹלָה", "transliteral": "ʾeṯ-hā-ʿō-lā", "traducao_palavra": "o holocausto" },
        { "hebraico": "וְנִתַּח", "transliteral": "wə-nit-taḥ", "traducao_palavra": "e partirá" },
        { "hebraico": "אֹתָהּ", "transliteral": "ʾō-ṯāh", "traducao_palavra": "ele" },
        { "hebraico": "לִנְתָחֶיהָ׃", "transliteral": "lin-ṯā-ḥe-hā", "traducao_palavra": "em seus pedaços" }
      ]
    },
    "7": {
      "traducao_completa": "E os filhos de Arão, o sacerdote, porão fogo sobre o altar, pondo em ordem a lenha sobre o fogo.",
      "palavras": [
        { "hebraico": "וְנָתְנוּ", "transliteral": "wə-nā-ṯə-nû", "traducao_palavra": "e porão" },
        { "hebraico": "בְּנֵי", "transliteral": "bə-nê", "traducao_palavra": "os filhos de" },
        { "hebraico": "אַהֲרֹן", "transliteral": "ʾa-hă-rōn", "traducao_palavra": "Arão" },
        { "hebraico": "הַכֹּהֵן", "transliteral": "hak-kō-hên", "traducao_palavra": "o sacerdote" },
        { "hebraico": "אֵשׁ", "transliteral": "ʾēš", "traducao_palavra": "fogo" },
        { "hebraico": "עַל־הַמִּזְבֵּחַ", "transliteral": "ʿal-ham-miz-bē-aḥ", "traducao_palavra": "sobre o altar" }
      ]
    },
    "8": {
      "traducao_completa": "E os filhos de Arão, os sacerdotes, porão em ordem os pedaços, a cabeça e a gordura sobre a lenha que está no fogo em cima do altar.",
      "palavras": [
        { "hebraico": "וְעָרְכוּ", "transliteral": "wə-ʿā-rə-ḵû", "traducao_palavra": "e porão em ordem" },
        { "hebraico": "בְּנֵי", "transliteral": "bə-nê", "traducao_palavra": "os filhos de" },
        { "hebraico": "אַהֲרֹן", "transliteral": "ʾa-hă-rōn", "traducao_palavra": "Arão" },
        { "hebraico": "הַכֹּהֲנִים", "transliteral": "hak-kō-hă-nîm", "traducao_palavra": "os sacerdotes" }
      ]
    },
    "9": {
      "traducao_completa": "Porém as suas entranhas e as suas pernas lavar-se-ão com água; e o sacerdote queimará tudo sobre o altar; holocausto é, oferta queimada de aroma suave a YHWH.",
      "palavras": [
        { "hebraico": "וְקִרְבּוֹ", "transliteral": "wə-qir-bô", "traducao_palavra": "e sua entranha" },
        { "hebraico": "וּכְרָעָיו", "transliteral": "û-ḵə-rā-ʿāyw", "traducao_palavra": "e suas pernas" },
        { "hebraico": "יִרְחַץ", "transliteral": "yir-ḥaṣ", "traducao_palavra": "lavará" },
        { "hebraico": "בַּמָּיִם", "transliteral": "bam-mā-yim", "traducao_palavra": "na água" },
        { "hebraico": "וְהִקְטִיר", "transliteral": "wə-hiq-ṭîr", "traducao_palavra": "e queimará" },
        { "hebraico": "הַכֹּהֵן", "transliteral": "hak-kō-hên", "traducao_palavra": "o sacerdote" },
        { "hebraico": "אֶת־הַכֹּל", "transliteral": "ʾeṯ-hak-kōl", "traducao_palavra": "o todo" },
        { "hebraico": "הַמִּזְבֵּחָה", "transliteral": "ham-miz-bê-ḥā", "traducao_palavra": "no altar" },
        { "hebraico": "עֹלָה", "transliteral": "ʿō-lā", "traducao_palavra": "holocausto" },
        { "hebraico": "אִשֵּׁה", "transliteral": "ʾiš-šē", "traducao_palavra": "oferta de fogo" },
        { "hebraico": "רֵיחַ־נִיחֹחַ", "transliteral": "rê-aḥ-nî-ḥō-aḥ", "traducao_palavra": "aroma de descanso" },
        { "hebraico": "לַיהוָה׃", "transliteral": "la-YHWH", "traducao_palavra": "a YHWH" }
      ]
    },
    "10": {
      "traducao_completa": "E se a sua oferta for do rebanho, das ovelhas ou das cabras, para holocausto, oferecerá macho sem defeito.",
      "palavras": [
        { "hebraico": "וְאִם־מִן־הַצֹּאן", "transliteral": "wə-ʾim-min-haṣ-ṣōn", "traducao_palavra": "e se do rebanho" }
      ]
    },
    "11": {
      "traducao_completa": "E o degolará ao lado do altar que dá para o norte, perante YHWH; e os filhos de Arão, os sacerdotes, aspergirão o seu sangue sobre o altar ao redor.",
      "palavras": [
        { "hebraico": "וְשָׁחַט", "transliteral": "wə-šā-ḥaṭ", "traducao_palavra": "e degolará" },
        { "hebraico": "אֹתוֹ", "transliteral": "ʾō-ṯô", "traducao_palavra": "ele" },
        { "hebraico": "עַל", "transliteral": "ʿal", "traducao_palavra": "sobre" },
        { "hebraico": "יֶרֶךְ", "transliteral": "ye-reḵ", "traducao_palavra": "o lado de" },
        { "hebraico": "הַמִּזְבֵּחַ", "transliteral": "ham-miz-bē-aḥ", "traducao_palavra": "o altar" },
        { "hebraico": "צָפֹנָה", "transliteral": "ṣā-p̄ō-nā", "traducao_palavra": "ao norte" }
      ]
    },
    "12": {
      "traducao_completa": "E o partirá nos seus pedaços, como também a sua cabeça e a sua gordura; e o sacerdote os porá em ordem sobre a lenha que está no fogo em cima do altar.",
      "palavras": [
        { "hebraico": "וְנִתַּח", "transliteral": "wə-nit-taḥ", "traducao_palavra": "e partirá" }
      ]
    },
    "13": {
      "traducao_completa": "Mas as entranhas e as pernas lavar-se-ão com água; e o sacerdote oferecerá tudo, e o queimará sobre o altar; holocausto é, oferta queimada de aroma suave a YHWH.",
      "palavras": [
        { "hebraico": "וְהַקֶּרֶב", "transliteral": "wə-haq-qe-reḇ", "traducao_palavra": "e a entranha" }
      ]
    },
    "14": {
      "traducao_completa": "E se a sua oferta a YHWH for holocausto de aves, oferecerá a sua oferta de rolas ou de pombinhos.",
      "palavras": [
        { "hebraico": "וְאִם", "transliteral": "wə-ʾim", "traducao_palavra": "e se" },
        { "hebraico": "מִן־הָעוֹף", "transliteral": "min-hā-ʿôp̄", "traducao_palavra": "das aves" },
        { "hebraico": "עֹלָה", "transliteral": "ʿō-lā", "traducao_palavra": "[for] holocausto" }
      ]
    },
    "15": {
      "traducao_completa": "E o sacerdote a trará ao altar, e lhe torcerá o pescoço, e a queimará sobre o altar; e o seu sangue será espremido na parede do altar.",
      "palavras": [
        { "hebraico": "וְהִקְרִיבוֹ", "transliteral": "wə-hiq-rî-ḇô", "traducao_palavra": "e a trará" },
        { "hebraico": "הַכֹּהֵן", "transliteral": "hak-kō-hên", "traducao_palavra": "o sacerdote" },
        { "hebraico": "אֶל־הַמִּזְבֵּחַ", "transliteral": "ʾel-ham-miz-bē-aḥ", "traducao_palavra": "ao altar" },
        { "hebraico": "וּמָלַק", "transliteral": "û-mā-laq", "traducao_palavra": "e torcerá [a unha]" },
        { "hebraico": "אֶת־רֹאשׁוֹ", "transliteral": "ʾeṯ-rō-šô", "traducao_palavra": "a sua cabeça" }
      ]
    },
    "16": {
      "traducao_completa": "E o seu papo com as suas penas tirará e o lançará junto ao altar, para o oriente, no lugar da cinza.",
      "palavras": [
        { "hebraico": "וְהֵסִיר", "transliteral": "wə-hē-sîr", "traducao_palavra": "e tirará" },
        { "hebraico": "אֶת־מֻרְאָתוֹ", "transliteral": "ʾeṯ-mur-ʾā-ṯô", "traducao_palavra": "o seu papo" }
      ]
    },
    "17": {
      "traducao_completa": "E partí-la-á pelas suas asas, porém não a dividirá; e o sacerdote a queimará sobre o altar em cima da lenha que está no fogo; holocausto é, oferta queimada de aroma suave a YHWH.",
      "palavras": [
        { "hebraico": "וְשִׁסַּע", "transliteral": "wə-šis-saʿ", "traducao_palavra": "e a fenderá" },
        { "hebraico": "אֹתוֹ", "transliteral": "ʾō-ṯô", "traducao_palavra": "ela" },
        { "hebraico": "בִכְנָפָיו", "transliteral": "ḇiḵ-nā-p̄āyw", "traducao_palavra": "pelas suas asas" },
        { "hebraico": "לֹא", "transliteral": "lō", "traducao_palavra": "não" },
        { "hebraico": "יַבְדִּיל", "transliteral": "yaḇ-dîl", "traducao_palavra": "dividirá" },
        { "hebraico": "וְהִקְטִיר", "transliteral": "wə-hiq-ṭîr", "traducao_palavra": "e queimará" }
      ]
    }
  }
}