        { "hebraico": "וְאָשֵׁם׃", "transliteral": "wə-ʾā-šēm", "traducao_palavra": "e for culpado" }
      ]
    },
    "23": {
      "traducao_completa": "Ou se o seu pecado, no qual pecou, lhe for notificado, então trará por sua oferta um bode, macho sem defeito.",
      "palavras": [
        { "hebraico": "אוֹ", "transliteral": "ʾô", "traducao_palavra": "ou" },
        { "hebraico": "הוֹדַע", "transliteral": "hô-ḏaʿ", "traducao_palavra": "for notificado/conhecido" },
        { "hebraico": "אֵלָיו", "transliteral": "ʾē-lāyw", "traducao_palavra": "a ele" },
        { "hebraico": "חַטָּאתוֹ", "transliteral": "ḥaṭ-ṭā-ṯô", "traducao_palavra": "seu pecado" },
        { "hebraico": "וְהֵבִיא", "transliteral": "wə-hē-ḇî", "traducao_palavra": "então trará" },
        { "hebraico": "קָרְבָּנוֹ", "transliteral": "qā-rə-bā-nô", "traducao_palavra": "sua oferta" },
        { "hebraico": "שְׂעִיר", "transliteral": "śə-ʿîr", "traducao_palavra": "um bode [cabeludo]" },
