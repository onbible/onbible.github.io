      ]
    },
    "20": {
      "traducao_completa": "E fará com este novilho como fez com o novilho da oferta pelo pecado; assim fará com ele; e o sacerdote fará expiação por eles, e lhes será perdoado.",
      "palavras": [
        { "hebraico": "וְעָשָׂה", "transliteral": "wə-ʿā-śā", "traducao_palavra": "e fará" },
        { "hebraico": "וְכִפֶּר", "transliteral": "wə-ḵip-pēr", "traducao_palavra": "e expiará" },
