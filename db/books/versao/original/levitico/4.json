        { "hebraico": "אֲשֶׁר", "transliteral": "ʾă-šer", "traducao_palavra": "quando/que" },
        { "hebraico": "נָשִׂיא", "transliteral": "nā-śî", "traducao_palavra": "um líder/príncipe" },
