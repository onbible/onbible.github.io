        { "hebraico": "לֵּאמֹר׃", "transliteral": "lē-mōr", "traducao_palavra": "dizendo" }
      ]
    },
    "2": {
      "traducao_completa": "Fala aos filhos de Israel, dizendo: Quando uma alma pecar por erro contra qualquer dos mandamentos de YHWH, naquilo que não se deve fazer, e fizer alguma delas;",
      "palavras": [
        { "hebraico": "דַּבֵּר", "transliteral": "dab-bēr", "traducao_palavra": "fala" },
        { "hebraico": "אֶל־בְּנֵי", "transliteral": "ʾel-bə-nê", "traducao_palavra": "aos filhos de" },
        { "hebraico": "יִשְׂרָאֵל", "transliteral": "yiś-rā-ʾēl", "traducao_palavra": "Israel" },
        { "hebraico": "לֵאמֹר", "transliteral": "lē-mōr", "traducao_palavra": "dizendo" },
        { "hebraico": "נֶפֶשׁ", "transliteral": "ne-p̄eš", "traducao_palavra": "alma/pessoa" },
        { "hebraico": "כִּי־תֶחֱטָא", "transliteral": "kî-ṯe-ḥĕ-ṭā", "traducao_palavra": "quando pecar" },
        { "hebraico": "בִשְׁגָגָה", "transliteral": "biš-ḡā-ḡā", "traducao_palavra": "por erro" },
        { "hebraico": "מִכֹּל", "transliteral": "mik-kōl", "traducao_palavra": "de todos" },
        { "hebraico": "מִצְוֺת", "transliteral": "miṣ-wōṯ", "traducao_palavra": "mandamentos de" },
        { "hebraico": "יְהוָה", "transliteral": "YHWH", "traducao_palavra": "YHWH" }
      ]
    },
    "3": {
      "traducao_completa": "Se o sacerdote ungido pecar para a culpa do povo, oferecerá a YHWH pelo seu pecado que cometeu, um novilho sem defeito, como oferta pelo pecado.",
      "palavras": [
        { "hebraico": "אִם", "transliteral": "ʾim", "traducao_palavra": "se" },
        { "hebraico": "הַכֹּהֵן", "transliteral": "hak-kō-hên", "traducao_palavra": "o sacerdote" },
        { "hebraico": "הַמָּשִׁיחַ", "transliteral": "ham-mā-šî-aḥ", "traducao_palavra": "o ungido" },
        { "hebraico": "יֶחֱטָא", "transliteral": "ye-ḥĕ-ṭā", "traducao_palavra": "pecar" },
        { "hebraico": "לְאַשְׁמַת", "transliteral": "lə-ʾaš-maṯ", "traducao_palavra": "para culpa de" },
        { "hebraico": "הָעָם", "transliteral": "hā-ʿām", "traducao_palavra": "o povo" },
        { "hebraico": "פַּר", "transliteral": "par", "traducao_palavra": "novilho" },
        { "hebraico": "תָּמִים", "transliteral": "tā-mîm", "traducao_palavra": "perfeito" }
      ]
    },
    "4": {
      "traducao_completa": "E trará o novilho à porta da tenda da congregação, perante YHWH, e porá a sua mão sobre a cabeça do novilho, e degolará o novilho perante YHWH.",
      "palavras": [
        { "hebraico": "וְהֵבִיא", "transliteral": "wə-hē-ḇî", "traducao_palavra": "e trará" },
        { "hebraico": "אֶת־הַפָּר", "transliteral": "ʾeṯ-hap-pār", "traducao_palavra": "o novilho" },
        { "hebraico": "וְסָמַךְ", "transliteral": "wə-sā-maḵ", "traducao_palavra": "e porá" }
      ]
    },
    "5": {
      "traducao_completa": "E o sacerdote ungido tomará do sangue do novilho, e o trará à tenda da congregação.",
      "palavras": [
        { "hebraico": "וְלָקַח", "transliteral": "wə-lā-qaḥ", "traducao_palavra": "e tomará" },
        { "hebraico": "הַכֹּהֵן", "transliteral": "hak-kō-hên", "traducao_palavra": "o sacerdote" },
        { "hebraico": "הַמָּשִׁיחַ", "transliteral": "ham-mā-šî-aḥ", "traducao_palavra": "o ungido" },
        { "hebraico": "מִדַּם", "transliteral": "mid-dam", "traducao_palavra": "do sangue de" }
      ]
    },
    "6": {
      "traducao_completa": "E o sacerdote molhará o seu dedo no sangue, e aspergirá do sangue sete vezes perante YHWH, diante do véu do santuário.",
      "palavras": [
        { "hebraico": "וְטָבַל", "transliteral": "wə-ṭā-ḇal", "traducao_palavra": "e molhará" },
        { "hebraico": "אֶצְבָּעוֹ", "transliteral": "ʾeṣ-bā-ʿô", "traducao_palavra": "seu dedo" },
        { "hebraico": "וְהִזָּה", "transliteral": "wə-hiz-zā", "traducao_palavra": "e aspergirá" },
        { "hebraico": "שֶׁבַע", "transliteral": "še-ḇaʿ", "traducao_palavra": "sete" },
        { "hebraico": "פְּעָמִים", "transliteral": "pə-ʿā-mîm", "traducao_palavra": "vezes" }
      ]
    },
    "7": {
      "traducao_completa": "Também o sacerdote porá do sangue sobre as pontas do altar do incenso aromático, perante YHWH, que está na tenda da congregação; e todo o [resto do] sangue do novilho derramará à base do altar do holocausto, que está à porta da tenda da congregação.",
      "palavras": [
        { "hebraico": "וְנָתַן", "transliteral": "wə-nā-ṯan", "traducao_palavra": "e porá" },
        { "hebraico": "הַכֹּהֵן", "transliteral": "hak-kō-hên", "traducao_palavra": "o sacerdote" },
        { "hebraico": "מִן־הַדָּם", "transliteral": "min-had-dām", "traducao_palavra": "do sangue" },
        { "hebraico": "עַל־קַרְנוֹת", "transliteral": "ʿal-qar-nôṯ", "traducao_palavra": "sobre pontas de" },
        { "hebraico": "מִזְבַּח", "transliteral": "miz-baḥ", "traducao_palavra": "altar de" },
        { "hebraico": "קְטֹרֶת", "transliteral": "qə-ṭō-reṯ", "traducao_palavra": "incenso" }
      ]
    },
    "8": {
      "traducao_completa": "E toda a gordura do novilho da oferta pelo pecado tirará dele: a gordura que cobre as entranhas, e toda a gordura que está sobre as entranhas,",
      "palavras": [
        { "hebraico": "וְאֶת־כָּל־חֵלֶב", "transliteral": "wə-ʾeṯ-kāl-ḥē-leḇ", "traducao_palavra": "e toda gordura" }
      ]
    },
    "9": {
      "traducao_completa": "E os dois rins, e a gordura que está sobre eles, e sobre as costas; e o redanho que está sobre o fígado, com os rins, os tirará,",
      "palavras": [
        { "hebraico": "וְאֵת", "transliteral": "wə-ʾēṯ", "traducao_palavra": "e" },
        { "hebraico": "שְׁתֵּי", "transliteral": "šə-tê", "traducao_palavra": "os dois" },
        { "hebraico": "הַכְּלָיֹת", "transliteral": "hak-kə-lā-yōṯ", "traducao_palavra": "rins" }
      ]
    },
    "10": {
      "traducao_completa": "Como se tira do boi do sacrifício de paz; e o sacerdote os queimará sobre o altar do holocausto.",
      "palavras": [
        { "hebraico": "כַּאֲשֶׁר", "transliteral": "ka-ʾă-šer", "traducao_palavra": "conforme" },
        { "hebraico": "יוּרָם", "transliteral": "yû-rām", "traducao_palavra": "se tira/levanta" }
      ]
    },
    "11": {
      "traducao_completa": "Mas o couro do novilho, e toda a sua carne, com a sua cabeça e com as suas pernas, e as suas entranhas, e o seu esterco,",
      "palavras": [
        { "hebraico": "וְאֶת־עוֹר", "transliteral": "wə-ʾeṯ-ʿôr", "traducao_palavra": "e a pele de" },
        { "hebraico": "הַפָּר", "transliteral": "hap-pār", "traducao_palavra": "o novilho" }
      ]
    },
    "12": {
      "traducao_completa": "Todo aquele novilho levará fora do arraial a um lugar limpo, onde se lança a cinza, e o queimará sobre a lenha no fogo; onde se lança a cinza, ali se queimará.",
      "palavras": [
        { "hebraico": "וְהוֹצִיא", "transliteral": "wə-hō-ṣî", "traducao_palavra": "e levará" },
        { "hebraico": "אֶל־מִחוּץ", "transliteral": "ʾel-mi-ḥûṣ", "traducao_palavra": "para fora de" },
        { "hebraico": "לַמַּחֲנֶה", "transliteral": "lam-ma-ḥă-neh", "traducao_palavra": "o arraial" }
      ]
    },
    "13": {
      "traducao_completa": "E se toda a congregação de Israel errar, e o negócio for oculto aos olhos da assembleia, e fizerem contra algum dos mandamentos de YHWH naquilo que não se deve fazer, e forem culpados,",
      "palavras": [
        { "hebraico": "וְאִם", "transliteral": "wə-ʾim", "traducao_palavra": "e se" },
        { "hebraico": "כָּל־עֲדַת", "transliteral": "kāl-ʿă-ḏaṯ", "traducao_palavra": "toda a congregação de" },
        { "hebraico": "יִשְׂרָאֵל", "transliteral": "yiś-rā-ʾēl", "traducao_palavra": "Israel" },
        { "hebraico": "יִשְׁגּוּ", "transliteral": "yiš-gû", "traducao_palavra": "errarem" },
        { "hebraico": "וְנֶעְלַם", "transliteral": "wə-ne-ʿă-lam", "traducao_palavra": "e for oculto" },
        { "hebraico": "דָּבָר", "transliteral": "dā-ḇār", "traducao_palavra": "o negócio" }
      ]
    },
    "14": {
      "traducao_completa": "E o pecado que cometeram for conhecido, então a assembleia oferecerá um novilho por oferta pelo pecado, e o trarão diante da tenda da congregação.",
      "palavras": [
        { "hebraico": "וְנוֹדְעָה", "transliteral": "wə-nō-ḏə-ʿā", "traducao_palavra": "e for conhecido" }
      ]
    },
    "15": {
      "traducao_completa": "E os anciãos da congregação porão as suas mãos sobre a cabeça do novilho perante YHWH; e degolar-se-á o novilho perante YHWH.",
      "palavras": [
        { "hebraico": "וְסָמְכוּ", "transliteral": "wə-sām-ḵû", "traducao_palavra": "e porão/apoiarão" },
        { "hebraico": "זִקְנֵי", "transliteral": "ziq-nê", "traducao_palavra": "anciãos de" }
      ]
    },
    "16": {
      "traducao_completa": "Então o sacerdote ungido trará do sangue do novilho à tenda da congregação.",
      "palavras": [
