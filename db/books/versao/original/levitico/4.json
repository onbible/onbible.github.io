        { "hebraico": "תָּמִים׃", "transliteral": "tā-mîm", "traducao_palavra": "perfeito" }
      ]
    },
    "24": {
      "traducao_completa": "E porá a sua mão sobre a cabeça do bode, e o degolará no lugar onde se degola o holocausto, perante YHWH; oferta pelo pecado é.",
      "palavras": [
        { "hebraico": "וְסָמַךְ", "transliteral": "wə-sā-maḵ", "traducao_palavra": "e porá" },
        { "hebraico": "יָדוֹ", "transliteral": "yā-ḏô", "traducao_palavra": "sua mão" },
        { "hebraico": "עַל־רֹאשׁ", "transliteral": "ʿal-rōš", "traducao_palavra": "sobre a cabeça de" },
        { "hebraico": "הַשָּׂעִיר", "transliteral": "ha-śā-ʿîr", "traducao_palavra": "o bode" },
        { "hebraico": "וְשָׁחַט", "transliteral": "wə-šā-ḥaṭ", "traducao_palavra": "e degolará" },
        { "hebraico": "אֹתוֹ", "transliteral": "ʾō-ṯô", "traducao_palavra": "ele" },
        { "hebraico": "בִּמְקוֹם", "transliteral": "bim-qôm", "traducao_palavra": "no lugar" },
        { "hebraico": "חַטָּאת", "transliteral": "ḥaṭ-ṭāṯ", "traducao_palavra": "pecado" },
        { "hebraico": "הִוא׃", "transliteral": "hî", "traducao_palavra": "ela [é]" }
      ]
    },
    "25": {
      "traducao_completa": "Depois o sacerdote tomará do sangue da oferta pelo pecado com o seu dedo, e o porá sobre as pontas do altar do holocausto; então o restante do seu sangue derramará à base do altar do holocausto.",
      "palavras": [
        { "hebraico": "וְלָקַח", "transliteral": "wə-lā-qaḥ", "traducao_palavra": "e tomará" },
        { "hebraico": "הַכֹּהֵן", "transliteral": "hak-kō-hên", "traducao_palavra": "o sacerdote" },
        { "hebraico": "מִדַּם", "transliteral": "mid-dam", "traducao_palavra": "do sangue de" }
      ]
    },
    "26": {
      "traducao_completa": "E queimará toda a sua gordura sobre o altar, como a gordura do sacrifício de paz; assim o sacerdote fará expiação por ele do seu pecado, e lhe será perdoado.",
