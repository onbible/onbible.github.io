        { "hebraico": "חַטַּאת", "transliteral": "ḥaṭ-ṭaṯ", "traducao_palavra": "pecado de" },
        { "hebraico": "הַקָּהָל", "transliteral": "haq-qā-hāl", "traducao_palavra": "a assembleia" },
        { "hebraico": "הוּא׃", "transliteral": "hû", "traducao_palavra": "é" }
      ]
    },
    "22": {
      "traducao_completa": "Quando um líder pecar e, por erro, fizer contra algum de todos os mandamentos de YHWH seu Deus aquilo que não se deve fazer, e se tornar culpado;",
