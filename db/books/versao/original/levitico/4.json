      ]
    },
    "18": {
      "traducao_completa": "E do sangue porá sobre as pontas do altar que está perante YHWH, na tenda da congregação; e todo o [resto do] sangue derramará à base do altar do holocausto, que está à porta da tenda da congregação.",
      "palavras": [
        { "hebraico": "וּמִן־הַדָּם", "transliteral": "û-min-had-dām", "traducao_palavra": "e do sangue" }
      ]
    },
    "19": {
      "traducao_completa": "E tirará dele toda a sua gordura, e a queimará sobre o altar.",
