{
  "livro": "Levítico - וַיִּקְרָא - Vayikra",
  "capítulo": 9,
  "titulos": {},
  "versiculos": {
    "1": {
      "traducao_completa": "E aconteceu que, ao oitavo dia, Moisés chamou a Arão, e a seus filhos, e aos anciãos de Israel;",
      "palavras": [
        { "hebraico": "וַיְהִי", "transliteral": "way-hî", "traducao_palavra": "e aconteceu" },
        { "hebraico": "בַּיּוֹם", "transliteral": "bay-yôm", "traducao_palavra": "no dia" },
        { "hebraico": "הַשְּׁמִינִי", "transliteral": "haš-šə-mî-nî", "traducao_palavra": "o oitavo" },
        { "hebraico": "קָרָא", "transliteral": "qā-rā", "traducao_palavra": "chamou" },
        { "hebraico": "מֹשֶׁה", "transliteral": "mō-šeh", "traducao_palavra": "Moisés" },
        { "hebraico": "לְאַהֲרֹן", "transliteral": "lə-ʾa-hă-rōn", "traducao_palavra": "a Arão" },
        { "hebraico": "וּלְבָנָיו", "transliteral": "û-lə-ḇā-nāyw", "traducao_palavra": "e a seus filhos" },
        { "hebraico": "וּלְזִקְנֵי", "transliteral": "û-lə-ziq-nê", "traducao_palavra": "e aos anciãos de" },
        { "hebraico": "יִשְׂרָאֵל", "transliteral": "yiś-rā-ʾēl", "traducao_palavra": "Israel" }
      ]
    },
    "2": {
      "traducao_completa": "E disse a Arão: Toma um bezerro, filho de boi, para oferta pelo pecado, e um carneiro para holocausto, ambos sem defeito, e oferece-os perante YHWH.",
      "palavras": [
        { "hebraico": "וַיֹּאמֶר", "transliteral": "way-yō-mer", "traducao_palavra": "e disse" },
        { "hebraico": "אֶל־אַהֲרֹן", "transliteral": "ʾel-ʾa-hă-rōn", "traducao_palavra": "a Arão" },
        { "hebraico": "קַח־לְךָ", "transliteral": "qaḥ-lə-ḵā", "traducao_palavra": "toma para ti" },
        { "hebraico": "עֵגֶל", "transliteral": "ʿê-ḡel", "traducao_palavra": "um bezerro" },
        { "hebraico": "בֶּן־בָּקָר", "transliteral": "ben-bā-qār", "traducao_palavra": "filho de gado" },
        { "hebraico": "לְחַטָּאת", "transliteral": "lə-ḥaṭ-ṭāṯ", "traducao_palavra": "para oferta pelo pecado" }
      ]
    },
    "3": {
      "traducao_completa": "E falarás aos filhos de Israel, dizendo: Tomai um bode para oferta pelo pecado, e um bezerro e um cordeiro, ambos de um ano e sem defeito, para holocausto;",
      "palavras": [
        { "hebraico": "וְאֶל־בְּנֵי", "transliteral": "wə-ʾel-bə-nê", "traducao_palavra": "e aos filhos de" },
        { "hebraico": "יִשְׂרָאֵל", "transliteral": "yiś-rā-ʾēl", "traducao_palavra": "Israel" },
        { "hebraico": "תְּדַבֵּר", "transliteral": "tə-ḏab-bēr", "traducao_palavra": "falarás" }
      ]
    },
    "4": {
      "traducao_completa": "Também um boi e um carneiro para oferta pacífica, para sacrificar perante YHWH, e oferta de manjares, amassada com azeite; porquanto hoje YHWH vos aparecerá.",
      "palavras": [
        { "hebraico": "וְשׁוֹר", "transliteral": "wə-šôr", "traducao_palavra": "e um boi" },
        { "hebraico": "וָאַיִל", "transliteral": "wā-ʾa-yil", "traducao_palavra": "e um carneiro" },
        { "hebraico": "לִשְׁלָמִים", "transliteral": "liš-lā-mîm", "traducao_palavra": "para sacrifício de paz" }
      ]
    },
    "5": {
      "traducao_completa": "Então trouxeram o que Moisés ordenara, perante a tenda da congregação, e chegou-se toda a congregação e se pôs perante YHWH.",
      "palavras": [
        { "hebraico": "וַיִּקְחוּ", "transliteral": "way-yiq-ḥû", "traducao_palavra": "e trouxeram" },
        { "hebraico": "אֵת", "transliteral": "ʾēṯ", "traducao_palavra": "[objeto]" },
        { "hebraico": "אֲשֶׁר", "transliteral": "ʾă-šer", "traducao_palavra": "o que" },
        { "hebraico": "צִוָּה", "transliteral": "ṣiw-wā", "traducao_palavra": "ordenou" },
        { "hebraico": "מֹשֶׁה", "transliteral": "mō-šeh", "traducao_palavra": "Moisés" }
      ]
    },
    "6": {
      "traducao_completa": "E disse Moisés: Esta coisa que YHWH ordenou fareis; e a glória de YHWH vos aparecerá.",
      "palavras": [
        { "hebraico": "וַיֹּאמֶר", "transliteral": "way-yō-mer", "traducao_palavra": "e disse" },
        { "hebraico": "מֹשֶׁה", "transliteral": "mō-šeh", "traducao_palavra": "Moisés" },
        { "hebraico": "זֶה", "transliteral": "zeh", "traducao_palavra": "este [é]" },
        { "hebraico": "הַדָּבָר", "transliteral": "had-dā-ḇār", "traducao_palavra": "o assunto/coisa" }
      ]
    },
    "7": {
      "traducao_completa": "E disse Moisés a Arão: Chega-te ao altar, e faze a tua oferta pelo pecado e o teu holocausto; e faze expiação por ti e pelo povo; depois faze a oferta do povo, e faze expiação por eles, como ordenou YHWH.",
      "palavras": [
        { "hebraico": "וַיֹּאמֶר", "transliteral": "way-yō-mer", "traducao_palavra": "e disse" },
        { "hebraico": "מֹשֶׁה", "transliteral": "mō-šeh", "traducao_palavra": "Moisés" },
        { "hebraico": "אֶל־אַהֲרֹן", "transliteral": "ʾel-ʾa-hă-rōn", "traducao_palavra": "a Arão" },
        { "hebraico": "קְרַב", "transliteral": "qə-raḇ", "traducao_palavra": "chega-te" }
      ]
    },
    "8": {
      "traducao_completa": "Então Arão se chegou ao altar, e degolou o bezerro da oferta pelo pecado, que era por si mesmo.",
      "palavras": [
        { "hebraico": "וַיִּקְרַב", "transliteral": "way-yiq-raḇ", "traducao_palavra": "e chegou-se" },
        { "hebraico": "אַהֲרֹן", "transliteral": "ʾa-hă-rōn", "traducao_palavra": "Arão" },
        { "hebraico": "אֶל־הַמִּזְבֵּעַ", "transliteral": "ʾel-ham-miz-bē-aḥ", "traducao_palavra": "ao altar" }
      ]
    },
    "9": {
      "traducao_completa": "E os filhos de Arão trouxeram-lhe o sangue, e molhou o seu dedo no sangue, e o pôs sobre as pontas do altar; e o resto do sangue derramou à base do altar.",
      "palavras": [
        { "hebraico": "וַיַּקְרִבוּ", "transliteral": "way-yaq-ri-ḇû", "traducao_palavra": "e trouxeram" },
        { "hebraico": "בְּנֵי", "transliteral": "bə-nê", "traducao_palavra": "os filhos de" },
        { "hebraico": "אַהֲרֹן", "transliteral": "ʾa-hă-rōn", "traducao_palavra": "Arão" }
      ]
    },
    "10": {
      "traducao_completa": "Mas a gordura, e os rins, e o redanho do fígado da oferta pelo pecado, queimou sobre o altar, como YHWH ordenara a Moisés.",
      "palavras": [
        { "hebraico": "וְאֶת־הַחֵלֶב", "transliteral": "wə-ʾeṯ-ha-ḥē-leḇ", "traducao_palavra": "e a gordura" }
      ]
    },
    "11": {
      "traducao_completa": "E a carne e o couro queimou com fogo fora do arraial.",
      "palavras": [
        { "hebraico": "וְאֶת־הַבָּשָׂר", "transliteral": "wə-ʾeṯ-hab-bā-śār", "traducao_palavra": "e a carne" },
        { "hebraico": "וְאֶת־הָעוֹר", "transliteral": "wə-ʾeṯ-hā-ʾôr", "traducao_palavra": "e o couro" }
      ]
    },
    "12": {
      "traducao_completa": "Depois degolou o holocausto, e os filhos de Arão lhe entregaram o sangue, e ele o aspergiu sobre o altar em redor.",
      "palavras": [
        { "hebraico": "וַיִּשְׁחָט", "transliteral": "way-yiš-ḥāṭ", "traducao_palavra": "e degolou" },
        { "hebraico": "אֶת־הָעֹלָה", "transliteral": "ʾeṯ-hā-ʿō-lā", "traducao_palavra": "o holocausto" }
      ]
    },
    "13": {
      "traducao_completa": "Também lhe entregaram o holocausto em seus pedaços, com a cabeça; e queimou-os sobre o altar.",
      "palavras": [
        { "hebraico": "וְאֶת־הָעֹלָה", "transliteral": "wə-ʾeṯ-hā-ʿō-lā", "traducao_palavra": "e o holocausto" }
      ]
    },
    "14": {
      "traducao_completa": "E lavou as entranhas e as pernas, e as queimou sobre o holocausto no altar.",
      "palavras": [
        { "hebraico": "וַיִּרְחַץ", "transliteral": "way-yir-ḥaṣ", "traducao_palavra": "e lavou" }
      ]
    },
    "15": {
      "traducao_completa": "Depois fez chegar a oferta do povo, e tomou o bode da oferta pelo pecado, que era pelo povo, e o degolou, e o ofereceu pelo pecado, como o primeiro.",
      "palavras": [
        { "hebraico": "וַיַּקְרֵב", "transliteral": "way-yaq-rēḇ", "traducao_palavra": "e fez chegar" },
        { "hebraico": "אֵת", "transliteral": "ʾēṯ", "traducao_palavra": "[objeto]" },
        { "hebraico": "קָרְבַּן", "transliteral": "qār-ban", "traducao_palavra": "a oferta de" },
        { "hebraico": "הָעָם", "transliteral": "hā-ʿām", "traducao_palavra": "o povo" }
      ]
    },
    "16": {
      "traducao_completa": "Também fez chegar o holocausto, e o ofereceu segundo o rito.",
      "palavras": [
        { "hebraico": "וַיַּקְרֵב", "transliteral": "way-yaq-rēḇ", "traducao_palavra": "e trouxe" },
        { "hebraico": "אֶת־הָעֹלָה", "transliteral": "ʾeṯ-hā-ʿō-lā", "traducao_palavra": "o holocausto" }
      ]
    },
    "17": {
      "traducao_completa": "E fez chegar a oferta de manjares, e encheu a sua mão dela, e a queimou sobre o altar, além do holocausto da manhã.",
      "palavras": [
        { "hebraico": "וַיַּקְרֵב", "transliteral": "way-yaq-rēḇ", "traducao_palavra": "e trouxe" },
        { "hebraico": "אֶת־הַמִּנְחָה", "transliteral": "ʾeṯ-ham-min-ḥā", "traducao_palavra": "a oferta de manjares" }
      ]
    },
    "18": {
      "traducao_completa": "Depois degolou o boi e o carneiro em sacrifício pacífico, que era pelo povo; e os filhos de Arão entregaram-lhe o sangue, que ele aspergiu sobre o altar em redor.",
      "palavras": [
        { "hebraico": "וַיִּשְׁחָט", "transliteral": "way-yiš-ḥāṭ", "traducao_palavra": "e degolou" }
      ]
    },
    "19": {
      "traducao_completa": "Como também a gordura do boi e do carneiro, a cauda, e o que cobre as entranhas, e os rins, e o redanho do fígado.",
      "palavras": [
        { "hebraico": "וְאֶת־הַחֲלָבִים", "transliteral": "wə-ʾeṯ-ha-ḥă-lā-ḇîm", "traducao_palavra": "e as gorduras" }
      ]
    },
    "20": {
      "traducao_completa": "E puseram a gordura sobre os peitos, e ele queimou a gordura sobre o altar;",
      "palavras": [
        { "hebraico": "וַיָּשִׂימוּ", "transliteral": "way-yā-śî-mû", "traducao_palavra": "e puseram" },
        { "hebraico": "אֶת־הַחֲלָבִים", "transliteral": "ʾeṯ-ha-ḥă-lā-ḇîm", "traducao_palavra": "as gorduras" },
        { "hebraico": "עַל־הֶחָזוֹת", "transliteral": "ʿal-he-ḥā-zōṯ", "traducao_palavra": "sobre os peitos" }
      ]
    },
    "21": {
      "traducao_completa": "Mas os peitos e a coxa direita Arão moveu por oferta movida perante YHWH, como Moisés ordenara.",
      "palavras": [
        { "hebraico": "וְאֵת", "transliteral": "wə-ʾēṯ", "traducao_palavra": "e" },
        { "hebraico": "הֶחָזוֹת", "transliteral": "he-ḥā-zōṯ", "traducao_palavra": "os peitos" }
      ]
    },
    "22": {
      "traducao_completa": "Depois Arão levantou as suas mãos para o povo e o abençoou; e desceu, depois de fazer a oferta pelo pecado, e o holocausto, e a oferta pacífica.",
      "palavras": [
        { "hebraico": "וַיִּשָּׂא", "transliteral": "way-yiś-śā", "traducao_palavra": "e levantou" },
        { "hebraico": "אַהֲרֹן", "transliteral": "ʾa-hă-rōn", "traducao_palavra": "Arão" },
        { "hebraico": "אֶת־יָדָו", "transliteral": "ʾeṯ-yā-ḏāw", "traducao_palavra": "as suas mãos" },
        { "hebraico": "אֶל־הָעָם", "transliteral": "ʾel-hā-ʿām", "traducao_palavra": "para o povo" },
        { "hebraico": "וַיְבָרְכֵם", "transliteral": "way-ḇā-rə-ḵêm", "traducao_palavra": "e abençoou-os" }
      ]
    },
    "23": {
      "traducao_completa": "Então entraram Moisés e Arão na tenda da congregação; depois saíram, e abençoaram o povo; e a glória de YHWH apareceu a todo o povo.",
      "palavras": [
        { "hebraico": "וַיָּבֹא", "transliteral": "way-yā-ḇō", "traducao_palavra": "e entraram" },
        { "hebraico": "מֹשֶׁה", "transliteral": "mō-šeh", "traducao_palavra": "Moisés" },
        { "hebraico": "וְאַהֲרֹן", "transliteral": "wə-ʾa-hă-rōn", "traducao_palavra": "e Arão" },
        { "hebraico": "אֶל־אֹהֶל", "transliteral": "ʾel-ʾō-hel", "traducao_palavra": "na tenda de" },
        { "hebraico": "מוֹעֵד", "transliteral": "mô-ʿēḏ", "traducao_palavra": "reunião/congregação" }
      ]
    },
    "24": {
      "traducao_completa": "Porque saiu fogo de diante de YHWH, e consumiu o holocausto e a gordura sobre o altar; o que vendo todo o povo, jubilaram e caíram sobre as suas faces.",
      "palavras": [
        { "hebraico": "וַתֵּצֵא", "transliteral": "wat-tē-ṣē", "traducao_palavra": "e saiu" },
        { "hebraico": "אֵשׁ", "transliteral": "ʾēš", "traducao_palavra": "fogo" },
        { "hebraico": "מִלִּפְנֵי", "transliteral": "mil-lip̄-nê", "traducao_palavra": "de diante de" },
        { "hebraico": "יְהוָה", "transliteral": "YHWH", "traducao_palavra": "YHWH" },
        { "hebraico": "וַתֹּאכַל", "transliteral": "wat-tō-ḵal", "traducao_palavra": "e consumiu" },
        { "hebraico": "עַל־הַמִּזְבֵּעַ", "transliteral": "ʿal-ham-miz-bē-aḥ", "traducao_palavra": "sobre o altar" },
        { "hebraico": "אֶת־הָעֹלָה", "transliteral": "ʾeṯ-hā-ʿō-lā", "traducao_palavra": "o holocausto" },
        { "hebraico": "וְאֶת־הַחֲלָבִים", "transliteral": "wə-ʾeṯ-ha-ḥă-lā-ḇîm", "traducao_palavra": "e as gorduras" }
      ]
    }
  }
}