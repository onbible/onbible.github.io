{
  "livro": "Levítico - וַיִּקְרָא - Vayikra",
  "capítulo": 6,
  "titulos": {},
  "versiculos": {
    "1": {
      "traducao_completa": "E falou YHWH a Moisés, dizendo:",
      "palavras": [
        { "hebraico": "וַיְדַבֵּר", "transliteral": "way-yə-ḏab-bēr", "traducao_palavra": "e falou" },
        { "hebraico": "יְהוָה", "transliteral": "YHWH", "traducao_palavra": "YHWH" },
        { "hebraico": "אֶל־מֹשֶׁה", "transliteral": "ʾel-mō-šeh", "traducao_palavra": "a Moisés" },
        { "hebraico": "לֵּאמֹר׃", "transliteral": "lē-mōr", "traducao_palavra": "dizendo" }
      ]
    },
    "2": {
      "traducao_completa": "Quando uma alma pecar e cometer transgressão contra YHWH, e negar ao seu próximo o que lhe deu em depósito, ou o que pôs na sua mão, ou o roubo, ou se extorquiu ao seu próximo;",
      "palavras": [
        { "hebraico": "נֶפֶשׁ", "transliteral": "ne-p̄eš", "traducao_palavra": "uma alma" },
        { "hebraico": "כִּי", "transliteral": "kî", "traducao_palavra": "quando" },
        { "hebraico": "תֶחֱטָא", "transliteral": "te-ḥĕ-ṭā", "traducao_palavra": "pecar" },
        { "hebraico": "וּמָעֲלָה", "transliteral": "û-mā-ʿă-lā", "traducao_palavra": "e cometer" },
        { "hebraico": "מַעַל", "transliteral": "ma-ʿal", "traducao_palavra": "transgressão" },
        { "hebraico": "בַּיהוָה", "transliteral": "ba-YHWH", "traducao_palavra": "contra YHWH" },
        { "hebraico": "וְכִחֵשׁ", "transliteral": "wə-ḵi-ḥêš", "traducao_palavra": "e negar" },
        { "hebraico": "בַּעֲמִיתוֹ", "transliteral": "ba-ʿă-mî-ṯô", "traducao_palavra": "ao seu próximo" },
        { "hebraico": "בְּפִקָּדוֹן", "transliteral": "bə-p̄iq-qā-ḏôn", "traducao_palavra": "em depósito" }
      ]
    },
    "3": {
      "traducao_completa": "Ou se achou o perdido, e o negar, ou jurar falsamente; se fizer alguma de todas as coisas em que o homem costuma pecar;",
      "palavras": [
        { "hebraico": "אוֹ־מָצָא", "transliteral": "ʾô-mā-ṣā", "traducao_palavra": "ou achou" },
        { "hebraico": "אֲבֵדָה", "transliteral": "ʾă-ḇê-ḏā", "traducao_palavra": "[algo] perdido" },
        { "hebraico": "וְכִחֶשׁ", "transliteral": "wə-ḵi-ḥeš", "traducao_palavra": "e o negar" },
        { "hebraico": "בָּהּ", "transliteral": "bāh", "traducao_palavra": "nele" },
        { "hebraico": "וְנִשְׁבַּע", "transliteral": "wə-niš-baʿ", "traducao_palavra": "e jurar" },
        { "hebraico": "עַל־שֶׁקֶר", "transliteral": "ʿal-še-qer", "traducao_palavra": "falsamente" }
      ]
    },
    "4": {
      "traducao_completa": "Será, pois, que, porquanto pecou e ficou culpado, restituirá o que roubou, ou o que extorquiu, ou o depósito que lhe foi dado, ou o perdido que achou,",
      "palavras": [
        { "hebraico": "וְהָיָה", "transliteral": "wə-hā-yā", "traducao_palavra": "e será" },
        { "hebraico": "כִּי־יֶחֱטָא", "transliteral": "kî-ye-ḥĕ-ṭā", "traducao_palavra": "que pecar" },
        { "hebraico": "וְאָשֵׁם", "transliteral": "wə-ʾā-šēm", "traducao_palavra": "e for culpado" },
        { "hebraico": "וְהֵשִׁיב", "transliteral": "wə-hê-šîḇ", "traducao_palavra": "restituirá" },
        { "hebraico": "אֶת־הַגְּזֵלָה", "transliteral": "ʾeṯ-hag-gə-zê-lā", "traducao_palavra": "o roubo" }
      ]
    },
    "5": {
      "traducao_completa": "Ou tudo aquilo sobre o que jurou falsamente; e o restituirá no seu todo, e ainda lhe acrescentará o seu quinto; a quem pertence, lho dará no dia da sua oferta pela culpa.",
      "palavras": [
        { "hebraico": "אוֹ", "transliteral": "ʾô", "traducao_palavra": "ou" },
        { "hebraico": "מִכֹּל", "transliteral": "mik-kōl", "traducao_palavra": "de tudo" },
        { "hebraico": "אֲשֶׁר־יִשָּׁבַע", "transliteral": "ʾă-šer-yiš-šā-ḇaʿ", "traducao_palavra": "que jurou" },
        { "hebraico": "עָלָיו", "transliteral": "ʿā-lāyw", "traducao_palavra": "sobre ele" },
        { "hebraico": "לַשֶּׁקֶר", "transliteral": "la-še-qer", "traducao_palavra": "falsamente" },
        { "hebraico": "וְשִׁלַּם", "transliteral": "wə-šil-lam", "traducao_palavra": "e pagará/restituirá" },
        { "hebraico": "אֹתוֹ", "transliteral": "ʾō-ṯô", "traducao_palavra": "ele" },
        { "hebraico": "בְּרֹאשׁוֹ", "transliteral": "bə-rō-šô", "traducao_palavra": "em seu todo" },
        { "hebraico": "וַחֲמִשִׁתָיו", "transliteral": "wa-ḥă-mi-ši-ṯāyw", "traducao_palavra": "e seus quintos" },
        { "hebraico": "יֹסֵף", "transliteral": "yō-sêp̄", "traducao_palavra": "acrescentará" }
      ]
    },
    "6": {
      "traducao_completa": "E a sua oferta pela culpa trará a YHWH: um carneiro sem defeito do rebanho, conforme a tua avaliação, para oferta pela culpa, ao sacerdote.",
      "palavras": [
        { "hebraico": "וְאֶת־אֲשָׁמוֹ", "transliteral": "wə-ʾeṯ-ʾă-šā-mô", "traducao_palavra": "e sua oferta pela culpa" },
        { "hebraico": "יָבִיא", "transliteral": "yā-ḇî", "traducao_palavra": "trará" },
        { "hebraico": "לַיהוָה", "transliteral": "la-YHWH", "traducao_palavra": "a YHWH" }
      ]
    },
    "7": {
      "traducao_completa": "E o sacerdote fará expiação por ele diante de YHWH, e lhe será perdoado qualquer de todas as coisas que fez, tornando-se culpado nelas.",
      "palavras": [
        { "hebraico": "וְכִפֶּר", "transliteral": "wə-ḵip-pēr", "traducao_palavra": "e expiará" },
        { "hebraico": "עָלָיו", "transliteral": "ʿā-lāyw", "traducao_palavra": "sobre ele" },
        { "hebraico": "הַכֹּהֵן", "transliteral": "hak-kō-hên", "traducao_palavra": "o sacerdote" }
      ]
    },
    "8": {
      "traducao_completa": "E falou YHWH a Moisés, dizendo:",
      "palavras": [
        { "hebraico": "וַיְדַבֵּר", "transliteral": "way-yə-ḏab-bēr", "traducao_palavra": "e falou" },
        { "hebraico": "יְהוָה", "transliteral": "YHWH", "traducao_palavra": "YHWH" },
        { "hebraico": "אֶל־מֹשֶׁה", "transliteral": "ʾel-mō-šeh", "traducao_palavra": "a Moisés" },
        { "hebraico": "לֵּאמֹר׃", "transliteral": "lē-mōr", "traducao_palavra": "dizendo" }
      ]
    },
    "9": {
      "traducao_completa": "Dá ordem a Arão e a seus filhos, dizendo: Esta é a lei do holocausto: o holocausto será queimado sobre o altar toda a noite até pela manhã, e o fogo do altar arderá nele.",
      "palavras": [
        { "hebraico": "צַו", "transliteral": "ṣaw", "traducao_palavra": "ordena" },
        { "hebraico": "אֶת־אַהֲרֹן", "transliteral": "ʾeṯ-ʾa-hă-rōn", "traducao_palavra": "a Arão" },
        { "hebraico": "זֹאת", "transliteral": "zōṯ", "traducao_palavra": "esta" },
        { "hebraico": "תּוֹרַת", "transliteral": "tō-raṯ", "traducao_palavra": "[é a] lei de" },
        { "hebraico": "הָעֹלָה", "transliteral": "hā-ʿō-lā", "traducao_palavra": "o holocausto" }
      ]
    },
    "10": {
      "traducao_completa": "E o sacerdote vestirá a sua veste de linho, e vestirá as calças de linho sobre a sua carne, e levantará a cinza, quando o fogo houver consumido o holocausto sobre o altar, e a porá junto ao altar.",
      "palavras": [
        { "hebraico": "וְלָבַשׁ", "transliteral": "wə-lā-ḇaš", "traducao_palavra": "e vestirá" },
        { "hebraico": "הַכֹּהֵן", "transliteral": "hak-kō-hên", "traducao_palavra": "o sacerdote" },
        { "hebraico": "מִדּוֹ־בַד", "transliteral": "mid-dō-ḇaḏ", "traducao_palavra": "sua veste de linho" }
      ]
    },
    "11": {
      "traducao_completa": "Depois despirá as suas vestes, e vestirá outras vestes; e levará a cinza fora do arraial para um lugar limpo.",
      "palavras": [
        { "hebraico": "וּפָשַׁט", "transliteral": "û-p̄ā-šaṭ", "traducao_palavra": "e despirá" },
        { "hebraico": "אֶת־בְּגָדָיו", "transliteral": "ʾeṯ-bə-ḡā-ḏāyw", "traducao_palavra": "suas vestes" }
      ]
    },
    "12": {
      "traducao_completa": "O fogo, pois, sobre o altar arderá nele, não se apagará; mas o sacerdote acenderá lenha nele cada manhã, e porá em ordem sobre ele o holocausto, e sobre ele queimará a gordura das ofertas de paz.",
      "palavras": [
        { "hebraico": "וְהָאֵשׁ", "transliteral": "wə-hā-ʾêš", "traducao_palavra": "e o fogo" },
        { "hebraico": "עַל־הַמִּזְבֵּחַ", "transliteral": "ʿal-ham-miz-bē-aḥ", "traducao_palavra": "sobre o altar" },
        { "hebraico": "תּוּקַד־בּוֹ", "transliteral": "tû-qaḏ-bô", "traducao_palavra": "arderá nele" },
        { "hebraico": "לֹא", "transliteral": "lō", "traducao_palavra": "não" },
        { "hebraico": "תִכְבֶּה", "transliteral": "tiḵ-beh", "traducao_palavra": "se apagará" }
      ]
    },
    "13": {
      "traducao_completa": "O fogo arderá continuamente sobre o altar; não se apagará.",
      "palavras": [
        { "hebraico": "אֵשׁ", "transliteral": "ʾêš", "traducao_palavra": "fogo" },
        { "hebraico": "תָּמִיד", "transliteral": "tā-mîḏ", "traducao_palavra": "continuamente" },
        { "hebraico": "תּוּקַד", "transliteral": "tû-qaḏ", "traducao_palavra": "arderá" }
      ]
    },
    "14": {
      "traducao_completa": "E esta é a lei da oferta de manjares: os filhos de Arão a oferecerão perante YHWH, diante do altar.",
      "palavras": [
        { "hebraico": "וְזֹאת", "transliteral": "wə-zōṯ", "traducao_palavra": "e esta" },
        { "hebraico": "תּוֹרַת", "transliteral": "tō-raṯ", "traducao_palavra": "[é a] lei de" },
        { "hebraico": "הַמִּנְחָה", "transliteral": "ham-min-ḥā", "traducao_palavra": "a oferta de manjares" }
      ]
    },
    "15": {
      "traducao_completa": "E dela tomará um punhado da flor de farinha da oferta de manjares, e do seu azeite, e todo o incenso que estiver sobre a oferta de manjares; então o queimará sobre o altar, por aroma suave, por sua porção memorial a YHWH.",
      "palavras": [
        { "hebraico": "וְהֵרִים", "transliteral": "wə-hē-rîm", "traducao_palavra": "e levantará/tomará" }
      ]
    },
    "16": {
      "traducao_completa": "E o restante dela comerão Arão e seus filhos; asmo se comerá no lugar santo, no pátio da tenda da congregação o comerão.",
      "palavras": [
        { "hebraico": "וְהַנּוֹתֶרֶת", "transliteral": "wə-han-nō-ṯe-reṯ", "traducao_palavra": "e o restante" }
      ]
    },
    "17": {
      "traducao_completa": "Não se cozerá com fermento; sua porção é que lhes dei das minhas ofertas queimadas; coisa santíssima é, como a oferta pelo pecado e como a oferta pela culpa.",
      "palavras": [
        { "hebraico": "לֹא", "transliteral": "lō", "traducao_palavra": "não" },
        { "hebraico": "תֵאָפֶה", "transliteral": "ṯê-ʾā-p̄eh", "traducao_palavra": "será cozida" },
        { "hebraico": "חָמֵץ", "transliteral": "ḥā-mêṣ", "traducao_palavra": "com fermento" }
      ]
    },
    "18": {
      "traducao_completa": "Todo o macho entre os filhos de Arão comerá dela; estatuto perpétuo será para as vossas gerações das ofertas queimadas de YHWH; tudo o que as tocar será santo.",
      "palavras": [
        { "hebraico": "כָּל־זָכָר", "transliteral": "kāl-zā-ḵār", "traducao_palavra": "todo macho" },
        { "hebraico": "בִּבְנֵי", "transliteral": "biḇ-nê", "traducao_palavra": "entre filhos de" },
        { "hebraico": "אַהֲרֹן", "transliteral": "ʾa-hă-rōn", "traducao_palavra": "Arão" },
        { "hebraico": "יֹאכֲלֶנָּה", "transliteral": "yō-ḵă-len-nā", "traducao_palavra": "comerá dela" }
      ]
    },
    "19": {
      "traducao_completa": "E falou YHWH a Moisés, dizendo:",
      "palavras": [
        { "hebraico": "וַיְדַבֵּר", "transliteral": "way-yə-ḏab-bēr", "traducao_palavra": "e falou" },
        { "hebraico": "יְהוָה", "transliteral": "YHWH", "traducao_palavra": "YHWH" },
        { "hebraico": "אֶל־מֹשֶׁה", "transliteral": "ʾel-mō-šeh", "traducao_palavra": "a Moisés" },
        { "hebraico": "לֵּאמֹר׃", "transliteral": "lē-mōr", "traducao_palavra": "dizendo" }
      ]
    },
    "20": {
      "traducao_completa": "Esta é a oferta de Arão e de seus filhos, que oferecerão a YHWH no dia em que um deles for ungido: a décima parte de um efa de flor de farinha, oferta de manjares contínua, metade dela pela manhã e a outra metade à tarde.",
      "palavras": [
        { "hebraico": "זֶה", "transliteral": "zeh", "traducao_palavra": "esta [é]" },
        { "hebraico": "קָרְבַּן", "transliteral": "qā-rə-ban", "traducao_palavra": "[a] oferta de" },
        { "hebraico": "אַהֲרֹן", "transliteral": "ʾa-hă-rōn", "traducao_palavra": "Arão" },
        { "hebraico": "וּבָנָיו", "transliteral": "û-ḇā-nāyw", "traducao_palavra": "e seus filhos" },
        { "hebraico": "אֲשֶׁר־יַקְרִיבוּ", "transliteral": "ʾă-šer-yaq-rî-ḇû", "traducao_palavra": "que oferecerão" },
        { "hebraico": "לַיהוָה", "transliteral": "la-YHWH", "traducao_palavra": "a YHWH" },
        { "hebraico": "בְּיוֹם", "transliteral": "bə-yôm", "traducao_palavra": "no dia" },
        { "hebraico": "הִמָּשַׁח", "transliteral": "him-mā-šaḥ", "traducao_palavra": "[de] ser ungido" },
        { "hebraico": "אֹתוֹ", "transliteral": "ʾō-ṯô", "traducao_palavra": "ele" }
      ]
    },
    "21": {
      "traducao_completa": "Numa assadeira se fará com azeite; cozida a trarás; em pedaços cozidos de oferta de manjares a oferecerás, por aroma suave a YHWH.",
      "palavras": [
        { "hebraico": "עַל־מַחֲבַת", "transliteral": "ʿal-ma-ḥă-ḇaṯ", "traducao_palavra": "sobre assadeira" },
        { "hebraico": "בַּשֶּׁמֶן", "transliteral": "baš-še-men", "traducao_palavra": "com azeite" },
        { "hebraico": "תֵּעָשֶׂה", "transliteral": "ṯê-ʿā-śeh", "traducao_palavra": "será feita" },
        { "hebraico": "מֻרְבֶּכֶת", "transliteral": "mur-be-ḵeṯ", "traducao_palavra": "cozida/misturada" },
        { "hebraico": "תְּבִיאֶנָּה", "transliteral": "tə-ḇî-ʾen-nā", "traducao_palavra": "a trarás" }
      ]
    },
    "22": {
      "traducao_completa": "E o sacerdote que, de entre seus filhos, for ungido em seu lugar, fará isso; estatuto perpétuo é de YHWH; tudo se queimará.",
      "palavras": [
        { "hebraico": "וְהַכֹּהֵן", "transliteral": "wə-hak-kō-hên", "traducao_palavra": "e o sacerdote" },
        { "hebraico": "הַמָּשִׁיחַ", "transliteral": "ham-mā-šî-aḥ", "traducao_palavra": "o ungido" },
        { "hebraico": "תַּחְתָּיו", "transliteral": "taḥ-tāyw", "traducao_palavra": "em seu lugar" },
        { "hebraico": "מִבָּנָיו", "transliteral": "mib-bā-nāyw", "traducao_palavra": "de seus filhos" }
      ]
    },
    "23": {
      "traducao_completa": "Assim toda a oferta de manjares do sacerdote será totalmente queimada; não se comerá.",
      "palavras": [
        { "hebraico": "וְכָל־מִנְחַת", "transliteral": "wə-ḵāl-min-ḥaṯ", "traducao_palavra": "e toda oferta de" },
        { "hebraico": "כֹּהֵן", "transliteral": "kō-hên", "traducao_palavra": "sacerdote" },
        { "hebraico": "כָּלִיל", "transliteral": "kā-lîl", "traducao_palavra": "total/inteira" },
        { "hebraico": "תִּהְיֶה", "transliteral": "tih-yeh", "traducao_palavra": "será" },
        { "hebraico": "לֹא", "transliteral": "lō", "traducao_palavra": "não" },
        { "hebraico": "תֵאָכֵל׃", "transliteral": "ṯê-ʾā-ḵêl", "traducao_palavra": "se comerá" }
      ]
    },
    "24": {
      "traducao_completa": "E falou YHWH a Moisés, dizendo:",
      "palavras": [
        { "hebraico": "וַיְדַבֵּר", "transliteral": "way-yə-ḏab-bēr", "traducao_palavra": "e falou" },
        { "hebraico": "יְהוָה", "transliteral": "YHWH", "traducao_palavra": "YHWH" },
        { "hebraico": "אֶל־מֹשֶׁה", "transliteral": "ʾel-mō-šeh", "traducao_palavra": "a Moisés" },
        { "hebraico": "לֵּאמֹר׃", "transliteral": "lē-mōr", "traducao_palavra": "dizendo" }
      ]
    },
    "25": {
      "traducao_completa": "Fala a Arão e a seus filhos, dizendo: Esta é a lei da oferta pelo pecado: no lugar onde se degola o holocausto se degolará a oferta pelo pecado perante YHWH; coisa santíssima é.",
      "palavras": [
        { "hebraico": "דַּבֵּר", "transliteral": "dab-bēr", "traducao_palavra": "fala" },
        { "hebraico": "אֶל־אַהֲרֹן", "transliteral": "ʾel-ʾa-hă-rōn", "traducao_palavra": "a Arão" },
        { "hebraico": "זֹאת", "transliteral": "zōṯ", "traducao_palavra": "esta [é]" },
        { "hebraico": "תּוֹרַת", "transliteral": "tō-raṯ", "traducao_palavra": "a lei de" },
        { "hebraico": "הַחַטָּאת", "transliteral": "ha-ḥaṭ-ṭāṯ", "traducao_palavra": "a oferta pelo pecado" },
        { "hebraico": "בִּמְקוֹם", "transliteral": "bim-qôm", "traducao_palavra": "no lugar" },
