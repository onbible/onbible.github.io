        { "hebraico": "בַּכֹּהֲנִים", "transliteral": "bak-kō-hă-nîm", "traducao_palavra": "entre os sacerdotes" },
        { "hebraico": "יֹאכַל", "transliteral": "yō-ḵal", "traducao_palavra": "comerá" },
        { "hebraico": "אֹתָהּ", "transliteral": "ʾō-ṯāh", "traducao_palavra": "ela" }
      ]
    },
    "30": {
      "traducao_completa": "Porém não se comerá nenhuma oferta pelo pecado, cujo sangue se traz à tenda da congregação para fazer expiação no santuário; no fogo será queimada.",
      "palavras": [
        { "hebraico": "וְכָל־חַטָּאת", "transliteral": "wə-ḵāl-ḥaṭ-ṭāṯ", "traducao_palavra": "e toda oferta pelo pecado" },
        { "hebraico": "אֲשֶׁר", "transliteral": "ʾă-šer", "traducao_palavra": "que" },
        { "hebraico": "יוּבָא", "transliteral": "yû-ḇā", "traducao_palavra": "for trazido" },
        { "hebraico": "מִדָּמָהּ", "transliteral": "mid-dā-māh", "traducao_palavra": "de seu sangue" },
        { "hebraico": "אֶל־אֹהֶל", "transliteral": "ʾel-ʾō-hel", "traducao_palavra": "à tenda de" },
        { "hebraico": "מוֹעֵד", "transliteral": "mô-ʿēḏ", "traducao_palavra": "congregação" },
        { "hebraico": "לְכַפֵּר", "transliteral": "lə-ḵap-pēr", "traducao_palavra": "para expiar" },
        { "hebraico": "בַּקֹּדֶשׁ", "transliteral": "baq-qō-ḏeš", "traducao_palavra": "no santuário" },
        { "hebraico": "בָּאֵשׁ", "transliteral": "bā-ʾêš", "traducao_palavra": "no fogo" },
        { "hebraico": "תִּשָּׂרֵף׃", "transliteral": "tiś-śā-rēp̄", "traducao_palavra": "será queimada" }
