    "26": {
      "traducao_completa": "O sacerdote que a oferecer pelo pecado a comerá; no lugar santo se comerá, no pátio da tenda da congregação.",
      "palavras": [
        { "hebraico": "הַכֹּהֵן", "transliteral": "hak-kō-hên", "traducao_palavra": "o sacerdote" },
        { "hebraico": "הַמְחַטֵּא", "transliteral": "ham-ḥaṭ-ṭê", "traducao_palavra": "que a oferece pelo pecado" },
        { "hebraico": "אֹתָהּ", "transliteral": "ʾō-ṯāh", "traducao_palavra": "ela" },
        { "hebraico": "יֹאכֲלֶנָּה", "transliteral": "yō-ḵă-len-nā", "traducao_palavra": "comerá ela" }
      ]
    },
    "27": {
      "traducao_completa": "Tudo o que tocar a sua carne será santo; e quando o seu sangue for espargido sobre qualquer veste, lavarás aquilo sobre que caiu o sangue no lugar santo.",
