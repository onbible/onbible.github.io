        { "hebraico": "כֹּל", "transliteral": "kōl", "traducao_palavra": "tudo" },
        { "hebraico": "אֲשֶׁר־יִגַּע", "transliteral": "ʾă-šer-yig-gaʿ", "traducao_palavra": "que tocar" },
        { "hebraico": "בִּבְשָׂרָהּ", "transliteral": "biḇ-śā-rāh", "traducao_palavra": "em sua carne" },
        { "hebraico": "יִקְדָּשׁ", "transliteral": "yiq-dāš", "traducao_palavra": "será santo" }
      ]
    },
    "28": {
      "traducao_completa": "E o vaso de barro em que for cozida será quebrado; porém, se for cozida num vaso de bronze, esfregar-se-á e lavar-se-á com água.",
      "palavras": [
        { "hebraico": "וּכְלִי־חֶרֶשׂ", "transliteral": "û-ḵəlî-ḥe-reś", "traducao_palavra": "e vaso de barro" },
        { "hebraico": "אֲשֶׁר", "transliteral": "ʾă-šer", "traducao_palavra": "que" },
        { "hebraico": "תְּבֻשַּׁל־בּוֹ", "transliteral": "tə-ḇuš-šal-bô", "traducao_palavra": "for cozida nele" },
        { "hebraico": "יִשָּׁבֵר", "transliteral": "yiš-šā-ḇêr", "traducao_palavra": "será quebrado" },
        { "hebraico": "וְאִם־בִּכְלִי", "transliteral": "wə-ʾim-biḵ-lî", "traducao_palavra": "e se em vaso de" },
        { "hebraico": "נְחֹשֶׁת", "transliteral": "nə-ḥō-šeṯ", "traducao_palavra": "bronze/cobre" }
