        { "hebraico": "יְהוָ֖ה", "transliteral": "YHWH", "traducao_palavra": "YHWH" },
        { "hebraico": "אֶל־מֹשֶׁ֥ה", "transliteral": "ʾel-mō-šeh", "traducao_palavra": "a Moisés" },
        { "hebraico": "לֵּאמֹֽר׃", "transliteral": "lē-mōr", "traducao_palavra": "dizendo" }
      ]
    },
    "2": {
      "traducao_completa": "Também dirás aos filhos de Israel: Qualquer dos filhos de Israel, ou dos estrangeiros que peregrinam em Israel, que der da sua semente a Moleque, certamente morrerá; o povo da terra o apedrejará com pedras.",
      "palavras": [
        { "hebraico": "וְאֶל־בְּנֵ֨י", "transliteral": "wə-ʾel-bə-nê", "traducao_palavra": "e aos filhos de" },
        { "hebraico": "יִשְׂרָאֵ֜ל", "transliteral": "yiś-rā-ʾēl", "traducao_palavra": "Israel" },
        { "hebraico": "תֹּאמַ֗ר", "transliteral": "tō-mar", "traducao_palavra": "dirás" },
        { "hebraico": "אִ֣ישׁ אִּישׁ֩", "transliteral": "ʾîš ʾîš", "traducao_palavra": "qualquer homem" },
        { "hebraico": "מִבְּנֵ֨י", "transliteral": "mib-bə-nê", "traducao_palavra": "dos filhos de" },
        { "hebraico": "יִשְׂרָאֵ֜ל", "transliteral": "yiś-rā-ʾēl", "traducao_palavra": "Israel" },
        { "hebraico": "וּמִן־הַגֵּ֣ר", "transliteral": "ū-min-ha-gēr", "traducao_palavra": "e do estrangeiro" },
        { "hebraico": "הַגָּ֣ר", "transliteral": "ha-gār", "traducao_palavra": "que habita" },
        { "hebraico": "בְּיִשְׂרָאֵ֗ל", "transliteral": "bə-yiś-rā-ʾēl", "traducao_palavra": "em Israel" },
        { "hebraico": "אֲשֶׁ֨ר יִתֵּ֧ן", "transliteral": "ʾă-šer yit-tên", "traducao_palavra": "que der" },
        { "hebraico": "מִזַּרְעֹ֛ו", "transliteral": "miz-zar-ʿô", "traducao_palavra": "da sua semente" },
        { "hebraico": "לַמֹּ֖לֶךְ", "transliteral": "lam-mō-leḵ", "traducao_palavra": "a Moleque" },
        { "hebraico": "מֹ֣ות יוּמָ֑ת", "transliteral": "môṯ yū-māṯ", "traducao_palavra": "certamente morrerá" },
        { "hebraico": "עַ֥ם", "transliteral": "ʿam", "traducao_palavra": "[o] povo de" },
        { "hebraico": "הָאָ֖רֶץ", "transliteral": "hā-ʾā-reṣ", "traducao_palavra": "a terra" },
        { "hebraico": "יִרְגְּמֻ֥הוּ", "transliteral": "yir-gə-mu-hû", "traducao_palavra": "o apedrejarão" },
        { "hebraico": "בָאָֽבֶן׃", "transliteral": "ḇā-ʾā-base", "traducao_palavra": "com pedra" }
      ]
    },
    "3": {
      "traducao_completa": "E eu porei a minha face contra esse homem, e o extirparei do meio do seu povo, porquanto deu da sua semente a Moleque, para contaminar o meu santuário e profanar o meu santo nome.",
      "palavras": [
        { "hebraico": "וַאֲנִ֞י", "transliteral": "wa-ʾă-nî", "traducao_palavra": "e Eu" },
        { "hebraico": "אֶתֵּ֤ן", "transliteral": "ʾet-tên", "traducao_palavra": "porei" },
        { "hebraico": "אֶת־פָּנַי֙", "transliteral": "ʾeṯ-pā-nay", "traducao_palavra": "minha face" },
        { "hebraico": "בָּאִ֣ישׁ", "transliteral": "bā-ʾîš", "traducao_palavra": "contra o homem" },
        { "hebraico": "הַה֔וּא", "transliteral": "ha-hû", "traducao_palavra": "aquele" },
        { "hebraico": "וְהִכְרַתִּ֥י", "transliteral": "wə-hiḵ-rat-tî", "traducao_palavra": "e o extirparei" },
        { "hebraico": "אֹתֹ֖ו", "transliteral": "ʾō-ṯô", "traducao_palavra": "ele" },
