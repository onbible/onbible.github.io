        { "hebraico": "מֹ֣ות יוּמָ֑ת", "transliteral": "môṯ yū-māṯ", "traducao_palavra": "certamente morrerá" }
      ]
    },
    "10": {
      "traducao_completa": "Também o homem que adulterar com a mulher de outro homem, a saber, o que adulterar com a mulher do seu próximo, certamente morrerão o adúltero e a adúltera.",
      "palavras": [
        { "hebraico": "וְאִ֗ישׁ", "transliteral": "wə-ʾîš", "traducao_palavra": "e um homem" },
        { "hebraico": "אֲשֶׁ֤ר יִנְאַף֙", "transliteral": "ʾă-šer yin-ʾap̄", "traducao_palavra": "que adulterar" },
        { "hebraico": "אֶת־אֵ֣שֶׁת אִ֔ישׁ", "transliteral": "ʾeṯ-ʾê-šeṯ ʾîš", "traducao_palavra": "com a mulher de [outro] homem" }
      ]
    },
    "11": {
      "traducao_completa": "E o homem que se deitar com a mulher de seu pai descobriu a nudez de seu pai; ambos certamente morrerão; o seu sangue será sobre eles.",
      "palavras": [
        { "hebraico": "וְאִ֗ישׁ", "transliteral": "wə-ʾîš", "traducao_palavra": "e um homem" },
        { "hebraico": "אֲשֶׁ֤ר יִשְׁכַּב֙", "transliteral": "ʾă-šer yiš-kab", "traducao_palavra": "que se deitar" },
        { "hebraico": "אֶת־אֵ֣שֶׁת אָבִ֔יו", "transliteral": "ʾeṯ-ʾê-šeṯ ʾā-ḇîw", "traducao_palavra": "com a mulher de seu pai" }
      ]
    },
    "12": {
      "traducao_completa": "E, quando um homem se deitar com a sua nora, ambos certamente morrerão; fizeram confusão; o seu sangue será sobre eles.",
      "palavras": [
        { "hebraico": "וְאִ֗ישׁ", "transliteral": "wə-ʾîš", "traducao_palavra": "e um homem" },
        { "hebraico": "אֲשֶׁ֤ר יִשְׁכ_כַּב֙", "transliteral": "ʾă-šer yiš-kab", "traducao_palavra": "que se deitar" },
        { "hebraico": "אֶת־כַּלָּתֹ֔ו", "transliteral": "ʾeṯ-kal-lā-ṯô", "traducao_palavra": "com a sua nora" }
      ]
    },
    "13": {
      "traducao_completa": "Quando também um homem se deitar com outro macho, como se fosse mulher, ambos fizeram abominação; certamente morrerão; o seu sangue será sobre eles.",
      "palavras": [
        { "hebraico": "וְאִ֗ישׁ", "transliteral": "wə-ʾîš", "traducao_palavra": "e um homem" },
        { "hebraico": "אֲשֶׁ֨ר יִשְׁכַּ֤ב", "transliteral": "ʾă-šer yiš-kab", "traducao_palavra": "que se deitar" },
        { "hebraico": "אֶת־זָכָר֙", "transliteral": "ʾeṯ-zā-ḵār", "traducao_palavra": "com um macho" },
        { "hebraico": "מִשְׁכְּבֵ֣י אִשָּׁ֔ה", "transliteral": "miš-kə-ḇê ʾiš-šā", "traducao_palavra": "[como] leito de mulher" }
      ]
    },
    "14": {
      "traducao_completa": "E, quando um homem tomar uma mulher e a sua mãe, maldade é; a ele e a elas queimarão com fogo, para que não haja maldade no meio de vós.",
      "palavras": [
        { "hebraico": "וְאִ֗ישׁ", "transliteral": "wə-ʾîš", "traducao_palavra": "e um homem" },
        { "hebraico": "אֲשֶׁ֨ר יִקַּ֧ח", "transliteral": "ʾă-šer yiq-qaḥ", "traducao_palavra": "que tomar" },
        { "hebraico": "אֶת־אִשָּׁ֛ה", "transliteral": "ʾeṯ-ʾiš-šā", "traducao_palavra": "uma mulher" },
        { "hebraico": "וְאֶת־אִמָּ֖הּ", "transliteral": "wə-ʾeṯ-ʾim-māh", "traducao_palavra": "e a sua mãe" }
      ]
    },
    "15": {
      "traducao_completa": "E, quando um homem se deitar com um animal, certamente morrerá; e matareis o animal.",
      "palavras": [
        { "hebraico": "וְאִ֕ישׁ", "transliteral": "wə-ʾîš", "traducao_palavra": "e um homem" },
        { "hebraico": "אֲשֶׁ֨ר יִתֵּ֧ן", "transliteral": "ʾă-šer yit-tên", "traducao_palavra": "que der" },
        { "hebraico": "שְׁכָבְתֹּ֛ו", "transliteral": "šə-ḵā-ḇə-ṯô", "traducao_palavra": "seu deitar" },
        { "hebraico": "בִּבְהֵמָ֖ה", "transliteral": "biḇ-hē-mā", "traducao_palavra": "com um animal" },
        { "hebraico": "מֹ֣ות יוּמָ֑ת", "transliteral": "môṯ yū-māṯ", "traducao_palavra": "certamente morrerá" },
        { "hebraico": "וְאֶת־הַבְּהֵמָ֖ה", "transliteral": "wə-ʾeṯ-hab-bə-hē-mā", "traducao_palavra": "e o animal" },
        { "hebraico": "תַּהֲרֹֽגוּ׃", "transliteral": "ta-hă-rō-ḡû", "traducao_palavra": "matareis" }
      ]
    },
    "16": {
      "traducao_completa": "E a mulher que se chegar a algum animal, para ajuntar-se com ele, matarás a mulher e o animal; certamente morrerão; o seu sangue será sobre eles.",
      "palavras": [
        { "hebraico": "וְאִשָּׁ֗ה", "transliteral": "wə-ʾiš-šā", "traducao_palavra": "e uma mulher" },
        { "hebraico": "אֲשֶׁ֨ר", "transliteral": "ʾă-šer", "traducao_palavra": "que" },
        { "hebraico": "תִּקְרַ֤ב", "transliteral": "tiq-raḇ", "traducao_palavra": "se chegar" },
        { "hebraico": "אֶל־כָּל־בְּהֵמָה֙", "transliteral": "ʾel-kāl-bə-hē-mā", "traducao_palavra": "a qualquer animal" },
        { "hebraico": "לְרִבְעָ֣ה", "transliteral": "lə-riḇ-ʿā", "traducao_palavra": "para copular/deitar" },
        { "hebraico": "אֹתָ֔הּ", "transliteral": "ʾō-ṯāh", "traducao_palavra": "com ele" },
        { "hebraico": "וְהָרַגְתָּ֥", "transliteral": "wə-hā-raḡ-tā", "traducao_palavra": "e matarás" },
        { "hebraico": "אֶת־הָאִשָּׁ֖ה", "transliteral": "ʾeṯ-hā-ʾiš-šā", "traducao_palavra": "a mulher" },
        { "hebraico": "וְאֶת־הַבְּהֵמָ֑ה", "transliteral": "wə-ʾeṯ-hab-bə-hē-mā", "traducao_palavra": "e o animal" },
        { "hebraico": "מֹ֥ות", "transliteral": "môṯ", "traducao_palavra": "morte" },
        { "hebraico": "יוּמָ֖תוּ", "transliteral": "yū-mā-ṯû", "traducao_palavra": "certamente morrerão" },
        { "hebraico": "דְּמֵיהֶ֥ם", "transliteral": "də-mê-hem", "traducao_palavra": "o sangue deles" },
