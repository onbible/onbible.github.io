      ]
    },
    "25": {
      "traducao_completa": "Fareis, pois, diferença entre os animais limpos e os imundos, e entre as aves imundas e as limpas; e as vossas almas não fareis abomináveis por causa dos animais, ou das aves, ou de tudo o que se arrasta sobre a terra, as quais coisas apartei de vós, para tê-las por imundas.",
      "palavras": [
        { "hebraico": "וְהִבְדַּלְתֶּ֞ם", "transliteral": "wə-hiḇ-dal-tem", "traducao_palavra": "e fareis separação" },
        { "hebraico": "בֵּין־הַבְּהֵמָ֤ה", "transliteral": "bên-hab-bə-hē-mā", "traducao_palavra": "entre o animal" },
