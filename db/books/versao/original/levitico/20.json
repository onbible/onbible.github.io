        { "hebraico": "כִּ֣י", "transliteral": "kî", "traducao_palavra": "porque" },
        { "hebraico": "מִזַּרְעֹו֙", "transliteral": "miz-zar-ʿô", "traducao_palavra": "da sua semente" },
        { "hebraico": "נָתַ֣ן", "transliteral": "nā-ṯan", "traducao_palavra": "deu" },
        { "hebraico": "לַמֹּ֔לֶךְ", "transliteral": "lam-mō-leḵ", "traducao_palavra": "a Moleque" },
        { "hebraico": "לְמַ֨עַן", "transliteral": "lə-ma-ʿan", "traducao_palavra": "a fim de" },
        { "hebraico": "טַמֵּא֙", "transliteral": "ṭam-mē", "traducao_palavra": "contaminar" },
        { "hebraico": "אֶת־מִקְדָּשִׁ֔י", "transliteral": "ʾeṯ-miq-dā-šî", "traducao_palavra": "o meu santuário" },
        { "hebraico": "וּלְחַלֵּ֖ל", "transliteral": "ū-lə-ḥal-lēl", "traducao_palavra": "e para profanar" },
        { "hebraico": "אֶת־שֵׁ֥ם", "transliteral": "ʾeṯ-šēm", "traducao_palavra": "o nome de" },
        { "hebraico": "קָדְשִֽׁי׃", "transliteral": "qāḏ-šî", "traducao_palavra": "minha santidade" }
      ]
    },
    "4": {
      "traducao_completa": "E, se o povo da terra de alguma maneira esconder os olhos daquele homem, quando ele der da sua semente a Moleque, para não o matar,",
      "palavras": [
        { "hebraico": "וְאִם֩", "transliteral": "wə-ʾim", "traducao_palavra": "e se" },
        { "hebraico": "הַעְלֵ֨ם", "transliteral": "ha-ʿə-lêm", "traducao_palavra": "escondendo" },
        { "hebraico": "יַעְלִ֨ימוּ", "transliteral": "ya-ʿə-lî-mû", "traducao_palavra": "esconderem" },
        { "hebraico": "עַ֤ם", "transliteral": "ʿam", "traducao_palavra": "[o] povo de" },
        { "hebraico": "הָאָ֨רֶץ", "transliteral": "hā-ʾā-reṣ", "traducao_palavra": "a terra" },
        { "hebraico": "אֶת־עֵינֵיהֶם֮", "transliteral": "ʾeṯ-ʿê-nê-hem", "traducao_palavra": "os seus olhos" },
        { "hebraico": "מִן־הָאִ֣ישׁ", "transliteral": "min-hā-ʾîš", "traducao_palavra": "daquele homem" }
      ]
    },
    "5": {
      "traducao_completa": "Então eu porei a minha face contra aquele homem, e contra a sua família, e o extirparei do meio do seu povo, com todos os que se prostituem após ele, prostituindo-se após Moleque.",
      "palavras": [
        { "hebraico": "וְשַׂמְתִּ֨י", "transliteral": "wə-śam-tî", "traducao_palavra": "e porei" },
        { "hebraico": "אֲנִ֧י", "transliteral": "ʾă-nî", "traducao_palavra": "Eu" },
        { "hebraico": "אֶת־פָּנַ֛י", "transliteral": "ʾeṯ-pā-nay", "traducao_palavra": "minha face" },
        { "hebraico": "בָּאִ֥ישׁ", "transliteral": "bā-ʾîš", "traducao_palavra": "contra o homem" },
        { "hebraico": "הַה֖וּא", "transliteral": "ha-hû", "traducao_palavra": "aquele" }
      ]
    },
    "6": {
      "traducao_completa": "Quando uma alma se virar para os necromantes e adivinhos, para se prostituir após eles, eu porei a minha face contra aquela alma, e a extirparei do meio do seu povo.",
      "palavras": [
        { "hebraico": "וְהַנֶּ֗פֶשׁ", "transliteral": "wə-han-ne-p̄eš", "traducao_palavra": "e a alma" },
        { "hebraico": "אֲשֶׁ֨ר תִּפְנֶ֤ה", "transliteral": "ʾă-šer tip̄-neh", "traducao_palavra": "que se virar" },
        { "hebraico": "אֶל־הָאֹבֹת֙", "transliteral": "ʾel-hā-ʾō-ḇōṯ", "traducao_palavra": "para os necromantes" }
      ]
    },
    "7": {
      "traducao_completa": "Santificai-vos, pois, e sede santos, pois eu sou YHWH vosso Deus.",
      "palavras": [
        { "hebraico": "וְהִתְקַדִּשְׁתֶּם", "transliteral": "wə-hiṯ-qad-diš-tem", "traducao_palavra": "e santificai-vos" },
        { "hebraico": "וִהְיִיתֶ֖ם", "transliteral": "wih-yî-ṯem", "traducao_palavra": "e sede" },
        { "hebraico": "קְדֹשִׁ֑ים", "transliteral": "qə-ḏō-šîm", "traducao_palavra": "santos" },
        { "hebraico": "כִּ֛י", "transliteral": "kî", "traducao_palavra": "porque" },
        { "hebraico": "אֲנִ֥י", "transliteral": "ʾă-nî", "traducao_palavra": "Eu [sou]" },
        { "hebraico": "יְהוָ֖ה", "transliteral": "YHWH", "traducao_palavra": "YHWH" },
        { "hebraico": "אֱלֹהֵיכֶֽם׃", "transliteral": "ʾĕ-lō-hê-ḵem", "traducao_palavra": "vosso Deus" }
      ]
    },
    "8": {
      "traducao_completa": "E guardareis os meus estatutos, e os cumprireis. Eu sou YHWH que vos santifico.",
      "palavras": [
        { "hebraico": "וּשְׁמַרְתֶּם֙", "transliteral": "ū-šə-mar-tem", "traducao_palavra": "e guardareis" },
        { "hebraico": "אֶת־חֻקֹּתַ֔י", "transliteral": "ʾeṯ-ḥuq-qō-ṯay", "traducao_palavra": "os meus estatutos" },
        { "hebraico": "וַעֲשִׂיתֶ֖ם", "transliteral": "wa-ʿă-śî-ṯem", "traducao_palavra": "e fareis" },
        { "hebraico": "אֹתָ֑ם", "transliteral": "ʾō-ṯām", "traducao_palavra": "eles" },
        { "hebraico": "אֲנִ֥י", "transliteral": "ʾă-nî", "traducao_palavra": "Eu [sou]" },
        { "hebraico": "יְהוָ֖ה", "transliteral": "YHWH", "traducao_palavra": "YHWH" },
        { "hebraico": "מְקַדִּשְׁכֶֽם׃", "transliteral": "mə-qad-diš-ḵem", "traducao_palavra": "quem vos santifica" }
      ]
    },
    "9": {
      "traducao_completa": "Pois qualquer que amaldiçoar a seu pai ou a sua mãe, certamente morrerá; amaldiçoou a seu pai ou a sua mãe; o seu sangue será sobre ele.",
      "palavras": [
        { "hebraico": "כִּֽי־אִ֣ישׁ אִ֔ישׁ", "transliteral": "kî-ʾîš ʾîš", "traducao_palavra": "pois qualquer homem" },
        { "hebraico": "אֲשֶׁ֥ר יְקַלֵּ֛ל", "transliteral": "ʾă-šer yə-qal-lēl", "traducao_palavra": "que amaldiçoar" },
        { "hebraico": "אֶת־אָבִ֥יו", "transliteral": "ʾeṯ-ʾā-ḇîw", "traducao_palavra": "a seu pai" },
