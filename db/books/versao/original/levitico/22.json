        { "hebraico": "יִטְהָ֑ר", "transliteral": "yiṭ-hār", "traducao_palavra": "seja limpo" },
        { "hebraico": "וְהַנֹּגֵ֙עַ֙", "transliteral": "wə-han-nō-ḡē-aʿ", "traducao_palavra": "e o que tocar" },
