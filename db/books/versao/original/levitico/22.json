        { "hebraico": "בְּכָל־שֶׁרֶץ", "transliteral": "bə-ḵāl-še-reṣ", "traducao_palavra": "em qualquer rastejante" },
        { "hebraico": "אֲשֶׁ֥ר", "transliteral": "ʾă-šer", "traducao_palavra": "que" },
