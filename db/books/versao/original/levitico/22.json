        { "hebraico": "כִּֽי־יִקְנֶ֥ה", "transliteral": "kî-yiq-neh", "traducao_palavra": "comprar" },
        { "hebraico": "נֶ֙פֶשׁ֙", "transliteral": "ne-p̄eš", "traducao_palavra": "uma alma" },
        { "hebraico": "קִנְיַ֣ן", "transliteral": "qin-yan", "traducao_palavra": "aquisição de" },
