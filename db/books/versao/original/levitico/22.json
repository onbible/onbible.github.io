        { "hebraico": "אֹ֨ו", "transliteral": "ʾô", "traducao_palavra": "ou" },
        { "hebraico": "שָׁב֜וּר", "transliteral": "šā-ḇûr", "traducao_palavra": "quebrado" },
        { "hebraico": "אֹו־חָר֣וּץ", "transliteral": "ʾô-ḥā-rûṣ", "traducao_palavra": "ou mutilado/cortado" },
