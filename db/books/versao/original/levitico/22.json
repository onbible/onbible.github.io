        { "hebraico": "אֲלֵהֶ֗ם", "transliteral": "ʾă-lê-hem", "traducao_palavra": "a eles" },
        { "hebraico": "לְדֹרֹֽתֵיכֶם֙", "transliteral": "lə-ḏō-rō-ṯê-ḵem", "traducao_palavra": "pelas vossas gerações" },
