        { "hebraico": "קֹ֑דֶשׁ", "transliteral": "qō-ḏeš", "traducao_palavra": "coisa santa" },
        { "hebraico": "תֹּושַׁ֥ב", "transliteral": "tô-šaḇ", "traducao_palavra": "[o] hóspede de" },
