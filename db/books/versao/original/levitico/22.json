        { "hebraico": "יְהוָ֖ה", "transliteral": "YHWH", "traducao_palavra": "YHWH" },
        { "hebraico": "מְקַדְּשָֽׁם׃", "transliteral": "mə-qad-də-šām", "traducao_palavra": "quem os santifica" }
