        { "hebraico": "יִשְׂרָאֵ֜ל", "transliteral": "yiś-rā-ʾēl", "traducao_palavra": "Israel" },
        { "hebraico": "וּמִן־הַגֵּ֣ר", "transliteral": "ū-min-ha-gēr", "traducao_palavra": "ou do estrangeiro" },
