        { "hebraico": "בַצֹּ֑אן", "transliteral": "baṣ-ṣōn", "traducao_palavra": "de rebanho [ovelhas/cabras]" },
        { "hebraico": "תָּמִ֤ים", "transliteral": "tā-mîm", "traducao_palavra": "perfeito" },
