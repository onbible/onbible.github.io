    },
    "10": {
      "traducao_completa": "Nenhum estranho comerá das coisas santas; nem o hóspede do sacerdote, nem o seu diarista comerão das coisas santas.",
      "palavras": [
        { "hebraico": "וְכָל־זָ֖ר", "transliteral": "wə-ḵāl-zār", "traducao_palavra": "e nenhum estranho" },
