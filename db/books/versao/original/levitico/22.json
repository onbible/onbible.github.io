    "9": {
      "traducao_completa": "Guardarão, pois, o meu preceito, para que por isso não levem pecado, e morram nele, havendo-o profanado. Eu sou YHWH que os santifico.",
      "palavras": [
        { "hebraico": "וְשָׁמְר֣וּ", "transliteral": "wə-šā-mə-rû", "traducao_palavra": "e guardarão" },
        { "hebraico": "אֶת־מִשְׁמַרְתִּ֗י", "transliteral": "ʾeṯ miš-mar-tî", "traducao_palavra": "o meu encargo/preceito" },
        { "hebraico": "וְלֹֽא־יִשְׂא֤וּ", "transliteral": "wə-lō-yiś-ʾû", "traducao_palavra": "para que não levem" },
        { "hebraico": "עָלָיו֙", "transliteral": "ʿā-lāyw", "traducao_palavra": "sobre si" },
        { "hebraico": "חֵ֔טְא", "transliteral": "ḥêṭ", "traducao_palavra": "pecado" },
        { "hebraico": "וּמֵ֥תוּ", "transliteral": "ū-mê-ṯû", "traducao_palavra": "e morram" },
        { "hebraico": "בֹ֖ו", "transliteral": "ḇô", "traducao_palavra": "nele" },
        { "hebraico": "כִּ֣י", "transliteral": "kî", "traducao_palavra": "pois" },
        { "hebraico": "יְחַלְּלֻ֑הוּ", "transliteral": "yə-ḥal-lə-lu-hû", "traducao_palavra": "o profanaram" },
