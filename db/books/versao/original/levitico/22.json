        { "hebraico": "הַשֶּׁ֖מֶשׁ", "transliteral": "haš-še-meš", "traducao_palavra": "o sol" },
        { "hebraico": "וְטָהֵ֑ר", "transliteral": "wə-ṭā-hêr", "traducao_palavra": "então será limpo" },
        { "hebraico": "וְאַחַר", "transliteral": "wə-ʾa-ḥar", "traducao_palavra": "e depois" },
