        { "hebraico": "בְּדַם", "transliteral": "bə-ḏam", "traducao_palavra": "no sangue de" },
        { "hebraico": "הַצִּפֹּר", "transliteral": "ha-ṣip-pōr", "traducao_palavra": "a ave" },
