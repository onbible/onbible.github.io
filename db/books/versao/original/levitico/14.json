    "7": {
      "traducao_completa": "E sobre aquele que se houver de purificar da lepra aspergirá sete vezes, e o declarará limpo; e soltará a ave viva sobre a face do campo.",
      "palavras": [
        { "hebraico": "וְהִזָּה", "transliteral": "wə-hiz-zā", "traducao_palavra": "e aspergirá" },
        { "hebraico": "עַל", "transliteral": "ʿal", "traducao_palavra": "sobre" },
        { "hebraico": "הַמִּטַּהֵר", "transliteral": "ham-miṭ-ṭa-hêr", "traducao_palavra": "aquele que se purifica" },
        { "hebraico": "מִן־הַצָּרַעַת", "transliteral": "min-haṣ-ṣā-rā-ʿaṯ", "traducao_palavra": "da lepra" },
        { "hebraico": "שֶׁבַע", "transliteral": "še-ḇaʿ", "traducao_palavra": "sete" },
