    "8": {
      "traducao_completa": "E o que se houver de purificar lavará as suas vestes, e rapará todo o seu pelo, e se lavará com água; assim será limpo; e depois entrará no arraial, porém ficará fora da sua tenda por sete dias.",
      "palavras": [
        { "hebraico": "וְכִבֶּס", "transliteral": "wə-ḵib-bes", "traducao_palavra": "e lavará" },
        { "hebraico": "הַמִּטַּהֵר", "transliteral": "ham-miṭ-ṭa-hêr", "traducao_palavra": "aquele que se purifica" },
        { "hebraico": "אֶת־בְּגָדָיו", "transliteral": "ʾeṯ-bə-ḡā-ḏāyw", "traducao_palavra": "suas vestes" },
        { "hebraico": "וְגִלַּח", "transliteral": "wə-ḡil-laḥ", "traducao_palavra": "e rapará" },
        { "hebraico": "אֶת־כָּל־שְׂעָרוֹ", "transliteral": "ʾeṯ-kāl-śə-ʿā-rô", "traducao_palavra": "todo seu pelo" },
        { "hebraico": "וְרָחַץ", "transliteral": "wə-rā-ḥaṣ", "traducao_palavra": "e se banhará" },
        { "hebraico": "בַּמַּיִם", "transliteral": "bam-ma-yim", "traducao_palavra": "na água" },
        { "hebraico": "וְטָהֵר", "transliteral": "wə-ṭā-hêr", "traducao_palavra": "e será limpo" },
        { "hebraico": "וְאַחַר", "transliteral": "wə-ʾa-ḥar", "traducao_palavra": "e depois" },
        { "hebraico": "יָבוֹא", "transliteral": "yā-ḇô", "traducao_palavra": "entrará" },
        { "hebraico": "אֶל־הַמַּחֲנֶה", "transliteral": "ʾel-ham-ma-ḥă-neh", "traducao_palavra": "no arraial" },
        { "hebraico": "וְיָשַׁב", "transliteral": "wə-yā-šāḇ", "traducao_palavra": "e habitará" },
        { "hebraico": "מִחוּץ", "transliteral": "mi-ḥûṣ", "traducao_palavra": "fora de" },
        { "hebraico": "לְאָהֳלוֹ", "transliteral": "lə-ʾā-hŏ-lô", "traducao_palavra": "sua tenda" },
        { "hebraico": "שִׁבְעַת", "transliteral": "šib-ʿaṯ", "traducao_palavra": "sete" },
        { "hebraico": "יָמִים׃", "transliteral": "yā-mîm", "traducao_palavra": "dias" }
      ]
    },
    "9": {
      "traducao_completa": "E será que, ao sétimo dia, rapará todo o seu pelo, a cabeça, e a barba, e as sobrancelhas dos seus olhos; e rapará todo o seu pelo, e lavará as suas vestes, e lavará a sua carne em água, e será limpo.",
      "palavras": [
        { "hebraico": "וְהָיָה", "transliteral": "wə-hā-yā", "traducao_palavra": "e será" },
        { "hebraico": "בַיּוֹם", "transliteral": "ḇay-yôm", "traducao_palavra": "no dia" },
        { "hebraico": "הַשְּׁבִיעִי", "transliteral": "haš-šə-ḇî-ʿî", "traducao_palavra": "sétimo" },
        { "hebraico": "יְגַלַּח", "transliteral": "yə-ḡal-laḥ", "traducao_palavra": "ele rapará" },
        { "hebraico": "אֶת־כָּל־שְׂעָרוֹ", "transliteral": "ʾeṯ-kāl-śə-ʿā-rô", "traducao_palavra": "todo seu pelo" }
      ]
    },
    "10": {
      "traducao_completa": "E ao oitavo dia tomará dois cordeiros sem defeito, e uma cordeira de um ano, sem defeito, e três décimas de flor de farinha para oferta de manjares, amassada com azeite, e um log de azeite;",
      "palavras": [
        { "hebraico": "וּבַיּוֹם", "transliteral": "ū-ḇay-yôm", "traducao_palavra": "e no dia" },
        { "hebraico": "הַשְּׁמִינִי", "transliteral": "haš-šə-mî-nî", "traducao_palavra": "oitavo" },
        { "hebraico": "יִקַּח", "transliteral": "yiq-qaḥ", "traducao_palavra": "tomará" },
        { "hebraico": "שְׁנֵי־כְבָשִׂים", "transliteral": "šə-nê-ḵə-ḇā-śîm", "traducao_palavra": "dois cordeiros" },
        { "hebraico": "תְּמִימִם", "transliteral": "tə-mî-mim", "traducao_palavra": "sem defeito" }
      ]
    },
    "11": {
      "traducao_completa": "E o sacerdote que faz a purificação apresentará o homem que se houver de purificar, com aquelas coisas, perante YHWH, à porta da tenda da congregação.",
      "palavras": [
        { "hebraico": "וְהֶעֱמִיד", "transliteral": "wə-he-ʿĕ-mîḏ", "traducao_palavra": "e apresentará/fará estar" },
        { "hebraico": "הַכֹּהֵן", "transliteral": "hak-kō-hên", "traducao_palavra": "o sacerdote" },
        { "hebraico": "הַמְטַהֵר", "transliteral": "ham-ṭa-hêr", "traducao_palavra": "que purifica" },
        { "hebraico": "אֵת", "transliteral": "ʾēṯ", "traducao_palavra": "[objeto]" },
        { "hebraico": "הָאִישׁ", "transliteral": "hā-ʾîš", "traducao_palavra": "o homem" },
        { "hebraico": "הַמִּטַּהֵר", "transliteral": "ham-miṭ-ṭa-hêr", "traducao_palavra": "que se purifica" },
        { "hebraico": "וְאֹתָם", "transliteral": "wə-ʾō-ṯām", "traducao_palavra": "e eles [sacrifícios]" },
        { "hebraico": "לִפְנֵי", "transliteral": "lip̄-nê", "traducao_palavra": "perante" },
        { "hebraico": "יְהוָה", "transliteral": "YHWH", "traducao_palavra": "YHWH" },
        { "hebraico": "פֶּתַח", "transliteral": "pe-ṯaḥ", "traducao_palavra": "[à] porta de" },
        { "hebraico": "אֹהֶל", "transliteral": "ʾō-hel", "traducao_palavra": "tenda de" },
        { "hebraico": "מוֹעֵד׃", "transliteral": "mô-ʿēḏ", "traducao_palavra": "reunião/congregação" }
      ]
    },
    "12": {
      "traducao_completa": "E o sacerdote tomará um dos cordeiros, e o oferecerá por oferta pela culpa, e o log de azeite; e os moverá por oferta movida perante YHWH.",
      "palavras": [
        { "hebraico": "וְלָקַח", "transliteral": "wə-lā-qaḥ", "traducao_palavra": "e tomará" },
        { "hebraico": "הַכֹּהֵן", "transliteral": "hak-kō-hên", "traducao_palavra": "o sacerdote" },
        { "hebraico": "אֶת־הַכֶּבֶשׂ", "transliteral": "ʾeṯ-ha-ke-ḇeś", "traducao_palavra": "o cordeiro" }
      ]
    },
    "13": {
      "traducao_completa": "Então degolará o cordeiro no lugar onde se degola a oferta pelo pecado e o holocausto, no lugar santo; porque, como a oferta pelo pecado, assim a oferta pela culpa é para o sacerdote; coisa santíssima é.",
      "palavras": [
        { "hebraico": "וְשָׁחַט", "transliteral": "wə-šā-ḥaṭ", "traducao_palavra": "e degolará" },
        { "hebraico": "אֶת־הַכֶּבֶשׂ", "transliteral": "ʾeṯ-ha-ke-ḇeś", "traducao_palavra": "o cordeiro" }
      ]
    },
    "14": {
      "traducao_completa": "E o sacerdote tomará do sangue da oferta pela culpa, e o sacerdote o porá sobre a ponta da orelha direita daquele que se houver de purificar, e sobre o polegar da sua mão direita, e sobre o polegar do seu pé direito.",
      "palavras": [
        { "hebraico": "וְלָקַח", "transliteral": "wə-lā-qaḥ", "traducao_palavra": "e tomará" },
        { "hebraico": "הַכֹּהֵן", "transliteral": "hak-kō-hên", "traducao_palavra": "o sacerdote" },
