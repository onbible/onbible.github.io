        { "hebraico": "אֶל־הַכֹּהֵן׃", "transliteral": "ʾel-hak-kō-hên", "traducao_palavra": "ao sacerdote" }
      ]
    },
    "3": {
      "traducao_completa": "E o sacerdote sairá fora do arraial, e o sacerdote o examinará, e eis que, se a praga da lepra do leproso estiver curada,",
      "palavras": [
        { "hebraico": "וְיָצָא", "transliteral": "wə-yā-ṣā", "traducao_palavra": "e sairá" },
        { "hebraico": "הַכֹּהֵן", "transliteral": "hak-kō-hên", "traducao_palavra": "o sacerdote" },
        { "hebraico": "אֶל־מִחוּץ", "transliteral": "ʾel-mi-ḥûṣ", "traducao_palavra": "para fora" },
        { "hebraico": "לַמַּחֲנֶה", "transliteral": "lam-ma-ḥă-neh", "traducao_palavra": "do arraial" },
        { "hebraico": "וְרָאָה", "transliteral": "wə-rā-ʾā", "traducao_palavra": "e examinará" },
        { "hebraico": "הַכֹּהֵן", "transliteral": "hak-kō-hên", "traducao_palavra": "o sacerdote" },
        { "hebraico": "וְהִנֵּה", "transliteral": "wə-hin-nê", "traducao_palavra": "e eis que" },
        { "hebraico": "נִרְפָּא", "transliteral": "nir-pā", "traducao_palavra": "está curada" },
        { "hebraico": "נֶגַע־הַצָּרַעַת", "transliteral": "ne-ḡaʿ-haṣ-ṣā-rā-ʿaṯ", "traducao_palavra": "a praga da lepra" },
        { "hebraico": "מִן־הַצָּרוּעַ׃", "transliteral": "min-haṣ-ṣā-rû-aʿ", "traducao_palavra": "do leproso" }
      ]
    },
    "4": {
      "traducao_completa": "Então o sacerdote ordenará que se tomem, para aquele que se houver de purificar, duas aves vivas e limpas, e pau de cedro, e carmesim, e hissopo.",
      "palavras": [
        { "hebraico": "וְצִוָּה", "transliteral": "wə-ṣiw-wā", "traducao_palavra": "então ordenará" },
        { "hebraico": "הַכֹּהֵן", "transliteral": "hak-kō-hên", "traducao_palavra": "o sacerdote" },
        { "hebraico": "וְלָקַח", "transliteral": "wə-lā-qaḥ", "traducao_palavra": "e se tomará" },
        { "hebraico": "לַמִּטַּהֵר", "transliteral": "lam-miṭ-ṭa-hêr", "traducao_palavra": "para aquele que se purifica" },
        { "hebraico": "שְׁתֵּי־צִפֳּרִים", "transliteral": "šə-tê-ṣip-pŏ-rîm", "traducao_palavra": "duas aves" },
        { "hebraico": "חַיּוֹת", "transliteral": "ḥay-yōṯ", "traducao_palavra": "vivas" },
        { "hebraico": "טְהֹרוֹת", "transliteral": "ṭə-hō-rōṯ", "traducao_palavra": "limpas" },
        { "hebraico": "וְעֵץ", "transliteral": "wə-ʿêṣ", "traducao_palavra": "e pau de" },
        { "hebraico": "אֶרֶז", "transliteral": "ʾe-rez", "traducao_palavra": "cedro" },
        { "hebraico": "וּשְׁנִי", "transliteral": "ū-šə-nî", "traducao_palavra": "e escarlate/carmesim" },
        { "hebraico": "תוֹלַעַת", "transliteral": "ṯô-la-ʿaṯ", "traducao_palavra": "[de] verme" },
        { "hebraico": "וְאֵזֹב׃", "transliteral": "wə-ʾē-zōḇ", "traducao_palavra": "e hissopo" }
      ]
    },
    "5": {
      "traducao_completa": "E ordenará o sacerdote que se degole uma ave num vaso de barro sobre águas vivas.",
      "palavras": [
        { "hebraico": "וְצִוָּה", "transliteral": "wə-ṣiw-wā", "traducao_palavra": "e ordenará" },
        { "hebraico": "הַכֹּהֵן", "transliteral": "hak-kō-hên", "traducao_palavra": "o sacerdote" },
        { "hebraico": "וְשָׁחַט", "transliteral": "wə-šā-ḥaṭ", "traducao_palavra": "e degolará" },
        { "hebraico": "אֶת־הַצִּפּוֹר", "transliteral": "ʾeṯ-ha-ṣip-pôr", "traducao_palavra": "a ave" },
        { "hebraico": "הָאֶחָת", "transliteral": "hā-ʾe-ḥāḏ", "traducao_palavra": "a uma" },
        { "hebraico": "אֶל־כְּלִי־חֶרֶשׂ", "transliteral": "ʾel-kə-lî-ḥe-reś", "traducao_palavra": "num vaso de barro" },
        { "hebraico": "עַל־מַיִם", "transliteral": "ʿal-ma-yim", "traducao_palavra": "sobre águas" },
        { "hebraico": "חַיִּים׃", "transliteral": "ḥay-yîm", "traducao_palavra": "vivas/correntes" }
      ]
    },
    "6": {
      "traducao_completa": "Quanto à ave viva, tomá-la-á, e o pau de cedro, e o carmesim, e o hissopo, e os molhará, com a ave viva, no sangue da ave que foi degolada sobre as águas vivas.",
      "palavras": [
        { "hebraico": "אֶת־הַצִּפֹּר", "transliteral": "ʾeṯ-ha-ṣip-pōr", "traducao_palavra": "a ave" },
        { "hebraico": "הַחַיָּה", "transliteral": "ha-ḥay-yā", "traducao_palavra": "viva" },
        { "hebraico": "יִקַּח", "transliteral": "yiq-qaḥ", "traducao_palavra": "tomará" },
        { "hebraico": "אֹתָהּ", "transliteral": "ʾō-ṯāh", "traducao_palavra": "ela" },
