        { "hebraico": "אֶת־הַצִּפֹּר", "transliteral": "ʾeṯ-ha-ṣip-pōr", "traducao_palavra": "a ave" },
        { "hebraico": "הַחַיָּה", "transliteral": "ha-ḥay-yā", "traducao_palavra": "viva" },
        { "hebraico": "עַל־פְּנֵי", "transliteral": "ʿal-pə-nê", "traducao_palavra": "sobre a face de" },
        { "hebraico": "הַשָּׂדֶה׃", "transliteral": "haś-śā-ḏeh", "traducao_palavra": "o campo" }
      ]
