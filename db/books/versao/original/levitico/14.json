        { "hebraico": "לֵּאמֹר׃", "transliteral": "lē-mōr", "traducao_palavra": "dizendo" }
      ]
    },
    "2": {
      "traducao_completa": "Esta será a lei do leproso no dia da sua purificação: será levado ao sacerdote;",
      "palavras": [
        { "hebraico": "זֹאת", "transliteral": "zōṯ", "traducao_palavra": "esta" },
        { "hebraico": "תִּהְיֶה", "transliteral": "tih-yeh", "traducao_palavra": "será" },
        { "hebraico": "תּוֹרַת", "transliteral": "tō-raṯ", "traducao_palavra": "a lei de" },
        { "hebraico": "הַמְּצֹרָע", "transliteral": "ham-mə-ṣō-rāʿ", "traducao_palavra": "o leproso" },
        { "hebraico": "בְּיוֹם", "transliteral": "bə-yôm", "traducao_palavra": "no dia de" },
        { "hebraico": "טָהֳרָתוֹ", "transliteral": "ṭā-hŏ-rā-ṯô", "traducao_palavra": "sua purificação" },
