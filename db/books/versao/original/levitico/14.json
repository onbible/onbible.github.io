        { "hebraico": "וְאֶת־הָאֵזֹב", "transliteral": "wə-ʾeṯ-hā-ʾē-zōḇ", "traducao_palavra": "e o hissopo" },
        { "hebraico": "וְטָבַל", "transliteral": "wə-ṭā-ḇal", "traducao_palavra": "e molhará" },
        { "hebraico": "אוֹתָם", "transliteral": "ʾô-ṯām", "traducao_palavra": "eles" },
        { "hebraico": "וְאֵת", "transliteral": "wə-ʾēṯ", "traducao_palavra": "e" },
        { "hebraico": "הַצִּפֹּר", "transliteral": "ha-ṣip-pōr", "traducao_palavra": "a ave" },
