      ]
    },
    "35": {
      "traducao_completa": "Então aquele de quem for a casa virá e informará ao sacerdote, dizendo: Parece-me que há como que praga em minha casa.",
      "palavras": [
        { "hebraico": "וּבָא", "transliteral": "ū-ḇā", "traducao_palavra": "e virá" },
        { "hebraico": "אֲשֶׁר־לוֹ", "transliteral": "ʾă-šer-lô", "traducao_palavra": "aquele de quem [for]" },
        { "hebraico": "הַבַּיִת", "transliteral": "hab-ba-yiṯ", "traducao_palavra": "a casa" },
        { "hebraico": "וְהִגִּיד", "transliteral": "wə-hig-gîḏ", "traducao_palavra": "e informará" },
        { "hebraico": "לַכֹּהֵן", "transliteral": "lak-kō-hên", "traducao_palavra": "ao sacerdote" },
        { "hebraico": "לֵאמֹר", "transliteral": "lē-mōr", "traducao_palavra": "dizendo" },
        { "hebraico": "כְּנֶגַע", "transliteral": "kə-ne-ḡaʿ", "traducao_palavra": "como praga" },
        { "hebraico": "נִרְאָה", "transliteral": "nir-ʾā", "traducao_palavra": "parece" },
        { "hebraico": "לִי", "transliteral": "lî", "traducao_palavra": "a mim" },
        { "hebraico": "בַּבָּיִת׃", "transliteral": "bab-bā-yiṯ", "traducao_palavra": "na casa" }
      ]
    },
    "36": {
      "traducao_completa": "E o sacerdote ordenará que despejem a casa, antes que o sacerdote venha para examinar a praga, para que tudo o que está na casa não se torne imundo; e depois virá o sacerdote para examinar a casa.",
      "palavras": [
        { "hebraico": "וְצִוָּה", "transliteral": "wə-ṣiw-wā", "traducao_palavra": "e ordenará" },
        { "hebraico": "הַכֹּהֵן", "transliteral": "hak-kō-hên", "traducao_palavra": "o sacerdote" },
        { "hebraico": "וּפִנּוּ", "transliteral": "ū-p̄in-nû", "traducao_palavra": "e despejarão" },
        { "hebraico": "אֶת־הַבַּיִת", "transliteral": "ʾeṯ-hab-ba-yiṯ", "traducao_palavra": "a casa" }
      ]
    },
    "37": {
      "traducao_completa": "E, examinando a praga, e eis que, se a praga estiver nas paredes da casa em covinhas esverdeadas ou avermelhadas, e parecerem mais profundas do que a parede,",
      "palavras": [
        { "hebraico": "וְרָאָה", "transliteral": "wə-rā-ʾā", "traducao_palavra": "e examinará" },
        { "hebraico": "אֶת־הַנֶּגַע", "transliteral": "ʾeṯ-han-ne-ḡaʿ", "traducao_palavra": "a praga" },
        { "hebraico": "וְהִנֵּה", "transliteral": "wə-hin-nê", "traducao_palavra": "e eis que" },
        { "hebraico": "הַנֶּגַע", "transliteral": "han-ne-ḡaʿ", "traducao_palavra": "a praga" },
        { "hebraico": "בְּקִירֹת", "transliteral": "bə-qî-rōṯ", "traducao_palavra": "nas paredes de" },
        { "hebraico": "הַבַּיִת", "transliteral": "hab-ba-yiṯ", "traducao_palavra": "a casa" },
        { "hebraico": "שְׁקַעֲרוּרֹת", "transliteral": "šə-qa-ʿă-rû-rōṯ", "traducao_palavra": "cavidades/covinhas" },
        { "hebraico": "יְרַקְרַקֹּת", "transliteral": "yə-raq-raq-qōṯ", "traducao_palavra": "esverdeadas" },
        { "hebraico": "אוֹ", "transliteral": "ʾô", "traducao_palavra": "ou" },
        { "hebraico": "אֲדַמְדַּמֹּת", "transliteral": "ʾă-ḏam-dam-mōṯ", "traducao_palavra": "avermelhadas" },
        { "hebraico": "וּמַרְאֵיהֶן", "transliteral": "ū-mar-ʾê-hen", "traducao_palavra": "e sua aparência" },
        { "hebraico": "שָׁפָל", "transliteral": "šā-p̄āl", "traducao_palavra": "baixa/profunda" },
        { "hebraico": "מִן־הַקִּיר׃", "transliteral": "min-haq-qîr", "traducao_palavra": "mais do que a parede" }
      ]
    },
    "38": {
      "traducao_completa": "Então o sacerdote sairá da casa à porta da casa, e fechará a casa por sete dias.",
      "palavras": [
        { "hebraico": "וְיָצָא", "transliteral": "wə-yā-ṣā", "traducao_palavra": "e sairá" },
        { "hebraico": "הַכֹּהֵן", "transliteral": "hak-kō-hên", "traducao_palavra": "o sacerdote" },
        { "hebraico": "מִן־הַבַּיִת", "transliteral": "min-hab-ba-yiṯ", "traducao_palavra": "da casa" },
        { "hebraico": "אֶל־פֶּתַח", "transliteral": "ʾel-pe-ṯaḥ", "traducao_palavra": "à porta de" },
        { "hebraico": "הַבָּיִת", "transliteral": "hab-bā-yiṯ", "traducao_palavra": "a casa" },
        { "hebraico": "וְהִסְגִּיר", "transliteral": "wə-his-gîr", "traducao_palavra": "e fechará/encerrará" },
        { "hebraico": "אֶת־הַבַּיִת", "transliteral": "ʾeṯ-hab-ba-yiṯ", "traducao_palavra": "a casa" },
        { "hebraico": "שִׁבְעַת", "transliteral": "šib-ʿaṯ", "traducao_palavra": "por sete" },
        { "hebraico": "יָמִים׃", "transliteral": "yā-mîm", "traducao_palavra": "dias" }
      ]
    },
    "39": {
      "traducao_completa": "E o sacerdote voltará ao sétimo dia, e examinará; e eis que, se a praga se tiver estendido nas paredes da casa,",
      "palavras": [
        { "hebraico": "וְשָׁב", "transliteral": "wə-šāḇ", "traducao_palavra": "e voltará" },
        { "hebraico": "הַכֹּהֵן", "transliteral": "hak-kō-hên", "traducao_palavra": "o sacerdote" },
        { "hebraico": "בַּיּוֹם", "transliteral": "bay-yôm", "traducao_palavra": "no dia" },
        { "hebraico": "הַשְּׁבִיעִי", "transliteral": "haš-šə-ḇî-ʿî", "traducao_palavra": "sétimo" },
        { "hebraico": "וְרָאָה", "transliteral": "wə-rā-ʾā", "traducao_palavra": "e examinará" },
        { "hebraico": "וְהִנֵּה", "transliteral": "wə-hin-nê", "traducao_palavra": "e eis que" },
        { "hebraico": "פָּשָׂה", "transliteral": "pā-śā", "traducao_palavra": "se espalhou" },
        { "hebraico": "הַנֶּגַע", "transliteral": "han-ne-ḡaʿ", "traducao_palavra": "a praga" },
        { "hebraico": "בְּקִירֹת", "transliteral": "bə-qî-rōṯ", "traducao_palavra": "nas paredes de" },
        { "hebraico": "הַבָּיִת׃", "transliteral": "hab-bā-yiṯ", "traducao_palavra": "a casa" }
      ]
    },
    "40": {
      "traducao_completa": "Então o sacerdote ordenará que arranquem as pedras em que estiver a praga, e que as lancem fora da cidade num lugar imundo.",
      "palavras": [
        { "hebraico": "וְצִוָּה", "transliteral": "wə-ṣiw-wā", "traducao_palavra": "e ordenará" },
        { "hebraico": "הַכֹּהֵן", "transliteral": "hak-kō-hên", "traducao_palavra": "o sacerdote" },
        { "hebraico": "וְחִלְּצוּ", "transliteral": "wə-ḥil-lə-ṣû", "traducao_palavra": "e arranquem/removam" },
        { "hebraico": "אֶת־הָאֲבָנִים", "transliteral": "ʾeṯ-hā-ʾă-ḇā-nîm", "traducao_palavra": "as pedras" },
        { "hebraico": "אֲשֶׁר", "transliteral": "ʾă-šer", "traducao_palavra": "que" },
        { "hebraico": "בָּהֵן", "transliteral": "bā-hên", "traducao_palavra": "nelas [está]" },
        { "hebraico": "הַנָּגַע", "transliteral": "han-nā-ḡaʿ", "traducao_palavra": "a praga" },
        { "hebraico": "וְהִשְׁלִיכוּ", "transliteral": "wə-hiš-lî-ḵû", "traducao_palavra": "e lancem" },
        { "hebraico": "אֶתְהֶן", "transliteral": "ʾeṯ-hen", "traducao_palavra": "elas" },
        { "hebraico": "אֶל־מִחוּץ", "transliteral": "ʾel-mi-ḥûṣ", "traducao_palavra": "para fora" },
        { "hebraico": "לָעִיר", "transliteral": "lā-ʿîr", "traducao_palavra": "da cidade" },
        { "hebraico": "אֶל־מָקוֹם", "transliteral": "ʾel-mā-qôm", "traducao_palavra": "num lugar" },
        { "hebraico": "טָמֵא׃", "transliteral": "ṭā-mē", "traducao_palavra": "imundo" }
      ]
    },
    "41": {
      "traducao_completa": "E fará raspar a casa por dentro ao redor, e o pó que rasparem lançarão fora da cidade, num lugar imundo.",
      "palavras": [
        { "hebraico": "וְאֶת־כָּל־הַבַּיִת", "transliteral": "wə-ʾeṯ-kāl-hab-ba-yiṯ", "traducao_palavra": "e toda a casa" },
        { "hebraico": "יַקְצִעַ", "transliteral": "yaq-ṣi-aʿ", "traducao_palavra": "ele fará raspar" },
        { "hebraico": "מִבַּיִת", "transliteral": "mib-ba-yiṯ", "traducao_palavra": "por dentro" },
        { "hebraico": "סָבִיב", "transliteral": "śā-ḇîḇ", "traducao_palavra": "ao redor" },
        { "hebraico": "וְשָׁפְכוּ", "transliteral": "wə-šā-p̄ə-ḵû", "traducao_palavra": "e derramarão/lançarão" },
        { "hebraico": "אֶת־הֶעָפָר", "transliteral": "ʾeṯ-he-ʿā-p̄ār", "traducao_palavra": "o pó" },
        { "hebraico": "אֲשֶׁר", "transliteral": "ʾă-šer", "traducao_palavra": "que" },
        { "hebraico": "הִקְצוּ", "transliteral": "hiq-ṣû", "traducao_palavra": "rasparem" },
        { "hebraico": "אֶל־מִחוּץ", "transliteral": "ʾel-mi-ḥûṣ", "traducao_palavra": "para fora" },
        { "hebraico": "לָעִיר", "transliteral": "lā-ʿîr", "traducao_palavra": "da cidade" },
        { "hebraico": "אֶל־מָקוֹם", "transliteral": "ʾel-mā-qôm", "traducao_palavra": "num lugar" },
        { "hebraico": "טָמֵא׃", "transliteral": "ṭā-mē", "traducao_palavra": "imundo" }
      ]
    },
    "42": {
      "traducao_completa": "Depois tomarão outras pedras e as porão no lugar das primeiras pedras; e tomar-se-á outro barro e se rebocará a casa.",
      "palavras": [
        { "hebraico": "וְלָקְחוּ", "transliteral": "wə-lā-qə-ḥû", "traducao_palavra": "e tomarão" },
        { "hebraico": "אֲבָנִים", "transliteral": "ʾă-ḇā-nîm", "traducao_palavra": "pedras" },
        { "hebraico": "אֲחֵרוֹת", "transliteral": "ʾă-ḥē-rōṯ", "traducao_palavra": "outras" },
        { "hebraico": "וְהֵבִיאוּ", "transliteral": "wə-hê-ḇî-ʾû", "traducao_palavra": "e as porão" },
        { "hebraico": "אֶל־תַּחַת", "transliteral": "ʾel-ta-ḥaṯ", "traducao_palavra": "no lugar de" },
        { "hebraico": "הָאֲבָנִים", "transliteral": "hā-ʾă-ḇā-nîm", "traducao_palavra": "as pedras" }
      ]
    },
    "43": {
      "traducao_completa": "E se a praga tornar a brotar na casa, depois de arrancadas as pedras, e depois de raspada a casa, e depois de rebocada,",
      "palavras": [
        { "hebraico": "וְאִם־יָשׁוּב", "transliteral": "wə-ʾim-yā-šûḇ", "traducao_palavra": "e se voltar" },
        { "hebraico": "הַנֶּגַע", "transliteral": "han-ne-ḡaʿ", "traducao_palavra": "a praga" }
      ]
    },
    "44": {
      "traducao_completa": "Então o sacerdote entrará e examinará; e eis que, se a praga se tiver estendido na casa, lepra roedora há na casa; imunda está.",
      "palavras": [
        { "hebraico": "וּבָא", "transliteral": "ū-ḇā", "traducao_palavra": "e entrará" },
        { "hebraico": "הַכֹּהֵן", "transliteral": "hak-kō-hên", "traducao_palavra": "o sacerdote" },
        { "hebraico": "וְרָאָה", "transliteral": "wə-rā-ʾā", "traducao_palavra": "e examinará" },
        { "hebraico": "צָרַעַת", "transliteral": "ṣā-rā-ʿaṯ", "traducao_palavra": "lepra" },
        { "hebraico": "מַמְאֶרֶת", "transliteral": "mam-ʾe-reṯ", "traducao_palavra": "roedora/maligna" }
      ]
    },
    "45": {
      "traducao_completa": "Portanto se derribará a casa, as suas pedras e a sua madeira, como também todo o reboco da casa; e se levará tudo para fora da cidade, a um lugar imundo.",
      "palavras": [
        { "hebraico": "וְנָתַץ", "transliteral": "wə-nā-ṯaṣ", "traducao_palavra": "e derribará/destruirá" },
        { "hebraico": "אֶת־הַבַּיִת", "transliteral": "ʾeṯ-hab-ba-yiṯ", "traducao_palavra": "a casa" }
      ]
    },
    "46": {
      "traducao_completa": "E o que entrar na casa, em qualquer dia em que estiver fechada, será imundo até à tarde.",
      "palavras": [
        { "hebraico": "וְהַבָּא", "transliteral": "wə-hab-bā", "traducao_palavra": "e o que entrar" },
        { "hebraico": "אֶל־הַבַּיִת", "transliteral": "ʾel-hab-ba-yiṯ", "traducao_palavra": "na casa" }
      ]
    },
    "47": {
      "traducao_completa": "Também o que se deitar na casa lavará as suas vestes; e o que comer na casa lavará as suas vestes.",
      "palavras": [
        { "hebraico": "וְהַשֹּׁכֵב", "transliteral": "wə-haš-šō-ḵêḇ", "traducao_palavra": "e o que se deitar" }
      ]
    },
    "48": {
      "traducao_completa": "Mas, entrando o sacerdote, e examinando-a, e eis que a praga se não tem estendido na casa, depois que a casa foi rebocada, o sacerdote declarará a casa limpa, porque a praga está curada.",
      "palavras": [
        { "hebraico": "וְאִם־בֹּא", "transliteral": "wə-ʾim-bō", "traducao_palavra": "mas se entrando" },
        { "hebraico": "יָבֹא", "transliteral": "yā-ḇō", "traducao_palavra": "entrar" },
        { "hebraico": "הַכֹּהֵן", "transliteral": "hak-kō-hên", "traducao_palavra": "o sacerdote" }
      ]
    },
    "49": {
      "traducao_completa": "E tomará, para purificar a casa, duas aves, e pau de cedro, e carmesim, e hissopo;",
      "palavras": [
        { "hebraico": "וְלָקַח", "transliteral": "wə-lā-qaḥ", "traducao_palavra": "e tomará" },
        { "hebraico": "לְחַטֵּא", "transliteral": "lə-ḥaṭ-ṭē", "traducao_palavra": "para purificar" },
        { "hebraico": "אֶת־הַבַּיִת", "transliteral": "ʾeṯ-hab-ba-yiṯ", "traducao_palavra": "a casa" }
      ]
    },
    "50": {
      "traducao_completa": "E degolará uma ave num vaso de barro sobre águas vivas;",
      "palavras": [
        { "hebraico": "וְשָׁחַט", "transliteral": "wə-šā-ḥaṭ", "traducao_palavra": "e degolará" }
      ]
    },
    "51": {
      "traducao_completa": "Então tomará o pau de cedro, e o hissopo, e o carmesim, e a ave viva, e os molhará no sangue da ave degolada e nas águas vivas, e aspergirá a casa sete vezes;",
      "palavras": [
        { "hebraico": "וְלָקַח", "transliteral": "wə-lā-qaḥ", "traducao_palavra": "e tomará" }
      ]
    },
    "52": {
      "traducao_completa": "Assim purificará aquela casa com o sangue da ave, e com as águas vivas, e com a ave viva, e com o pau de cedro, e com o hissopo, e com o carmesim.",
      "palavras": [
        { "hebraico": "וְחִטֵּא", "transliteral": "wə-ḥiṭ-ṭē", "traducao_palavra": "e purificará" }
      ]
    },
    "53": {
      "traducao_completa": "Então soltará a ave viva para fora da cidade, sobre a face do campo; assim fará expiação pela casa, e será limpa.",
      "palavras": [
        { "hebraico": "וְשִׁלַּח", "transliteral": "wə-šil-laḥ", "traducao_palavra": "e soltará" }
      ]
    },
    "54": {
      "traducao_completa": "Esta é a lei de toda a praga da lepra e da tinha,",
      "palavras": [
        { "hebraico": "זֹאת", "transliteral": "zōṯ", "traducao_palavra": "esta [é]" },
        { "hebraico": "הַתּוֹרָה", "transliteral": "hat-tō-rā", "traducao_palavra": "a lei" },
        { "hebraico": "לְכָל־נֶגַע", "transliteral": "lə-ḵāl-ne-ḡaʿ", "traducao_palavra": "para toda praga" }
      ]
    },
    "55": {
      "traducao_completa": "E da lepra das vestes e das casas,",
      "palavras": [
        { "hebraico": "וּלְצָרַעַת", "transliteral": "ū-lə-ṣā-rā-ʿaṯ", "traducao_palavra": "e para a lepra de" },
        { "hebraico": "הַבֶּגֶד", "transliteral": "hab-be-ḡeḏ", "traducao_palavra": "a veste" },
        { "hebraico": "וּלְבָיִת׃", "transliteral": "ū-lə-ḇā-yiṯ", "traducao_palavra": "e para casa" }
      ]
    },
    "56": {
      "traducao_completa": "E do inchaço, e da pápula, e da mancha lustrosa,",
      "palavras": [
        { "hebraico": "וְלַשְׂאֵת", "transliteral": "wə-laś-śə-ʾēṯ", "traducao_palavra": "e para o inchaço" }
      ]
