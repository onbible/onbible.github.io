{
  "livro": "Levítico - וַיִּקְרָא - Vayikra",
  "capítulo": 5,
  "titulos": {},
  "versiculos": {
    "1": {
      "traducao_completa": "E quando uma alma pecar, ouvindo a voz de uma adjuração, e sendo testemunha, ou tendo visto, ou tendo sabido, se não o declarar, então levará a sua iniquidade.",
      "palavras": [
        { "hebraico": "וְנֶפֶשׁ", "transliteral": "wə-ne-p̄eš", "traducao_palavra": "e uma alma" },
        { "hebraico": "כִּי־תֶחֱטָא", "transliteral": "kî-ṯe-ḥĕ-ṭā", "traducao_palavra": "quando pecar" },
        { "hebraico": "וְשָׁמְעָה", "transliteral": "wə-šām-ʿā", "traducao_palavra": "e ouvir" },
        { "hebraico": "קוֹל", "transliteral": "qōl", "traducao_palavra": "a voz de" },
        { "hebraico": "אָלָה", "transliteral": "ʾā-lā", "traducao_palavra": "adjuração" },
        { "hebraico": "וְהוּא", "transliteral": "wə-hû", "traducao_palavra": "e ele [sendo]" },
        { "hebraico": "עֵד", "transliteral": "ʿēḏ", "traducao_palavra": "testemunha" },
        { "hebraico": "אוֹ", "transliteral": "ʾô", "traducao_palavra": "ou" },
        { "hebraico": "רָאָה", "transliteral": "rā-ʾā", "traducao_palavra": "viu" },
        { "hebraico": "אוֹ", "transliteral": "ʾô", "traducao_palavra": "ou" },
        { "hebraico": "יָדָע", "transliteral": "yā-ḏāʿ", "traducao_palavra": "soube" },
        { "hebraico": "אִם־לוֹא", "transliteral": "ʾim-lō", "traducao_palavra": "se não" },
        { "hebraico": "יַגִּיד", "transliteral": "yag-gîḏ", "traducao_palavra": "declarar" },
        { "hebraico": "וְנָשָׂא", "transliteral": "wə-nā-śā", "traducao_palavra": "então levará" },
        { "hebraico": "עֲוֺנֹו׃", "transliteral": "ʿă-wō-nô", "traducao_palavra": "sua iniquidade" }
      ]
    },
    "2": {
      "traducao_completa": "Ou quando uma alma tocar em alguma coisa imunda, seja corpo morto de animal selvagem imundo, ou corpo morto de gado imundo, ou corpo morto de réptil imundo, e lhe for oculto, ele será imundo e culpado.",
      "palavras": [
        { "hebraico": "אוֹ", "transliteral": "ʾô", "traducao_palavra": "ou" },
        { "hebraico": "נֶפֶשׁ", "transliteral": "ne-p̄eš", "traducao_palavra": "alma" },
        { "hebraico": "אֲשֶׁר", "transliteral": "ʾă-šer", "traducao_palavra": "que" },
        { "hebraico": "תִּגַּע", "transliteral": "tig-gaʿ", "traducao_palavra": "tocar" },
        { "hebraico": "בְּכָל־דָּבָר", "transliteral": "bə-ḵāl-dā-ḇār", "traducao_palavra": "em qualquer coisa" },
        { "hebraico": "טָמֵא", "transliteral": "ṭā-mē", "traducao_palavra": "imunda" },
        { "hebraico": "אוֹ", "transliteral": "ʾô", "traducao_palavra": "ou" },
        { "hebraico": "בְנִבְלַת", "transliteral": "ḇə-niḇ-laṯ", "traducao_palavra": "em cadáver de" },
        { "hebraico": "חַיָּה", "transliteral": "ḥay-yā", "traducao_palavra": "animal selvagem" },
        { "hebraico": "טְמֵאָה", "transliteral": "ṭə-mē-ʾā", "traducao_palavra": "imundo" }
      ]
    },
    "3": {
      "traducao_completa": "Ou se tocar a imundícia de um homem, qualquer que seja a imundícia com que se faça imundo, e lhe for oculto, e o souber depois, será culpado.",
      "palavras": [
        { "hebraico": "אוֹ", "transliteral": "ʾô", "traducao_palavra": "ou" },
        { "hebraico": "כִי", "transliteral": "ḵî", "traducao_palavra": "se" },
        { "hebraico": "יִגַּע", "transliteral": "yig-gaʿ", "traducao_palavra": "tocar" },
        { "hebraico": "בְּטֻמְאַת", "transliteral": "bə-ṭum-ʾaṯ", "traducao_palavra": "na imundícia de" },
        { "hebraico": "אָדָם", "transliteral": "ʾā-ḏām", "traducao_palavra": "homem" },
        { "hebraico": "וְנֶעְלַם", "transliteral": "wə-ne-ʿə-lam", "traducao_palavra": "e for oculto" },
        { "hebraico": "מִמֶּנּוּ", "transliteral": "mim-men-nû", "traducao_palavra": "dele" },
        { "hebraico": "וְהוּא", "transliteral": "wə-hû", "traducao_palavra": "e ele" },
        { "hebraico": "יָדַע", "transliteral": "yā-ḏaʿ", "traducao_palavra": "souber" },
        { "hebraico": "וְאָשֵׁם׃", "transliteral": "wə-ʾā-šēm", "traducao_palavra": "será culpado" }
      ]
    },
    "4": {
      "traducao_completa": "Ou quando uma alma jurar, pronunciando temerariamente com os lábios, para fazer mal ou para fazer bem, em tudo o que o homem pronuncia temerariamente com juramento, e lhe for oculto, e o souber depois, culpado será numa destas coisas.",
      "palavras": [
        { "hebraico": "אוֹ", "transliteral": "ʾô", "traducao_palavra": "ou" },
        { "hebraico": "נֶפֶשׁ", "transliteral": "ne-p̄eš", "traducao_palavra": "alma" },
        { "hebraico": "כִּי", "transliteral": "ḵî", "traducao_palavra": "quando" },
        { "hebraico": "תִשָּׁבַע", "transliteral": "tiš-šā-ḇaʿ", "traducao_palavra": "jurar" },
        { "hebraico": "לְבַטֵּא", "transliteral": "lə-ḇaṭ-ṭê", "traducao_palavra": "para pronunciar" },
        { "hebraico": "בִשְׂפָתַיִם", "transliteral": "biś-p̄ā-ṯa-yim", "traducao_palavra": "com lábios" }
      ]
    },
    "5": {
      "traducao_completa": "E será que, sendo culpado numa destas coisas, confessará aquilo em que pecou.",
      "palavras": [
        { "hebraico": "וְהָיָה", "transliteral": "wə-hā-yā", "traducao_palavra": "e será" },
        { "hebraico": "כִי־יֶאְשַׁם", "transliteral": "ḵî-ye-ʾə-šam", "traducao_palavra": "que sendo culpado" },
        { "hebraico": "לְאַחַת", "transliteral": "lə-ʾa-ḥaṯ", "traducao_palavra": "em uma" },
        { "hebraico": "מֵאֵלֶּה", "transliteral": "mē-ʾēl-leh", "traducao_palavra": "destas" },
        { "hebraico": "וְהִתְוַדָּה", "transliteral": "wə-hiṯ-wad-dā", "traducao_palavra": "então confessará" },
        { "hebraico": "אֲשֶׁר", "transliteral": "ʾă-šer", "traducao_palavra": "o que" },
        { "hebraico": "חָטָא", "transliteral": "ḥā-ṭā", "traducao_palavra": "pecou" }
      ]
    },
    "6": {
      "traducao_completa": "E trará a sua oferta pela culpa a YHWH, pelo seu pecado que pecou: uma fêmea do rebanho, uma cordeira ou uma cabra, para oferta pelo pecado; e o sacerdote por ele fará expiação do seu pecado.",
      "palavras": [
        { "hebraico": "וְהֵבִיא", "transliteral": "wə-hē-ḇî", "traducao_palavra": "e trará" },
        { "hebraico": "אֶת־אֲשָׁמוֹ", "transliteral": "ʾeṯ-ʾă-šā-mô", "traducao_palavra": "sua oferta pela culpa" },
        { "hebraico": "לַיהוָה", "transliteral": "la-YHWH", "traducao_palavra": "a YHWH" },
        { "hebraico": "נְקֵבָה", "transliteral": "nə-qē-ḇā", "traducao_palavra": "fêmea" },
        { "hebraico": "מִן־הַצֹּאן", "transliteral": "min-haṣ-ṣōn", "traducao_palavra": "do rebanho" }
      ]
    },
    "7": {
      "traducao_completa": "Mas, se a sua mão não puder chegar a gado miúdo, trará a YHWH, em oferta pela culpa do pecado que cometeu, duas rolas ou dois pombinhos: um para oferta pelo pecado e o outro para holocausto.",
      "palavras": [
        { "hebraico": "וְאִם־לֹא", "transliteral": "wə-ʾim-lō", "traducao_palavra": "e se não" },
        { "hebraico": "תַגִּיעַ", "transliteral": "tag-gî-aʿ", "traducao_palavra": "alcançar" },
        { "hebraico": "יָדוֹ", "transliteral": "yā-ḏô", "traducao_palavra": "sua mão" },
        { "hebraico": "דֵּי", "transliteral": "dê", "traducao_palavra": "suficiente para" },
        { "hebraico": "שֶׂה", "transliteral": "śeh", "traducao_palavra": "um cordeiro" }
      ]
    },
    "8": {
      "traducao_completa": "E os trará ao sacerdote, o qual oferecerá primeiro o que é para a oferta pelo pecado; e lhe torcerá o pescoço, mas não o dividirá.",
      "palavras": [
        { "hebraico": "וְהֵבִיא", "transliteral": "wə-hē-ḇî", "traducao_palavra": "e os trará" },
        { "hebraico": "אֶתְהֶם", "transliteral": "ʾeṯ-hem", "traducao_palavra": "eles" },
        { "hebraico": "אֶל־הַכֹּהֵן", "transliteral": "ʾel-hak-kō-hên", "traducao_palavra": "ao sacerdote" }
      ]
    },
    "9": {
      "traducao_completa": "E aspergirá do sangue da oferta pelo pecado sobre a parede do altar, e o restante daquele sangue será espremido à base do altar; oferta pelo pecado é.",
      "palavras": [
        { "hebraico": "וְהִזָּה", "transliteral": "wə-hiz-zā", "traducao_palavra": "e aspergirá" },
        { "hebraico": "מִדַּם", "transliteral": "mid-dam", "traducao_palavra": "do sangue de" }
      ]
    },
    "10": {
      "traducao_completa": "E do outro fará holocausto, conforme o rito; assim o sacerdote por ele fará expiação do seu pecado que pecou, e lhe será perdoado.",
      "palavras": [
        { "hebraico": "וְאֶת־הַשֵּׁנִי", "transliteral": "wə-ʾeṯ-haš-šê-nî", "traducao_palavra": "e o segundo" },
        { "hebraico": "יַעֲשֶׂה", "transliteral": "ya-ʿă-śeh", "traducao_palavra": "fará" },
        { "hebraico": "עֹלָה", "transliteral": "ʿō-lā", "traducao_palavra": "holocausto" },
        { "hebraico": "כַּמִּשְׁפָּט", "transliteral": "kam-miš-pāṭ", "traducao_palavra": "conforme o rito/juízo" }
      ]
    },
    "11": {
      "traducao_completa": "Porém, se a sua mão não puder chegar a duas rolas ou a dois pombinhos, então aquele que pecou trará por sua oferta a décima parte de um efa de flor de farinha, para oferta pelo pecado; não deitará sobre ela azeite nem lhe porá incenso, pois é oferta pelo pecado.",
      "palavras": [
        { "hebraico": "וְאִם־לֹא", "transliteral": "wə-ʾim-lō", "traducao_palavra": "e se não" },
        { "hebraico": "תַשִּׂיג", "transliteral": "taś-śîḡ", "traducao_palavra": "alcançar" },
        { "hebraico": "יָדוֹ", "transliteral": "yā-ḏô", "traducao_palavra": "sua mão" }
      ]
    },
    "12": {
      "traducao_completa": "E a trará ao sacerdote, e o sacerdote tomará dela o seu punho cheio, por sua porção memorial, e a queimará sobre o altar, em cima das ofertas queimadas de YHWH; oferta pelo pecado é.",
      "palavras": [
        { "hebraico": "וֶהֱבִיאָהּ", "transliteral": "we-hĕ-ḇî-ʾāh", "traducao_palavra": "e a trará" },
        { "hebraico": "אֶל־הַכֹּהֵן", "transliteral": "ʾel-hak-kō-hên", "traducao_palavra": "ao sacerdote" }
      ]
    },
    "13": {
      "traducao_completa": "Assim o sacerdote por ela fará expiação do seu pecado que pecou em alguma destas coisas, e lhe será perdoado; e o restante será do sacerdote, como a oferta de manjares.",
      "palavras": [
        { "hebraico": "וְכִפֶּר", "transliteral": "wə-ḵip-pēr", "traducao_palavra": "e fará expiação" },
        { "hebraico": "עָלָיו", "transliteral": "ʿā-lāyw", "traducao_palavra": "sobre ele" }
      ]
    },
    "14": {
      "traducao_completa": "E falou YHWH a Moisés, dizendo:",
      "palavras": [
        { "hebraico": "וַיְדַבֵּר", "transliteral": "way-yə-ḏab-bēr", "traducao_palavra": "e falou" },
        { "hebraico": "יְהוָה", "transliteral": "YHWH", "traducao_palavra": "YHWH" },
        { "hebraico": "אֶל־מֹשֶׁה", "transliteral": "ʾel-mō-šeh", "traducao_palavra": "a Moisés" },
        { "hebraico": "לֵּאמֹר׃", "transliteral": "lē-mōr", "traducao_palavra": "dizendo" }
      ]
    },
    "15": {
      "traducao_completa": "Quando uma alma cometer uma transgressão e pecar por erro nas coisas sagradas de YHWH, então trará a YHWH por sua oferta pela culpa um carneiro sem defeito do rebanho, conforme a tua avaliação em siclos de prata, segundo o siclo do santuário, para oferta pela culpa.",
      "palavras": [
        { "hebraico": "נֶפֶשׁ", "transliteral": "ne-p̄eš", "traducao_palavra": "uma alma" },
        { "hebraico": "כִּי־תִמְעֹל", "transliteral": "kî-ṯim-ʿōl", "traducao_palavra": "quando transgredir" },
        { "hebraico": "מַעַל", "transliteral": "ma-ʿal", "traducao_palavra": "uma transgressão" },
        { "hebraico": "וְחָטְאָה", "transliteral": "wə-ḥā-ṭə-ʾā", "traducao_palavra": "e pecar" },
        { "hebraico": "בִּשְׁגָגָה", "transliteral": "biš-ḡā-ḡā", "traducao_palavra": "por erro" },
        { "hebraico": "מִקָּדְשֵׁי", "transliteral": "miq-qā-ḏə-šê", "traducao_palavra": "das coisas sagradas de" },
        { "hebraico": "יְהוָה", "transliteral": "YHWH", "traducao_palavra": "YHWH" },
        { "hebraico": "אֵיל", "transliteral": "ʾêl", "traducao_palavra": "um carneiro" },
        { "hebraico": "תָּמִים", "transliteral": "tā-mîm", "traducao_palavra": "perfeito" }
      ]
    },
    "16": {
      "traducao_completa": "Assim restituirá o que pecou nas coisas sagradas, e ainda lhe acrescentará o seu quinto, e o dará ao sacerdote; e o sacerdote com o carneiro da oferta pela culpa fará expiação por ele, e lhe será perdoado.",
      "palavras": [
        { "hebraico": "וְאֵת", "transliteral": "wə-ʾēṯ", "traducao_palavra": "e" },
        { "hebraico": "אֲשֶׁר", "transliteral": "ʾă-šer", "traducao_palavra": "o que" },
        { "hebraico": "חָטָא", "transliteral": "ḥā-ṭā", "traducao_palavra": "pecou" },
        { "hebraico": "מִן־הַקֹּדֶשׁ", "transliteral": "min-haq-qō-ḏeš", "traducao_palavra": "no [que é] sagrado" },
        { "hebraico": "יְשַׁלֵּם", "transliteral": "yə-šal-lêm", "traducao_palavra": "restituirá" },
        { "hebraico": "חֲמִישִׁיתוֹ", "transliteral": "ḥă-mî-šî-ṯô", "traducao_palavra": "seu quinto" },
        { "hebraico": "יוֹסֵף", "transliteral": "yô-sêp̄", "traducao_palavra": "acrescentará" },
        { "hebraico": "עָלָיו", "transliteral": "ʿā-lāyw", "traducao_palavra": "sobre ele" }
      ]
    },
    "17": {
      "traducao_completa": "E, se alguma alma pecar, e fizer contra algum de todos os mandamentos de YHWH o que não se deve fazer, ainda que não o soubesse, contudo será culpada, e levará a sua iniquidade.",
      "palavras": [
        { "hebraico": "וְאִם־נֶפֶשׁ", "transliteral": "wə-ʾim-ne-p̄eš", "traducao_palavra": "e se uma alma" },
        { "hebraico": "תֶּחֱטָא", "transliteral": "te-ḥĕ-ṭā", "traducao_palavra": "pecar" },
        { "hebraico": "וְעָשְׂתָה", "transliteral": "wə-ʿāś-ṯā", "traducao_palavra": "e fizer" },
        { "hebraico": "וְלֹא־יָדָע", "transliteral": "wə-lō-yā-ḏāʿ", "traducao_palavra": "e não soubesse" },
        { "hebraico": "וְאָשֵׁם", "transliteral": "wə-ʾā-šēm", "traducao_palavra": "e será culpada" }
      ]
    },
    "18": {
      "traducao_completa": "E trará ao sacerdote um carneiro sem defeito do rebanho, conforme a tua avaliação, para oferta pela culpa; e o sacerdote por ela fará expiação do seu erro em que errou sem o saber, e lhe será perdoado.",
      "palavras": [
        { "hebraico": "וְהֵבִיא", "transliteral": "wə-hē-ḇî", "traducao_palavra": "e trará" },
        { "hebraico": "אֵיִל", "transliteral": "ʾê-yil", "traducao_palavra": "um carneiro" }
      ]
    },
    "19": {
      "traducao_completa": "Oferta pela culpa é; certamente se fez culpado perante YHWH.",
      "palavras": [
        { "hebraico": "אָשָׁם", "transliteral": "ʾā-šām", "traducao_palavra": "oferta pela culpa" },
        { "hebraico": "הוּא", "transliteral": "hû", "traducao_palavra": "é" },
        { "hebraico": "אָשֹׁם", "transliteral": "ʾā-šōm", "traducao_palavra": "certamente" },
        { "hebraico": "אָשַׁם", "transliteral": "ʾā-šam", "traducao_palavra": "ele se fez culpado" },
        { "hebraico": "לַיהוָה׃", "transliteral": "la-YHWH", "traducao_palavra": "a YHWH" }
      ]
    }
  }
}