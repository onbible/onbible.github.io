        { "hebraico": "יִשְׂרָאֵל", "transliteral": "yiś-rā-ʾēl", "traducao_palavra": "Israel" },
        { "hebraico": "וַאֲמַרְתֶּם", "transliteral": "wa-ʾă-mar-tem", "traducao_palavra": "e direis" },
        { "hebraico": "אֲלֵהֶם", "transliteral": "ʾă-lê-hem", "traducao_palavra": "lhes" },
        { "hebraico": "אִישׁ אִישׁ", "transliteral": "ʾîš ʾîš", "traducao_palavra": "qualquer homem" },
        { "hebraico": "כִּי", "transliteral": "kî", "traducao_palavra": "quando" },
