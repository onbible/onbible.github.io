        { "hebraico": "זָב", "transliteral": "zāḇ", "traducao_palavra": "fluxo" },
        { "hebraico": "מִבְּשָׂרוֹ", "transliteral": "mib-bə-śā-rô", "traducao_palavra": "de sua carne" },
