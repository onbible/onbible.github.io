  "versiculos": {
    "1": {
      "traducao_completa": "E Nadabe e Abiú, filhos de Arão, tomaram cada um o seu incensário, e puseram neles fogo, e puseram incenso sobre ele, e ofereceram fogo estranho perante YHWH, o que ele não lhes ordenara.",
      "palavras": [
