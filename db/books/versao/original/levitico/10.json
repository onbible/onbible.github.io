        { "hebraico": "לֹא", "transliteral": "lō", "traducao_palavra": "não" },
        { "hebraico": "צִוָּה", "transliteral": "ṣiw-wā", "traducao_palavra": "ordenou" },
        { "hebraico": "אֹתָם׃", "transliteral": "ʾō-ṯām", "traducao_palavra": "lhes" }
      ]
    },
    "2": {
      "traducao_completa": "Então saiu fogo de diante de YHWH e os consumiu; e morreram perante YHWH.",
      "palavras": [
        { "hebraico": "וַתֵּצֵא", "transliteral": "wat-tē-ṣē", "traducao_palavra": "e saiu" },
        { "hebraico": "אֵשׁ", "transliteral": "ʾēš", "traducao_palavra": "fogo" },
        { "hebraico": "מִלִּפְנֵי", "transliteral": "mil-lip̄-nê", "traducao_palavra": "de diante de" },
        { "hebraico": "יְהוָה", "transliteral": "YHWH", "traducao_palavra": "YHWH" },
        { "hebraico": "וַתֹּאכַל", "transliteral": "wat-tō-ḵal", "traducao_palavra": "e consumiu" },
        { "hebraico": "אוֹתָם", "transliteral": "ʾô-ṯām", "traducao_palavra": "eles" },
        { "hebraico": "וַיָּמֻתוּ", "transliteral": "way-yā-mu-ṯû", "traducao_palavra": "e morreram" },
        { "hebraico": "לִפְנֵי", "transliteral": "lip̄-nê", "traducao_palavra": "perante" },
