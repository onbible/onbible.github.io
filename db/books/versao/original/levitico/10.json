        { "hebraico": "וַיִּתְּנוּ", "transliteral": "way-yit-tə-nû", "traducao_palavra": "e puseram" },
        { "hebraico": "בָהֵן", "transliteral": "ḇā-hên", "traducao_palavra": "neles" },
        { "hebraico": "אֵשׁ", "transliteral": "ʾēš", "traducao_palavra": "fogo" },
