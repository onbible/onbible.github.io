        { "hebraico": "עָלֶיהָ", "transliteral": "ʿā-le-hā", "traducao_palavra": "sobre ele" },
        { "hebraico": "קְטֹרֶת", "transliteral": "qə-ṭō-reṯ", "traducao_palavra": "incenso" },
        { "hebraico": "וַיַּקְרִיבוּ", "transliteral": "way-yaq-rî-ḇû", "traducao_palavra": "e ofereceram" },
