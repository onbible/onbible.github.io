        { "hebraico": "בְנֵי־אַהֲרֹן", "transliteral": "ḇə-nê-ʾa-hă-rōn", "traducao_palavra": "filhos de Arão" },
        { "hebraico": "נָדָב", "transliteral": "nā-ḏāḇ", "traducao_palavra": "Nadabe" },
