      ]
    },
    "3": {
      "traducao_completa": "E disse Moisés a Arão: Isto é o que YHWH falou, dizendo: Serei santificado naqueles que se chegam a mim, e serei glorificado perante todo o povo. Mas Arão calou-se.",
      "palavras": [
        { "hebraico": "וַיֹּאמֶר", "transliteral": "way-yō-mer", "traducao_palavra": "e disse" },
        { "hebraico": "מֹשֶׁה", "transliteral": "mō-šeh", "traducao_palavra": "Moisés" },
        { "hebraico": "אֶל־אַהֲרֹן", "transliteral": "ʾel-ʾa-hă-rōn", "traducao_palavra": "a Arão" },
        { "hebraico": "הוּא", "transliteral": "hû", "traducao_palavra": "isto [é]" },
        { "hebraico": "אֲשֶׁר־דִּבֶּר", "transliteral": "ʾă-šer-dib-bêr", "traducao_palavra": "o que falou" },
        { "hebraico": "יְהוָה", "transliteral": "YHWH", "traducao_palavra": "YHWH" },
        { "hebraico": "לֵאמֹר", "transliteral": "lē-mōr", "traducao_palavra": "dizendo" },
        { "hebraico": "בִּקְרֹבַי", "transliteral": "biq-rō-ḇay", "traducao_palavra": "nos que se aproximam de mim" },
        { "hebraico": "אֶקָּדֵשׁ", "transliteral": "ʾeq-qā-ḏêš", "traducao_palavra": "serei santificado" },
        { "hebraico": "וְעַל־פְּנֵי", "transliteral": "wə-ʿal-pə-nê", "traducao_palavra": "e diante de" },
        { "hebraico": "כָל־הָעָם", "transliteral": "ḵāl-hā-ʿām", "traducao_palavra": "todo o povo" },
        { "hebraico": "אֶכָּבֵד", "transliteral": "ʾek-kā-ḇêḏ", "traducao_palavra": "serei glorificado" },
        { "hebraico": "וַיִּדֹּם", "transliteral": "way-yid-dōm", "traducao_palavra": "e calou-se" },
        { "hebraico": "אַהֲרֹן׃", "transliteral": "ʾa-hă-rōn", "traducao_palavra": "Arão" }
      ]
    },
    "4": {
      "traducao_completa": "E Moisés chamou a Misael e a Elzafã, filhos de Uziel, tio de Arão, e disse-lhes: Chegai-vos, tirai a vossos irmãos de diante do santuário, para fora do arraial.",
      "palavras": [
        { "hebraico": "וַיִּקְרָא", "transliteral": "way-yiq-rā", "traducao_palavra": "e chamou" },
        { "hebraico": "מֹשֶׁה", "transliteral": "mō-šeh", "traducao_palavra": "Moisés" },
        { "hebraico": "אֶל־מִֽישָׁאֵל", "transliteral": "ʾel-mî-šā-ʾēl", "traducao_palavra": "a Misael" },
        { "hebraico": "וְאֶל־אֶלְזָפָן", "transliteral": "wə-ʾel-ʾel-zā-p̄ān", "traducao_palavra": "e a Elzafã" },
        { "hebraico": "בְּנֵי", "transliteral": "bə-nê", "traducao_palavra": "filhos de" },
        { "hebraico": "עֻזִּיאֵל", "transliteral": "ʿuz-zî-ʾēl", "traducao_palavra": "Uziel" },
        { "hebraico": "דֹּד", "transliteral": "dōḏ", "traducao_palavra": "tio de" },
        { "hebraico": "אַהֲרֹן", "transliteral": "ʾa-hă-rōn", "traducao_palavra": "Arão" }
      ]
    },
    "5": {
      "traducao_completa": "Chegaram-se, pois, e levaram-nos nas suas túnicas para fora do arraial, como Moisés tinha dito.",
      "palavras": [
        { "hebraico": "וַיִּקְרְבוּ", "transliteral": "way-yiq-rə-ḇû", "traducao_palavra": "e chegaram-se" },
        { "hebraico": "וַיִּשָּׂאֻם", "transliteral": "way-yiś-śā-ʾum", "traducao_palavra": "e levaram-nos" },
        { "hebraico": "בְּכֻתֳּנֹתָם", "transliteral": "bə-ḵut-to-nō-ṯām", "traducao_palavra": "nas suas túnicas" }
      ]
    },
    "6": {
      "traducao_completa": "E Moisés disse a Arão, e a seus filhos Eleazar e Itamar: Não descubrais as vossas cabeças, nem rasgueis as vossas vestes, para que não morrais, nem venha a ira sobre toda a congregação; mas vossos irmãos, toda a casa de Israel, lamentem este incêndio que YHWH acendeu.",
      "palavras": [
        { "hebraico": "וַיֹּאמֶר", "transliteral": "way-yō-mer", "traducao_palavra": "e disse" },
        { "hebraico": "מֹשֶׁה", "transliteral": "mō-šeh", "traducao_palavra": "Moisés" },
        { "hebraico": "אֶל־אַהֲרֹן", "transliteral": "ʾel-ʾa-hă-rōn", "traducao_palavra": "a Arão" }
      ]
    },
    "7": {
      "traducao_completa": "E não saireis da porta da tenda da congregação, para que não morrais; porque está sobre vós o azeite da unção de YHWH. E fizeram conforme a palavra de Moisés.",
      "palavras": [
        { "hebraico": "וּמִפֶּתַח", "transliteral": "û-mip-pe-ṯaḥ", "traducao_palavra": "e da porta de" },
        { "hebraico": "אֹהֶל", "transliteral": "ʾō-hel", "traducao_palavra": "tenda de" },
        { "hebraico": "מוֹעֵד", "transliteral": "mô-ʿēḏ", "traducao_palavra": "reunião/congregação" },
        { "hebraico": "לֹא", "transliteral": "lō", "traducao_palavra": "não" },
        { "hebraico": "תֵצְאוּ", "transliteral": "ṯê-ṣə-ʾû", "traducao_palavra": "saireis" }
      ]
    },
    "8": {
      "traducao_completa": "E falou YHWH a Arão, dizendo:",
      "palavras": [
        { "hebraico": "וַיְדַבֵּר", "transliteral": "way-yə-ḏab-bēr", "traducao_palavra": "e falou" },
        { "hebraico": "יְהוָה", "transliteral": "YHWH", "traducao_palavra": "YHWH" },
        { "hebraico": "אֶל־אַהֲרֹן", "transliteral": "ʾel-ʾa-hă-rōn", "traducao_palavra": "a Arão" },
        { "hebraico": "לֵאמֹר׃", "transliteral": "lē-mōr", "traducao_palavra": "dizendo" }
      ]
    },
    "9": {
      "traducao_completa": "Vinho nem bebida forte tu nem teus filhos contigo bebereis, quando entrardes na tenda da congregação, para que não morrais; estatuto perpétuo será isso entre as vossas gerações;",
      "palavras": [
        { "hebraico": "יַיִן", "transliteral": "ya-yin", "traducao_palavra": "vinho" },
        { "hebraico": "וְשֵׁכָר", "transliteral": "wə-šê-ḵār", "traducao_palavra": "e bebida forte" },
        { "hebraico": "אַל־תֵּשְׁתְּ", "transliteral": "ʾal-têšt", "traducao_palavra": "não bebas" },
        { "hebraico": "אַתָּה", "transliteral": "ʾat-tā", "traducao_palavra": "tu" },
        { "hebraico": "וּבָנֶיךָ", "transliteral": "û-ḇā-ne-ḵā", "traducao_palavra": "e teus filhos" },
        { "hebraico": "אִתָּךְ", "transliteral": "ʾit-tāḵ", "traducao_palavra": "contigo" }
      ]
    },
    "10": {
      "traducao_completa": "E para fazer diferença entre o santo e o profano e entre o imundo e o limpo,",
      "palavras": [
        { "hebraico": "וּֽלְהַבְדִּיל", "transliteral": "û-lə-haḇ-dîl", "traducao_palavra": "e para separar/distinguir" },
        { "hebraico": "בֵּין", "transliteral": "bên", "traducao_palavra": "entre" },
        { "hebraico": "הַקֹּדֶשׁ", "transliteral": "haq-qō-ḏeš", "traducao_palavra": "o santo" },
        { "hebraico": "וּבֵין", "transliteral": "û-ḇên", "traducao_palavra": "e entre" },
        { "hebraico": "הַחֹל", "transliteral": "ha-ḥōl", "traducao_palavra": "o comum/profano" }
      ]
    },
    "11": {
      "traducao_completa": "E para ensinar aos filhos de Israel todos os estatutos que YHWH lhes tem falado pela mão de Moisés.",
      "palavras": [
        { "hebraico": "וּלְהוֹרֹת", "transliteral": "û-lə-hō-rōṯ", "traducao_palavra": "e para ensinar" },
        { "hebraico": "אֶת־בְּנֵי", "transliteral": "ʾeṯ-bə-nê", "traducao_palavra": "aos filhos de" },
        { "hebraico": "יִשְׂרָאÉל", "transliteral": "yiś-rā-ʾēl", "traducao_palavra": "Israel" }
      ]
    },
    "12": {
      "traducao_completa": "E disse Moisés a Arão, e a Eleazar e a Itamar, seus filhos, que lhe ficaram: Tomai a oferta de manjares que sobejou das ofertas queimadas de YHWH, e comei-a sem levedura junto ao altar, porquanto coisa santíssima é.",
      "palavras": [
        { "hebraico": "וַיְדַבֵּר", "transliteral": "way-yə-ḏab-bēr", "traducao_palavra": "e falou" },
        { "hebraico": "מֹשֶׁה", "transliteral": "mō-šeh", "traducao_palavra": "Moisés" }
      ]
    },
    "13": {
      "traducao_completa": "Portanto a comereis em lugar santo; porque isto é a tua porção, e a porção de teus filhos, das ofertas queimadas de YHWH; porque assim me foi ordenado.",
      "palavras": [
        { "hebraico": "וַאֲכַלְתֶּם", "transliteral": "wa-ʾă-ḵal-tem", "traducao_palavra": "e a comereis" },
        { "hebraico": "אֹתָהּ", "transliteral": "ʾō-ṯāh", "traducao_palavra": "ela" },
        { "hebraico": "בְּמָקוֹם", "transliteral": "bə-mā-qôm", "traducao_palavra": "em lugar" },
        { "hebraico": "קָדֹשׁ", "transliteral": "qā-ḏōš", "traducao_palavra": "santo" }
      ]
    },
    "14": {
      "traducao_completa": "Também o peito movido e a coxa alçada comereis em lugar limpo, tu, e teus filhos e tuas filhas contigo; porque foram dados por tua porção, e por porção de teus filhos, dos sacrifícios pacíficos dos filhos de Israel.",
      "palavras": [
        { "hebraico": "וְאֵת", "transliteral": "wə-ʾēṯ", "traducao_palavra": "e" },
        { "hebraico": "חֲזֵה", "transliteral": "ḥă-zê", "traducao_palavra": "o peito de" },
        { "hebraico": "הַתְּנוּפָה", "transliteral": "hat-tə-nû-p̄ā", "traducao_palavra": "a oferta movida" }
      ]
    },
    "15": {
      "traducao_completa": "A coxa alçada e o peito movido trarão com as ofertas queimadas da gordura, para mover por oferta movida perante YHWH; o que será por estatuto perpétuo para ti, e para teus filhos contigo, como YHWH tem ordenado.",
      "palavras": [
        { "hebraico": "שׁוֹק", "transliteral": "šôq", "traducao_palavra": "a coxa de" },
        { "hebraico": "הַתְּרוּמָה", "transliteral": "hat-tə-rû-mā", "traducao_palavra": "a oferta alçada" }
      ]
    },
    "16": {
      "traducao_completa": "E Moisés buscou diligentemente o bode da oferta pelo pecado, e eis que já era queimado; portanto indignou-se grandemente contra Eleazar e contra Itamar, os filhos que ficaram de Arão, dizendo:",
      "palavras": [
        { "hebraico": "וְאֵת", "transliteral": "wə-ʾēṯ", "traducao_palavra": "e" },
        { "hebraico": "שְׂעִיר", "transliteral": "śə-ʿîr", "traducao_palavra": "o bode de" },
        { "hebraico": "הַחַטָּאת", "transliteral": "ha-ḥaṭ-ṭāṯ", "traducao_palavra": "a oferta pelo pecado" },
        { "hebraico": "דָּרֹשׁ", "transliteral": "dā-rōš", "traducao_palavra": "buscou" },
        { "hebraico": "דָּרַשׁ", "transliteral": "dā-raš", "traducao_palavra": "diligentemente" },
        { "hebraico": "מֹשֶׁה", "transliteral": "mō-šeh", "traducao_palavra": "Moisés" }
      ]
    },
    "17": {
      "traducao_completa": "Por que não comestes a oferta pelo pecado no lugar santo, porquanto coisa santíssima é; e YHWH a deu a vós, para que levásseis a iniquidade da congregação, para fazer expiação por eles diante de YHWH?",
      "palavras": [
        { "hebraico": "מַדּוּעַ", "transliteral": "mad-dû-aʿ", "traducao_palavra": "por que" },
        { "hebraico": "לֹא־אֲכַלְתֶּם", "transliteral": "lō-ʾă-ḵal-tem", "traducao_palavra": "não comestes" }
      ]
    },
    "18": {
      "traducao_completa": "Eis que não se trouxe o seu sangue para dentro do santuário; certamente a deveríeis ter comido no lugar santo, como eu tinha ordenado.",
      "palavras": [
        { "hebraico": "הֵן", "transliteral": "hên", "traducao_palavra": "eis que" },
        { "hebraico": "לֹא־הוּבָא", "transliteral": "lō-hû-ḇā", "traducao_palavra": "não se trouxe" }
      ]
    },
    "19": {
      "traducao_completa": "E disse Arão a Moisés: Eis que hoje ofereceram a sua oferta pelo pecado e o seu holocausto perante YHWH, e tais coisas me sucederam; se eu hoje comera a oferta pelo pecado, seria isso aceitável aos olhos de YHWH?",
      "palavras": [
        { "hebraico": "וַיְדַבֵּר", "transliteral": "way-yə-ḏab-bēr", "traducao_palavra": "e falou" },
        { "hebraico": "אַהֲרֹן", "transliteral": "ʾa-hă-rōn", "traducao_palavra": "Arão" },
        { "hebraico": "אֶל־מֹשֶׁה", "transliteral": "ʾel-mō-šeh", "traducao_palavra": "a Moisés" }
      ]
    },
    "20": {
      "traducao_completa": "E Moisés, ouvindo isto, deu-se por satisfeito.",
      "palavras": [
        { "hebraico": "וַיִּשְׁמַע", "transliteral": "way-yiš-maʿ", "traducao_palavra": "e ouviu" },
        { "hebraico": "מֹשֶׁה", "transliteral": "mō-šeh", "traducao_palavra": "Moisés" },
        { "hebraico": "וַיִּיטַב", "transliteral": "way-yî-ṭaḇ", "traducao_palavra": "e pareceu bom" },
        { "hebraico": "בְּעֵינָיו׃", "transliteral": "bə-ʿê-nāyw", "traducao_palavra": "aos seus olhos" }
      ]
    }
  }
}