{
  "livro": "Levítico - וַיִּקְרָא - Vayikra",
  "capítulo": 3,
  "titulos": {},
  "versiculos": {
    "1": {
      "traducao_completa": "E se a sua oferta for sacrifício de paz, se a oferecer do gado, seja macho ou fêmea, oferecê-la-á sem defeito perante YHWH.",
      "palavras": [
        { "hebraico": "וְאִם־זֶבַח", "transliteral": "wə-ʾim-ze-ḇaḥ", "traducao_palavra": "e se sacrifício de" },
        { "hebraico": "שְׁלָמִים", "transliteral": "šə-lā-mîm", "traducao_palavra": "paz/recompensa" },
        { "hebraico": "קָרְבָּנוֹ", "transliteral": "qā-rə-bā-nô", "traducao_palavra": "sua oferta" },
        { "hebraico": "אִם", "transliteral": "ʾim", "traducao_palavra": "se" },
        { "hebraico": "מִן־הַבָּקָר", "transliteral": "min-hab-bā-qār", "traducao_palavra": "do gado" },
        { "hebraico": "הוּא", "transliteral": "hû", "traducao_palavra": "ele" },
        { "hebraico": "מַקְרִיב", "transliteral": "maq-rîḇ", "traducao_palavra": "oferecer" },
        { "hebraico": "אִם־זָכָר", "transliteral": "ʾim-zā-ḵār", "traducao_palavra": "se macho" },
        { "hebraico": "אִם־נְקֵבָה", "transliteral": "ʾim-nə-qē-ḇā", "traducao_palavra": "se fêmea" },
        { "hebraico": "תָּמִים", "transliteral": "tā-mîm", "traducao_palavra": "perfeito" },
        { "hebraico": "יַקְרִיבֶנּוּ", "transliteral": "yaq-rî-ḇen-nû", "traducao_palavra": "o oferecerá" },
        { "hebraico": "לִפְנֵי", "transliteral": "lip̄-nê", "traducao_palavra": "diante de" },
        { "hebraico": "יְהוָה׃", "transliteral": "YHWH", "traducao_palavra": "YHWH" }
      ]
    },
    "2": {
      "traducao_completa": "E porá a sua mão sobre a cabeça da sua oferta, e a degolará à porta da tenda da congregação; e os filhos de Arão, os sacerdotes, aspergirão o sangue sobre o altar, ao redor.",
      "palavras": [
        { "hebraico": "וְסָמַךְ", "transliteral": "wə-sā-maḵ", "traducao_palavra": "e porá/apoiará" },
        { "hebraico": "יָדוֹ", "transliteral": "yā-ḏô", "traducao_palavra": "sua mão" },
        { "hebraico": "עַל", "transliteral": "ʿal", "traducao_palavra": "sobre" },
        { "hebraico": "רֹאשׁ", "transliteral": "rōš", "traducao_palavra": "cabeça de" },
        { "hebraico": "קָרְבָּנוֹ", "transliteral": "qā-rə-bā-nô", "traducao_palavra": "sua oferta" }
      ]
    },
    "3": {
      "traducao_completa": "E do sacrifício de paz oferecerá a YHWH oferta queimada: a gordura que cobre as entranhas, e toda a gordura que está sobre as entranhas,",
      "palavras": [
        { "hebraico": "וְהִקְרִיב", "transliteral": "wə-hiq-rîḇ", "traducao_palavra": "e oferecerá" },
        { "hebraico": "מִזֶּבַח", "transliteral": "miz-ze-ḇaḥ", "traducao_palavra": "do sacrifício de" },
        { "hebraico": "הַשְּׁלָמִים", "transliteral": "haš-šə-lā-mîm", "traducao_palavra": "a paz" },
        { "hebraico": "אִשֶּׁה", "transliteral": "ʾiš-šē", "traducao_palavra": "oferta queimada" },
        { "hebraico": "לַיהוָה", "transliteral": "la-YHWH", "traducao_palavra": "a YHWH" },
        { "hebraico": "אֶת־הַחֵלֶב", "transliteral": "ʾeṯ-ha-ḥē-leḇ", "traducao_palavra": "a gordura" }
      ]
    },
    "4": {
      "traducao_completa": "E ambos os rins, e a gordura que está sobre eles, e sobre as costas; e o redanho que está sobre o fígado, com os rins, os tirará.",
      "palavras": [
        { "hebraico": "וְאֵת", "transliteral": "wə-ʾēṯ", "traducao_palavra": "e" },
        { "hebraico": "שְׁתֵּי", "transliteral": "šə-tê", "traducao_palavra": "os dois" },
        { "hebraico": "הַכְּלָיֹת", "transliteral": "hak-kə-lā-yōṯ", "traducao_palavra": "rins" }
      ]
    },
    "5": {
      "traducao_completa": "E os filhos de Arão queimarão isso sobre o altar, em cima do holocausto, que estará sobre a lenha no fogo; oferta queimada é, de aroma suave a YHWH.",
      "palavras": [
        { "hebraico": "וְהִקְטִירוּ", "transliteral": "wə-hiq-ṭî-rû", "traducao_palavra": "e queimarão" },
        { "hebraico": "אֹתוֹ", "transliteral": "ʾō-ṯô", "traducao_palavra": "ele" },
        { "hebraico": "בְנֵי־אַהֲרֹן", "transliteral": "ḇə-nê-ʾa-hă-rōn", "traducao_palavra": "os filhos de Arão" }
      ]
    },
    "6": {
      "traducao_completa": "E se a sua oferta para sacrifício de paz a YHWH for do rebanho, seja macho ou fêmea, sem defeito a oferecerá.",
      "palavras": [
        { "hebraico": "וְאִם־מִן־הַצֹּאן", "transliteral": "wə-ʾim-min-haṣ-ṣōn", "traducao_palavra": "e se do rebanho" }
      ]
    },
    "7": {
      "traducao_completa": "Se oferecer um cordeiro por sua oferta, oferecê-lo-á perante YHWH.",
      "palavras": [
        { "hebraico": "אִם־כֶּשֶׂב", "transliteral": "ʾim-ke-śeḇ", "traducao_palavra": "se um cordeiro" }
      ]
    },
    "8": {
      "traducao_completa": "E porá a sua mão sobre a cabeça da sua oferta, e a degolará diante da tenda da congregação; e os filhos de Arão aspergirão o seu sangue sobre o altar, ao redor.",
      "palavras": [
        { "hebraico": "וְסָמַךְ", "transliteral": "wə-sā-maḵ", "traducao_palavra": "e porá" }
      ]
    },
    "9": {
      "traducao_completa": "Então, do sacrifício de paz, oferecerá a YHWH oferta queimada: a sua gordura, a cauda inteira, a qual tirará rente ao espinhaço, e a gordura que cobre as entranhas, e toda a gordura que está sobre as entranhas,",
      "palavras": [
        { "hebraico": "וְהִקְרִיב", "transliteral": "wə-hiq-rîḇ", "traducao_palavra": "e oferecerá" },
        { "hebraico": "חֶלְבּוֹ", "transliteral": "ḥel-bô", "traducao_palavra": "sua gordura" },
        { "hebraico": "הָאַלְיָה", "transliteral": "hā-ʾal-yā", "traducao_palavra": "a cauda gorda" }
      ]
    },
    "10": {
      "traducao_completa": "E ambos os rins, e a gordura que está sobre eles, e sobre as costas; e o redanho que está sobre o fígado, com os rins, os tirará.",
      "palavras": [
        { "hebraico": "וְאֵת", "transliteral": "wə-ʾēṯ", "traducao_palavra": "e" },
        { "hebraico": "שְׁתֵּי", "transliteral": "šə-tê", "traducao_palavra": "os dois" },
        { "hebraico": "הַכְּלָיֹת", "transliteral": "hak-kə-lā-yōṯ", "traducao_palavra": "rins" }
      ]
    },
    "11": {
      "traducao_completa": "E o sacerdote o queimará sobre o altar; é o manjar da oferta queimada a YHWH.",
      "palavras": [
        { "hebraico": "וְהִקְטִירוֹ", "transliteral": "wə-hiq-ṭî-rô", "traducao_palavra": "e o queimará" },
        { "hebraico": "הַכֹּהֵן", "transliteral": "hak-kō-hên", "traducao_palavra": "o sacerdote" },
        { "hebraico": "לֶחֶם", "transliteral": "le-ḥem", "traducao_palavra": "alimento/pão" }
      ]
    },
    "12": {
      "traducao_completa": "E se a sua oferta for uma cabra, perante YHWH a oferecerá.",
      "palavras": [
        { "hebraico": "וְאִם", "transliteral": "wə-ʾim", "traducao_palavra": "e se" },
        { "hebraico": "עַז", "transliteral": "ʿaz", "traducao_palavra": "uma cabra" }
      ]
    },
    "13": {
      "traducao_completa": "E porá a sua mão sobre a cabeça dela, e a degolará diante da tenda da congregação; e os filhos de Arão aspergirão o seu sangue sobre o altar, ao redor.",
      "palavras": [
        { "hebraico": "וְסָמַךְ", "transliteral": "wə-sā-maḵ", "traducao_palavra": "e porá" }
      ]
    },
    "14": {
      "traducao_completa": "Depois oferecerá dela a sua oferta, por oferta queimada a YHWH: a gordura que cobre as entranhas, e toda a gordura que está sobre as entranhas,",
      "palavras": [
        { "hebraico": "וְהִקְרִיב", "transliteral": "wə-hiq-rîḇ", "traducao_palavra": "e oferecerá" }
      ]
    },
    "15": {
      "traducao_completa": "E ambos os rins, e a gordura que está sobre eles, e sobre as costas; e o redanho que está sobre o fígado, com os rins, os tirará.",
      "palavras": [
        { "hebraico": "וְאֵת", "transliteral": "wə-ʾēṯ", "traducao_palavra": "e" }
      ]
    },
    "16": {
      "traducao_completa": "E o sacerdote os queimará sobre o altar; é o manjar da oferta queimada de aroma suave. Toda a gordura será de YHWH.",
      "palavras": [
        { "hebraico": "וְהִקְטִירָם", "transliteral": "wə-hiq-ṭî-rām", "traducao_palavra": "e os queimará" },
        { "hebraico": "כָּל־חֵלֶב", "transliteral": "kāl-ḥē-leḇ", "traducao_palavra": "toda gordura" },
        { "hebraico": "לַיהוָה׃", "transliteral": "la-YHWH", "traducao_palavra": "a YHWH" }
      ]
    },
    "17": {
      "traducao_completa": "Estatuto perpétuo será pelas vossas gerações, em todas as vossas habitações: nenhuma gordura nem sangue algum comereis.",
      "palavras": [
        { "hebraico": "חֻקַּת", "transliteral": "ḥuq-qaṯ", "traducao_palavra": "estatuto de" },
        { "hebraico": "עוֹלָם", "transliteral": "ʿô-lām", "traducao_palavra": "eternidade" },
        { "hebraico": "לְדֹרֹתֵיכֶם", "transliteral": "lə-ḏō-rō-ṯê-ḵem", "traducao_palavra": "para vossas gerações" },
        { "hebraico": "בְּכֹל", "transliteral": "bə-ḵōl", "traducao_palavra": "em todas" },
        { "hebraico": "מֹושְׁבֹתֵיכֶם", "transliteral": "mô-šə-ḇō-ṯê-ḵem", "traducao_palavra": "vossas moradas" },
        { "hebraico": "כָּל־חֵלֶב", "transliteral": "kāl-ḥē-leḇ", "traducao_palavra": "toda gordura" },
        { "hebraico": "וְכָל־דָּם", "transliteral": "wə-ḵāl-dām", "traducao_palavra": "e todo sangue" },
        { "hebraico": "לֹא", "transliteral": "lō", "traducao_palavra": "não" },
        { "hebraico": "תֹאכֵלוּ׃", "transliteral": "ṯō-ḵê-lû", "traducao_palavra": "comereis" }
      ]
    }
  }
