        { "hebraico": "שָׁלֹ֣שׁ שָׁנִ֗ים", "transliteral": "šā-lōš šā-nîm", "traducao_palavra": "três anos" },
        { "hebraico": "יִהְיֶ֥ה לָכֶ֛ם", "transliteral": "yih-yeh lā-ḵem", "traducao_palavra": "será para vós" },
