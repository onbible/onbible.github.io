{
  "livro": "Levítico - וַיִּקְרָא - Vayikra",
  "capítulo": 7,
  "titulos": {},
  "versiculos": {
    "1": {
      "traducao_completa": "E esta é a lei da oferta pela culpa: coisa santíssima é.",
      "palavras": [
        { "hebraico": "וְזֹאת", "transliteral": "wə-zōṯ", "traducao_palavra": "e esta" },
        { "hebraico": "תּוֹרַת", "transliteral": "tō-raṯ", "traducao_palavra": "[é a] lei de" },
        { "hebraico": "הָאָשָׁם", "transliteral": "hā-ʾā-šām", "traducao_palavra": "a oferta pela culpa" },
        { "hebraico": "קֹדֶשׁ", "transliteral": "qō-ḏeš", "traducao_palavra": "santo de" },
        { "hebraico": "קָדָשִׁים", "transliteral": "qā-ḏā-šîm", "traducao_palavra": "santos [santíssima]" },
        { "hebraico": "הוּא׃", "transliteral": "hû", "traducao_palavra": "ela [é]" }
      ]
    },
    "2": {
      "traducao_completa": "No lugar onde degolam o holocausto, degolarão a oferta pela culpa, e o seu sangue se aspergirá sobre o altar ao redor.",
      "palavras": [
        { "hebraico": "בִּמְקוֹם", "transliteral": "bim-qôm", "traducao_palavra": "no lugar" },
        { "hebraico": "אֲשֶׁר", "transliteral": "ʾă-šer", "traducao_palavra": "que" },
        { "hebraico": "יִשְׁחֲטוּ", "transliteral": "yiš-ḥă-ṭû", "traducao_palavra": "degolam" },
        { "hebraico": "אֶת־הָעֹלָה", "transliteral": "ʾeṯ-hā-ʿō-lā", "traducao_palavra": "o holocausto" },
        { "hebraico": "יִשְׁחֲטוּ", "transliteral": "yiš-ḥă-ṭû", "traducao_palavra": "degolarão" },
        { "hebraico": "אֶת־הָאָשָׁם", "transliteral": "ʾeṯ-hā-ʾā-šām", "traducao_palavra": "a oferta pela culpa" },
        { "hebraico": "וְאֶת־דָּמוֹ", "transliteral": "wə-ʾeṯ-dā-mô", "traducao_palavra": "e o seu sangue" },
        { "hebraico": "יִזְרֹק", "transliteral": "yiz-rōq", "traducao_palavra": "aspergirá" },
        { "hebraico": "עַל־הַמִּזְבֵּחַ", "transliteral": "ʿal-ham-miz-bē-aḥ", "traducao_palavra": "sobre o altar" },
        { "hebraico": "סָבִיב׃", "transliteral": "śā-ḇîḇ", "traducao_palavra": "ao redor" }
      ]
    },
    "3": {
      "traducao_completa": "E dela oferecerá toda a sua gordura: a cauda e a gordura que cobre as entranhas,",
      "palavras": [
        { "hebraico": "וְאֵת", "transliteral": "wə-ʾēṯ", "traducao_palavra": "e" },
        { "hebraico": "כָּל־חֶלְבּוֹ", "transliteral": "kāl-ḥel-bô", "traducao_palavra": "toda sua gordura" },
        { "hebraico": "יַקְרִיב", "transliteral": "yaq-rîḇ", "traducao_palavra": "oferecerá" },
        { "hebraico": "מִמֶּנּוּ", "transliteral": "mim-men-nû", "traducao_palavra": "dela" }
      ]
    },
    "4": {
      "traducao_completa": "E ambos os rins, e a gordura que está sobre eles, e sobre as costas; e o redanho que está sobre o fígado, com os rins, os tirará.",
      "palavras": [
        { "hebraico": "וְאֵת", "transliteral": "wə-ʾēṯ", "traducao_palavra": "e" },
        { "hebraico": "שְׁתֵּי", "transliteral": "šə-tê", "traducao_palavra": "os dois" },
        { "hebraico": "הַכְּלָיֹת", "transliteral": "hak-kə-lā-yōṯ", "traducao_palavra": "rins" }
      ]
    },
    "5": {
      "traducao_completa": "E o sacerdote os queimará sobre o altar em oferta queimada a YHWH; oferta pela culpa é.",
      "palavras": [
        { "hebraico": "וְהִקְטִיר", "transliteral": "wə-hiq-ṭîr", "traducao_palavra": "e queimará" },
        { "hebraico": "אֹתָם", "transliteral": "ʾō-ṯām", "traducao_palavra": "eles" },
        { "hebraico": "הַכֹּהֵן", "transliteral": "hak-kō-hên", "traducao_palavra": "o sacerdote" },
        { "hebraico": "הַמִּזְבֵּחָה", "transliteral": "ham-miz-bê-ḥā", "traducao_palavra": "no altar" }
      ]
    },
    "6": {
      "traducao_completa": "Todo o macho entre os sacerdotes a comerá; no lugar santo se comerá; coisa santíssima é.",
      "palavras": [
        { "hebraico": "כָּל־זָכָר", "transliteral": "kāl-zā-ḵār", "traducao_palavra": "todo macho" },
        { "hebraico": "בַּכֹּהֲנִים", "transliteral": "bak-kō-hă-nîm", "traducao_palavra": "entre os sacerdotes" },
        { "hebraico": "יֹאכֲלֶנּוּ", "transliteral": "yō-ḵă-len-nû", "traducao_palavra": "comerá ela" }
      ]
    },
    "7": {
      "traducao_completa": "Como a oferta pelo pecado, assim será a oferta pela culpa; uma mesma lei haverá para elas: será do sacerdote que houver feito expiação com ela.",
      "palavras": [
        { "hebraico": "כַּחַטָּאת", "transliteral": "ka-ḥaṭ-ṭāṯ", "traducao_palavra": "como a oferta pelo pecado" },
        { "hebraico": "כָּאָשָׁם", "transliteral": "kā-ʾā-šām", "traducao_palavra": "assim [será] a oferta pela culpa" },
        { "hebraico": "תּוֹרָה", "transliteral": "tō-rā", "traducao_palavra": "lei" },
        { "hebraico": "אַחַת", "transliteral": "ʾa-ḥaṯ", "traducao_palavra": "uma [só]" },
        { "hebraico": "לָהֶם", "transliteral": "lā-hem", "traducao_palavra": "para elas" }
      ]
    },
    "8": {
      "traducao_completa": "Também o sacerdote que oferecer o holocausto de alguém, o mesmo sacerdote terá para si o couro do holocausto que oferecer.",
      "palavras": [
        { "hebraico": "וְהַכֹּהֵן", "transliteral": "wə-hak-kō-hên", "traducao_palavra": "e o sacerdote" },
        { "hebraico": "הַמַּקְרִיב", "transliteral": "ham-maq-rîḇ", "traducao_palavra": "que oferece" },
        { "hebraico": "אֶת־עוֹלַת", "transliteral": "ʾeṯ-ʿô-laṯ", "traducao_palavra": "o holocausto de" }
      ]
    },
    "9": {
      "traducao_completa": "E toda a oferta de manjares que se cozer no forno, e tudo o que se preparar na sertã e na assadeira, será do sacerdote que a oferecer.",
      "palavras": [
        { "hebraico": "וְכָל־מִנְחָה", "transliteral": "wə-ḵāl-min-ḥā", "traducao_palavra": "e toda oferta de manjares" }
      ]
    },
    "10": {
      "traducao_completa": "E toda a oferta de manjares, amassada com azeite ou seca, será de todos os filhos de Arão, tanto de um como de outro.",
      "palavras": [
        { "hebraico": "וְכָל־מִנְחָה", "transliteral": "wə-ḵāl-min-ḥā", "traducao_palavra": "e toda oferta de manjares" }
      ]
    },
    "11": {
      "traducao_completa": "E esta é a lei do sacrifício de paz que se oferecerá a YHWH:",
      "palavras": [
        { "hebraico": "וְזֹאת", "transliteral": "wə-zōṯ", "traducao_palavra": "e esta" },
        { "hebraico": "תּוֹרַת", "transliteral": "tō-raṯ", "traducao_palavra": "a lei de" },
        { "hebraico": "זֶבַח", "transliteral": "ze-ḇaḥ", "traducao_palavra": "sacrifício de" },
        { "hebraico": "הַשְּׁלָמִים", "transliteral": "haš-šə-lā-mîm", "traducao_palavra": "a paz" }
      ]
    },
    "12": {
      "traducao_completa": "Se o oferecer por ação de graças, com o sacrifício de ação de graças oferecerá bolos asmos amassados com azeite, e coscorões asmos untados com azeite, e bolos de flor de farinha cozidos, amassados com azeite.",
      "palavras": [
        { "hebraico": "אִם", "transliteral": "ʾim", "traducao_palavra": "se" },
        { "hebraico": "עַל־תּוֹדָה", "transliteral": "ʿal-tô-ḏā", "traducao_palavra": "por ação de graças" },
        { "hebraico": "יַקְרִיבֶנּוּ", "transliteral": "yaq-rî-ḇen-nû", "traducao_palavra": "ele o oferecer" }
      ]
    },
    "13": {
      "traducao_completa": "Com os bolos oferecerá, por sua oferta, pão levedado, com o sacrifício de ação de graças de sua oferta de paz.",
      "palavras": [
        { "hebraico": "עַל־חַלֹּת", "transliteral": "ʿal-ḥal-lōṯ", "traducao_palavra": "com os bolos de" },
        { "hebraico": "לֶחֶם", "transliteral": "le-ḥem", "traducao_palavra": "pão" },
        { "hebraico": "חָמֵץ", "transliteral": "ḥā-mêṣ", "traducao_palavra": "levedado" }
      ]
    },
    "14": {
      "traducao_completa": "E de toda a oferta oferecerá uma parte por oferta alçada a YHWH, que será do sacerdote que aspergir o sangue da oferta de paz.",
      "palavras": [
        { "hebraico": "וְהִקְרִיב", "transliteral": "wə-hiq-rîḇ", "traducao_palavra": "e oferecerá" },
        { "hebraico": "מִמֶּנּוּ", "transliteral": "mim-men-nû", "traducao_palavra": "dele" },
        { "hebraico": "אֶחָד", "transliteral": "ʾe-ḥāḏ", "traducao_palavra": "um" },
        { "hebraico": "מִכָּל־קָרְבָּן", "transliteral": "mik-kāl-qā-rə-bān", "traducao_palavra": "de toda oferta" },
        { "hebraico": "תְּרוּמָה", "transliteral": "tə-rû-mā", "traducao_palavra": "oferta alçada" },
        { "hebraico": "לַיהוָה", "transliteral": "la-YHWH", "traducao_palavra": "a YHWH" }
      ]
    },
    "15": {
      "traducao_completa": "E a carne do sacrifício de ação de graças da sua oferta de paz se comerá no dia do seu oferecimento; nada se deixará dela até à manhã.",
      "palavras": [
        { "hebraico": "וּבְשַׂר", "transliteral": "û-ḇə-śar", "traducao_palavra": "e a carne de" },
        { "hebraico": "זֶבַח", "transliteral": "ze-ḇaḥ", "traducao_palavra": "sacrifício de" }
      ]
    },
    "16": {
      "traducao_completa": "E, se o sacrifício da sua oferta for voto ou oferta voluntária, no dia em que oferecer o seu sacrifício se comerá; e o que dele sobejar também se comerá no dia seguinte;",
      "palavras": [
        { "hebraico": "וְאִם־נֶדֶר", "transliteral": "wə-ʾim-ne-ḏer", "traducao_palavra": "e se voto" },
        { "hebraico": "אוֹ", "transliteral": "ʾô", "traducao_palavra": "ou" },
        { "hebraico": "נְדָבָה", "transliteral": "nə-ḏā-ḇā", "traducao_palavra": "oferta voluntária" }
      ]
    },
    "17": {
      "traducao_completa": "Mas o que sobejar da carne do sacrifício ao terceiro dia será queimado no fogo.",
      "palavras": [
        { "hebraico": "וְהַנּוֹתָר", "transliteral": "wə-han-nō-ṯār", "traducao_palavra": "e o sobejante" },
        { "hebraico": "מִבְּשַׂר", "transliteral": "mib-bə-śar", "traducao_palavra": "da carne de" }
      ]
    },
    "18": {
      "traducao_completa": "Porque, se da carne do sacrifício da sua oferta de paz se comer ao terceiro dia, não será aceito, nem será imputado a quem o oferecer; coisa abominável será, e a alma que dela comer levará a sua iniquidade.",
      "palavras": [
        { "hebraico": "וְאִם", "transliteral": "wə-ʾim", "traducao_palavra": "e se" },
        { "hebraico": "הֵאָכֹל", "transliteral": "hê-ʾā-ḵōl", "traducao_palavra": "comer" },
        { "hebraico": "פִּגּוּל", "transliteral": "pig-gûl", "traducao_palavra": "coisa abominável/rejeitada" }
      ]
    },
    "19": {
      "traducao_completa": "E a carne que tocar alguma coisa imunda não se comerá; com fogo será queimada; mas, quanto à carne, qualquer que estiver limpo comerá dela.",
      "palavras": [
        { "hebraico": "וְהַבָּשָׂר", "transliteral": "wə-hab-bā-śār", "traducao_palavra": "e a carne" },
        { "hebraico": "אֲשֶׁר־יִגַּע", "transliteral": "ʾă-šer-yig-gaʿ", "traducao_palavra": "que tocar" },
        { "hebraico": "בְּכָל־טָמֵא", "transliteral": "bə-ḵāl-ṭā-mē", "traducao_palavra": "em qualquer [coisa] imunda" }
      ]
    },
    "20": {
      "traducao_completa": "Porém, a alma que comer a carne do sacrifício de paz, que pertence a YHWH, estando nela a sua imundícia, aquela alma será extirpada do seu povo.",
      "palavras": [
        { "hebraico": "וְהַנֶּפֶשׁ", "transliteral": "wə-han-ne-p̄eš", "traducao_palavra": "e a alma" },
        { "hebraico": "אֲשֶׁר־תֹּאכַל", "transliteral": "ʾă-šer-tō-ḵal", "traducao_palavra": "que comer" },
        { "hebraico": "בָּשָׂר", "transliteral": "bā-śār", "traducao_palavra": "carne" },
        { "hebraico": "מִזֶּבַח", "transliteral": "miz-ze-ḇaḥ", "traducao_palavra": "do sacrifício de" },
        { "hebraico": "הַשְּׁלָמִים", "transliteral": "haš-šə-lā-mîm", "traducao_palavra": "a paz" },
        { "hebraico": "אֲשֶׁר", "transliteral": "ʾă-šer", "traducao_palavra": "que [é]" },
        { "hebraico": "לַיהוָה", "transliteral": "la-YHWH", "traducao_palavra": "de YHWH" },
        { "hebraico": "וְטֻמְאָתוֹ", "transliteral": "wə-ṭum-ʾā-ṯô", "traducao_palavra": "e sua imundícia" },
        { "hebraico": "עָלָיו", "transliteral": "ʿā-lāyw", "traducao_palavra": "[está] sobre ela" },
        { "hebraico": "וְנִכְרְתָה", "transliteral": "wə-niḵ-rə-ṯā", "traducao_palavra": "e será extirpada" },
        { "hebraico": "הַנֶּפֶשׁ", "transliteral": "han-ne-p̄eš", "traducao_palavra": "a alma" },
        { "hebraico": "הַהִיא", "transliteral": "ha-hî", "traducao_palavra": "aquela" },
        { "hebraico": "מֵעַמֶּיהָ׃", "transliteral": "mē-ʿam-me-hā", "traducao_palavra": "de seu povo" }
      ]
    },
    "21": {
      "traducao_completa": "E quando uma alma tocar alguma coisa imunda, como imundícia de homem, ou animal imundo, ou qualquer abominação imunda, e comer da carne do sacrifício de paz, que pertence a YHWH, aquela alma será extirpada do seu povo.",
      "palavras": [
        { "hebraico": "וְנֶפֶשׁ", "transliteral": "wə-ne-p̄eš", "traducao_palavra": "e uma alma" },
        { "hebraico": "כִּי־תִגַּע", "transliteral": "kî-ṯig-gaʿ", "traducao_palavra": "quando tocar" },
        { "hebraico": "בְּכָל־טָמֵא", "transliteral": "bə-ḵāl-ṭā-mē", "traducao_palavra": "em qualquer [coisa] imunda" }
      ]
    },
    "22": {
      "traducao_completa": "E falou YHWH a Moisés, dizendo:",
      "palavras": [
        { "hebraico": "וַיְדַבֵּר", "transliteral": "way-yə-ḏab-bēr", "traducao_palavra": "e falou" },
        { "hebraico": "יְהוָה", "transliteral": "YHWH", "traducao_palavra": "YHWH" },
        { "hebraico": "אֶל־מֹשֶׁה", "transliteral": "ʾel-mō-šeh", "traducao_palavra": "a Moisés" },
        { "hebraico": "לֵּאמֹר׃", "transliteral": "lē-mōr", "traducao_palavra": "dizendo" }
      ]
    },
    "23": {
      "traducao_completa": "Fala aos filhos de Israel, dizendo: Nenhuma gordura de boi, nem de carneiro, nem de cabra comereis.",
      "palavras": [
        { "hebraico": "דַּבֵּר", "transliteral": "dab-bēr", "traducao_palavra": "fala" },
        { "hebraico": "אֶל־בְּנֵי", "transliteral": "ʾel-bə-nê", "traducao_palavra": "aos filhos de" },
        { "hebraico": "יִשְׂרָאֵל", "transliteral": "yiś-rā-ʾēl", "traducao_palavra": "Israel" },
        { "hebraico": "כָּל־חֵלֶב", "transliteral": "kāl-ḥē-leḇ", "traducao_palavra": "toda gordura" },
        { "hebraico": "שׁוֹר", "transliteral": "šôr", "traducao_palavra": "boi" },
        { "hebraico": "וְכֶשֶׂב", "transliteral": "wə-ḵe-śeḇ", "traducao_palavra": "e carneiro" },
        { "hebraico": "וָעֵז", "transliteral": "wā-ʿēz", "traducao_palavra": "e cabra" },
        { "hebraico": "לֹא", "transliteral": "lō", "traducao_palavra": "não" },
        { "hebraico": "תֹאכֵלוּ׃", "transliteral": "ṯō-ḵê-lû", "traducao_palavra": "comereis" }
      ]
    },
    "24": {
      "traducao_completa": "A gordura do animal que morre por si mesmo, e a gordura do que é despedaçado por feras, pode servir para qualquer outro uso, mas de maneira nenhuma a comereis.",
      "palavras": [
        { "hebraico": "וְחֵלֶב", "transliteral": "wə-ḥē-leḇ", "traducao_palavra": "e a gordura de" },
        { "hebraico": "נְבֵלָה", "transliteral": "nə-ḇê-lā", "traducao_palavra": "animal morto" }
      ]
    },
    "25": {
      "traducao_completa": "Porque qualquer que comer a gordura do animal, do qual se oferece a YHWH oferta queimada, a alma que a comer será extirpada do seu povo.",
      "palavras": [
        { "hebraico": "כִּי", "transliteral": "kî", "traducao_palavra": "porque" },
        { "hebraico": "כָּל־אֹכֵל", "transliteral": "kāl-ʾō-ḵēl", "traducao_palavra": "todo o que comer" },
        { "hebraico": "חֵלֶב", "transliteral": "ḥē-leḇ", "traducao_palavra": "gordura" }
      ]
    },
    "26": {
      "traducao_completa": "E nenhum sangue comereis em qualquer das vossas habitações, quer de aves quer de gado.",
      "palavras": [
        { "hebraico": "וְכָל־דָּם", "transliteral": "wə-ḵāl-dām", "traducao_palavra": "e todo sangue" },
        { "hebraico": "לֹא", "transliteral": "lō", "traducao_palavra": "não" },
        { "hebraico": "תֹאכְלוּ", "transliteral": "ṯō-ḵə-lû", "traducao_palavra": "comereis" }
      ]
    },
    "27": {
      "traducao_completa": "Qualquer alma que comer algum sangue, aquela alma será extirpada do seu povo.",
      "palavras": [
        { "hebraico": "כָּל־נֶפֶשׁ", "transliteral": "kāl-ne-p̄eš", "traducao_palavra": "toda alma" }
      ]
    },
    "28": {
