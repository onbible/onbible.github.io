        { "hebraico": "הִקְרִ֖יב", "transliteral": "hiqərîḇ", "traducao_palavra": "aproximou-se" },
        { "hebraico": "לָבֹ֣וא", "transliteral": "lāḇôʾ", "traducao_palavra": "para entrar" },
        { "hebraico": "מִצְרָ֑יְמָה", "transliteral": "miṣərāyəmâ", "traducao_palavra": "no Egito" },
        { "hebraico": "וַיֹּ֙אמֶר֙", "transliteral": "wayyōʾmer", "traducao_palavra": "e disse" },
        { "hebraico": "אֶל־שָׂרַ֣י", "transliteral": "ʾel-śārāy", "traducao_palavra": "a Sarai" },
        { "hebraico": "אִשְׁתֹּ֔ו", "transliteral": "ʾištô", "traducao_palavra": "sua mulher" },
        { "hebraico": "הִנֵּה־נָ֣א", "transliteral": "hinnēh-nāʾ", "traducao_palavra": "Eis agora" },
        { "hebraico": "יָדַ֔עְתִּי", "transliteral": "yāḏaʿtî", "traducao_palavra": "sei" },
        { "hebraico": "כִּ֛י", "transliteral": "kî", "traducao_palavra": "que" },
        { "hebraico": "אִשָּׁ֥ה", "transliteral": "ʾiššâ", "traducao_palavra": "mulher" },
        { "hebraico": "יְפַת־מַרְאֶ֖ה", "transliteral": "yəp̱aṯ-marʾeh", "traducao_palavra": "bela de aparência" },
        { "hebraico": "אָֽתְּ׃", "transliteral": "ʾātt", "traducao_palavra": "[és] tu" }
      ]
    },
    "12": {
      "traducao_completa": "e será que, quando os egípcios te virem, dirão: Esta é a sua mulher. E matar-me-ão a mim, e a ti guardarão em vida.",
      "palavras": [
        { "hebraico": "וְהָיָ֗ה", "transliteral": "wəhāyâ", "traducao_palavra": "E será" },
        { "hebraico": "כִּֽי־יִרְא֤וּ", "transliteral": "kî-yirʾû", "traducao_palavra": "que verão" },
        { "hebraico": "אֹתָךְ֙", "transliteral": "ʾōṯāḵ", "traducao_palavra": "te" },
        { "hebraico": "הַמִּצְרִ֔ים", "transliteral": "hammiṣərîm", "traducao_palavra": "os egípcios" },
        { "hebraico": "וְאָמְר֖וּ", "transliteral": "wəʾāmərû", "traducao_palavra": "e dirão" },
        { "hebraico": "אִשְׁתֹּ֣ו", "transliteral": "ʾištô", "traducao_palavra": "sua mulher" },
        { "hebraico": "זֹ֑את", "transliteral": "zōʾṯ", "traducao_palavra": "esta [é]" },
        { "hebraico": "וְהָרְג֥וּ", "transliteral": "wəhārəḡû", "traducao_palavra": "e matarão" },
        { "hebraico": "אֹתִ֖י", "transliteral": "ʾōṯî", "traducao_palavra": "me" },
        { "hebraico": "וְאֹתָ֥ךְ", "transliteral": "wəʾōṯāḵ", "traducao_palavra": "e te" },
        { "hebraico": "יְחַיּֽוּ׃", "transliteral": "yəḥayyû", "traducao_palavra": "deixarão viver" }
      ]
    },
    "13": {
      "traducao_completa": "Dize, peço-te, que és minha irmã, para que me vá bem por tua causa, e viva a minha alma por amor de ti.",
      "palavras": [
        { "hebraico": "אִמְרִי־נָ֖א", "transliteral": "ʾimərî-nāʾ", "traducao_palavra": "Dize, peço" },
        { "hebraico": "אֲחֹ֣תִי", "transliteral": "ʾăḥōṯî", "traducao_palavra": "minha irmã" },
        { "hebraico": "אָ֑תְּ", "transliteral": "ʾātt", "traducao_palavra": "[és] tu" },
        { "hebraico": "לְמַ֙עַן֙", "transliteral": "ləmaʿan", "traducao_palavra": "para que" },
        { "hebraico": "יִֽיטַב־לִ֣י", "transliteral": "yîṭaḇ-lî", "traducao_palavra": "vá bem para mim" },
        { "hebraico": "בַעֲבוּרֵ֔ךְ", "transliteral": "ḇaʿăḇûrēḵ", "traducao_palavra": "por causa de ti" },
        { "hebraico": "וְחָיְתָ֥ה", "transliteral": "wəḥāyəṯâ", "traducao_palavra": "e viva" },
        { "hebraico": "נַפְשִׁ֖י", "transliteral": "nap̄šî", "traducao_palavra": "minha alma" },
        { "hebraico": "בִּגְלָלֵֽךְ׃", "transliteral": "biḡəlālēḵ", "traducao_palavra": "por causa de ti" }
      ]
    },
    "14": {
      "traducao_completa": "E aconteceu que, entrando Abrão no Egito, viram os egípcios a mulher, que era muito formosa.",
      "palavras": [
        { "hebraico": "וַיְהִ֕י", "transliteral": "wayəhî", "traducao_palavra": "E foi/aconteceu" },
        { "hebraico": "כְּבֹ֥וא", "transliteral": "kəḇôʾ", "traducao_palavra": "ao entrar" },
        { "hebraico": "אַבְרָ֖ם", "transliteral": "ʾaḇrām", "traducao_palavra": "Abrão" },
        { "hebraico": "מִצְרָ֑יְמָה", "transliteral": "miṣərāyəmâ", "traducao_palavra": "no Egito" },
        { "hebraico": "וַיִּרְא֤וּ", "transliteral": "wayyirʾû", "traducao_palavra": "e viram" },
        { "hebraico": "הַמִּצְרִים֙", "transliteral": "hammiṣərîm", "traducao_palavra": "os egípcios" },
        { "hebraico": "אֶת־הָ֣אִשָּׁ֔ה", "transliteral": "ʾeṯ-hāʾiššâ", "traducao_palavra": "[obj] a mulher" },
        { "hebraico": "כִּֽי־יָפָ֥ה", "transliteral": "kî-yāp̄â", "traducao_palavra": "que bela" },
        { "hebraico": "הִ֖וא", "transliteral": "hîw", "traducao_palavra": "ela [era]" },
        { "hebraico": "מְאֹֽד׃", "transliteral": "məʾōḏ", "traducao_palavra": "muito" }
      ]
    },
    "15": {
      "traducao_completa": "E viram-na os príncipes de Faraó, e gabaram-na diante de Faraó; e foi a mulher levada à casa de Faraó.",
      "palavras": [
        { "hebraico": "וַיִּרְא֤וּ", "transliteral": "wayyirʾû", "traducao_palavra": "E viram" },
        { "hebraico": "אֹתָהּ֙", "transliteral": "ʾōṯāh", "traducao_palavra": "ela" },
        { "hebraico": "שָׂרֵ֣י", "transliteral": "śārê", "traducao_palavra": "príncipes de" },
        { "hebraico": "פַרְעֹ֔ה", "transliteral": "p̱arəʿōh", "traducao_palavra": "Faraó" },
        { "hebraico": "וַיְהַֽלְל֥וּ", "transliteral": "wayəhalləlû", "traducao_palavra": "e louvaram/gabaram" },
        { "hebraico": "אֹתָ֖הּ", "transliteral": "ʾōṯāh", "traducao_palavra": "ela" },
        { "hebraico": "אֶל־פַרְעֹ֑ה", "transliteral": "ʾel-p̱arəʿōh", "traducao_palavra": "a Faraó" },
        { "hebraico": "וַתֻּקַּ֥ח", "transliteral": "wattuqqaḥ", "traducao_palavra": "e foi levada" },
        { "hebraico": "הָאִשָּׁ֖ה", "transliteral": "hāʾiššâ", "traducao_palavra": "a mulher" },
        { "hebraico": "בֵּ֥ית", "transliteral": "bêṯ", "traducao_palavra": "casa de" },
        { "hebraico": "פַרְעֹֽה׃", "transliteral": "p̱arəʿōh", "traducao_palavra": "Faraó" }
      ]
    },
    "16": {
      "traducao_completa": "E fez bem a Abrão por causa dela; e ele teve ovelhas, e vacas, e jumentos, e servos, e servas, e jumentas, e camelos.",
      "palavras": [
        { "hebraico": "וּלְאַבְרָ֥ם", "transliteral": "ûləʾaḇrām", "traducao_palavra": "E a Abrão" },
        { "hebraico": "הֵיטִ֖יב", "transliteral": "hêṭîḇ", "traducao_palavra": "fez bem" },
        { "hebraico": "בַּעֲבוּרָ֑הּ", "transliteral": "baʿăḇûrāh", "traducao_palavra": "por causa dela" },
        { "hebraico": "וַֽיְהִי־לֹ֤ו", "transliteral": "wayəhî-lô", "traducao_palavra": "e foram para ele" },
        { "hebraico": "צֹאן־וּבָקָר֙", "transliteral": "ṣōn-ûḇāqār", "traducao_palavra": "ovelhas e gado" },
        { "hebraico": "וַחֲמֹרִ֔ים", "transliteral": "waḥămōrîm", "traducao_palavra": "e jumentos" },
        { "hebraico": "וַעֲבָדִים֙", "transliteral": "waʿăḇāḏîm", "traducao_palavra": "e servos" },
        { "hebraico": "וּשְׁפָחֹ֔ת", "transliteral": "ûšəp̱āḥōṯ", "traducao_palavra": "e servas" },
        { "hebraico": "וַאֲתֹנֹ֖ת", "transliteral": "waʾăṯōnōṯ", "traducao_palavra": "e jumentas" },
        { "hebraico": "וּגְמַלִּֽים׃", "transliteral": "ûḡəmallîm", "traducao_palavra": "e camelos" }
      ]
    },
    "17": {
      "traducao_completa": "Feriu, porém, o SENHOR a Faraó com grandes pragas, e a sua casa, por causa de Sarai, mulher de Abrão.",
      "palavras": [
        { "hebraico": "וַיְנַגַּ֨ע", "transliteral": "wayənaggaʿ", "traducao_palavra": "E feriu" },
        { "hebraico": "יְהוָ֧ה", "transliteral": "YHWH", "traducao_palavra": "YHWH" },
        { "hebraico": "אֶת־פַּרְעֹ֛ה", "transliteral": "ʾeṯ-p̱arəʿōh", "traducao_palavra": "[obj] Faraó" },
        { "hebraico": "נְגָעִ֥ים", "transliteral": "nəḡāʿîm", "traducao_palavra": "golpes/pragas" },
        { "hebraico": "גְּדֹלִ֖ים", "transliteral": "gəḏōlîm", "traducao_palavra": "grandes" },
        { "hebraico": "וְאֶת־בֵּיתֹ֑ו", "transliteral": "wəʾeṯ-bêṯô", "traducao_palavra": "e sua casa" },
        { "hebraico": "עַל־דְּבַ֥ר", "transliteral": "ʿal-dəḇar", "traducao_palavra": "por causa de/pela palavra de" },
        { "hebraico": "שָׂרַ֖י", "transliteral": "śārāy", "traducao_palavra": "Sarai" },
        { "hebraico": "אֵ֥שֶׁת", "transliteral": "ʾēšeṯ", "traducao_palavra": "mulher de" },
        { "hebraico": "אַבְרָֽם׃", "transliteral": "ʾaḇrām", "traducao_palavra": "Abrão" }
      ]
    },
    "18": {
      "traducao_completa": "Então chamou Faraó a Abrão, e disse: Que é isto que me fizeste? Por que não me disseste que ela era tua mulher?",
      "palavras": [
        { "hebraico": "וַיִּקְרָ֤א", "transliteral": "wayyiqrāʾ", "traducao_palavra": "E chamou" },
        { "hebraico": "פַרְעֹה֙", "transliteral": "p̱arəʿōh", "traducao_palavra": "Faraó" },
        { "hebraico": "לְאַבְרָ֔ם", "transliteral": "ləʾaḇrām", "traducao_palavra": "a Abrão" },
        { "hebraico": "וַיֹּ֕אמֶר", "transliteral": "wayyōʾmer", "traducao_palavra": "e disse" },
        { "hebraico": "מַה־זֹּ֖את", "transliteral": "mah-zzōʾṯ", "traducao_palavra": "O que [é] isto [que]" },
        { "hebraico": "עָשִׂ֣יתָ", "transliteral": "ʿāśîṯā", "traducao_palavra": "fizeste" },
        { "hebraico": "לִּ֑י", "transliteral": "llî", "traducao_palavra": "para mim?" },
        { "hebraico": "לָ֚מָּה", "transliteral": "lāmmâ", "traducao_palavra": "Por que" },
        { "hebraico": "לֹא־הִגַּ֣דְתָּ", "transliteral": "lōʾ-higgaḏttā", "traducao_palavra": "não contaste/mostraste" },
        { "hebraico": "לִּ֔י", "transliteral": "llî", "traducao_palavra": "a mim" },
        { "hebraico": "כִּ֥י", "transliteral": "kî", "traducao_palavra": "que" },
        { "hebraico": "אִשְׁתְּךָ֖", "transliteral": "ʾištəḵā", "traducao_palavra": "tua mulher" },
        { "hebraico": "הִֽוא׃", "transliteral": "hîw", "traducao_palavra": "[é] ela" }
      ]
    },
    "19": {
      "traducao_completa": "Por que disseste: É minha irmã? De maneira que a tomei por minha mulher; agora, pois, eis aqui tua mulher; toma-a e vai-te.",
      "palavras": [
        { "hebraico": "לָמָ֤ה", "transliteral": "lāmâ", "traducao_palavra": "Por que" },
        { "hebraico": "אָמַ֙רְתָּ֙", "transliteral": "ʾāmarəttā", "traducao_palavra": "disseste" },
        { "hebraico": "אֲחֹ֣תִי", "transliteral": "ʾăḥōṯî", "traducao_palavra": "minha irmã" },
        { "hebraico": "הִ֔וא", "transliteral": "hîw", "traducao_palavra": "[é] ela" },
        { "hebraico": "וָאֶקַּ֥ח", "transliteral": "wāʾeqqaḥ", "traducao_palavra": "e tomei" },
        { "hebraico": "אֹתָ֖הּ", "transliteral": "ʾōṯāh", "traducao_palavra": "ela" },
        { "hebraico": "לִ֣י", "transliteral": "lî", "traducao_palavra": "para mim" },
        { "hebraico": "לְאִשָּׁ֑ה", "transliteral": "ləʾiššâ", "traducao_palavra": "por mulher" },
        { "hebraico": "וְעַתָּ֕ה", "transliteral": "wəʿattâ", "traducao_palavra": "e agora" },
        { "hebraico": "הִנֵּ֥ה", "transliteral": "hinnēh", "traducao_palavra": "eis" },
        { "hebraico": "אִשְׁתְּךָ֖", "transliteral": "ʾištəḵā", "traducao_palavra": "tua mulher" },
        { "hebraico": "קַ֥ח", "transliteral": "qaḥ", "traducao_palavra": "toma" },
        { "hebraico": "וָלֵֽךְ׃", "transliteral": "wālēḵ", "traducao_palavra": "e vai-te" }
      ]
    },
    "20": {
      "traducao_completa": "E Faraó deu ordens a seus homens a respeito dele; e acompanharam-no, a ele, e a sua mulher e a tudo o que tinha.",
      "palavras": [
