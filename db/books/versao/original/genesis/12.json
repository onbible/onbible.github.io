        { "hebraico": "וַיָּבֹ֖אוּ", "transliteral": "wayyāḇōʾû", "traducao_palavra": "e vieram" },
        { "hebraico": "אַ֥רְצָה", "transliteral": "ʾarṣâ", "traducao_palavra": "à terra de" },
