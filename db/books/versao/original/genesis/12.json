        { "hebraico": "שָׁנִים֙", "transliteral": "šānîm", "traducao_palavra": "anos" },
        { "hebraico": "וְשִׁבְעִ֣ים", "transliteral": "wəšiḇʿîm", "traducao_palavra": "e setenta" },
        { "hebraico": "שָׁנָ֔ה", "transliteral": "šānâ", "traducao_palavra": "anos" },
        { "hebraico": "בְּצֵאתֹ֖ו", "transliteral": "bəṣēʾṯô", "traducao_palavra": "ao sair ele" },
        { "hebraico": "מֵחָרָֽן׃", "transliteral": "mēḥārān", "traducao_palavra": "de Harã" }
      ]
    },
    "5": {
      "traducao_completa": "E tomou Abrão a Sarai, sua mulher, e a Ló, filho de seu irmão, e todos os bens que haviam adquirido, e as almas que lhes acresceram em Harã; e saíram para irem à terra de Canaã; e vieram à terra de Canaã.",
      "palavras": [
