        { "hebraico": "אַבְרָ֗ם", "transliteral": "ʾaḇrām", "traducao_palavra": "Abrão" },
        { "hebraico": "כַּאֲשֶׁ֨ר", "transliteral": "kaʾăšer", "traducao_palavra": "conforme" },
        { "hebraico": "דִּבֶּ֤ר", "transliteral": "dibber", "traducao_palavra": "falou" },
