        { "hebraico": "אַבְרָם֩", "transliteral": "ʾaḇrām", "traducao_palavra": "Abrão" },
        { "hebraico": "אֶת־שָׂרַ֨י", "transliteral": "ʾeṯ-śārāy", "traducao_palavra": "[obj] Sarai" },
        { "hebraico": "אִשְׁתֹּ֜ו", "transliteral": "ʾištô", "traducao_palavra": "sua mulher" },
