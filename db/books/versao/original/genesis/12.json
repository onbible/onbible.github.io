{
  "livro": "Gênesis - בְּרֵאשִׁית - Bereshit",
  "capítulo": 12,
  "titulos": {},
  "versiculos": {
    "1": {
      "traducao_completa": "E disse o SENHOR a Abrão: Sai da tua terra, da tua parentela e da casa de teu pai, para a terra que eu te mostrarei.",
      "palavras": [
        { "hebraico": "וַיֹּ֤אמֶר", "transliteral": "wayyōʾmer", "traducao_palavra": "E disse" },
        { "hebraico": "יְהוָה֙", "transliteral": "YHWH", "traducao_palavra": "YHWH" },
        { "hebraico": "אֶל־אַבְרָ֔ם", "transliteral": "ʾel-ʾaḇrām", "traducao_palavra": "a Abrão" },
        { "hebraico": "לֶךְ־לְךָ֛", "transliteral": "leḵ-ləḵā", "traducao_palavra": "vai-te/sai" },
        { "hebraico": "מֵאַרְצְךָ֥", "transliteral": "mēʾarṣəḵā", "traducao_palavra": "da tua terra" },
        { "hebraico": "וּמִמֹּולַדְתְּךָ֖", "transliteral": "ûmimmôlaḏttəḵā", "traducao_palavra": "e da tua parentela" },
        { "hebraico": "וּמִבֵּ֣ית", "transliteral": "ûmibbêṯ", "traducao_palavra": "e da casa de" },
        { "hebraico": "אָבִ֑יךָ", "transliteral": "ʾāḇîḵā", "traducao_palavra": "teu pai" },
        { "hebraico": "אֶל־הָאָ֖רֶץ", "transliteral": "ʾel-hāʾāreṣ", "traducao_palavra": "para a terra" },
        { "hebraico": "אֲשֶׁ֥ר", "transliteral": "ʾăšer", "traducao_palavra": "que" },
        { "hebraico": "אַרְאֶֽךָּ׃", "transliteral": "ʾarʾekkā", "traducao_palavra": "eu te mostrarei" }
      ]
    },
    "2": {
      "traducao_completa": "E far-te-ei uma grande nação, e abençoar-te-ei e engrandecerei o teu nome; e tu serás uma bênção.",
      "palavras": [
        { "hebraico": "וְאֶֽעֶשְׂךָ֙", "transliteral": "wəʾeʿeśəḵā", "traducao_palavra": "E far-te-ei" },
        { "hebraico": "לְגֹ֣וי", "transliteral": "ləḡôy", "traducao_palavra": "em nação" },
        { "hebraico": "גָּדֹ֔ול", "transliteral": "gāḏôl", "traducao_palavra": "grande" },
        { "hebraico": "וַאֲבָרֶכְךָ֔", "transliteral": "waʾăḇāreḵəḵā", "traducao_palavra": "e abençoar-te-ei" },
        { "hebraico": "וַאֲגַדְּלָ֖ה", "transliteral": "waʾăḡaddəlâ", "traducao_palavra": "e engrandecerei" },
        { "hebraico": "שְׁמֶ֑ךָ", "transliteral": "šəmeḵā", "traducao_palavra": "teu nome" },
        { "hebraico": "וֶהְיֵ֖ה", "transliteral": "wehəyēh", "traducao_palavra": "e sê" },
        { "hebraico": "בְּרָכָֽה׃", "transliteral": "bərāḵâ", "traducao_palavra": "uma bênção" }
      ]
    },
    "3": {
      "traducao_completa": "E abençoarei os que te abençoarem, e amaldiçoarei o que te amaldiçoar; e em ti serão benditas todas as famílias da terra.",
      "palavras": [
        { "hebraico": "וַאֲבָֽרְכָה֙", "transliteral": "waʾăḇārəḵâ", "traducao_palavra": "E abençoarei" },
        { "hebraico": "מְבָרְכֶ֔יךָ", "transliteral": "məḇārəḵeyḵā", "traducao_palavra": "os que te abençoarem" },
        { "hebraico": "וּמְקַלֶּלְךָ֖", "transliteral": "ûməqalleleḵā", "traducao_palavra": "e o que te amaldiçoar" },
        { "hebraico": "אָאֹ֑ר", "transliteral": "ʾāʾōr", "traducao_palavra": "amaldiçoarei" },
        { "hebraico": "וְנִבְרְכ֣וּ", "transliteral": "wənibərəḵû", "traducao_palavra": "e serão benditas" },
        { "hebraico": "בְךָ֔", "transliteral": "ḇəḵā", "traducao_palavra": "em ti" },
        { "hebraico": "כֹּ֖ל", "transliteral": "kōl", "traducao_palavra": "todas" },
        { "hebraico": "מִשְׁפְּחֹ֥ת", "transliteral": "mišpəḥōṯ", "traducao_palavra": "as famílias de" },
        { "hebraico": "הָאֲדָמָֽה׃", "transliteral": "hāʾăḏāmâ", "traducao_palavra": "a terra/solo" }
      ]
    },
    "4": {
      "traducao_completa": "E partiu Abrão como o SENHOR lhe tinha dito, e foi Ló com ele; e era Abrão da idade de setenta e cinco anos quando saiu de Harã.",
      "palavras": [
