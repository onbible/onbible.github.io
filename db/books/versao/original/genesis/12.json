        { "hebraico": "אֲשֶׁר־עָשׂ֣וּ", "transliteral": "ʾăšer-ʿāśû", "traducao_palavra": "que fizeram/adquiriram" },
        { "hebraico": "בְחָרָ֑ן", "transliteral": "ḇəḥārān", "traducao_palavra": "em Harã" },
