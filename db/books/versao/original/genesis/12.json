        { "hebraico": "פַּרְעֹ֖ה", "transliteral": "p̱arəʿōh", "traducao_palavra": "Faraó" },
        { "hebraico": "אֲנָשִׁ֑ים", "transliteral": "ʾănāšîm", "traducao_palavra": "homens" },
        { "hebraico": "וַיְשַׁלְּח֥וּ", "transliteral": "wayəšalləḥû", "traducao_palavra": "e acompanharam/enviaram" },
        { "hebraico": "אֹתֹ֛ו", "transliteral": "ʾōṯô", "traducao_palavra": "ele" },
        { "hebraico": "וְאֶת־אִשְׁתֹּ֖ו", "transliteral": "wəʾeṯ-ištô", "traducao_palavra": "e sua mulher" },
        { "hebraico": "וְאֶת־כָּל־אֲשֶׁר־לֹֽו׃", "transliteral": "wəʾeṯ-kāl-ʾăšer-lô", "traducao_palavra": "e tudo o que era dele" }
