    "6": {
      "traducao_completa": "E ele os alcançou e falou-lhes estas palavras.",
      "palavras": [
        { "hebraico": "וַיַּשִּׂגֵם", "transliteral": "way-yaś-śi-ḡēm", "traducao_palavra": "e alcançou-os" },
