        { "hebraico": "אוֹ־אָח׃", "transliteral": "ʾô-ʾāḥ", "traducao_palavra": "ou irmão" }
      ]
    },
    "20": {
      "traducao_completa": "E dissemos ao meu senhor: Temos um pai ancião, e um menino da sua velhice, o mais novo; seu irmão morreu, e ficou ele só de sua mãe, e seu pai o ama.",
      "palavras": [
        { "hebraico": "וַנֹּאמֶר", "transliteral": "wan-nō-mer", "traducao_palavra": "e dissemos" },
