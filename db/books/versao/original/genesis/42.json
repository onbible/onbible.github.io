        { "hebraico": "וַיֹּאמֶר", "transliteral": "way-yō-mer", "traducao_palavra": "e disse" },
        { "hebraico": "גַּם־עַתָּה", "transliteral": "gam-ʿat-tā", "traducao_palavra": "também agora" },
