        { "hebraico": "כָּמֹנִי׃", "transliteral": "kā-mō-nî", "traducao_palavra": "como eu" }
      ]
    },
    "16": {
      "traducao_completa": "E disse Judá: O que diremos ao meu senhor? O que falaremos? E como nos justificaremos? Deus achou a iniquidade dos teus servos; eis que somos servos do meu senhor, tanto nós como aquele em cuja mão foi achado o copo.",
      "palavras": [
        { "hebraico": "וַיֹּאמֶר", "transliteral": "way-yō-mer", "traducao_palavra": "e disse" },
        { "hebraico": "יְהוּדָה", "transliteral": "yə-hû-ḏāh", "traducao_palavra": "Judá" },
        { "hebraico": "מַה־נֹּאמַר", "transliteral": "mah-nō-mar", "traducao_palavra": "o que diremos" },
        { "hebraico": "לַאדֹנִי", "transliteral": "la-ḏō-nî", "traducao_palavra": "ao meu senhor" },
        { "hebraico": "מַה־נְּדַבֵּר", "transliteral": "mah-nə-ḏab-bēr", "traducao_palavra": "o que falaremos" },
        { "hebraico": "וּמַה־נִּצְטַדָּק", "transliteral": "û-mah-niṣ-ṭad-dāq", "traducao_palavra": "e como justificaremos" },
