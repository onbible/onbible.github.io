      ]
    },
    "18": {
      "traducao_completa": "Então Judá se aproximou dele e disse: Rogo-te, meu senhor, fale o teu servo uma palavra aos ouvidos do meu senhor, e não se acenda a tua ira contra o teu servo, porque tu és como Faraó.",
      "palavras": [
