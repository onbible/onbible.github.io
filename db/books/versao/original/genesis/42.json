        { "hebraico": "אֲדֹנִי", "transliteral": "ʾă-ḏō-nî", "traducao_palavra": "meu senhor" },
        { "hebraico": "יְדַבֶּר־נָא", "transliteral": "yə-ḏab-ber-nā", "traducao_palavra": "fale peço" },
        { "hebraico": "עַבְדְּךָ", "transliteral": "ʿaḇ-də-ḵā", "traducao_palavra": "teu servo" },
        { "hebraico": "דָבָר", "transliteral": "ḏā-ḇār", "traducao_palavra": "uma palavra" },
        { "hebraico": "בְּאָזְנֵי", "transliteral": "bə-ʾā-zə-nê", "traducao_palavra": "nos ouvidos de" },
        { "hebraico": "אֲדֹנִי", "transliteral": "ʾă-ḏō-nî", "traducao_palavra": "meu senhor" },
        { "hebraico": "וְאַל־יִחַר", "transliteral": "wə-ʾal-yi-ḥar", "traducao_palavra": "e não se acenda" },
        { "hebraico": "אַפְּךָ", "transliteral": "ʾap-pə-ḵā", "traducao_palavra": "tua ira" },
        { "hebraico": "בְּעַבְדֶּךָ", "transliteral": "bə-ʿaḇ-de-ḵā", "traducao_palavra": "contra teu servo" },
        { "hebraico": "כִּי", "transliteral": "kî", "traducao_palavra": "porque" },
        { "hebraico": "כָמוֹךָ", "transliteral": "ḵā-mô-ḵā", "traducao_palavra": "como tu [és]" },
        { "hebraico": "כְּפַרְעֹה׃", "transliteral": "kə-p̄ar-ʿōh", "traducao_palavra": "como Faraó" }
      ]
    },
    "19": {
