    "21": {
      "traducao_completa": "E disseste aos teus servos: Fazei-o descer a mim, para que eu ponha os meus olhos sobre ele.",
      "palavras": [
        { "hebraico": "וַתֹּאמֶר", "transliteral": "wat-tō-mer", "traducao_palavra": "e disseste" },
        { "hebraico": "אֶל־עֲבָדֶיךָ", "transliteral": "ʾel-ʿă-ḇā-ḏe-ḵā", "traducao_palavra": "aos teus servos" },
        { "hebraico": "הוֹרִדֻהוּ", "transliteral": "hô-ri-ḏu-hû", "traducao_palavra": "fazei-o descer" },
        { "hebraico": "אֵלָי", "transliteral": "ʾē-lāy", "traducao_palavra": "a mim" },
        { "hebraico": "וְאָשִׂימָה", "transliteral": "wə-ʾā-śî-mā", "traducao_palavra": "e porei" },
        { "hebraico": "עֵינִי", "transliteral": "ʿê-nî", "traducao_palavra": "meu olho" },
        { "hebraico": "עָלָיו׃", "transliteral": "ʿā-lāw", "traducao_palavra": "sobre ele" }
      ]
    },
    "22": {
      "traducao_completa": "E dissemos ao meu senhor: O menino não pode deixar a seu pai; se deixar a seu pai, este morrerá.",
      "palavras": [
        { "hebraico": "וַנֹּאמֶר", "transliteral": "wan-nō-mer", "traducao_palavra": "e dissemos" },
        { "hebraico": "אֶל־אֲדֹנִי", "transliteral": "ʾel-ʾă-ḏō-nî", "traducao_palavra": "ao meu senhor" },
        { "hebraico": "לֹא־יוּכַל", "transliteral": "lō-yû-ḵal", "traducao_palavra": "não poderá" },
        { "hebraico": "הַנַּעַר", "transliteral": "han-na-ʿar", "traducao_palavra": "o menino" },
        { "hebraico": "לַעֲזֹב", "transliteral": "la-ʿă-zōḇ", "traducao_palavra": "deixar" },
