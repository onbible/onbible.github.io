        { "hebraico": "אֵלָיו", "transliteral": "ʾē-lāw", "traducao_palavra": "dele" },
        { "hebraico": "יְהוּדָה", "transliteral": "yə-hû-ḏāh", "traducao_palavra": "Judá" },
        { "hebraico": "וַיֹּאמֶר", "transliteral": "way-yō-mer", "traducao_palavra": "e disse" },
