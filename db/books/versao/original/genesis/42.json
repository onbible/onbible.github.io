        { "hebraico": "הִנְנּוּ", "transliteral": "hin-nə-nû", "traducao_palavra": "eis-nos" },
        { "hebraico": "עֲבָדִים", "transliteral": "ă-ḇā-ḏîm", "traducao_palavra": "servos" },
