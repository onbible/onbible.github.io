        { "hebraico": "זְקֻנִים", "transliteral": "zə-qu-nîm", "traducao_palavra": "[da] velhice" },
        { "hebraico": "קָטָן", "transliteral": "qā-ṭān", "traducao_palavra": "pequeno" },
        { "hebraico": "וְאָחִיו", "transliteral": "wə-ʾā-ḥîw", "traducao_palavra": "e seu irmão" },
