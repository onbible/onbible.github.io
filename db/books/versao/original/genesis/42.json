{
  "livro": "Gênesis - בְּרֵאשִׁית - Bereshit",
  "capítulo": 44,
  "titulos": {},
  "versiculos": {
    "1": {
      "traducao_completa": "E ordenou ao que estava sobre a sua casa, dizendo: Enche os sacos destes homens de mantimento, tanto quanto puderem carregar, e põe o dinheiro de cada um na boca do seu saco.",
      "palavras": [
