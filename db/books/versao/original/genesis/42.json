        { "hebraico": "וָמֵת", "transliteral": "wā-mēṯ", "traducao_palavra": "morra" },
        { "hebraico": "וְגַם־אֲנַחְנוּ", "transliteral": "wə-ḡam-ʾă-naḥ-nû", "traducao_palavra": "e também nós" },
