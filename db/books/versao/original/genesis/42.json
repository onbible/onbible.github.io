        { "hebraico": "וְאַתֶּם", "transliteral": "wə-ʾat-tem", "traducao_palavra": "e vós" },
        { "hebraico": "תִּהְיוּ", "transliteral": "tih-yû", "traducao_palavra": "sereis" },
        { "hebraico": "נְקִיִּם׃", "transliteral": "nə-qî-yim", "traducao_palavra": "inocentes" }
