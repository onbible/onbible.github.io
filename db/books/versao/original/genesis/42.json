        { "hebraico": "יְדַבֵּר", "transliteral": "yə-ḏab-bēr", "traducao_palavra": "fala" },
        { "hebraico": "אֲדֹנִי", "transliteral": "ʾă-ḏō-nî", "traducao_palavra": "meu senhor" },
