        { "hebraico": "הַגָּבִיעַ", "transliteral": "hag-gā-ḇî-aʿ", "traducao_palavra": "o copo" },
        { "hebraico": "בְּיָדוֹ׃", "transliteral": "bə-yā-ḏô", "traducao_palavra": "em sua mão" }
      ]
    },
    "17": {
      "traducao_completa": "E ele disse: Longe esteja de mim fazer isto; o homem em cuja mão foi achado o copo, ele será o meu servo; e vós, subi em paz para o vosso pai.",
      "palavras": [
        { "hebraico": "וַיֹּאמֶר", "transliteral": "way-yō-mer", "traducao_palavra": "e disse" },
        { "hebraico": "חָלִילָה", "transliteral": "ḥā-lî-lā", "traducao_palavra": "longe [esteja]" },
        { "hebraico": "לִּי", "transliteral": "lî", "traducao_palavra": "de mim" },
        { "hebraico": "מֵעֲשׂוֹת", "transliteral": "mē-ʿă-śôṯ", "traducao_palavra": "de fazer" },
        { "hebraico": "זֹּאת", "transliteral": "zōṯ", "traducao_palavra": "isto" },
