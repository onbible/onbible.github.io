        { "hebraico": "יִהְיֶה־לִּי", "transliteral": "yih-yeh-lî", "traducao_palavra": "será para mim" },
        { "hebraico": "עָבֶד", "transliteral": "ʿā-ḇeḏ", "traducao_palavra": "servo" },
