        { "hebraico": "אַחֲרֵי", "transliteral": "ʾa-ḥă-rê", "traducao_palavra": "depois de" },
        { "hebraico": "הָאֲנָשִׁים", "transliteral": "hā-ʾă-nā-šîm", "traducao_palavra": "os homens" },
        { "hebraico": "וְהִשַּׂגְתָּם", "transliteral": "wə-hiś-śāḡ-tām", "traducao_palavra": "e alcançando-os" },
