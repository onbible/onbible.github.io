        { "hebraico": "יוּכְלוּן", "transliteral": "yû-ḵə-lûn", "traducao_palavra": "puderem" },
        { "hebraico": "שְׂאֵת", "transliteral": "śə-ʾēṯ", "traducao_palavra": "carregar" },
        { "hebraico": "וְשִׂים", "transliteral": "wə-śîm", "traducao_palavra": "e põe" },
        { "hebraico": "כֶּסֶף־אִישׁ", "transliteral": "ke-sep̄-ʾîš", "traducao_palavra": "dinheiro de cada um" },
