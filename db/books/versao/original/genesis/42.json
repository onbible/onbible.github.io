        { "hebraico": "אֲלֵהֶם", "transliteral": "ʾă-lē-hem", "traducao_palavra": "a eles" },
        { "hebraico": "לָמָּה", "transliteral": "lām-mā", "traducao_palavra": "por que" },
        { "hebraico": "שִׁלַּמְתֶּם", "transliteral": "šil-lam-tem", "traducao_palavra": "pagastes" },
        { "hebraico": "רָעָה", "transliteral": "rā-ʿā", "traducao_palavra": "mal" },
