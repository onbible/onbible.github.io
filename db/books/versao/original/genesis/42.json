        { "hebraico": "וַיִּוָּתֵר", "transliteral": "way-yiw-wā-ṯēr", "traducao_palavra": "e ficou" },
        { "hebraico": "הוּא", "transliteral": "hû", "traducao_palavra": "ele" },
        { "hebraico": "לְבַדּוֹ", "transliteral": "lə-ḇad-dô", "traducao_palavra": "só dele" },
        { "hebraico": "לְאִמּוֹ", "transliteral": "lə-ʾim-mô", "traducao_palavra": "[em relação] a sua mãe" },
