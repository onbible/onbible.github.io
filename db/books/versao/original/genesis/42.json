        { "hebraico": "כַּדָּבָר", "transliteral": "kad-dā-ḇār", "traducao_palavra": "conforme a coisa" },
        { "hebraico": "הַזֶּה׃", "transliteral": "haz-zeh", "traducao_palavra": "esta" }
      ]
    },
    "8": {
      "traducao_completa": "Eis que o dinheiro que achamos na boca dos nossos sacos, trouxemo-lo de volta a ti da terra de Canaã; como pois roubaríamos da casa do teu senhor prata ou ouro?",
