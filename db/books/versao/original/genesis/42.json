      ]
    },
    "2": {
      "traducao_completa": "E o meu copo, o copo de prata, porás na boca do saco do mais novo, com o dinheiro do seu cereal. E ele fez conforme a palavra de José, que havia falado.",
      "palavras": [
        { "hebraico": "וְאֶת־גְּבִיעִי", "transliteral": "wə-ʾeṯ-ḡə-ḇî-ʿî", "traducao_palavra": "e o meu copo" },
        { "hebraico": "גְּבִיעַ", "transliteral": "ḡə-ḇî-aʿ", "traducao_palavra": "copo de" },
        { "hebraico": "הַכֶּסֶף", "transliteral": "hak-ke-sep̄", "traducao_palavra": "a prata" },
        { "hebraico": "תָּשִׂים", "transliteral": "tā-śîm", "traducao_palavra": "porás" },
