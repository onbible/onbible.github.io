        { "hebraico": "יָצְאוּ", "transliteral": "yā-ṣə-ʾû", "traducao_palavra": "saíram de" },
        { "hebraico": "אֶת־הָעִיר", "transliteral": "ʾeṯ-hā-ʿîr", "traducao_palavra": "a cidade" },
        { "hebraico": "לֹא", "transliteral": "lō", "traducao_palavra": "não" },
        { "hebraico": "הִרְחִיקוּ", "transliteral": "hir-ḥî-qû", "traducao_palavra": "se distanciaram" },
        { "hebraico": "וְיוֹסֵף", "transliteral": "wə-yô-sēp̄", "traducao_palavra": "e José" },
        { "hebraico": "אָמַר", "transliteral": "אָמַר", "traducao_palavra": "disse" },
