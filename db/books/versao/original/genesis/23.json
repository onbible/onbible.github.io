      ]
    },
    "9": {
      "traducao_completa": "E que ele me dê a caverna de Macpela, que [é] dele, que [está] na extremidade do seu campo; por dinheiro total a dê a mim no vosso meio, para propriedade de sepulcro.",
      "palavras": [
        { "hebraico": "וְיִתֶּן־לִ֗י", "transliteral": "wəyitten-lî", "traducao_palavra": "e ele dê a mim" },
