    "8": {
      "traducao_completa": "E falou com eles, dizendo: Se é com a vossa alma sepultar meu morto de diante de minha face, ouvi-me e intercedei por mim perante Efrom, filho de Zoar.",
      "palavras": [
        { "hebraico": "וַיְדַבֵּ֥ר", "transliteral": "wayḏabbēr", "traducao_palavra": "e falou" },
