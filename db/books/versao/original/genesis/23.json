        { "hebraico": "לֵאמֹ֑ר", "transliteral": "lēʾmōr", "traducao_palavra": "dizendo" },
        { "hebraico": "אִם־יֵ֣שׁ", "transliteral": "ʾim-yēš", "traducao_palavra": "se existe" },
        { "hebraico": "אֶֽת־נַפְשְׁכֶ֗ם", "transliteral": "ʾeṯ-napšəḵem", "traducao_palavra": "com vossa alma/vontade" },
        { "hebraico": "לִקְבֹּ֤ר", "transliteral": "liqbbōr", "traducao_palavra": "sepultar" },
        { "hebraico": "אֶת־מֵתִי֙", "transliteral": "ʾeṯ-mēṯî", "traducao_palavra": "meu morto" },
        { "hebraico": "מִלְּפָנַ֔י", "transliteral": "milləpānay", "traducao_palavra": "de diante de minha face" },
        { "hebraico": "שְׁמָע֕וּנִי", "transliteral": "šəmāʿûnî", "traducao_palavra": "ouvi-me" },
        { "hebraico": "וּפִגְעוּ־לִ֖י", "transliteral": "ûp̄iḡʿû-lî", "traducao_palavra": "e intercedei por mim" },
        { "hebraico": "בְּעֶפְר֥וֹן", "transliteral": "bəʿep̄rôn", "traducao_palavra": "em/perante Efrom" },
