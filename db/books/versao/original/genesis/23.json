        { "hebraico": "אַבְרָהָ֑ם", "transliteral": "ʾaḇrāhām", "traducao_palavra": "Abraão" },
        { "hebraico": "לִפְנֵ֖י", "transliteral": "lip̄nê", "traducao_palavra": "diante de" },
        { "hebraico": "עַ֥ם", "transliteral": "ʿam", "traducao_palavra": "povo de" },
        { "hebraico": "הָאָֽרֶץ׃", "transliteral": "hāʾāreṣ", "traducao_palavra": "a terra" }
      ]
    },
    "13": {
      "traducao_completa": "E falou a Efrom aos ouvidos do povo da terra, dizendo: Somente se tu, rogo-te, ouve-me; darei o dinheiro do campo, toma-o de mim e sepultarei meu morto ali.",
      "palavras": [
        { "hebraico": "וַיְדַבֵּ֨ר", "transliteral": "wayḏabbēr", "traducao_palavra": "e falou" },
        { "hebraico": "אֶל־עֶפְר֜וֹן", "transliteral": "ʾel-ʿep̄rôn", "traducao_palavra": "a Efrom" },
        { "hebraico": "בְּאָזְנֵ֤י", "transliteral": "bəʾāznê", "traducao_palavra": "nos ouvidos de" },
        { "hebraico": "עַם־הָאָ֙רֶץ֙", "transliteral": "ʿam-hāʾāreṣ", "traducao_palavra": "povo da terra" },
        { "hebraico": "לֵאמֹ֔ר", "transliteral": "lēʾmōr", "traducao_palavra": "dizendo" },
        { "hebraico": "אַ֣ךְ", "transliteral": "ʾaḵ", "traducao_palavra": "somente" },
        { "hebraico": "אִם־אַתָּ֥ה", "transliteral": "ʾim-ʾattâ", "traducao_palavra": "se tu" },
        { "hebraico": "לוּ", "transliteral": "lû", "traducao_palavra": "quem dera/rogo-te" },
        { "hebraico": "שְׁמָעֵ֑נִי", "transliteral": "šəmāʿēnî", "traducao_palavra": "ouve-me" },
        { "hebraico": "נָתַ֜תִּי", "transliteral": "nāṯattî", "traducao_palavra": "eu darei" },
        { "hebraico": "כֶּ֤סֶף", "transliteral": "kesep̄", "traducao_palavra": "dinheiro de" },
        { "hebraico": "הַשָּׂדֶה֙", "transliteral": "haśśāḏeh", "traducao_palavra": "o campo" },
        { "hebraico": "קַ֣ח", "transliteral": "qaḥ", "traducao_palavra": "toma" },
        { "hebraico": "מִמֶּ֔נִּי", "transliteral": "mimmennî", "traducao_palavra": "de mim" },
        { "hebraico": "וְאֶקְבְּרָ֥ה", "transliteral": "wəʾeqbərâ", "traducao_palavra": "e sepultarei" },
        { "hebraico": "אֶת־מֵתִ֖י", "transliteral": "ʾeṯ-mēṯî", "traducao_palavra": "o meu morto" },
        { "hebraico": "שָֽׁמָּה׃", "transliteral": "šāmmâ", "traducao_palavra": "lá/ali" }
      ]
    },
    "14": {
      "traducao_completa": "E respondeu Efrom a Abraão, dizendo-lhe:",
      "palavras": [
        { "hebraico": "וַיַּ֧עַן", "transliteral": "wayyaʿan", "traducao_palavra": "e respondeu" },
        { "hebraico": "עֶפְר֛וֹן", "transliteral": "ʿep̄rôn", "traducao_palavra": "Efrom" },
        { "hebraico": "אֶת־אַבְרָהָ֥ם", "transliteral": "ʾeṯ-ʾaḇrāhām", "traducao_palavra": "a Abraão" },
        { "hebraico": "לֵאמֹ֥ר", "transliteral": "lēʾmōr", "traducao_palavra": "dizendo" },
        { "hebraico": "לּֽוֹ׃", "transliteral": "lô", "traducao_palavra": "a ele" }
      ]
    },
    "15": {
      "traducao_completa": "Meu senhor, ouve-me; a terra de quatrocentos siclos de prata entre mim e entre ti, o que é isso? E teu morto sepulta.",
      "palavras": [
        { "hebraico": "אֲדֹנִ֣י", "transliteral": "ʾăḏōnî", "traducao_palavra": "meu senhor" },
        { "hebraico": "שְׁמָעֵ֔נִי", "transliteral": "šəmāʿēnî", "traducao_palavra": "ouve-me" },
        { "hebraico": "אֶרֶץ֩", "transliteral": "ʾereṣ", "traducao_palavra": "terra de" },
        { "hebraico": "אַרְבַּ֨ע", "transliteral": "ʾarbaʿ", "traducao_palavra": "quatro" },
        { "hebraico": "מֵאֹ֧ת", "transliteral": "mēʾōṯ", "traducao_palavra": "centenas" },
        { "hebraico": "שֶֽׁקֶל־כֶּ֛סֶף", "transliteral": "šeqel-kesep̄", "traducao_palavra": "siclo de prata" },
        { "hebraico": "בֵּינִ֥י", "transliteral": "bênî", "traducao_palavra": "entre mim" },
        { "hebraico": "וּבֵינְךָ֖", "transliteral": "ûḇênəḵā", "traducao_palavra": "e entre ti" },
        { "hebraico": "מַה־הִ֑וא", "transliteral": "mah-hîʾ", "traducao_palavra": "o que ela/isso" },
        { "hebraico": "וְאֶת־מֵתְךָ֖", "transliteral": "wəʾeṯ-mēṯəḵā", "traducao_palavra": "e o teu morto" },
        { "hebraico": "קְבֹֽר׃", "transliteral": "qəḇōr", "traducao_palavra": "sepulta" }
      ]
    },
    "16": {
      "traducao_completa": "E ouviu Abraão a Efrom; e pesou Abraão para Efrom a prata que falara aos ouvidos dos filhos de Hete: quatrocentos siclos de prata, passando ao mercador.",
      "palavras": [
        { "hebraico": "וַיִּשְׁמַ֣ע", "transliteral": "wayyišmaʿ", "traducao_palavra": "e ouviu" },
        { "hebraico": "אַבְרָהָם֮", "transliteral": "ʾaḇrāhām", "traducao_palavra": "Abraão" },
        { "hebraico": "אֶל־עֶפְרוֹן֒", "transliteral": "ʾel-ʿep̄rôn", "traducao_palavra": "a Efrom" },
        { "hebraico": "וַיִּשְׁקֹ֤ל", "transliteral": "wayyišqōl", "traducao_palavra": "e pesou" },
        { "hebraico": "אַבְרָהָם֙", "transliteral": "ʾaḇrāhām", "traducao_palavra": "Abraão" },
        { "hebraico": "לְעֶפְרֹ֔ן", "transliteral": "ləʿep̄rōn", "traducao_palavra": "para Efrom" },
        { "hebraico": "אֶת־הַכֶּ֕סֶף", "transliteral": "ʾeṯ-hakkesep̄", "traducao_palavra": "a prata" },
        { "hebraico": "אֲשֶׁ֥ר", "transliteral": "ʾăšer", "traducao_palavra": "que" },
        { "hebraico": "דִּבֶּ֖ר", "transliteral": "dibber", "traducao_palavra": "falou" },
        { "hebraico": "בְּאָזְנֵ֣י", "transliteral": "bəʾāznê", "traducao_palavra": "nos ouvidos de" },
        { "hebraico": "בְנֵi־חֵ֑ת", "transliteral": "ḇənê-ḥēṯ", "traducao_palavra": "filhos de Hete" },
        { "hebraico": "אַרְבַּ֤ע", "transliteral": "ʾarbaʿ", "traducao_palavra": "quatro" },
        { "hebraico": "מֵאֹוֹת֙", "transliteral": "mēʾôṯ", "traducao_palavra": "centenas" },
        { "hebraico": "שֶׁ֣קֶל", "transliteral": "šeqel", "traducao_palavra": "siclo de" },
        { "hebraico": "כֶּ֔סֶף", "transliteral": "kesep̄", "traducao_palavra": "prata" },
        { "hebraico": "עֹבֵ֖ר", "transliteral": "ʿōḇēr", "traducao_palavra": "passando/corrente" },
        { "hebraico": "לַסֹּחֵֽר׃", "transliteral": "lassōḥēr", "traducao_palavra": "ao mercador" }
      ]
    },
    "17": {
      "traducao_completa": "E foi estabelecido o campo de Efrom, que [está] em Macpela, que [está] diante de Manre; o campo e a caverna que nele [está], e toda árvore que no campo [está], em todo o seu limite ao redor.",
      "palavras": [
        { "hebraico": "וַיָּ֣קָם", "transliteral": "wayyāqom", "traducao_palavra": "e foi estabelecido/levantou" },
        { "hebraico": "שְׂדֵ֣ה", "transliteral": "śəḏē", "traducao_palavra": "campo de" },
        { "hebraico": "עֶפְר֗וֹן", "transliteral": "ʿep̄rôn", "traducao_palavra": "Efrom" },
        { "hebraico": "אֲשֶׁר֙", "transliteral": "ʾăšer", "traducao_palavra": "que" },
        { "hebraico": "בַּמַּכְפֵּלָ֔ה", "transliteral": "bammaḵpēlâ", "traducao_palavra": "em Macpela" },
        { "hebraico": "אֲשֶׁ֖ר", "transliteral": "ʾăšer", "traducao_palavra": "que" },
        { "hebraico": "לִפְנֵ֣י", "transliteral": "lip̄nê", "traducao_palavra": "diante de" },
        { "hebraico": "מַמְרֵ֑א", "transliteral": "mamrē", "traducao_palavra": "Manre" },
        { "hebraico": "הַשָּׂדֶה֙", "transliteral": "haśśāḏeh", "traducao_palavra": "o campo" },
        { "hebraico": "וְהַמְּעָרָ֣ה", "transliteral": "wəhamməʿārâ", "traducao_palavra": "e a caverna" },
        { "hebraico": "אֲשֶׁר־בּ֔וֹ", "transliteral": "ʾăšer-bô", "traducao_palavra": "que nela" },
        { "hebraico": "וְכָל־הָעֵץ֙", "transliteral": "wəḵol-hāʿēṣ", "traducao_palavra": "e toda árvore" },
        { "hebraico": "אֲשֶׁ֣ר", "transliteral": "ʾăšer", "traducao_palavra": "que" },
        { "hebraico": "בַּשָּׂדֶ֔ה", "transliteral": "baśśāḏeh", "traducao_palavra": "no campo" },
        { "hebraico": "בְּכָל־גְּבֻל֖וֹ", "transliteral": "bəḵāl-gəḇulô", "traducao_palavra": "em todo seu limite" },
        { "hebraico": "סָבִֽיב׃", "transliteral": "sāḇîḇ", "traducao_palavra": "ao redor" }
      ]
    },
    "18": {
      "traducao_completa": "A Abraão por compra, aos olhos dos filhos de Hete, entre todos os que entravam na porta da sua cidade.",
      "palavras": [
        { "hebraico": "לְאַבְרָהָ֥ם", "transliteral": "ləʾaḇrāhām", "traducao_palavra": "a Abraão" },
        { "hebraico": "לְמִקְנָ֖ה", "transliteral": "ləmiqnâ", "traducao_palavra": "por aquisição/compra" },
        { "hebraico": "לְעֵינֵ֣י", "transliteral": "ləʿênê", "traducao_palavra": "aos olhos de" },
        { "hebraico": "בְנֵי־חֵ֑ת", "transliteral": "ḇənê-ḥēṯ", "traducao_palavra": "filhos de Hete" },
        { "hebraico": "בְּכֹ֖ל", "transliteral": "bəḵōl", "traducao_palavra": "em todos" },
        { "hebraico": "בָּאֵ֥י", "transliteral": "bāʾê", "traducao_palavra": "os que entravam" },
        { "hebraico": "שַֽׁעַר־עִירֽוֹ׃", "transliteral": "šaʿar-ʿîrô", "traducao_palavra": "porta de sua cidade" }
      ]
    },
    "19": {
      "traducao_completa": "E depois disso, sepultou Abraão Sara, sua mulher, na caverna do campo de Macpela, diante de Manre, ela [é] Hebrom, na terra de Canaã.",
      "palavras": [
