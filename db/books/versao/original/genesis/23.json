        { "hebraico": "קָבַ֨ר", "transliteral": "qāḇar", "traducao_palavra": "sepultou" },
        { "hebraico": "אַבְרָהָ֜ם", "transliteral": "ʾaḇrāhām", "traducao_palavra": "Abraão" },
        { "hebraico": "אֶת־שָׂרָ֣ה", "transliteral": "ʾeṯ-śārâ", "traducao_palavra": "a Sara" },
