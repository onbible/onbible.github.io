        { "hebraico": "שָׂרָ֔ה", "transliteral": "śārâ", "traducao_palavra": "Sara" },
        { "hebraico": "מֵאָ֥ה", "transliteral": "mēʾâ", "traducao_palavra": "cem" },
        { "hebraico": "שָׁנָ֛ה", "transliteral": "šānâ", "traducao_palavra": "ano" },
