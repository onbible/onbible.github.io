        { "hebraico": "לִסְפֹּ֥ד", "transliteral": "lispōḏ", "traducao_palavra": "para lamentar" },
        { "hebraico": "לְשָׂרָ֖ה", "transliteral": "ləśārâ", "traducao_palavra": "a Sara" },
        { "hebraico": "וְלִבְכֹּתָֽהּ׃", "transliteral": "wəliḇkōṯāh", "traducao_palavra": "e para chorá-la" }
      ]
    },
    "3": {
      "traducao_completa": "E levantou-se Abraão de diante da face de seu morto, e falou aos filhos de Hete, dizendo:",
      "palavras": [
        { "hebraico": "וַיָּ֙קָם֙", "transliteral": "wayyāqom", "traducao_palavra": "e levantou-se" },
        { "hebraico": "אַבְרָהָ֔ם", "transliteral": "ʾaḇrāhām", "traducao_palavra": "Abraão" },
        { "hebraico": "מֵעַ֖ל", "transliteral": "mēʿal", "traducao_palavra": "de sobre" },
        { "hebraico": "פְּנֵ֣י", "transliteral": "pənê", "traducao_palavra": "face de" },
        { "hebraico": "מֵת֑וֹ", "transliteral": "mēṯô", "traducao_palavra": "seu morto" },
        { "hebraico": "וַיְדַבֵּ֥ר", "transliteral": "wayḏabbēr", "traducao_palavra": "e falou" },
        { "hebraico": "אֶל־בְּנֵי־חֵ֖ת", "transliteral": "ʾel-bənê-ḥēṯ", "traducao_palavra": "a filhos de Hete" },
        { "hebraico": "לֵאמֹֽר׃", "transliteral": "lēʾmōr", "traducao_palavra": "dizendo" }
      ]
    },
    "4": {
      "traducao_completa": "Estrangeiro e residente sou eu convosco; dai-me propriedade de sepulcro convosco, e sepultarei meu morto de diante de minha face.",
      "palavras": [
        { "hebraico": "גֵּר־וְתוֹשָׁ֥ב", "transliteral": "gēr-wəṯôšāḇ", "traducao_palavra": "estrangeiro e residente" },
        { "hebraico": "אָנֹכִ֖י", "transliteral": "ʾānōḵî", "traducao_palavra": "eu" },
        { "hebraico": "עִמָּכֶ֑ם", "transliteral": "ʿimmāḵem", "traducao_palavra": "com vós" },
        { "hebraico": "תְּנ֨וּ", "transliteral": "tənû", "traducao_palavra": "dai" },
        { "hebraico": "לִ֤י", "transliteral": "lî", "traducao_palavra": "a mim" },
        { "hebraico": "אֲחֻזַּת־קֶ֙בֶר֙", "transliteral": "ʾăḥuẓẓat-qeḇer", "traducao_palavra": "propriedade de sepulcro" },
        { "hebraico": "עִמָּכֶ֔ם", "transliteral": "ʿimmāḵem", "traducao_palavra": "com vós" },
        { "hebraico": "וְאֶקְבְּרָ֥ה", "transliteral": "wəʾeqbərâ", "traducao_palavra": "e sepultarei" },
        { "hebraico": "מֵתִ֖י", "transliteral": "mēṯî", "traducao_palavra": "meu morto" },
        { "hebraico": "מִלְּפָנָֽי׃", "transliteral": "milləpānāy", "traducao_palavra": "de diante de minha face" }
      ]
    },
    "5": {
      "traducao_completa": "E responderam os filhos de Hete a Abraão, dizendo-lhe:",
      "palavras": [
        { "hebraico": "וַיַּעֲנ֧וּ", "transliteral": "wayyaʿănû", "traducao_palavra": "e responderam" },
        { "hebraico": "בְנֵי־חֵ֛ת", "transliteral": "ḇənê-ḥēṯ", "traducao_palavra": "filhos de Hete" },
        { "hebraico": "אֶת־אַבְרָהָ֖ם", "transliteral": "ʾeṯ-ʾaḇrāhām", "traducao_palavra": "a Abraão" },
        { "hebraico": "לֵאמֹ֥ר", "transliteral": "lēʾmōr", "traducao_palavra": "dizendo" },
        { "hebraico": "לּֽוֹ׃", "transliteral": "lô", "traducao_palavra": "a ele" }
      ]
    },
    "6": {
      "traducao_completa": "Ouve-nos, meu senhor; um príncipe de Deus és tu no nosso meio; no melhor de nossos sepulcros sepulta o teu morto; nenhum de nós seu sepulcro negará a ti, de sepultar teu morto.",
      "palavras": [
        { "hebraico": "שְׁמָעֵ֣נוּ ׀", "transliteral": "šəmāʿēnû", "traducao_palavra": "ouve-nos" },
        { "hebraico": "אֲדֹנִ֗י", "transliteral": "ʾăḏōnî", "traducao_palavra": "meu senhor" },
        { "hebraico": "נְשִׂ֨יא", "transliteral": "nəśîʾ", "traducao_palavra": "príncipe de" },
        { "hebraico": "אֱלֹהִ֤ים", "transliteral": "ʾĕlōhîm", "traducao_palavra": "Deus" },
        { "hebraico": "אַתָּה֙", "transliteral": "ʾattâ", "traducao_palavra": "tu" },
        { "hebraico": "בְּתוֹכֵ֔נוּ", "transliteral": "bəṯôḵēnû", "traducao_palavra": "no nosso meio" },
        { "hebraico": "בְּמִבְחַ֣ר", "transliteral": "bəmiḇḥar", "traducao_palavra": "no escolhido/melhor de" },
        { "hebraico": "קְבָרֵ֔ינוּ", "transliteral": "qəḇārênû", "traducao_palavra": "nossos sepulcros" },
        { "hebraico": "קְבֹ֖ר", "transliteral": "qəḇōr", "traducao_palavra": "sepulta" },
        { "hebraico": "אֶת־מֵתֶ֑ךָ", "transliteral": "ʾeṯ-mēṯeḵā", "traducao_palavra": "o teu morto" },
        { "hebraico": "אִ֣ישׁ", "transliteral": "ʾîš", "traducao_palavra": "homem/ninguém" },
        { "hebraico": "מִמֶּ֔נּוּ", "transliteral": "mimmennû", "traducao_palavra": "de nós" },
        { "hebraico": "אֶת־קִבְר֛וֹ", "transliteral": "ʾeṯ-qiḇrô", "traducao_palavra": "o seu sepulcro" },
