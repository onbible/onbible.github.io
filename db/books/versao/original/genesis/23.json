        { "hebraico": "נְתַתִּ֥יהָ", "transliteral": "nəṯattîhā", "traducao_palavra": "eu a dei" },
        { "hebraico": "לָּ֖ךְ", "transliteral": "lāḵ", "traducao_palavra": "a ti" },
