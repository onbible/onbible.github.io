        { "hebraico": "מִמְּךָ֖", "transliteral": "mimməḵā", "traducao_palavra": "de ti" },
        { "hebraico": "מִקְּבֹ֥ר", "transliteral": "miqqəḇōr", "traducao_palavra": "de sepultar" },
        { "hebraico": "מֵתֶֽךָ׃", "transliteral": "mēṯeḵā", "traducao_palavra": "teu morto" }
      ]
    },
    "7": {
      "traducao_completa": "E levantou-se Abraão e inclinou-se ao povo da terra, aos filhos de Hete.",
      "palavras": [
        { "hebraico": "וַיָּ֧קָם", "transliteral": "wayyāqom", "traducao_palavra": "e levantou-se" },
        { "hebraico": "אַבְרָהָ֛ם", "transliteral": "ʾaḇrāhām", "traducao_palavra": "Abraão" },
        { "hebraico": "וַיִּשְׁתַּ֥חוּ", "transliteral": "wayyištāḥû", "traducao_palavra": "e inclinou-se" },
