        { "hebraico": "בִּקְצֵ֣ה", "transliteral": "biqṣē", "traducao_palavra": "na extremidade de" },
        { "hebraico": "שָׂדֵ֑הוּ", "transliteral": "śāḏēhû", "traducao_palavra": "seu campo" },
        { "hebraico": "בְּכֶ֨סֶף", "transliteral": "bəḵesep̄", "traducao_palavra": "por prata/dinheiro" },
        { "hebraico": "מָלֵ֜א", "transliteral": "mālēʾ", "traducao_palavra": "cheio/total" },
        { "hebraico": "יִתְּנֶ֥נָּה", "transliteral": "yittənennâ", "traducao_palavra": "ele a dará" },
        { "hebraico": "לִּ֛י", "transliteral": "lî", "traducao_palavra": "a mim" },
        { "hebraico": "בְּתוֹכְכֶ֖ם", "transliteral": "bəṯôḵəḵem", "traducao_palavra": "no vosso meio" },
        { "hebraico": "לַאֲחֻזַּת־קָֽבֶר׃", "transliteral": "laʾăḥuẓẓat-qāḇer", "traducao_palavra": "para propriedade de sepulcro" }
