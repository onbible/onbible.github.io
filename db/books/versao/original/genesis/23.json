        { "hebraico": "אֶל־מְעָרַ֞ת", "transliteral": "ʾel-məʿāraṯ", "traducao_palavra": "na caverna de" },
        { "hebraico": "שְׂדֵ֧ה", "transliteral": "śəḏē", "traducao_palavra": "campo de" },
        { "hebraico": "הַמַּכְפֵּלָ֛ה", "transliteral": "hammāḵpēlâ", "traducao_palavra": "Macpela" },
        { "hebraico": "עַל־פְּנֵ֥י", "transliteral": "ʿal-pənê", "traducao_palavra": "diante de" },
        { "hebraico": "מַמְרֵ֖א", "transliteral": "mamrē", "traducao_palavra": "Manre" },
        { "hebraico": "הִ֣וא", "transliteral": "hîʾ", "traducao_palavra": "ela" },
        { "hebraico": "חֶבְר֑וֹן", "transliteral": "ḥeḇrôn", "traducao_palavra": "Hebrom" },
        { "hebraico": "בְּאֶ֖רֶץ", "transliteral": "bəʾereṣ", "traducao_palavra": "na terra de" },
