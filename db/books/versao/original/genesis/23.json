        { "hebraico": "שָׁנָ֖ה", "transliteral": "šānâ", "traducao_palavra": "ano" },
        { "hebraico": "וְשֶׁ֣בַע", "transliteral": "wəšebaʿ", "traducao_palavra": "e sete" },
        { "hebraico": "שָׁנִ֑ים", "transliteral": "šānîm", "traducao_palavra": "anos" },
        { "hebraico": "שְׁנֵ֖י", "transliteral": "šənê", "traducao_palavra": "anos de" },
        { "hebraico": "חַיֵּ֥י", "transliteral": "ḥayyê", "traducao_palavra": "vida de" },
        { "hebraico": "שָׂרָֽה׃", "transliteral": "śārâ", "traducao_palavra": "Sara" }
      ]
    },
    "2": {
      "traducao_completa": "E morreu Sara em Quiriate-Arba, ela [é] Hebrom, na terra de Canaã; e veio Abraão para lamentar Sara e para chorá-la.",
      "palavras": [
        { "hebraico": "וַתָּ֣מָת", "transliteral": "wattāmoṯ", "traducao_palavra": "e morreu" },
        { "hebraico": "שָׂרָה", "transliteral": "śārâ", "traducao_palavra": "Sara" },
        { "hebraico": "בְּקִרְיַ֣ת", "transliteral": "bəqiryat", "traducao_palavra": "em cidade de" },
        { "hebraico": "אַרְבַּ֔ע", "transliteral": "ʾarbaʿ", "traducao_palavra": "Arba" },
        { "hebraico": "הִ֥וא", "transliteral": "hîʾ", "traducao_palavra": "ela" },
        { "hebraico": "חֶבְר֖וֹן", "transliteral": "ḥeḇrôn", "traducao_palavra": "Hebrom" },
        { "hebraico": "בְּאֶ֣רֶץ", "transliteral": "bəʾereṣ", "traducao_palavra": "na terra de" },
        { "hebraico": "כְּנָ֑עַן", "transliteral": "kənāʿan", "traducao_palavra": "Canaã" },
