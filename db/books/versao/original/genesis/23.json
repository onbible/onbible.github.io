    "10": {
      "traducao_completa": "E Efrom estava sentado no meio dos filhos de Hete; e respondeu Efrom, o hitita, a Abraão aos ouvidos dos filhos de Hete, para todos os que entravam na porta da sua cidade, dizendo:",
      "palavras": [
        { "hebraico": "וְעֶפְר֥וֹן", "transliteral": "wəʿep̄rôn", "traducao_palavra": "e Efrom" },
        { "hebraico": "יֹשֵׁ֖ב", "transliteral": "yōšēḇ", "traducao_palavra": "estava sentado" },
        { "hebraico": "בְּת֣וֹךְ", "transliteral": "bəṯôḵ", "traducao_palavra": "no meio de" },
        { "hebraico": "בְּנֵי־חֵ֑ת", "transliteral": "bənê-ḥēṯ", "traducao_palavra": "filhos de Hete" },
        { "hebraico": "וַיַּעַן֩", "transliteral": "wayyaʿan", "traducao_palavra": "e respondeu" },
        { "hebraico": "עֶפְר֨וֹן", "transliteral": "ʿep̄rôn", "traducao_palavra": "Efrom" },
        { "hebraico": "הַחִתִּ֨י", "transliteral": "haḥittî", "traducao_palavra": "o hitita" },
        { "hebraico": "אֶת־אַבְרָהָ֜ם", "transliteral": "ʾeṯ-ʾaḇrāhām", "traducao_palavra": "a Abraão" },
        { "hebraico": "בְּאָזְנֵ֥י", "transliteral": "bəʾāznê", "traducao_palavra": "nos ouvidos de" },
        { "hebraico": "בְנֵי־חֵ֛ת", "transliteral": "ḇənê-ḥēṯ", "traducao_palavra": "filhos de Hete" },
        { "hebraico": "לְכֹ֛ל", "transliteral": "ləḵōl", "traducao_palavra": "para todos" },
        { "hebraico": "בָּאֵ֥י", "transliteral": "bāʾê", "traducao_palavra": "os que entravam" },
        { "hebraico": "שַֽׁעַר־עִיר֖וֹ", "transliteral": "šaʿar-ʿîrô", "traducao_palavra": "porta de sua cidade" },
        { "hebraico": "לֵאמֹֽר׃", "transliteral": "lēʾmōr", "traducao_palavra": "dizendo" }
      ]
    },
    "11": {
      "traducao_completa": "Não, meu senhor, ouve-me; o campo eu te dou, e a caverna que nele [está], a ti eu a dou; aos olhos dos filhos do meu povo eu a dou a ti; sepulta teu morto.",
      "palavras": [
        { "hebraico": "לֹֽא־אֲדֹנִ֣י", "transliteral": "lōʾ-ʾăḏōnî", "traducao_palavra": "não meu senhor" },
        { "hebraico": "שְׁמָעֵ֔נוּ", "transliteral": "šəmāʿēnû", "traducao_palavra": "ouve-me" },
        { "hebraico": "הַשָּׂדֶה֙", "transliteral": "haśśāḏeh", "traducao_palavra": "o campo" },
        { "hebraico": "נָתַ֣תִּי", "transliteral": "nāṯattî", "traducao_palavra": "eu dei" },
        { "hebraico": "לָ֔ךְ", "transliteral": "lāḵ", "traducao_palavra": "a ti" },
        { "hebraico": "וְהַמְּעָרָ֥ה", "transliteral": "wəhamməʿārâ", "traducao_palavra": "e a caverna" },
        { "hebraico": "אֲשֶׁר־בּ֖וֹ", "transliteral": "ʾăšer-bô", "traducao_palavra": "que nela" },
        { "hebraico": "לְךָ֣", "transliteral": "ləḵā", "traducao_palavra": "a ti" },
        { "hebraico": "נְתַתִּ֑יהָ", "transliteral": "nəṯattîhā", "traducao_palavra": "eu a dei" },
        { "hebraico": "לְעֵינֵ֧י", "transliteral": "ləʿênê", "traducao_palavra": "aos olhos de" },
