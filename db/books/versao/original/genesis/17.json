        { "hebraico": "אֵלָ֑יו", "transliteral": "ʾēlāyw", "traducao_palavra": "a ele" },
        { "hebraico": "אֲנִי־אֵ֣ל", "transliteral": "ʾănî-ʾēl", "traducao_palavra": "Eu [sou] Deus" },
        { "hebraico": "שַׁדַּ֔י", "transliteral": "šadday", "traducao_palavra": "Todo-Poderoso" },
        { "hebraico": "הִתְהַלֵּ֥ךְ", "transliteral": "hiṯhallēḵ", "traducao_palavra": "anda" },
