        { "hebraico": "וַהֲקִמֹתִ֨י", "transliteral": "wahăqimōṯî", "traducao_palavra": "e estabelecerei" },
        { "hebraico": "אֶת־בְּרִיתִ֧י", "transliteral": "ʾeṯ-bərîṯî", "traducao_palavra": "minha aliança" },
