        { "hebraico": "עוֹלָֽם׃", "transliteral": "ʿôlām", "traducao_palavra": "eterna" }
      ]
    },
    "14": {
      "traducao_completa": "E o macho incircunciso, cuja carne do prepúcio não for circuncidada, aquela alma será extirpada do seu povo; quebrou a minha aliança.",
