        { "hebraico": "אַבְרָהָ֛ם", "transliteral": "ʾaḇrāhām", "traducao_palavra": "Abraão" },
        { "hebraico": "עַל־פָּנָ֖יו", "transliteral": "ʿal-pānāyw", "traducao_palavra": "sobre seu rosto" },
        { "hebraico": "וַיִּצְחָ֑ק", "transliteral": "wayyiṣḥāq", "traducao_palavra": "e riu" },
        { "hebraico": "וַיֹּ֣אמֶer", "transliteral": "wayyōʾmer", "traducao_palavra": "e disse" },
