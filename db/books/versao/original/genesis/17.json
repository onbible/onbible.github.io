        { "hebraico": "אֶת־בְּרִיתִ֖י", "transliteral": "ʾeṯ-bərîṯî", "traducao_palavra": "[obj] minha aliança" },
        { "hebraico": "הֵפַֽר׃", "transliteral": "hēp̱ar", "traducao_palavra": "quebrou" }
