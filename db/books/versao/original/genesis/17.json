  "versiculos": {
    "1": {
      "traducao_completa": "E era Abrão da idade de noventa e nove anos, quando apareceu o SENHOR a Abrão e disse-lhe: Eu sou o Deus Todo-Poderoso; anda na minha presença e sê perfeito.",
      "palavras": [
        { "hebraico": "וַיְהִ֣י", "transliteral": "wayəhî", "traducao_palavra": "E foi/era" },
        { "hebraico": "אַבְרָ֗ם", "transliteral": "ʾaḇrām", "traducao_palavra": "Abrão" },
        { "hebraico": "בֶּן־תִּשְׁעִ֤ים", "transliteral": "ben-tišʿîm", "traducao_palavra": "filho de noventa" },
        { "hebraico": "שָׁנָה֙", "transliteral": "šānâ", "traducao_palavra": "ano" },
        { "hebraico": "וְתֵ֣שַׁע", "transliteral": "wəṯēšaʿ", "traducao_palavra": "e nove" },
        { "hebraico": "שָׁנִ֔ים", "transliteral": "šānîm", "traducao_palavra": "anos" },
        { "hebraico": "וַיֵּרָ֧א", "transliteral": "wayyērāʾ", "traducao_palavra": "e apareceu" },
