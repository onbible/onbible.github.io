        { "hebraico": "מְאֹ֑ד", "transliteral": "məʾōḏ", "traducao_palavra": "muito" },
        { "hebraico": "שְׁנֵים־עָשָׂ֤ר", "transliteral": "šənêm-ʿāśār", "traducao_palavra": "doze" },
        { "hebraico": "נְשִׂיאִם֙", "transliteral": "nəśîʾim", "traducao_palavra": "príncipes" },
