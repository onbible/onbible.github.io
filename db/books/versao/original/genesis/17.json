    "6": {
      "traducao_completa": "E te farei frutificar grandissimamente, e de ti farei nações, e reis sairão de ti.",
      "palavras": [
        { "hebraico": "וְהִפְרֵתִ֤י", "transliteral": "wəhip̱rēṯî", "traducao_palavra": "E farei frutificar" },
