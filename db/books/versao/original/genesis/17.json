        { "hebraico": "עֹ֥וד", "transliteral": "ʿôḏ", "traducao_palavra": "mais" },
        { "hebraico": "אֶת־שִׁמְךָ֖", "transliteral": "ʾeṯ-šiməḵā", "traducao_palavra": "[obj] teu nome" },
