        { "hebraico": "וֶהְיֵ֥ה", "transliteral": "wehəyēh", "traducao_palavra": "e sê" },
        { "hebraico": "תָמִֽים׃", "transliteral": "ṯāmîm", "traducao_palavra": "íntegro" }
      ]
    },
    "2": {
      "traducao_completa": "E porei a minha aliança entre mim e ti, e te multiplicarei grandissimamente.",
      "palavras": [
        { "hebraico": "וְאֶתְּנָ֥ה", "transliteral": "wəʾettenâ", "traducao_palavra": "E porei" },
        { "hebraico": "בְרִיתִ֖י", "transliteral": "ḇərîṯî", "traducao_palavra": "minha aliança" },
        { "hebraico": "בֵּינִ֣י", "transliteral": "bênî", "traducao_palavra": "entre mim" },
        { "hebraico": "וּבֵינֶ֑ךָ", "transliteral": "ûḇêneqā", "traducao_palavra": "e entre ti" },
