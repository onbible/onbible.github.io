        { "hebraico": "עַל־שְׂפַ֣ת", "transliteral": "ʿal-śəp̱aṯ", "traducao_palavra": "sobre o lábio/praia de" },
        { "hebraico": "הַיָּ֑ם", "transliteral": "hayyām", "traducao_palavra": "o mar" },
        { "hebraico": "וְיִרַ֣שׁ", "transliteral": "wəyiraš", "traducao_palavra": "e herdará/possuirá" },
        { "hebraico": "זַרְעֲךָ֔", "transliteral": "zarʿăḵā", "traducao_palavra": "tua semente" },
        { "hebraico": "אֵ֖ת שַׁ֥עַר", "transliteral": "ʾeṯ šaʿar", "traducao_palavra": "[obj] a porta de" },
