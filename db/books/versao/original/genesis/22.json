        { "hebraico": "יֵרָאֶֽה׃", "transliteral": "yērāʾeh", "traducao_palavra": "será visto/provido" }
      ]
    },
    "15": {
      "traducao_completa": "E o anjo do SENHOR chamou a Abraão pela segunda vez desde os céus,",
      "palavras": [
