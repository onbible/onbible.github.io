        { "hebraico": "וַיֵּ֤לֶךְ", "transliteral": "wayyēleḵ", "traducao_palavra": "e foi" },
        { "hebraico": "אַבְרָהָם֙", "transliteral": "ʾaḇrāhām", "traducao_palavra": "Abraão" },
        { "hebraico": "וַיִּקַּ֣ח", "transliteral": "wayyiqqaḥ", "traducao_palavra": "e tomou" },
