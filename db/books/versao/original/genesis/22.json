        { "hebraico": "אַבְרָהָם֙", "transliteral": "ʾaḇrāhām", "traducao_palavra": "Abraão" },
        { "hebraico": "אֶל־נְעָרָ֔יו", "transliteral": "ʾel-nəʿārāyw", "traducao_palavra": "a seus jovens" },
        { "hebraico": "וַיָּקֻ֥מוּ", "transliteral": "wayyāqumû", "traducao_palavra": "e levantaram-se" },
        { "hebraico": "וַיֵּלְכ֥וּ", "transliteral": "wayyēləḵû", "traducao_palavra": "e foram" },
        { "hebraico": "יַחְדָּ֖ו", "transliteral": "yaḥdāw", "traducao_palavra": "juntos" },
        { "hebraico": "אֶל־בְּאֵ֣ר שָׁ֑בַע", "transliteral": "ʾel-bəʾēr šāḇaʿ", "traducao_palavra": "para Berseba" },
        { "hebraico": "וַיֵּ֥שֶׁב", "transliteral": "wayyēšeḇ", "traducao_palavra": "e habitou" },
        { "hebraico": "אַבְרָהָ֖ם", "transliteral": "ʾaḇrāhām", "traducao_palavra": "Abraão" },
        { "hebraico": "בְּאֵ֥ר שָֽׁבַע׃", "transliteral": "bəʾēr šāḇaʿ", "traducao_palavra": "em Berseba" }
      ]
    },
    "20": {
      "traducao_completa": "E sucedeu, depois destas coisas, que anunciaram a Abraão, dizendo: Eis que também Milca deu à luz filhos a Naor teu irmão:",
