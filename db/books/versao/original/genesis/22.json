        { "hebraico": "ואֶת־חֲזֹ֔ו", "transliteral": "wəʾeṯ-ḥăzô", "traducao_palavra": "e [obj] Hazo" },
        { "hebraico": "וְאֶת־פִּלְדָּ֖שׁ", "transliteral": "wəʾeṯ-pildāš", "traducao_palavra": "e [obj] Pildas" },
        { "hebraico": "וְאֶת־יִדְלָ֑ף", "transliteral": "wəʾeṯ-yiḏlāp̱", "traducao_palavra": "e [obj] Jidlafe" },
        { "hebraico": "וְאֶת־בְּתוּאֵֽל׃", "transliteral": "wəʾeṯ-bəṯûʾēl", "traducao_palavra": "e [obj] Betuel" }
