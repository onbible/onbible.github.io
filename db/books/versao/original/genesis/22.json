        { "hebraico": "וַיֹּ֖אמֶר", "transliteral": "wayyōʾmer", "traducao_palavra": "e ele disse" },
        { "hebraico": "הִנֵּֽנִי׃", "transliteral": "hinnēnî", "traducao_palavra": "Eis-me aqui" }
      ]
    },
    "12": {
      "traducao_completa": "E disse: Não estendas a tua mão sobre o moço, e não lhe faças nada; porquanto agora sei que temes a Deus, e não me negaste o teu filho, o teu único.",
      "palavras": [
        { "hebraico": "וַיֹּ֗אמֶר", "transliteral": "wayyōʾmer", "traducao_palavra": "E disse" },
        { "hebraico": "אַל־תִּשְׁלַ֤ח", "transliteral": "ʾal-tišlaḥ", "traducao_palavra": "Não estendas" },
        { "hebraico": "יָדְךָ֙", "transliteral": "yāḏəḵā", "traducao_palavra": "tua mão" },
        { "hebraico": "אֶל־הַנַּ֔עַר", "transliteral": "ʾel-hannaʿar", "traducao_palavra": "para o moço" },
        { "hebraico": "וְאַל־תַּ֥עַשׂ", "transliteral": "wəʾal-taʿaś", "traducao_palavra": "e não faças" },
        { "hebraico": "לֹ֖ו", "transliteral": "lô", "traducao_palavra": "lhe" },
        { "hebraico": "מְא֑וּמָה", "transliteral": "məʾûmâ", "traducao_palavra": "alguma coisa" },
        { "hebraico": "כִּ֣י ׀", "transliteral": "kî", "traducao_palavra": "porque" },
        { "hebraico": "עַתָּ֣ה", "transliteral": "ʿattâ", "traducao_palavra": "agora" },
        { "hebraico": "יָדַ֗עְתִּי", "transliteral": "yāḏaʿtî", "traducao_palavra": "sei" },
        { "hebraico": "כִּֽי־יְרֵ֤א", "transliteral": "kî-yərēʾ", "traducao_palavra": "que temente a" },
        { "hebraico": "אֱלֹהִים֙", "transliteral": "ʾĕlōhîm", "traducao_palavra": "Deus" },
        { "hebraico": "אָ֔תָּה", "transliteral": "ʾāttâ", "traducao_palavra": "[és] tu" },
        { "hebraico": "וְלֹ֥א", "transliteral": "wəlōʾ", "traducao_palavra": "e não" },
