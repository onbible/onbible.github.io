        { "hebraico": "אַבְרָהָם֙", "transliteral": "ʾaḇrāhām", "traducao_palavra": "Abraão" },
        { "hebraico": "אֶת־יָדֹ֔ו", "transliteral": "ʾeṯ-yāḏô", "traducao_palavra": "[obj] sua mão" },
        { "hebraico": "וַיִּקַּ֖ח", "transliteral": "wayyiqqaḥ", "traducao_palavra": "e tomou" },
