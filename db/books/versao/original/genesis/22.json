        { "hebraico": "אֵלָ֔יו", "transliteral": "ʾēlāyw", "traducao_palavra": "a ele" },
        { "hebraico": "אַבְרָהָ֖ם", "transliteral": "ʾaḇrāhām", "traducao_palavra": "Abraão" },
        { "hebraico": "וַיֹּ֥אמֶר", "transliteral": "wayyōʾmer", "traducao_palavra": "e ele disse" },
        { "hebraico": "הִנֵּֽנִי׃", "transliteral": "hinnēnî", "traducao_palavra": "Eis-me aqui" }
