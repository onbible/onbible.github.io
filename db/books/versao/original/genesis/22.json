        { "hebraico": "גַם־הִ֛יא", "transliteral": "gam-hî", "traducao_palavra": "também ela" },
        { "hebraico": "בָּנִ֖ים", "transliteral": "bānîm", "traducao_palavra": "filhos" },
        { "hebraico": "לְנָחֹ֥ור", "transliteral": "lənāḥôr", "traducao_palavra": "para Naor" },
        { "hebraico": "אָחִֽיךָ׃", "transliteral": "ʾāḥîḵā", "traducao_palavra": "teu irmão" }
