        { "hebraico": "אֶת־יְחִידְךָ֖", "transliteral": "ʾeṯ-yəḥîḏəḵā", "traducao_palavra": "[obj] teu único" },
        { "hebraico": "מִמֶּֽנִּי׃", "transliteral": "mimmēnnî", "traducao_palavra": "de mim" }
      ]
    },
    "13": {
      "traducao_completa": "Então levantou Abraão os seus olhos e olhou; e eis um carneiro detrás dele, travado pelos seus chifres num matagal; e foi Abraão, e tomou o carneiro, e ofereceu-o em holocausto, em lugar de seu filho.",
