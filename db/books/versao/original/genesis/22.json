      ]
    },
    "18": {
      "traducao_completa": "E em tua semente serão benditas todas as nações da terra; porquanto obedeceste à minha voz.",
      "palavras": [
        { "hebraico": "וְהִתְבָּרֲכ֣וּ", "transliteral": "wəhiṯbbārăḵû", "traducao_palavra": "E bendirão a si mesmas" },
        { "hebraico": "בְזַרְעֲךָ֔", "transliteral": "ḇəzarʿăḵā", "traducao_palavra": "em tua semente" },
        { "hebraico": "כֹּ֖ל", "transliteral": "kōl", "traducao_palavra": "todas" },
        { "hebraico": "גֹּויֵ֣י", "transliteral": "gôyê", "traducao_palavra": "as nações de" },
        { "hebraico": "הָאָ֑רֶץ", "transliteral": "hāʾāreṣ", "traducao_palavra": "a terra" },
        { "hebraico": "עֵ֕קֶב", "transliteral": "ʿēqeḇ", "traducao_palavra": "consequência de" },
        { "hebraico": "אֲשֶׁ֥ר", "transliteral": "ʾăšer", "traducao_palavra": "que" },
        { "hebraico": "שָׁמַ֖עְתָּ", "transliteral": "šāmaʿttā", "traducao_palavra": "ouviste/obedeceste" },
