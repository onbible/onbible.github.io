        { "hebraico": "וַיְהִ֗י", "transliteral": "wayəhî", "traducao_palavra": "E foi/aconteceu" },
        { "hebraico": "אַחֲרֵי֙", "transliteral": "ʾaḥărê", "traducao_palavra": "depois de" },
        { "hebraico": "הַדְּבָרִ֣ים", "transliteral": "haddəḇārîm", "traducao_palavra": "as coisas" },
        { "hebraico": "הָאֵ֔לֶּה", "transliteral": "hāʾēlleh", "traducao_palavra": "estas" },
        { "hebraico": "וַיֻּגַּ֥ד", "transliteral": "wayyuggaḏ", "traducao_palavra": "e foi contado" },
        { "hebraico": "לְאַבְרָהָ֖ם", "transliteral": "ləʾaḇrāhām", "traducao_palavra": "a Abraão" },
        { "hebraico": "לֵאמֹ֑ר", "transliteral": "lēʾmōr", "traducao_palavra": "dizendo" },
        { "hebraico": "הִ֠נֵּה", "transliteral": "hinnēh", "traducao_palavra": "Eis" },
        { "hebraico": "יָלְדָ֨ה", "transliteral": "yāləḏâ", "traducao_palavra": "gerou" },
