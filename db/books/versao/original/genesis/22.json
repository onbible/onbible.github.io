        { "hebraico": "וַיַּעֲלֵ֥הוּ", "transliteral": "wayyaʿălēhû", "traducao_palavra": "e ofereceu-o" },
        { "hebraico": "לְעֹלָ֖ה", "transliteral": "ləʿōlâ", "traducao_palavra": "em holocausto" },
        { "hebraico": "תַּ֥חַת", "transliteral": "taḥaṯ", "traducao_palavra": "em lugar de" },
        { "hebraico": "בְּנֹֽו׃", "transliteral": "bənô", "traducao_palavra": "seu filho" }
      ]
    },
    "14": {
      "traducao_completa": "E chamou Abraão o nome daquele lugar: O SENHOR proverá; donde se diz até ao dia de hoje: No monte do SENHOR se proverá.",
