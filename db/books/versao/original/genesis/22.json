        { "hebraico": "מַלְאַךְ", "transliteral": "malʾaḵ", "traducao_palavra": "o anjo de" },
        { "hebraico": "יְהוָה֙", "transliteral": "YHWH", "traducao_palavra": "YHWH" },
        { "hebraico": "מִן־הַשָּׁמַ֔יִם", "transliteral": "min-haššāmayim", "traducao_palavra": "dos céus" },
        { "hebraico": "וַי  ֹּ֖אמֶר", "transliteral": "wayyōʾmer", "traducao_palavra": "e disse" },
        { "hebraico": "אַבְרָהָ֣ם ׀", "transliteral": "ʾaḇrāhām", "traducao_palavra": "Abraão" },
