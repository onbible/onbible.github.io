        { "hebraico": "הַזֶּ֔ה", "transliteral": "hazzeh", "traducao_palavra": "esta" },
        { "hebraico": "וְלֹ֥א", "transliteral": "wəlōʾ", "traducao_palavra": "e não" },
        { "hebraico": "חָשַׂ֖כְתָּ", "transliteral": "ḥāśaḵttā", "traducao_palavra": "negaste" },
        { "hebraico": "אֶת־בִּנְךָ֥", "transliteral": "ʾeṯ-binəḵā", "traducao_palavra": "[obj] teu filho" },
        { "hebraico": "אֶת־יְחִידֶֽךָ׃", "transliteral": "ʾeṯ-yəḥîḏeḵā", "traducao_palavra": "[obj] teu único" }
      ]
    },
    "17": {
      "traducao_completa": "que deveras te abençoarei, e grandissimamente multiplicarei a tua semente como as estrelas dos céus, e como a areia que está na praia do mar; e a tua semente possuirá a porta dos seus inimigos;",
      "palavras": [
        { "hebraico": "כִּֽי־בָרֵ֣ךְ", "transliteral": "kî-ḇārēḵ", "traducao_palavra": "que abençoando" },
        { "hebraico": "אֲבָרֶכְךָ֗", "transliteral": "ʾăḇāreḵəḵā", "traducao_palavra": "abençoar-te-ei" },
        { "hebraico": "וְהַרְבָּ֨ה", "transliteral": "wəharbbâ", "traducao_palavra": "e multiplicando" },
        { "hebraico": "אַרְבֶּ֤ה", "transliteral": "ʾarbbeh", "traducao_palavra": "multiplicarei" },
