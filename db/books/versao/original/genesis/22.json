        { "hebraico": "וַיִּשָּׂ֨א", "transliteral": "wayyiśśāʾ", "traducao_palavra": "E levantou" },
        { "hebraico": "אַבְרָהָ֤ם", "transliteral": "ʾaḇrāhām", "traducao_palavra": "Abraão" },
        { "hebraico": "אֶת־עֵינָיו֙", "transliteral": "ʾeṯ-ʿêneyāyw", "traducao_palavra": "[obj] seus olhos" },
