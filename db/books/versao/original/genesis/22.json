    "24": {
      "traducao_completa": "E a sua concubina, cujo nome era Reumá, ela também deu à luz a Teba, a Gaã, a Taás e a Maaca.",
      "palavras": [
        { "hebraico": "וּפִֽילַגְשֹׁ֖ו", "transliteral": "ûp̱îlaḡšô", "traducao_palavra": "E sua concubina" },
