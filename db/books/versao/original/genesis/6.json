        { "hebraico": "יְהוָ֔ה", "transliteral": "YHWH", "traducao_palavra": "YHWH" },
        { "hebraico": "כִּ֥י", "transliteral": "kî", "traducao_palavra": "que" },
        { "hebraico": "רַבָּ֛ה", "transliteral": "rabbâ", "traducao_palavra": "grande [era]" },
        { "hebraico": "רָעַ֥ת", "transliteral": "rāʿaṯ", "traducao_palavra": "a maldade de" },
