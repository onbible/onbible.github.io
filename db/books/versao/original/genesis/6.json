        { "hebraico": "כָּל־בָּשָׂ֛ר", "transliteral": "kāl-bāśār", "traducao_palavra": "toda carne" },
        { "hebraico": "אֶת־דַּרְכֹּ֖ו", "transliteral": "ʾeṯ-darḵô", "traducao_palavra": "[obj] seu caminho" },
        { "hebraico": "עַל־הָאָֽרֶץ׃", "transliteral": "ʿal-hāʾāreṣ", "traducao_palavra": "sobre a terra" }
      ]
    },
    "13": {
      "traducao_completa": "Então disse Deus a Noé: O fim de toda a carne é chegado perante mim; porque a terra está cheia de violência por causa deles; e eis que os destruirei com a terra.",
      "palavras": [
        { "hebraico": "וַיֹּ֨אמֶר", "transliteral": "wayyōʾmer", "traducao_palavra": "E disse" },
        { "hebraico": "אֱלֹהִ֜ים", "transliteral": "ʾĕlōhîm", "traducao_palavra": "Deus" },
        { "hebraico": "לְנֹ֗חַ", "transliteral": "lənōḥa", "traducao_palavra": "a Noé" },
        { "hebraico": "קֵ֤ץ", "transliteral": "qēṣ", "traducao_palavra": "O fim de" },
        { "hebraico": "כָּל־בָּשָׂר֙", "transliteral": "kāl-bāśār", "traducao_palavra": "toda carne" },
        { "hebraico": "בָּ֣א", "transliteral": "bāʾ", "traducao_palavra": "chegou" },
        { "hebraico": "לְפָנַ֔י", "transliteral": "ləp̱ānay", "traducao_palavra": "perante mim" },
        { "hebraico": "כִּֽי־מָלְאָ֥ה", "transliteral": "kî-māləʾâ", "traducao_palavra": "porque encheu-se" },
        { "hebraico": "הָאָ֛רֶץ", "transliteral": "hāʾāreṣ", "traducao_palavra": "a terra" },
        { "hebraico": "חָמָ֖ס", "transliteral": "ḥāmās", "traducao_palavra": "violência" },
        { "hebraico": "מִפְּנֵיהֶ֑ם", "transliteral": "mippənêhem", "traducao_palavra": "por causa deles" },
        { "hebraico": "וְהִנְנִ֥י", "transliteral": "wəhinnənî", "traducao_palavra": "e eis que eu" },
        { "hebraico": "מַשְׁחִיתָ֖ם", "transliteral": "mašḥîṯām", "traducao_palavra": "destruirei os" },
        { "hebraico": "אֶת־הָאָֽרֶץ׃", "transliteral": "ʾeṯ-hāʾāreṣ", "traducao_palavra": "com a terra" }
      ]
    },
    "14": {
      "traducao_completa": "Faze para ti uma arca da madeira de gofer; farás compartimentos na arca e a betumarás por dentro e por fora com betume.",
      "palavras": [
        { "hebraico": "עֲשֵׂ֤ה", "transliteral": "ʿăśēh", "traducao_palavra": "Faze" },
        { "hebraico": "לְךָ֙", "transliteral": "ləḵā", "traducao_palavra": "para ti" },
        { "hebraico": "תֵּבַ֣ת", "transliteral": "tēḇaṯ", "traducao_palavra": "uma arca de" },
        { "hebraico": "עֲצֵי־גֹ֔פֶר", "transliteral": "ʿăṣê-ḡōp̱er", "traducao_palavra": "madeiras de gofer" },
        { "hebraico": "קִנִּ֖ים", "transliteral": "qinnîm", "traducao_palavra": "ninhos/compartimentos" },
        { "hebraico": "תַּעֲשֶׂ֣ה", "transliteral": "taʿăśeh", "traducao_palavra": "farás" },
        { "hebraico": "אֶת־הַתֵּבָ֑ה", "transliteral": "ʾeṯ-hattēḇâ", "traducao_palavra": "[obj] a arca" },
        { "hebraico": "וְכָפַרְתָּ֥", "transliteral": "wəḵāp̱artā", "traducao_palavra": "e cobrirás/betumarás" },
        { "hebraico": "אֹתָ֛הּ", "transliteral": "ʾōṯāh", "traducao_palavra": "ela" },
        { "hebraico": "מִבַּ֥יִת", "transliteral": "mibbayiṯ", "traducao_palavra": "de dentro" },
        { "hebraico": "וּמִח֖וּץ", "transliteral": "ûmiḥûṣ", "traducao_palavra": "e de fora" },
        { "hebraico": "בַּכֹּֽפֶר׃", "transliteral": "bak-kōp̱er", "traducao_palavra": "com o betume" }
      ]
    },
    "15": {
      "traducao_completa": "E desta maneira a farás: De trezentos côvados o comprimento da arca, e de cinquenta côvados a sua largura, e de trinta côvados a sua altura.",
      "palavras": [
        { "hebraico": "וְזֶ֕ה", "transliteral": "wəzeh", "traducao_palavra": "E assim" },
        { "hebraico": "אֲשֶׁ֥ר", "transliteral": "ʾăšer", "traducao_palavra": "que" },
        { "hebraico": "תַּעֲשֶׂ֖ה", "transliteral": "taʿăśeh", "traducao_palavra": "farás" },
        { "hebraico": "אֹתָ֑הּ", "transliteral": "ʾōṯāh", "traducao_palavra": "ela" },
        { "hebraico": "שְׁלֹ֧שׁ", "transliteral": "šəlōš", "traducao_palavra": "três" },
        { "hebraico": "מֵאֹ֣ות", "transliteral": "mēʾōṯ", "traducao_palavra": "centenas" },
        { "hebraico": "אַמָּה֮", "transliteral": "ʾammâ", "traducao_palavra": "côvado" },
        { "hebraico": "אֹ֣רֶךְ", "transliteral": "ʾōreḵ", "traducao_palavra": "o comprimento de" },
        { "hebraico": "הַתֵּבָה֒", "transliteral": "hattēḇâ", "traducao_palavra": "a arca" },
        { "hebraico": "חֲמִשִּׁ֤ים", "transliteral": "ḥămiššîm", "traducao_palavra": "cinquenta" },
        { "hebraico": "אַמָּה֙", "transliteral": "ʾammâ", "traducao_palavra": "côvado" },
        { "hebraico": "רָחְבָּ֔הּ", "transliteral": "rāḥəbāh", "traducao_palavra": "sua largura" },
        { "hebraico": "וּשְׁלֹשִׁ֥ים", "transliteral": "ûšəlōšîm", "traducao_palavra": "e trinta" },
        { "hebraico": "אַמָּה֙", "transliteral": "ʾammâ", "traducao_palavra": "côvado" },
        { "hebraico": "קֹומָתָֽהּ׃", "transliteral": "qômāṯāh", "traducao_palavra": "sua altura" }
      ]
    },
    "16": {
      "traducao_completa": "Farás na arca uma janela, e de um côvado a finalizarás em cima; e a porta da arca porás ao seu lado; farás nela andares baixos, segundos e terceiros.",
      "palavras": [
        { "hebraico": "צֹ֣הַר", "transliteral": "ṣōhar", "traducao_palavra": "Luz/janela" },
        { "hebraico": "תַּעֲשֶׂ֣ה", "transliteral": "taʿăśeh", "traducao_palavra": "farás" },
        { "hebraico": "לַתֵּבָ֗ה", "transliteral": "lattēḇâ", "traducao_palavra": "para a arca" },
        { "hebraico": "וְאֶל־אַמָּה֙", "transliteral": "wəʾel-ʾammâ", "traducao_palavra": "e para um côvado" },
        { "hebraico": "תְּכַלֶּ֣נָּה", "transliteral": "ṯəḵallennâ", "traducao_palavra": "acabarás ela" },
        { "hebraico": "מִלְמַ֔עְלָה", "transliteral": "milmaʿlâ", "traducao_palavra": "de cima" },
        { "hebraico": "וּפֶ֥תַח", "transliteral": "ûp̱eṯaḥ", "traducao_palavra": "e a porta de" },
        { "hebraico": "הַתֵּבָ֖ה", "transliteral": "hattēḇâ", "traducao_palavra": "a arca" },
        { "hebraico": "בְּצִדָּ֣הּ", "transliteral": "bəṣiddāh", "traducao_palavra": "em seu lado" },
        { "hebraico": "תָּשִׂ֑ים", "transliteral": "ṯāśîm", "traducao_palavra": "porás" },
        { "hebraico": "תַּחְתִּיִּ֛ם", "transliteral": "ṯaḥtiyyîm", "traducao_palavra": "[andares] inferiores" },
        { "hebraico": "שְׁנִיִּ֥ם", "transliteral": "šəniyyîm", "traducao_palavra": "segundos" },
        { "hebraico": "וּשְׁלִשִׁ֖ים", "transliteral": "ûšəlišîm", "traducao_palavra": "e terceiros" },
        { "hebraico": "תַּעֲשֶֽׂהָ׃", "transliteral": "taʿăśehā", "traducao_palavra": "farás ela" }
      ]
    },
    "17": {
      "traducao_completa": "E eis que eu trago o dilúvio de águas sobre a terra, para destruir toda a carne em que há espírito de vida debaixo dos céus; tudo o que há na terra expirará.",
      "palavras": [
        { "hebraico": "וַאֲנִ֗י", "transliteral": "waʾănî", "traducao_palavra": "E eu" },
        { "hebraico": "הִנְנִ֨י", "transliteral": "hinnənî", "traducao_palavra": "eis que eu" },
        { "hebraico": "מֵבִ֧יא", "transliteral": "mēḇîʾ", "traducao_palavra": "trazendo" },
        { "hebraico": "אֶת־הַמַּבּ֛וּל", "transliteral": "ʾeṯ-hammabbûl", "traducao_palavra": "[obj] o dilúvio" },
        { "hebraico": "מַ֖יִם", "transliteral": "mayim", "traducao_palavra": "águas" },
        { "hebraico": "עַל־הָאָ֑רֶץ", "transliteral": "ʿal-hāʾāreṣ", "traducao_palavra": "sobre a terra" },
        { "hebraico": "לְשַׁחֵ֣ת", "transliteral": "ləšaḥēṯ", "traducao_palavra": "para destruir" },
        { "hebraico": "כָּל־בָּשָׂ֗ר", "transliteral": "kāl-bāśār", "traducao_palavra": "toda carne" },
        { "hebraico": "אֲשֶׁר־בֹּו֙", "transliteral": "ʾăšer-bô", "traducao_palavra": "que nela" },
        { "hebraico": "ר֣וּחַ", "transliteral": "rûaḥ", "traducao_palavra": "espírito de" },
        { "hebraico": "חַיִּ֔ים", "transliteral": "ḥayyîm", "traducao_palavra": "vida" },
        { "hebraico": "מִתַּ֖חַת", "transliteral": "mittaḥaṯ", "traducao_palavra": "de debaixo de" },
        { "hebraico": "הַשָּׁמָ֑יִם", "transliteral": "haššāmāyim", "traducao_palavra": "os céus" },
        { "hebraico": "כֹּ֥ל", "transliteral": "kōl", "traducao_palavra": "tudo" },
        { "hebraico": "אֲשֶׁר־בָּאָ֖רֶץ", "transliteral": "ʾăšer-bāʾāreṣ", "traducao_palavra": "que na terra" },
        { "hebraico": "יִגְוָֽע׃", "transliteral": "yiḡwāʿ", "traducao_palavra": "expirará" }
      ]
    },
    "18": {
      "traducao_completa": "Mas contigo estabelecerei a minha aliança; e entrarás na arca, tu e os teus filhos, e a tua mulher, e as mulheres de teus filhos contigo.",
      "palavras": [
        { "hebraico": "וַהֲקִמֹתִ֥י", "transliteral": "wahăqimōṯî", "traducao_palavra": "E estabelecerei" },
        { "hebraico": "אֶת־בְּרִיתִ֖י", "transliteral": "ʾeṯ-bərîṯî", "traducao_palavra": "[obj] minha aliança" },
        { "hebraico": "אִתָּ֑ךְ", "transliteral": "ʾittāḵ", "traducao_palavra": "contigo" },
        { "hebraico": "וּבָאתָ֙", "transliteral": "ûḇāʾṯā", "traducao_palavra": "e entrarás" },
        { "hebraico": "אֶל־הַתֵּבָ֔ה", "transliteral": "ʾel-hattēḇâ", "traducao_palavra": "para a arca" },
        { "hebraico": "אַתָּ֕ה", "transliteral": "ʾattâ", "traducao_palavra": "tu" },
        { "hebraico": "וּבָנֶיךָ", "transliteral": "ûḇāneyḵā", "traducao_palavra": "e teus filhos" },
        { "hebraico": "וְאִשְׁתְּךָ", "transliteral": "wəʾištəḵā", "traducao_palavra": "e tua mulher" },
        { "hebraico": "וּנְשֵֽׁי־בָנֶ֖יךָ", "transliteral": "ûnəšê-ḇāneyḵā", "traducao_palavra": "e mulheres de teus filhos" },
        { "hebraico": "אִתָּֽךְ׃", "transliteral": "ʾittāḵ", "traducao_palavra": "contigo" }
      ]
    },
    "19": {
      "traducao_completa": "E de tudo o que vive, de toda a carne, dois de cada espécie meterás na arca, para os conservar vivos contigo; macho e fêmea serão.",
      "palavras": [
        { "hebraico": "וּמִכָּל־הָ֠חַי", "transliteral": "ûmikkāl-hāḥay", "traducao_palavra": "E de todo o vivente" },
        { "hebraico": "מִכָּל־בָּשָׂ֞ר", "transliteral": "mikkāl-bāśār", "traducao_palavra": "de toda carne" },
        { "hebraico": "שְׁנַ֧יִם", "transliteral": "šənayim", "traducao_palavra": "dois" },
        { "hebraico": "מִכֹּ֛ל", "transliteral": "mikkōl", "traducao_palavra": "de cada/todos" },
        { "hebraico": "תָּבִ֥יא", "transliteral": "tāḇîʾ", "traducao_palavra": "trarás" },
        { "hebraico": "אֶל־הַתֵּבָ֖ה", "transliteral": "ʾel-hattēḇâ", "traducao_palavra": "para a arca" },
        { "hebraico": "לְהַחֲיֹ֣ת", "transliteral": "ləhaḥayōṯ", "traducao_palavra": "para conservar vivo" },
        { "hebraico": "אִתָּ֑ךְ", "transliteral": "ʾittāḵ", "traducao_palavra": "contigo" },
        { "hebraico": "זָכָ֥ר", "transliteral": "zāḵār", "traducao_palavra": "macho" },
        { "hebraico": "וּנְקֵבָ֖ה", "transliteral": "ûnəqēḇâ", "traducao_palavra": "e fêmea" },
        { "hebraico": "יִהְיֽוּ׃", "transliteral": "yihyû", "traducao_palavra": "serão" }
      ]
    },
    "20": {
      "traducao_completa": "Das aves segundo as suas espécies, e do gado segundo as suas espécies, de todo o réptil da terra segundo as suas espécies, dois de cada espécie virão a ti, para os conservar em vida.",
      "palavras": [
        { "hebraico": "מֵהָעֹ֣וף", "transliteral": "mēhāʿôp̱", "traducao_palavra": "Das aves" },
        { "hebraico": "לְמִינֵ֗הוּ", "transliteral": "ləmînēhû", "traducao_palavra": "conforme sua espécie" },
        { "hebraico": "וּמִן־הַבְּהֵמָה֙", "transliteral": "ûmin-habbəhēmâ", "traducao_palavra": "e do animal/gado" },
        { "hebraico": "לְמִינָ֔הּ", "transliteral": "ləmînāh", "traducao_palavra": "conforme sua espécie" },
        { "hebraico": "מִכֹּ֛ל", "transliteral": "mikkōl", "traducao_palavra": "de todo" },
        { "hebraico": "רֶ֥מֶשׂ", "transliteral": "remeś", "traducao_palavra": "réptil de" },
        { "hebraico": "הָאֲדָמָ֖ה", "transliteral": "hāʾăḏāmâ", "traducao_palavra": "o solo" },
        { "hebraico": "לְמִינֵ֑הוּ", "transliteral": "ləmînēhû", "traducao_palavra": "conforme sua espécie" },
        { "hebraico": "שְׁנַ֧יִם", "transliteral": "šənayim", "traducao_palavra": "dois" },
        { "hebraico": "מִכֹּ֛ל", "transliteral": "mikkōl", "traducao_palavra": "de cada" },
        { "hebraico": "יָבֹ֥אוּ", "transliteral": "yāḇōʾû", "traducao_palavra": "virão" },
        { "hebraico": "אֵלֶ֖יךָ", "transliteral": "ʾēleyḵā", "traducao_palavra": "a ti" },
        { "hebraico": "לְהַחֲיֹֽות׃", "transliteral": "ləhaḥayôṯ", "traducao_palavra": "para conservar vivo" }
      ]
    },
    "21": {
      "traducao_completa": "E tu toma para ti de toda a comida que se come, e ajunta-a para ti; e te será para mantimento, a ti e a eles.",
      "palavras": [
        { "hebraico": "וְאַתָּ֣ה", "transliteral": "wəʾattâ", "traducao_palavra": "E tu" },
        { "hebraico": "קַח־לְךָ֗", "transliteral": "qaḥ-ləḵā", "traducao_palavra": "toma para ti" },
        { "hebraico": "מִכָּל־מַֽאֲכָל֙", "transliteral": "mikkāl-maʾăḵāl", "traducao_palavra": "de toda comida" },
        { "hebraico": "אֲשֶׁ֣ר", "transliteral": "ʾăšer", "traducao_palavra": "que" },
        { "hebraico": "יֵֽאָכֵ֔ל", "transliteral": "yēʾāḵēl", "traducao_palavra": "se come" },
        { "hebraico": "וְאָסַפְתָּ֖", "transliteral": "wəʾāsap̱tā", "traducao_palavra": "e ajunta" },
        { "hebraico": "אֵלֶ֑יךָ", "transliteral": "ʾēleyḵā", "traducao_palavra": "para ti" },
        { "hebraico": "וְהָיָ֥ה", "transliteral": "wəhāyâ", "traducao_palavra": "e será" },
        { "hebraico": "לְךָ֛", "transliteral": "ləḵā", "traducao_palavra": "para ti" },
        { "hebraico": "וְלָהֶ֖ם", "transliteral": "wəlāhem", "traducao_palavra": "e para eles" },
        { "hebraico": "לְאָכְלָֽה׃", "transliteral": "ləʾāḵəlâ", "traducao_palavra": "para mantimento" }
      ]
    },
    "22": {
      "traducao_completa": "E assim fez Noé; conforme tudo o que Deus lhe mandou, assim o fez.",
      "palavras": [
        { "hebraico": "וַיַּ֖עַשׂ", "transliteral": "wayyaʿaś", "traducao_palavra": "E fez" },
        { "hebraico": "נֹ֑חַ", "transliteral": "nōḥa", "traducao_palavra": "Noé" },
        { "hebraico": "כְּ֠כֹל", "transliteral": "kəḵōl", "traducao_palavra": "conforme tudo" },
        { "hebraico": "אֲשֶׁ֨ר", "transliteral": "ʾăšer", "traducao_palavra": "que" },
        { "hebraico": "צִוָּ֥ה", "transliteral": "ṣiwwâ", "traducao_palavra": "ordenou" },
        { "hebraico": "אֹתֹ֛ו", "transliteral": "ʾōṯô", "traducao_palavra": "o" },
        { "hebraico": "אֱלֹהִ֖ים", "transliteral": "ʾĕlōhîm", "traducao_palavra": "Deus" },
        { "hebraico": "כֵּ֥ן", "transliteral": "kēn", "traducao_palavra": "assim" },
        { "hebraico": "עָשָֽׂה׃", "transliteral": "ʿāśâ", "traducao_palavra": "fez" }
      ]
    }
  }
}