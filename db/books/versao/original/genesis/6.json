        { "hebraico": "אַחֲרֵי־כֵ֗ן", "transliteral": "ʾaḥărê-ḵēn", "traducao_palavra": "depois disso" },
        { "hebraico": "אֲשֶׁ֨ר", "transliteral": "ʾăšer", "traducao_palavra": "que" },
