        { "hebraico": "בָשָׂ֑ר", "transliteral": "ḇāśār", "traducao_palavra": "carne" },
        { "hebraico": "וְהָי֣וּ", "transliteral": "wəhāyû", "traducao_palavra": "e serão" },
        { "hebraico": "יָמָ֔יו", "transliteral": "yāmāyw", "traducao_palavra": "seus dias" },
        { "hebraico": "מֵאָ֥ה", "transliteral": "mēʾâ", "traducao_palavra": "cem" },
        { "hebraico": "וְעֶשְׂרִ֖ים", "transliteral": "wəʿeśrîm", "traducao_palavra": "e vinte" },
        { "hebraico": "שָׁנָֽה׃", "transliteral": "šānâ", "traducao_palavra": "anos" }
      ]
    },
    "4": {
      "traducao_completa": "Havia gigantes na terra naqueles dias; e também depois, quando os filhos de Deus entraram às filhas do homem e delas geraram filhos; estes eram os valentes que houve na antiguidade, os homens de renome.",
