        { "hebraico": "לָהֶ֑ם", "transliteral": "lāhem", "traducao_palavra": "para eles" },
        { "hebraico": "הֵ֧מָּה", "transliteral": "hēmmâ", "traducao_palavra": "estes [eram]" },
