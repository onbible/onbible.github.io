        { "hebraico": "רוּחִ֤י", "transliteral": "rûḥî", "traducao_palavra": "meu Espírito" },
        { "hebraico": "בָֽאָדָם֙", "transliteral": "bāʾāḏām", "traducao_palavra": "no homem" },
        { "hebraico": "לְעֹלָ֔ם", "transliteral": "ləʿōlām", "traducao_palavra": "para sempre" },
        { "hebraico": "בְּשַׁגַּ֖ם", "transliteral": "bəšaggam", "traducao_palavra": "visto que também" },
