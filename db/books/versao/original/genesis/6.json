{
  "livro": "Gênesis - בְּרֵאשִׁית - Bereshit",
  "capítulo": 6,
  "titulos": {},
  "versiculos": {
    "1": {
      "traducao_completa": "E aconteceu que, quando o homem começou a multiplicar-se sobre a face da terra, e filhas lhes nasceram,",
      "palavras": [
        { "hebraico": "וַֽיְהִי֙", "transliteral": "wayəhî", "traducao_palavra": "E aconteceu" },
        { "hebraico": "כִּֽי־הֵחֵ֣ל", "transliteral": "kî-hēḥēl", "traducao_palavra": "quando começou" },
        { "hebraico": "הָֽאָדָ֔ם", "transliteral": "hāʾāḏām", "traducao_palavra": "o homem" },
        { "hebraico": "לָרֹ֖ב", "transliteral": "lārōḇ", "traducao_palavra": "a multiplicar-se" },
        { "hebraico": "עַל־פְּנֵ֣י", "transliteral": "ʿal-pənê", "traducao_palavra": "sobre a face de" },
        { "hebraico": "הָֽאֲדָמָ֑ה", "transliteral": "hāʾăḏāmâ", "traducao_palavra": "a terra" },
        { "hebraico": "וּבָנֹ֖ות", "transliteral": "ûḇānôṯ", "traducao_palavra": "e filhas" },
        { "hebraico": "יֻלְּד֥וּ", "transliteral": "yulləḏû", "traducao_palavra": "nasceram" },
        { "hebraico": "לָהֶֽם׃", "transliteral": "lāhem", "traducao_palavra": "para eles" }
      ]
    },
    "2": {
      "traducao_completa": "viram os filhos de Deus que as filhas do homem eram boas; e tomaram para si mulheres de todas as que escolheram.",
