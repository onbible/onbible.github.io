        { "hebraico": "כִּ֥י", "transliteral": "kî", "traducao_palavra": "que" },
        { "hebraico": "טֹבֹ֖ת", "transliteral": "ṭōḇōṯ", "traducao_palavra": "boas" },
        { "hebraico": "הֵ֑נָּה", "transliteral": "hēnnâ", "traducao_palavra": "[eram] elas" },
        { "hebraico": "וַיִּקְח֤וּ", "transliteral": "wayyiqḥû", "traducao_palavra": "e tomaram" },
        { "hebraico": "לָהֶם֙", "transliteral": "lāhem", "traducao_palavra": "para eles" },
        { "hebraico": "נָשִׁ֔ים", "transliteral": "nāšîm", "traducao_palavra": "mulheres" },
        { "hebraico": "מִכֹּ֖ל", "transliteral": "mikkōl", "traducao_palavra": "de todas" },
        { "hebraico": "אֲשֶׁ֥ר", "transliteral": "ʾăšer", "traducao_palavra": "que" },
        { "hebraico": "בָּחָֽרוּ׃", "transliteral": "bāḥārû", "traducao_palavra": "escolheram" }
      ]
    },
    "3": {
      "traducao_completa": "E disse o SENHOR: Não permanecerá o meu Espírito no homem para sempre, pois ele também é carne; portanto os seus dias serão cento e vinte anos.",
      "palavras": [
