    "6": {
      "traducao_completa": "Quem derramar o sangue do homem, pelo homem o seu sangue será derramado; porque Deus fez o homem à sua imagem.",
      "palavras": [
        { "hebraico": "שֹׁפֵךְ֙", "transliteral": "šōp̄ēḵ", "traducao_palavra": "O que derrama" },
        { "hebraico": "דַּ֣ם", "transliteral": "dam", "traducao_palavra": "sangue de" },
        { "hebraico": "הָאָדָ֔ם", "transliteral": "hāʾāḏām", "traducao_palavra": "o homem" },
        { "hebraico": "בָּאָדָ֖ם", "transliteral": "bāʾāḏām", "traducao_palavra": "pelo homem" },
