    "7": {
      "traducao_completa": "Mas vós, frutificai e multiplicai-vos; povoai abundantemente a terra e multiplicai-vos nela.",
      "palavras": [
        { "hebraico": "וְאַתֶּ֖ם", "transliteral": "wəʾattem", "traducao_palavra": "E vós" },
