        { "hebraico": "הַֽחַיָּה֮", "transliteral": "haḥayyâ", "traducao_palavra": "vivente" },
        { "hebraico": "אֲשֶׁ֣ר", "transliteral": "ʾăšer", "traducao_palavra": "que" },
