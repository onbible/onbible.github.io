{
  "livro": "Gênesis - בְּרֵאשִׁית - Bereshit",
  "capítulo": 9,
  "titulos": {},
  "versiculos": {
    "1": {
      "traducao_completa": "E abençoou Deus a Noé e a seus filhos, e disse-lhes: Frutificai e multiplicai-vos, e enchei a terra.",
      "palavras": [
        { "hebraico": "וַיְבָ֥רֶךְ", "transliteral": "wayəḇāreḵ", "traducao_palavra": "E abençoou" },
        { "hebraico": "אֱלֹהִ֖ים", "transliteral": "ʾĕlōhîm", "traducao_palavra": "Deus" },
        { "hebraico": "אֶת־נֹ֣חַ", "transliteral": "ʾeṯ-nōḥa", "traducao_palavra": "[obj] Noé" },
        { "hebraico": "וְאֶת־בָּנָ֑יו", "transliteral": "wəʾeṯ-bānāyw", "traducao_palavra": "e seus filhos" },
        { "hebraico": "וַיֹּ֣אמֶר", "transliteral": "wayyōʾmer", "traducao_palavra": "e disse" },
        { "hebraico": "לָהֶ֔ם", "transliteral": "lāhem", "traducao_palavra": "lhes" },
        { "hebraico": "פְּר֥וּ", "transliteral": "pərû", "traducao_palavra": "frutificai" },
        { "hebraico": "וּרְב֖וּ", "transliteral": "ûrəḇû", "traducao_palavra": "e multiplicai-vos" },
        { "hebraico": "וּמִלְא֥וּ", "transliteral": "ûmilʾû", "traducao_palavra": "e enchei" },
        { "hebraico": "אֶת־הָאָֽרֶץ׃", "transliteral": "ʾeṯ-hāʾāreṣ", "traducao_palavra": "[obj] a terra" }
      ]
    },
    "2": {
      "traducao_completa": "E o temor de vós e o pavor de vós será sobre todo animal da terra, e sobre toda ave dos céus; em tudo o que se move na terra, e em todos os peixes do mar, nas vossas mãos são entregues.",
      "palavras": [
        { "hebraico": "וּמוֹרַאֲכֶ֤ם", "transliteral": "ûmôraʾăḵem", "traducao_palavra": "E o temor de vós" },
        { "hebraico": "וְחִתְּכֶם֙", "transliteral": "wəḥitəḵem", "traducao_palavra": "e o pavor de vós" },
        { "hebraico": "יִֽהְיֶ֔ה", "transliteral": "yihyeh", "traducao_palavra": "será" },
        { "hebraico": "עַ֚ל", "transliteral": "ʿal", "traducao_palavra": "sobre" },
        { "hebraico": "כָּל־חַיַּ֣ת", "transliteral": "kāl-ḥayyaṯ", "traducao_palavra": "toda vida de" },
        { "hebraico": "הָאָ֔רֶץ", "transliteral": "hāʾāreṣ", "traducao_palavra": "a terra" },
        { "hebraico": "וְעַ֖ל", "transliteral": "wəʿal", "traducao_palavra": "e sobre" },
        { "hebraico": "כָּל־עֹ֣וף", "transliteral": "kāl-ʿôp̱", "traducao_palavra": "toda ave de" },
        { "hebraico": "הַשָּׁמָ֑יִם", "transliteral": "haššāmāyim", "traducao_palavra": "os céus" },
        { "hebraico": "בְּכֹל֩", "transliteral": "bəḵōl", "traducao_palavra": "em tudo" },
        { "hebraico": "אֲשֶׁ֨ר", "transliteral": "ʾăšer", "traducao_palavra": "que" },
        { "hebraico": "תִּרְמֹ֨שׂ", "transliteral": "tirmōś", "traducao_palavra": "rasteja" },
        { "hebraico": "הָֽאֲדָמָ֜ה", "transliteral": "hāʾăḏāmâ", "traducao_palavra": "o solo" },
        { "hebraico": "וּֽבְכָל־דְּגֵ֥י", "transliteral": "ûḇəḵāl-dəḡê", "traducao_palavra": "e em todos os peixes de" },
        { "hebraico": "הַיָּ֖ם", "transliteral": "hayyām", "traducao_palavra": "o mar" },
        { "hebraico": "בְּיֶדְכֶ֥ם", "transliteral": "bəyeḏəḵem", "traducao_palavra": "em vossa mão" },
        { "hebraico": "נִתָּֽנוּ׃", "transliteral": "nittānû", "traducao_palavra": "foram entregues" }
      ]
    },
    "3": {
      "traducao_completa": "Tudo o que se move, que é vivente, ser-vos-á para mantimento; como a erva verde vos dei tudo.",
