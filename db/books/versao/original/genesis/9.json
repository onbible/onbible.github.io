        { "hebraico": "הוּא־חַ֔י", "transliteral": "hû-ḥay", "traducao_palavra": "ele [é] vivente" },
        { "hebraico": "לָכֶ֥ם", "transliteral": "lāḵem", "traducao_palavra": "para vós" },
        { "hebraico": "יִהְיֶ֖ה", "transliteral": "yihyeh", "traducao_palavra": "será" },
        { "hebraico": "לְאָכְלָ֑ה", "transliteral": "ləʾāḵəlâ", "traducao_palavra": "para alimento" },
        { "hebraico": "כְּיֶ֣רֶק", "transliteral": "kəyereq", "traducao_palavra": "como o verde de" },
        { "hebraico": "עֵ֔שֶׂב", "transliteral": "ʿēśeḇ", "traducao_palavra": "erva" },
        { "hebraico": "נָתַ֥תִּי", "transliteral": "nāṯattî", "traducao_palavra": "dei" },
