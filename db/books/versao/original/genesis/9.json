        { "hebraico": "כָּל־חַיָּ֖ה", "transliteral": "kāl-ḥayyâ", "traducao_palavra": "todo animal" },
        { "hebraico": "אֶדְרְשֶׁ֑נּוּ", "transliteral": "ʾeḏrəšennû", "traducao_palavra": "requererei ele" },
