        { "hebraico": "וּרְב֑וּ", "transliteral": "ûrəḇû", "traducao_palavra": "e multiplicai-vos" },
        { "hebraico": "שִׁרְצ֥וּ", "transliteral": "širṣû", "traducao_palavra": "enxameai" },
        { "hebraico": "בָאָ֖רֶץ", "transliteral": "ḇāʾāreṣ", "traducao_palavra": "na terra" },
        { "hebraico": "וּרְבוּ־בָֽהּ׃", "transliteral": "ûrəḇû-ḇāh", "traducao_palavra": "e multiplicai-vos nela" }
      ]
