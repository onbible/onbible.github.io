        { "hebraico": "וַיְכַסּ֕וּ", "transliteral": "wayəḵassû", "traducao_palavra": "e cobriram" },
        { "hebraico": "אֵ֖ת", "transliteral": "ʾēṯ", "traducao_palavra": "[obj]" },
        { "hebraico": "עֶרְוַ֣ת", "transliteral": "ʿerwaṯ", "traducao_palavra": "a nudez de" },
