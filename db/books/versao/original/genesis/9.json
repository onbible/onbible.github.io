      ]
    },
    "4": {
      "traducao_completa": "Mas a carne com sua vida, isto é, seu sangue, não comereis.",
      "palavras": [
        { "hebraico": "אַךְ־בָּשָׂ֕ר", "transliteral": "ʾak-bāśār", "traducao_palavra": "Apenas carne" },
        { "hebraico": "בְּנַפְשֹׁ֥ו", "transliteral": "bənap̄šô", "traducao_palavra": "em sua alma/vida" },
        { "hebraico": "דָמֹ֖ו", "transliteral": "ḏāmô", "traducao_palavra": "seu sangue" },
        { "hebraico": "לֹ֥א", "transliteral": "lōʾ", "traducao_palavra": "não" },
        { "hebraico": "תֹאכֵֽלוּ׃", "transliteral": "ṯōʾḵēlû", "traducao_palavra": "comereis" }
      ]
    },
    "5": {
      "traducao_completa": "E certamente requererei o sangue das vossas vidas; da mão de todo animal o requererei; como também da mão do homem, e da mão do irmão de cada um requererei a vida do homem.",
      "palavras": [
        { "hebraico": "וְאַ֨ךְ", "transliteral": "wəʾak", "traducao_palavra": "E certamente" },
        { "hebraico": "אֶת־דִּמְכֶ֤ם", "transliteral": "ʾeṯ-diməḵem", "traducao_palavra": "[obj] vosso sangue" },
