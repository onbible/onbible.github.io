    "9": {
      "traducao_completa": "E eu, eis que estabeleço a minha aliança convosco e com a vossa semente depois de vós,",
      "palavras": [
        { "hebraico": "וַאֲנִ֕י", "transliteral": "waʾănî", "traducao_palavra": "E eu" },
        { "hebraico": "הִנְנִ֥י", "transliteral": "hinnənî", "traducao_palavra": "eis que eu" },
        { "hebraico": "מֵקִים", "transliteral": "mēqîm", "traducao_palavra": "estabeleço" },
        { "hebraico": "אֶת־בְּרִיתִ֖י", "transliteral": "ʾeṯ-bərîṯî", "traducao_palavra": "[obj] minha aliança" },
