        { "hebraico": "וַיֵּ֧לֶךְ", "transliteral": "wayyēleḵ", "traducao_palavra": "e foi" },
        { "hebraico": "יִצְחָ֛ק", "transliteral": "yiṣḥāq", "traducao_palavra": "Isaque" },
        { "hebraico": "אֶל־אֲבִימֶ֥לֶךְ", "transliteral": "ʾel-ʾăḇîmeleḵ", "traducao_palavra": "para Abimeleque" },
        { "hebraico": "מֶֽלֶךְ־פְּלִשְׁתִּ֖ים", "transliteral": "meleḵ-pəlištîm", "traducao_palavra": "rei dos filisteus" },
