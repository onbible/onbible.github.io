        { "hebraico": "פֶּן־יַהַרְגֻ֜נִי", "transliteral": "pen-yaharḡunî", "traducao_palavra": "para que não me matem" },
        { "hebraico": "אַנְשֵׁ֤י", "transliteral": "ʾanšê", "traducao_palavra": "homens de" },
        { "hebraico": "הַמָּקֹום֙", "transliteral": "hammāqôm", "traducao_palavra": "o lugar" },
