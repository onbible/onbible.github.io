        { "hebraico": "וַיְהִ֗י", "transliteral": "wayhî", "traducao_palavra": "e foi" },
        { "hebraico": "כִּ֣י", "transliteral": "kî", "traducao_palavra": "quando" },
        { "hebraico": "אָֽרְכוּ־לֹ֥ו", "transliteral": "ʾārəḵû-lô", "traducao_palavra": "se prolongaram para ele" },
