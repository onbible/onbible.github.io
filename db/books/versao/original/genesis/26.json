  "versiculos": {
    "1": {
      "traducao_completa": "E foi fome na terra, além da fome a primeira que foi nos dias de Abraão; e foi Isaque para Abimeleque, rei dos filisteus, para Gerar.",
      "palavras": [
        { "hebraico": "וַיְהִ֤י", "transliteral": "wayhî", "traducao_palavra": "e foi" },
