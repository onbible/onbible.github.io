        { "hebraico": "אֶת־זַרְעֲךָ֙", "transliteral": "ʾeṯ-zarʿăḵā", "traducao_palavra": "a tua semente" },
        { "hebraico": "כְּכֹוכְבֵ֣י", "transliteral": "kəḵôḵəḇê", "traducao_palavra": "como estrelas de" },
