    },
    "10": {
      "traducao_completa": "E disse Abimeleque: O que [é] isto que fizeste conosco? Por pouco se deitaria um do povo com tua mulher, e trarias sobre nós culpa.",
      "palavras": [
        { "hebraico": "וַיֹּ֣אמֶר", "transliteral": "wayyōʾmer", "traducao_palavra": "e disse" },
        { "hebraico": "אֲבִימֶ֔לֶךְ", "transliteral": "ʾăḇîmeleḵ", "traducao_palavra": "Abimeleque" },
        { "hebraico": "מַה־זֹּ֖את", "transliteral": "mah-zzōʾṯ", "traducao_palavra": "o que isto" },
        { "hebraico": "עָשִׂ֣יתָ", "transliteral": "ʿāśîṯā", "traducao_palavra": "fizeste" },
        { "hebraico": "לָּ֑נוּ", "transliteral": "lānû", "traducao_palavra": "conosco" },
