        { "hebraico": "אָמַ֖רְתָּ", "transliteral": "ʾāmarṯā", "traducao_palavra": "disseste" },
        { "hebraico": "אֲחֹ֣תִי", "transliteral": "ʾăḥōṯî", "traducao_palavra": "minha irmã" },
        { "hebraico": "הִ֑יא", "transliteral": "hîʾ", "traducao_palavra": "ela" },
        { "hebraico": "וַיֹּ֤אמֶר", "transliteral": "wayyōʾmer", "traducao_palavra": "e disse" },
        { "hebraico": "אֵלָיו֙", "transliteral": "ʾēlāyw", "traducao_palavra": "a ele" },
