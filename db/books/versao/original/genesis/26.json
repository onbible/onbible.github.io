        { "hebraico": "נִשְׁבַּ֖עְתִּי", "transliteral": "nišbaʿtî", "traducao_palavra": "jurei" },
        { "hebraico": "לְאַבְרָהָ֥ם", "transliteral": "ləʾaḇrāhām", "traducao_palavra": "para Abraão" },
