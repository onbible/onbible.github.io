        { "hebraico": "אֶת־כָּל־הָאֲרָצֹ֣ת", "transliteral": "ʾeṯ-kāl-hāʾărāṣōṯ", "traducao_palavra": "todas as terras" },
        { "hebraico": "הָאֵ֔ל", "transliteral": "hāʾēl", "traducao_palavra": "estas" },
        { "hebraico": "וַהֲקִמֹתִי֙", "transliteral": "wahaqimōṯî", "traducao_palavra": "e estabelecerei" },
