        { "hebraico": "אֲשֶׁ֖ר", "transliteral": "ʾăšer", "traducao_palavra": "que" },
        { "hebraico": "אֹמַ֥ר", "transliteral": "ʾōmar", "traducao_palavra": "eu disser" },
        { "hebraico": "אֵלֶֽיךָ׃", "transliteral": "ʾēleyḵā", "traducao_palavra": "para ti" }
      ]
    },
    "3": {
      "traducao_completa": "Reside nesta terra e eu serei contigo e te abençoarei; pois a ti e à tua semente darei todas estas terras, e estabelecerei o juramento que jurei para Abraão, teu pai.",
      "palavras": [
