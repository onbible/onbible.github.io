        { "hebraico": "אֲחֹ֣תִי", "transliteral": "ʾăḥōṯî", "traducao_palavra": "minha irmã" },
        { "hebraico": "הִ֑וא", "transliteral": "hîʾ", "traducao_palavra": "ela" },
        { "hebraico": "כִּ֤י", "transliteral": "kî", "traducao_palavra": "pois" },
        { "hebraico": "יָרֵא֙", "transliteral": "yārēʾ", "traducao_palavra": "temeu" },
