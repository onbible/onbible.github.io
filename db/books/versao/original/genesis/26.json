        { "hebraico": "בִּגְרָֽר׃", "transliteral": "biḡrār", "traducao_palavra": "em Gerar" }
      ]
    },
    "7": {
      "traducao_completa": "E perguntaram os homens do lugar sobre a sua mulher; e ele disse: Minha irmã ela [é]; pois temeu dizer: Minha mulher, para que não me matem os homens do lugar por causa de Rebeca, pois boa de aparência [era] ela.",
      "palavras": [
        { "hebraico": "וַֽיִּשְׁאֲל֞וּ", "transliteral": "wayyišʾălû", "traducao_palavra": "e perguntaram" },
