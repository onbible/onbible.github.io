    "5": {
      "traducao_completa": "Visto que ouviu Abraão a minha voz, e guardou o meu encargo, meus mandamentos, meus estatutos e minhas leis.",
      "palavras": [
        { "hebraico": "עֵ֕קֶב", "transliteral": "ʿēqeḇ", "traducao_palavra": "visto que/consequência" },
        { "hebraico": "אֲשֶׁר־שָׁמַ֥ע", "transliteral": "ʾăšer-šāmaʿ", "traducao_palavra": "que ouviu" },
        { "hebraico": "אַבְרָהָ֖ם", "transliteral": "ʾaḇrāhām", "traducao_palavra": "Abraão" },
        { "hebraico": "בְּקֹלִ֑י", "transliteral": "bəqōlî", "traducao_palavra": "na minha voz" },
        { "hebraico": "וַיִּשְׁמֹר֙", "transliteral": "wayyišmōr", "traducao_palavra": "e guardou" },
