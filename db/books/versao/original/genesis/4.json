      ]
    },
    "14": {
      "traducao_completa": "Eis que hoje me lanças da face da terra, e da tua face me esconderei; e serei fugitivo e vagabundo na terra, e será que todo aquele que me achar, me matará.",
      "palavras": [
        { "hebraico": "הֵן֩", "transliteral": "hēn", "traducao_palavra": "Eis" },
        { "hebraico": "גֵּרַ֨שְׁתָּ", "transliteral": "ḡēraštā", "traducao_palavra": "expulsaste" },
        { "hebraico": "אֹתִ֜י", "transliteral": "ʾōṯî", "traducao_palavra": "me" },
        { "hebraico": "הַיּ֗וֹם", "transliteral": "hayyôm", "traducao_palavra": "hoje" },
        { "hebraico": "מֵעַל֙", "transliteral": "mēʿal", "traducao_palavra": "de sobre" },
        { "hebraico": "פְּנֵ֣י", "transliteral": "pənê", "traducao_palavra": "a face de" },
        { "hebraico": "הָאֲדָמָ֔ה", "transliteral": "hāʾăḏāmâ", "traducao_palavra": "o solo" },
        { "hebraico": "וּמִפָּנֶ֖יךָ", "transliteral": "ûmippāneyḵā", "traducao_palavra": "e de tua face" },
