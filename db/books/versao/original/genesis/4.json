        { "hebraico": "צִלָּֽה׃", "transliteral": "ṣillâ", "traducao_palavra": "Zilá" }
      ]
    },
    "20": {
      "traducao_completa": "E Ada deu à luz a Jabal; este foi o pai dos que habitam em tendas e possuem gado.",
      "palavras": [
        { "hebraico": "וַתֵּ֥לֶד", "transliteral": "wattēleḏ", "traducao_palavra": "E deu à luz" },
