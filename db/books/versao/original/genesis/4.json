        { "hebraico": "וְעִירָ֕ד", "transliteral": "wəʿîrāḏ", "traducao_palavra": "e Irade" },
        { "hebraico": "יָלַ֖ד", "transliteral": "yālaḏ", "traducao_palavra": "gerou" },
        { "hebraico": "אֶת־מְחֽוּיָאֵ֑ל", "transliteral": "ʾeṯ-məḥûyāʾēl", "traducao_palavra": "[obj] Meuiael" },
        { "hebraico": "וּמְחִיָּאֵ֗ל", "transliteral": "ûməḥiyyāʾēl", "traducao_palavra": "e Meuiael" },
        { "hebraico": "יָלַד֙", "transliteral": "yālaḏ", "traducao_palavra": "gerou" },
        { "hebraico": "אֶת־מְתֽוּשָׁאֵ֔ל", "transliteral": "ʾeṯ-məṯûšāʾēl", "traducao_palavra": "[obj] Metusael" },
        { "hebraico": "וּמְתֽוּשָׁאֵ֖ל", "transliteral": "ûməṯûšāʾēl", "traducao_palavra": "e Metusael" },
        { "hebraico": "יָלַ֥ד", "transliteral": "yālaḏ", "traducao_palavra": "gerou" },
