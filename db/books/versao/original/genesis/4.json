    "23": {
      "traducao_completa": "E disse Lameque a suas mulheres Ada e Zilá: Ouvi a minha voz; vós, mulheres de Lameque, escutai o meu dito: porque eu matei um homem por me ferir, e um jovem por me pisar.",
      "palavras": [
        { "hebraico": "וַיֹּ֨אמֶר", "transliteral": "wayyōʾmer", "traducao_palavra": "E disse" },
        { "hebraico": "לֶ֜מֶךְ", "transliteral": "lemeḵ", "traducao_palavra": "Lameque" },
        { "hebraico": "לְנָשָׁ֗יו", "transliteral": "lənāšāyw", "traducao_palavra": "a suas mulheres" },
