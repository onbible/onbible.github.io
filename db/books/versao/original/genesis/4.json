        { "hebraico": "אֶת־אִשְׁתֹּ֔ו", "transliteral": "ʾeṯ-ʾištô", "traducao_palavra": "[obj] sua mulher" },
        { "hebraico": "וַתַּ֖הַר", "transliteral": "wattahar", "traducao_palavra": "e ela concebeu" },
        { "hebraico": "וַתֵּ֣לֶד", "transliteral": "wattēleḏ", "traducao_palavra": "e deu à luz" },
