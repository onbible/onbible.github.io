        { "hebraico": "וַֽיְהִי֙", "transliteral": "wayəhî", "traducao_palavra": "e ele foi" },
        { "hebraico": "בֹּ֣נֶה", "transliteral": "bōneh", "traducao_palavra": "edificando" },
        { "hebraico": "עִ֔יר", "transliteral": "ʿîr", "traducao_palavra": "uma cidade" },
        { "hebraico": "וַיִּקְרָא֙", "transliteral": "wayyiqrāʾ", "traducao_palavra": "e chamou" },
        { "hebraico": "שֵׁ֣ם", "transliteral": "šēm", "traducao_palavra": "nome de" },
        { "hebraico": "הָעִ֔יר", "transliteral": "hāʿîr", "traducao_palavra": "a cidade" },
        { "hebraico": "כְּשֵׁ֖ם", "transliteral": "kəšēm", "traducao_palavra": "como o nome de" },
        { "hebraico": "בְּנֹ֥ו", "transliteral": "bənô", "traducao_palavra": "seu filho" },
        { "hebraico": "חֲנֹֽוךְ׃", "transliteral": "ḥănôḵ", "traducao_palavra": "Enoque" }
      ]
