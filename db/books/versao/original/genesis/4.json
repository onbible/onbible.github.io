        { "hebraico": "וַיֹּ֧אמֶר", "transliteral": "wayyōʾmer", "traducao_palavra": "E disse" },
        { "hebraico": "ל֣וֹ", "transliteral": "lô", "traducao_palavra": "lhe" },
        { "hebraico": "יְהוָ֗ה", "transliteral": "YHWH", "traducao_palavra": "YHWH" },
        { "hebraico": "לָכֵן֙", "transliteral": "lāḵēn", "traducao_palavra": "Portanto" },
        { "hebraico": "כָּל־הֹרֵ֣ג", "transliteral": "kāl-hōrēḡ", "traducao_palavra": "todo o que matar" },
        { "hebraico": "קַ֔יִן", "transliteral": "qayin", "traducao_palavra": "Caim" },
        { "hebraico": "שִׁבְעָתַ֖יִם", "transliteral": "šiḇʿāṯayim", "traducao_palavra": "sete vezes" },
