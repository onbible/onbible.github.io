        { "hebraico": "שִׁבְעָתַ֖יִם", "transliteral": "šiḇʿāṯayim", "traducao_palavra": "sete vezes" },
        { "hebraico": "יֻקַּם־קָ֑יִן", "transliteral": "yuqqam-qayin", "traducao_palavra": "será vingado Caim" },
        { "hebraico": "וְלֶ֖מֶךְ", "transliteral": "wəlemeḵ", "traducao_palavra": "mas Lameque" },
        { "hebraico": "שִׁבְעִ֥ים", "transliteral": "šiḇʿîm", "traducao_palavra": "setenta" },
