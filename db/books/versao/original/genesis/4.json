        { "hebraico": "נָשִׁ֑ים", "transliteral": "nāšîm", "traducao_palavra": "mulheres" },
        { "hebraico": "שֵׁ֤ם", "transliteral": "šēm", "traducao_palavra": "nome de" },
        { "hebraico": "הָאַחַת֙", "transliteral": "hāʾaḥaṯ", "traducao_palavra": "a primeira" },
        { "hebraico": "עָדָ֔ה", "transliteral": "ʿāḏâ", "traducao_palavra": "Ada" },
        { "hebraico": "וְשֵׁ֥ם", "transliteral": "wəšēm", "traducao_palavra": "e o nome de" },
