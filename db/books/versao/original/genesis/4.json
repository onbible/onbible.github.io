        { "hebraico": "לָ֑ךְ", "transliteral": "lāḵ", "traducao_palavra": "para ti" },
        { "hebraico": "נָ֥ע", "transliteral": "nāʿ", "traducao_palavra": "fugitivo/errante" },
        { "hebraico": "וָנָ֖ד", "transliteral": "wānāḏ", "traducao_palavra": "e vagabundo" },
        { "hebraico": "תִּהְיֶ֥ה", "transliteral": "ṯihyeh", "traducao_palavra": "serás" },
        { "hebraico": "בָאָֽרֶץ׃", "transliteral": "ḇāʾāreṣ", "traducao_palavra": "na terra" }
      ]
    },
    "13": {
      "traducao_completa": "E disse Caim ao SENHOR: É maior a minha maldade do que a que eu possa suportar.",
      "palavras": [
        { "hebraico": "וַיֹּ֥אמֶר", "transliteral": "wayyōʾmer", "traducao_palavra": "E disse" },
        { "hebraico": "קַ֖יִן", "transliteral": "qayin", "traducao_palavra": "Caim" },
        { "hebraico": "אֶל־יְהוָ֑ה", "transliteral": "ʾel-YHWH", "traducao_palavra": "a YHWH" },
        { "hebraico": "גָּדֹ֥ול", "transliteral": "gāḏôl", "traducao_palavra": "grande" },
