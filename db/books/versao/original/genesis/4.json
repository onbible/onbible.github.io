{
  "livro": "Gênesis - בְּרֵאשִׁית - Bereshit",
  "capítulo": 4,
  "titulos": {},
  "versiculos": {
    "1": {
      "traducao_completa": "E o homem conheceu a Eva, sua mulher, e ela concebeu e deu à luz a Caim, e disse: Alcancei um homem com o SENHOR.",
      "palavras": [
        { "hebraico": "וְהָאָדָ֖ם", "transliteral": "wəhāʾāḏām", "traducao_palavra": "E o homem" },
        { "hebraico": "יָדַ֑ע", "transliteral": "yāḏaʿ", "traducao_palavra": "conheceu" },
        { "hebraico": "אֶת־חַוָּ֣ה", "transliteral": "ʾeṯ-ḥawwâ", "traducao_palavra": "[obj] Eva" },
        { "hebraico": "אִשְׁתּ֔וֹ", "transliteral": "ʾištô", "traducao_palavra": "sua mulher" },
        { "hebraico": "וַתַּ֖הַר", "transliteral": "wattahar", "traducao_palavra": "e ela concebeu" },
        { "hebraico": "וַתֵּ֣לֶד", "transliteral": "wattēleḏ", "traducao_palavra": "e deu à luz" },
        { "hebraico": "אֶת־קַ֔יִן", "transliteral": "ʾeṯ-qayin", "traducao_palavra": "[obj] Caim" },
        { "hebraico": "וַתֹּ֕אמֶר", "transliteral": "wattōʾmer", "traducao_palavra": "e disse" },
        { "hebraico": "קָנִ֥יתִי", "transliteral": "qānîṯî", "traducao_palavra": "alcancei/adquiri" },
        { "hebraico": "אִ֖ישׁ", "transliteral": "ʾîš", "traducao_palavra": "um homem" },
        { "hebraico": "אֶת־יְהוָֽה׃", "transliteral": "ʾeṯ-YHWH", "traducao_palavra": "com YHWH" }
      ]
    },
    "2": {
      "traducao_completa": "E tornou a dar à luz a seu irmão Abel; e Abel foi pastor de ovelhas, e Caim foi lavrador da terra.",
      "palavras": [
        { "hebraico": "וַתֹּ֣סֶף", "transliteral": "wattōsep̱", "traducao_palavra": "E tornou/acrescentou" },
        { "hebraico": "לָלֶ֔דֶת", "transliteral": "lāleḏeṯ", "traducao_palavra": "a dar à luz" },
        { "hebraico": "אֶת־אָחִ֖יו", "transliteral": "ʾeṯ-ʾāḥîw", "traducao_palavra": "[obj] seu irmão" },
        { "hebraico": "אֶת־הָ֑בֶל", "transliteral": "ʾeṯ-hāḇel", "traducao_palavra": "[obj] Abel" },
        { "hebraico": "וַֽיְהִי־הֶ֙בֶל֙", "transliteral": "wayəhî-heḇel", "traducao_palavra": "e foi Abel" },
        { "hebraico": "רֹ֣עֵה", "transliteral": "rōʿēh", "traducao_palavra": "pastor de" },
        { "hebraico": "צֹ֔אן", "transliteral": "ṣōn", "traducao_palavra": "ovelhas" },
        { "hebraico": "וְקַ֕יִן", "transliteral": "wəqayin", "traducao_palavra": "e Caim" },
        { "hebraico": "הָיָ֖ה", "transliteral": "hāyâ", "traducao_palavra": "foi" },
        { "hebraico": "עֹבֵ֥ד", "transliteral": "ʿōḇēḏ", "traducao_palavra": "servindo/lavrando" },
        { "hebraico": "אֲדָמָֽה׃", "transliteral": "ʾăḏāmâ", "traducao_palavra": "terra" }
      ]
    },
    "3": {
      "traducao_completa": "E aconteceu ao cabo de dias que Caim trouxe do fruto da terra uma oferta ao SENHOR.",
      "palavras": [
        { "hebraico": "וַֽיְהִ֖י", "transliteral": "wayəhî", "traducao_palavra": "E foi/aconteceu" },
        { "hebraico": "מִקֵּ֣ץ", "transliteral": "miqqēṣ", "traducao_palavra": "ao fim de" },
        { "hebraico": "יָמִ֑ים", "transliteral": "yāmîm", "traducao_palavra": "dias" },
        { "hebraico": "וַיָּבֵ֨א", "transliteral": "wayyāḇēʾ", "traducao_palavra": "e trouxe" },
        { "hebraico": "קַ֜יִן", "transliteral": "qayin", "traducao_palavra": "Caim" },
        { "hebraico": "מִפְּרִ֧י", "transliteral": "mippərî", "traducao_palavra": "do fruto de" },
        { "hebraico": "הָאֲדָמָ֛ה", "transliteral": "hāʾăḏāmâ", "traducao_palavra": "a terra" },
        { "hebraico": "מִנְחָ֖ה", "transliteral": "minḥâ", "traducao_palavra": "uma oferta" },
        { "hebraico": "לַיהוָֽה׃", "transliteral": "laYHWH", "traducao_palavra": "ao SENHOR" }
      ]
    },
    "4": {
      "traducao_completa": "E Abel também trouxe dos primogênitos das suas ovelhas, e da sua gordura; e atentou o SENHOR para Abel e para a sua oferta.",
      "palavras": [
        { "hebraico": "וְהֶ֨בֶל", "transliteral": "wəheḇel", "traducao_palavra": "E Abel" },
        { "hebraico": "הֵבִ֥יא", "transliteral": "hēḇîʾ", "traducao_palavra": "trouxe" },
        { "hebraico": "גַם־הוּא֙", "transliteral": "gam-hû", "traducao_palavra": "também ele" },
        { "hebraico": "מִבְּכֹרֹ֥ת", "transliteral": "mibbəḵōrōṯ", "traducao_palavra": "dos primogênitos de" },
        { "hebraico": "צֹאנֹ֖ו", "transliteral": "ṣōnô", "traducao_palavra": "suas ovelhas" },
        { "hebraico": "וּמֵחֶלְבֵהֶ֑ן", "transliteral": "ûmēḥelḇēhen", "traducao_palavra": "e de suas gorduras" },
        { "hebraico": "וַיִּ֣שַׁע", "transliteral": "wayyišaʿ", "traducao_palavra": "e atentou/olhou" },
        { "hebraico": "יְהוָ֔ה", "transliteral": "YHWH", "traducao_palavra": "YHWH" },
        { "hebraico": "אֶל־הֶ֖בֶל", "transliteral": "ʾel-heḇel", "traducao_palavra": "para Abel" },
        { "hebraico": "וְאֶל־מִנְחָתֽוֹ׃", "transliteral": "wəʾel-minḥāṯô", "traducao_palavra": "e para sua oferta" }
      ]
    },
    "5": {
      "traducao_completa": "Mas para Caim e para a sua oferta não atentou. E irou-se Caim fortemente, e descaiu-lhe o semblante.",
      "palavras": [
        { "hebraico": "וְאֶל־קַ֜יִן", "transliteral": "wəʾel-qayin", "traducao_palavra": "Mas para Caim" },
        { "hebraico": "וְאֶל־מִנְחָתֹ֖ו", "transliteral": "wəʾel-minḥāṯô", "traducao_palavra": "e para sua oferta" },
        { "hebraico": "לֹ֣א", "transliteral": "lōʾ", "traducao_palavra": "não" },
        { "hebraico": "שָׁעָ֑ה", "transliteral": "šāʿâ", "traducao_palavra": "atentou" },
        { "hebraico": "וַיִּ֤חַר", "transliteral": "wayyiḥar", "traducao_palavra": "e irou-se" },
        { "hebraico": "לְקַ֙יִן֙", "transliteral": "ləqayin", "traducao_palavra": "para Caim" },
        { "hebraico": "מְאֹ֔ד", "transliteral": "məʾōḏ", "traducao_palavra": "fortemente" },
        { "hebraico": "וַֽיִּפְּל֖וּ", "transliteral": "wayyippəlû", "traducao_palavra": "e decaíram" },
        { "hebraico": "פָּנָֽיו׃", "transliteral": "pānāyw", "traducao_palavra": "suas faces" }
      ]
    },
    "6": {
      "traducao_completa": "E disse o SENHOR a Caim: Por que te iraste? E por que descaiu o teu semblante?",
      "palavras": [
        { "hebraico": "וַיֹּ֥אמֶר", "transliteral": "wayyōʾmer", "traducao_palavra": "E disse" },
        { "hebraico": "יְהוָ֖ה", "transliteral": "YHWH", "traducao_palavra": "YHWH" },
        { "hebraico": "אֶל־קָ֑יִן", "transliteral": "ʾel-qayin", "traducao_palavra": "a Caim" },
        { "hebraico": "לָ֚מָּה", "transliteral": "lāmmâ", "traducao_palavra": "Por que" },
        { "hebraico": "חָ֣רָה", "transliteral": "ḥārâ", "traducao_palavra": "iraste" },
        { "hebraico": "לָ֔ךְ", "transliteral": "lāḵ", "traducao_palavra": "te/a ti" },
        { "hebraico": "וְלָ֖מָּה", "transliteral": "wəlāmmâ", "traducao_palavra": "e por que" },
        { "hebraico": "נָפְל֥וּ", "transliteral": "nāp̱əlû", "traducao_palavra": "decaíram" },
        { "hebraico": "פָנֶֽיךָ׃", "transliteral": "pāneyḵā", "traducao_palavra": "tuas faces" }
      ]
    },
    "7": {
      "traducao_completa": "Se bem fizeres, não haverá aceitação? E se não fizeres bem, o pecado jaz à porta, e para ti será o seu desejo, mas tu dominarás sobre ele.",
      "palavras": [
        { "hebraico": "הֲלֹ֤וא", "transliteral": "hălôʾ", "traducao_palavra": "Acaso não" },
        { "hebraico": "אִם־תֵּיטִיב֙", "transliteral": "ʾim-têṭîḇ", "traducao_palavra": "se fizeres bem" },
        { "hebraico": "שְׂאֵ֔ת", "transliteral": "śəʾēṯ", "traducao_palavra": "[haverá] elevação/aceitação" },
        { "hebraico": "וְאִם֙", "transliteral": "wəʾim", "traducao_palavra": "e se" },
        { "hebraico": "לֹ֣א", "transliteral": "lōʾ", "traducao_palavra": "não" },
        { "hebraico": "תֵיטִ֔יב", "transliteral": "ṯêṭîḇ", "traducao_palavra": "fizeres bem" },
        { "hebraico": "לַפֶּ֖תַח", "transliteral": "lappeṯaḥ", "traducao_palavra": "à porta" },
        { "hebraico": "חַטָּ֣את", "transliteral": "ḥaṭṭāʾṯ", "traducao_palavra": "pecado" },
        { "hebraico": "רֹבֵ֑ץ", "transliteral": "rōḇēṣ", "traducao_palavra": "jaz/espreita" },
        { "hebraico": "וְאֵלֶ֙יךָ֙", "transliteral": "wəʾēleyḵā", "traducao_palavra": "e para ti" },
        { "hebraico": "תְּשׁוּקָתֹ֔ו", "transliteral": "təšûqāṯô", "traducao_palavra": "seu desejo" },
        { "hebraico": "וְאַתָּ֖ה", "transliteral": "wəʾattâ", "traducao_palavra": "mas tu" },
        { "hebraico": "תִּמְשָׁל־בּֽוֹ׃", "transliteral": "timšāl-bô", "traducao_palavra": "dominarás nele" }
      ]
    },
    "8": {
      "traducao_completa": "E falou Caim com seu irmão Abel; e sucedeu que, estando eles no campo, se levantou Caim contra seu irmão Abel, e o matou.",
      "palavras": [
        { "hebraico": "וַיֹּ֥אמֶר", "transliteral": "wayyōʾmer", "traducao_palavra": "E disse/falou" },
        { "hebraico": "קַ֖יִן", "transliteral": "qayin", "traducao_palavra": "Caim" },
        { "hebraico": "אֶל־הֶ֣בֶל", "transliteral": "ʾel-heḇel", "traducao_palavra": "a Abel" },
        { "hebraico": "אָחִ֑יו", "transliteral": "ʾāḥîw", "traducao_palavra": "seu irmão" },
        { "hebraico": "וַֽיְהִי֙", "transliteral": "wayəhî", "traducao_palavra": "e foi" },
        { "hebraico": "בִּהְיוֹתָ֣ם", "transliteral": "bihyôṯām", "traducao_palavra": "estando eles" },
        { "hebraico": "בַּשָּׂדֶ֔ה", "transliteral": "baśśāḏeh", "traducao_palavra": "no campo" },
        { "hebraico": "וַיָּ֨קָם", "transliteral": "wayyāqām", "traducao_palavra": "e levantou-se" },
        { "hebraico": "קַ֜יִן", "transliteral": "qayin", "traducao_palavra": "Caim" },
        { "hebraico": "אֶל־הֶ֥בֶל", "transliteral": "ʾel-heḇel", "traducao_palavra": "contra Abel" },
        { "hebraico": "אָחִ֖יו", "transliteral": "ʾāḥîw", "traducao_palavra": "seu irmão" },
        { "hebraico": "וַיַּהַרְגֵֽהוּ׃", "transliteral": "wayyaharḡēhû", "traducao_palavra": "e o matou" }
      ]
    },
    "9": {
      "traducao_completa": "E disse o SENHOR a Caim: Onde está Abel, teu irmão? E ele disse: Não sei; sou eu guardador do meu irmão?",
      "palavras": [
        { "hebraico": "וַיֹּ֤אמֶר", "transliteral": "wayyōʾmer", "traducao_palavra": "E disse" },
        { "hebraico": "יְהוָה֙", "transliteral": "YHWH", "traducao_palavra": "YHWH" },
        { "hebraico": "אֶל־קַ֔יִן", "transliteral": "ʾel-qayin", "traducao_palavra": "a Caim" },
        { "hebraico": "אֵ֖י", "transliteral": "ʾê", "traducao_palavra": "Onde" },
        { "hebraico": "הֶ֣בֶל", "transliteral": "heḇel", "traducao_palavra": "Abel" },
        { "hebraico": "אָחִ֑יךָ", "transliteral": "ʾāḥîḵā", "traducao_palavra": "teu irmão?" },
        { "hebraico": "וַיֹּ֙אמֶר֙", "transliteral": "wayyōʾmer", "traducao_palavra": "e disse" },
        { "hebraico": "לֹ֣א", "transliteral": "lōʾ", "traducao_palavra": "Não" },
        { "hebraico": "יָדַ֔עְתִּי", "transliteral": "yāḏaʿtî", "traducao_palavra": "sei" },
        { "hebraico": "הֲשֹׁמֵ֥ר", "transliteral": "hăšōmēr", "traducao_palavra": "Acaso guardador de" },
        { "hebraico": "אָחִ֖י", "transliteral": "ʾāḥî", "traducao_palavra": "meu irmão" },
        { "hebraico": "אָנֹֽכִי׃", "transliteral": "ʾānōḵî", "traducao_palavra": "[sou] eu?" }
      ]
    },
    "10": {
      "traducao_completa": "E disse Deus: Que fizeste? A voz do sangue do teu irmão clama a mim desde a terra.",
      "palavras": [
        { "hebraico": "וַיֹּ֖אמֶer", "transliteral": "wayyōʾmer", "traducao_palavra": "E disse" },
        { "hebraico": "מֶ֣ה", "transliteral": "meh", "traducao_palavra": "Que" },
        { "hebraico": "עָשִׂ֑יתָ", "transliteral": "ʿāśîṯā", "traducao_palavra": "fizeste?" },
        { "hebraico": "ק֚וֹל", "transliteral": "qôl", "traducao_palavra": "A voz de" },
        { "hebraico": "דְּמֵ֣י", "transliteral": "dəmê", "traducao_palavra": "sangues de" },
        { "hebraico": "אָחִ֔יךָ", "transliteral": "ʾāḥîḵā", "traducao_palavra": "teu irmão" },
        { "hebraico": "צֹעֲקִ֥ים", "transliteral": "ṣōʿăqîm", "traducao_palavra": "clamando" },
        { "hebraico": "אֵלַ֖י", "transliteral": "ʾēlay", "traducao_palavra": "a mim" },
        { "hebraico": "מִן־הָאֲדָמָֽה׃", "transliteral": "min-hāʾăḏāmâ", "traducao_palavra": "desde o solo" }
      ]
    },
    "11": {
      "traducao_completa": "E agora maldito és tu desde a terra, que abriu a sua boca para receber da tua mão o sangue do teu irmão.",
      "palavras": [
        { "hebraico": "וְעַתָּ֖ה", "transliteral": "wəʿattâ", "traducao_palavra": "E agora" },
        { "hebraico": "אָר֣וּר", "transliteral": "ʾārûr", "traducao_palavra": "maldito" },
        { "hebraico": "אָ֑תָּה", "transliteral": "ʾāttâ", "traducao_palavra": "[és] tu" },
        { "hebraico": "מִן־הָאֲדָמָה֙", "transliteral": "min-hāʾăḏāmâ", "traducao_palavra": "desde o solo" },
        { "hebraico": "אֲשֶׁ֣ר", "transliteral": "ʾăšer", "traducao_palavra": "que" },
        { "hebraico": "פָּצְתָ֣ה", "transliteral": "pāṣəṯâ", "traducao_palavra": "abriu" },
        { "hebraico": "אֶת־פִּ֔יהָ", "transliteral": "ʾeṯ-pîhā", "traducao_palavra": "[obj] sua boca" },
        { "hebraico": "לָקַ֛חַת", "transliteral": "lāqaḥaṯ", "traducao_palavra": "para receber" },
        { "hebraico": "אֶת־דְּמֵ֥י", "transliteral": "ʾeṯ-dəmê", "traducao_palavra": "[obj] os sangues de" },
        { "hebraico": "אָחִ֖יךָ", "transliteral": "ʾāḥîḵā", "traducao_palavra": "teu irmão" },
        { "hebraico": "מִיָּדֶֽךָ׃", "transliteral": "miyyāḏeḵā", "traducao_palavra": "da tua mão" }
      ]
    },
    "12": {
      "traducao_completa": "Quando lavrares a terra, não te dará mais a sua força; fugitivo e vagabundo serás na terra.",
      "palavras": [
        { "hebraico": "כִּ֤י", "transliteral": "kî", "traducao_palavra": "Quando" },
        { "hebraico": "תַעֲבֹד֙", "transliteral": "ṯaʿăḇōḏ", "traducao_palavra": "lavrares" },
        { "hebraico": "אֶת־הָ֣אֲדָמָ֔ה", "transliteral": "ʾeṯ-hāʾăḏāmâ", "traducao_palavra": "[obj] o solo" },
        { "hebraico": "לֹֽא־תֹסֵ֥ף", "transliteral": "lōʾ-ṯōsēp̱", "traducao_palavra": "não tornará" },
