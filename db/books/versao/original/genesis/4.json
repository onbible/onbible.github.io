        { "hebraico": "גַם־הִ֗יא", "transliteral": "gam-hî", "traducao_palavra": "também ela" },
        { "hebraico": "יָלְדָה֙", "transliteral": "yāləḏâ", "traducao_palavra": "gerou" },
