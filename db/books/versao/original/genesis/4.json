        { "hebraico": "אִמְרָתִ֑י", "transliteral": "ʾimrāṯî", "traducao_palavra": "meu dito" },
        { "hebraico": "כִּ֣י", "transliteral": "kî", "traducao_palavra": "porque" },
        { "hebraico": "אִ֤ישׁ", "transliteral": "ʾîš", "traducao_palavra": "um homem" },
        { "hebraico": "הָרַ֙גְתִּי֙", "transliteral": "hāraḡtî", "traducao_palavra": "matei" },
