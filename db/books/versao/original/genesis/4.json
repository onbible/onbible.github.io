      ]
    },
    "19": {
      "traducao_completa": "E tomou Lameque para si duas mulheres; o nome de uma era Ada, e o nome da outra, Zilá.",
      "palavras": [
        { "hebraico": "וַיִּֽקַּֽח־לֹ֥ו", "transliteral": "wayyiqqaḥ-lô", "traducao_palavra": "E tomou para si" },
        { "hebraico": "לֶ֖מֶךְ", "transliteral": "lemeḵ", "traducao_palavra": "Lameque" },
