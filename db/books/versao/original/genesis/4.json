        { "hebraico": "יְהוָ֤ה", "transliteral": "YHWH", "traducao_palavra": "YHWH" },
        { "hebraico": "לְקַ֙יִן֙", "transliteral": "ləqayin", "traducao_palavra": "em Caim" },
        { "hebraico": "אֹ֔ות", "transliteral": "ʾôṯ", "traducao_palavra": "um sinal" },
        { "hebraico": "לְבִלְתִּ֥י", "transliteral": "ləḇilttî", "traducao_palavra": "para não" },
        { "hebraico": "הַכּוֹת־אֹתֹ֖ו", "transliteral": "hakkôṯ-ʾōṯô", "traducao_palavra": "ferir ele" },
        { "hebraico": "כָּל־מֹצְאֹֽו׃", "transliteral": "kāl-mōṣəʾô", "traducao_palavra": "quem quer que o ache" }
      ]
    },
    "16": {
      "traducao_completa": "E saiu Caim de diante da face do SENHOR, e habitou na terra de Nod, ao oriente do Éden.",
      "palavras": [
        { "hebraico": "וַיֵּ֥צֵא", "transliteral": "wayyēṣēʾ", "traducao_palavra": "E saiu" },
        { "hebraico": "קַ֖יִן", "transliteral": "qayin", "traducao_palavra": "Caim" },
        { "hebraico": "מִלִּפְנֵ֣י", "transliteral": "millip̄nê", "traducao_palavra": "de diante de" },
        { "hebraico": "יְהוָ֑ה", "transliteral": "YHWH", "traducao_palavra": "YHWH" },
        { "hebraico": "וַיֵּ֥שֶׁב", "transliteral": "wayyēšeḇ", "traducao_palavra": "e habitou" },
        { "hebraico": "בְּאֶֽרֶץ־נֹ֖וד", "transliteral": "bəʾereṣ-nôḏ", "traducao_palavra": "na terra de Nod" },
        { "hebraico": "קִדְמַת־עֵֽדֶן׃", "transliteral": "qiḏmaṯ-ʿēḏen", "traducao_palavra": "ao oriente de Éden" }
      ]
    },
    "17": {
      "traducao_completa": "E conheceu Caim a sua mulher, e ela concebeu, e deu à luz a Enoque; e ele edificou uma cidade, e chamou o nome da cidade conforme o nome de seu filho Enoque.",
      "palavras": [
