        { "hebraico": "וְהָיִ֜יתִי", "transliteral": "wəhāyîṯî", "traducao_palavra": "e serei" },
        { "hebraico": "נָ֤ע", "transliteral": "nāʿ", "traducao_palavra": "fugitivo" },
        { "hebraico": "וָנָד֙", "transliteral": "wānāḏ", "traducao_palavra": "e vagabundo" },
        { "hebraico": "בָּאָ֔רֶץ", "transliteral": "bāʾāreṣ", "traducao_palavra": "na terra" },
        { "hebraico": "וְהָיָ֥ה", "transliteral": "wəhāyâ", "traducao_palavra": "e acontecerá" },
        { "hebraico": "כָל־מֹצְאִ֖י", "transliteral": "ḵāl-mōṣəʾî", "traducao_palavra": "todo o que me achar" },
        { "hebraico": "יַֽהַרְגֵֽנִי׃", "transliteral": "yaharḡēnî", "traducao_palavra": "me matará" }
      ]
    },
    "15": {
      "traducao_completa": "O SENHOR, porém, disse-lhe: Portanto qualquer que matar a Caim, sete vezes será castigado. E pôs o SENHOR um sinal em Caim, para que o não ferisse qualquer que o achasse.",
