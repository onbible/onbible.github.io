        { "hebraico": "אָחִ֖יו", "transliteral": "ʾāḥîw", "traducao_palavra": "seu irmão" },
        { "hebraico": "יוּבָ֑ל", "transliteral": "yûḇāl", "traducao_palavra": "Jubal" },
