        { "hebraico": "לְיַעֲקֹב", "transliteral": "lə-ya-ʿă-qōḇ", "traducao_palavra": "a Jacó" },
        { "hebraico": "וַיֹּאמֶר", "transliteral": "way-yō-mer", "traducao_palavra": "e disse" },
        { "hebraico": "הִנֵּה", "transliteral": "hin-nēh", "traducao_palavra": "eis" },
        { "hebraico": "בִּנְךָ", "transliteral": "bin-ḵā", "traducao_palavra": "teu filho" },
        { "hebraico": "יוֹסֵף", "transliteral": "yô-sēp̄", "traducao_palavra": "José" },
        { "hebraico": "בָּא", "transliteral": "bā", "traducao_palavra": "vem" },
        { "hebraico": "אֵלֶיךָ", "transliteral": "ʾē-le-ḵā", "traducao_palavra": "a ti" },
        { "hebraico": "וַיִּתְחַזֵּק", "transliteral": "way-yiṯ-ḥaz-zēq", "traducao_palavra": "e esforçou-se" },
        { "hebraico": "יִשְׂרָאֵל", "transliteral": "yiś-rā-ʾēl", "traducao_palavra": "Israel" },
