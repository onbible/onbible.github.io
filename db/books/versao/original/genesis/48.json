        { "hebraico": "וְיִצְחָק", "transliteral": "wə-yiṣ-ḥāq", "traducao_palavra": "e Isaque" },
        { "hebraico": "הָאֱלֹהִים", "transliteral": "hā-ʾĕ-lō-hîm", "traducao_palavra": "o Deus" },
        { "hebraico": "הָרֹעֶה", "transliteral": "hā-rō-ʿeh", "traducao_palavra": "o apascentador/pastor" },
        { "hebraico": "אֹתִי", "transliteral": "ʾō-ṯî", "traducao_palavra": "de mim" },
        { "hebraico": "מֵעוֹדִי", "transliteral": "mē-ʿô-ḏî", "traducao_palavra": "desde a minha existência" },
