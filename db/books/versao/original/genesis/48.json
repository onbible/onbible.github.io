      ]
    },
    "19": {
      "traducao_completa": "Mas seu pai recusou e disse: Eu sei, meu filho, eu sei; também ele será por povo, e também ele será grande; contudo, o seu irmão menor será maior do que ele, e a sua semente será a plenitude das nações.",
      "palavras": [
        { "hebraico": "וַיְמָאֵן", "transliteral": "way-mə-ʾā-ēn", "traducao_palavra": "e recusou" },
        { "hebraico": "אָבִיו", "transliteral": "ʾā-ḇîw", "traducao_palavra": "seu pai" },
        { "hebraico": "וַיֹּאמֶר", "transliteral": "way-yō-mer", "traducao_palavra": "e disse" },
        { "hebraico": "יָדַעְתִּי", "transliteral": "yā-ḏaʿ-tî", "traducao_palavra": "eu sei" },
        { "hebraico": "בְנִי", "transliteral": "ḇə-nî", "traducao_palavra": "meu filho" },
