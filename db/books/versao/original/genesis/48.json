      ]
    },
    "20": {
      "traducao_completa": "E abençoou-os naquele dia, dizendo: Por ti abençoará Israel, dizendo: Deus te ponha como a Efraim e como a Manassés. E pôs a Efraim diante de Manassés.",
      "palavras": [
        { "hebraico": "וַיְבָרְכֵם", "transliteral": "way-ḇā-rə-ḵēm", "traducao_palavra": "e abençoou-os" },
