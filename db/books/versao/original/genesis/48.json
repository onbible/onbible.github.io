      ]
    },
    "5": {
      "traducao_completa": "E agora, os teus dois filhos, que te nasceram na terra do Egito, antes de eu vir a ti ao Egito, meus são; Efraim e Manassés serão meus como Rúben e Simeão.",
      "palavras": [
        { "hebraico": "וְעַתָּה", "transliteral": "wə-ʿat-tāh", "traducao_palavra": "e agora" },
        { "hebraico": "שְׁנֵי־בָנֶיךָ", "transliteral": "šə-nê-ḇā-ne-ḵā", "traducao_palavra": "teus dois filhos" },
        { "hebraico": "הַנּוֹלָדִים", "transliteral": "han-nô-lā-ḏîm", "traducao_palavra": "os nascidos" },
        { "hebraico": "לְךָ", "transliteral": "lə-ḵā", "traducao_palavra": "para ti" },
        { "hebraico": "בְּאֶרֶץ", "transliteral": "bə-ʾe-reṣ", "traducao_palavra": "na terra de" },
        { "hebraico": "מִצְרַיִם", "transliteral": "miṣ-ra-yim", "traducao_palavra": "Egito" },
        { "hebraico": "עַד־בֹּאִי", "transliteral": "ʿaḏ-bō-ʾî", "traducao_palavra": "até a minha vinda" },
        { "hebraico": "אֵלֶיךָ", "transliteral": "ʾē-le-ḵā", "traducao_palavra": "a ti" },
        { "hebraico": "מִצְרַיְמָה", "transliteral": "miṣ-ray-mā", "traducao_palavra": "ao Egito" },
        { "hebraico": "לִי־הֵם", "transliteral": "lî-hēm", "traducao_palavra": "meus são eles" },
        { "hebraico": "אֶפְרַיִם", "transliteral": "ʾep̄-ra-yim", "traducao_palavra": "Efraim" },
        { "hebraico": "וּמְנַשֶּׁה", "transliteral": "û-mə-naš-šeh", "traducao_palavra": "e Manassés" },
        { "hebraico": "כִּרְאוּבֵן", "transliteral": "kir-ʾû-ḇēn", "traducao_palavra": "como Rúben" },
        { "hebraico": "וְשִׁמְעוֹן", "transliteral": "wə-šim-ʿôn", "traducao_palavra": "e Simeão" },
        { "hebraico": "יִהְיוּ־לִי׃", "transliteral": "yih-yû-lî", "traducao_palavra": "serão meus" }
      ]
    },
    "6": {
      "traducao_completa": "E a tua descendência que gerares depois deles será tua; pelo nome de seus irmãos serão chamados na sua herança.",
      "palavras": [
        { "hebraico": "וּמוֹלַדְתְּךָ", "transliteral": "û-mô-laḏ-tə-ḵā", "traducao_palavra": "e tua posteridade" },
        { "hebraico": "אֲשֶׁר־הוֹלַדְתָּ", "transliteral": "ʾă-šer-hô-laḏ-tā", "traducao_palavra": "que gerares" },
        { "hebraico": "אַחֲרֵיהֶם", "transliteral": "ʾa-ḥă-rê-hem", "traducao_palavra": "depois deles" },
        { "hebraico": "לְךָ", "transliteral": "lə-ḵā", "traducao_palavra": "tua" },
        { "hebraico": "יִהְיוּ", "transliteral": "yih-yû", "traducao_palavra": "serão" },
        { "hebraico": "עַל", "transliteral": "ʿal", "traducao_palavra": "pelo" },
        { "hebraico": "שֵׁם", "transliteral": "šēm", "traducao_palavra": "nome de" },
        { "hebraico": "אֲחֵיהֶם", "transliteral": "ʾă-ḥê-hem", "traducao_palavra": "seus irmãos" },
        { "hebraico": "יִקָּרְאוּ", "transliteral": "yiq-qā-rə-ʾû", "traducao_palavra": "serão chamados" },
        { "hebraico": "בְּנַחֲלָתָם׃", "transliteral": "bə-na-ḥă-lā-ṯām", "traducao_palavra": "na herança deles" }
      ]
    },
    "7": {
      "traducao_completa": "E eu, vindo de Padã, morreu-me Raquel na terra de Canaã, no caminho, havendo ainda uma pequena distância para chegar a Efrata; e sepultei-a ali no caminho de Efrata, que é Belém.",
      "palavras": [
        { "hebraico": "וַאֲנִי", "transliteral": "wa-ʾă-nî", "traducao_palavra": "e eu" },
        { "hebraico": "בְּבֹאִי", "transliteral": "bə-ḇō-ʾî", "traducao_palavra": "vindo eu" },
        { "hebraico": "מִפַּדָּן", "transliteral": "mip-pad-dān", "traducao_palavra": "de Padã" },
        { "hebraico": "מֵתָה", "transliteral": "mē-ṯā", "traducao_palavra": "morreu" },
        { "hebraico": "עָלַי", "transliteral": "ʿā-lay", "traducao_palavra": "em relação a mim" },
        { "hebraico": "רָחֵל", "transliteral": "rā-ḥēl", "traducao_palavra": "Raquel" },
        { "hebraico": "בְּאֶרֶץ", "transliteral": "bə-ʾe-reṣ", "traducao_palavra": "na terra de" },
        { "hebraico": "כְּנַעַן", "transliteral": "kə-na-ʿan", "traducao_palavra": "Canaã" },
        { "hebraico": "בַּדֶּרֶךְ", "transliteral": "bad-de-reḵ", "traducao_palavra": "no caminho" },
        { "hebraico": "בְּעוֹד", "transliteral": "bə-ʿôḏ", "traducao_palavra": "havendo ainda" },
        { "hebraico": "כִּבְרַת־אֶרֶץ", "transliteral": "kiḇ-raṯ-ʾe-reṣ", "traducao_palavra": "distância de terra" },
        { "hebraico": "לָבֹא", "transliteral": "lā-ḇō", "traducao_palavra": "para chegar" },
        { "hebraico": "אֶפְרָתָה", "transliteral": "ʾep̄-rā-ṯā", "traducao_palavra": "[a] Efrata" },
        { "hebraico": "וָאֶקְבְּרֶהָ", "transliteral": "wā-ʾeq-bə-re-hā", "traducao_palavra": "e sepultei-a" },
        { "hebraico": "שָּׁם", "transliteral": "šām", "traducao_palavra": "ali" },
        { "hebraico": "בְּדֶרֶךְ", "transliteral": "bə-ḏe-reḵ", "traducao_palavra": "no caminho de" },
        { "hebraico": "אֶפְרָת", "transliteral": "ʾep̄-rāṯ", "traducao_palavra": "Efrata" },
        { "hebraico": "הִוא", "transliteral": "hî", "traducao_palavra": "ela [é]" },
        { "hebraico": "בֵּית־לָחֶם׃", "transliteral": "bêṯ-lā-ḥem", "traducao_palavra": "Belém" }
      ]
    },
    "8": {
      "traducao_completa": "E viu Israel os filhos de José e disse: Quem são estes?",
      "palavras": [
        { "hebraico": "וַיַּרְא", "transliteral": "way-yarʾ", "traducao_palavra": "e viu" },
        { "hebraico": "יִשְׂרָאֵל", "transliteral": "yiś-rā-ʾēl", "traducao_palavra": "Israel" },
        { "hebraico": "אֶת־בְּנֵי", "transliteral": "ʾeṯ-bə-nê", "traducao_palavra": "[os] filhos de" },
        { "hebraico": "יוֹסֵף", "transliteral": "yô-sēp̄", "traducao_palavra": "José" },
        { "hebraico": "וַיֹּאמֶר", "transliteral": "way-yō-mer", "traducao_palavra": "e disse" },
        { "hebraico": "מִי־אֵלֶּה׃", "transliteral": "mî-ʾēl-leh", "traducao_palavra": "quem [são] estes?" }
      ]
    },
    "9": {
      "traducao_completa": "E disse José a seu pai: Eles são meus filhos, que Deus me deu aqui. E ele disse: Trazei-os, peço-te, a mim, para que eu os abençoe.",
      "palavras": [
        { "hebraico": "וַיֹּאמֶר", "transliteral": "way-yō-mer", "traducao_palavra": "e disse" },
        { "hebraico": "יוֹסֵף", "transliteral": "yô-sēp̄", "traducao_palavra": "José" },
        { "hebraico": "אֶל־אָבִיו", "transliteral": "ʾel-ʾā-ḇîw", "traducao_palavra": "a seu pai" },
        { "hebraico": "בָּנַי", "transliteral": "bā-nay", "traducao_palavra": "meus filhos" },
        { "hebraico": "הֵם", "transliteral": "hēm", "traducao_palavra": "[são] eles" },
        { "hebraico": "אֲשֶׁר־נָתַן־לִי", "transliteral": "ʾă-šer-nā-ṯan-lî", "traducao_palavra": "que deu para mim" },
        { "hebraico": "אֱלֹהִים", "transliteral": "ʾĕ-lō-hîm", "traducao_palavra": "Deus" },
        { "hebraico": "בָּזֶה", "transliteral": "bā-zeh", "traducao_palavra": "aqui" },
        { "hebraico": "וַיֹּאמַר", "transliteral": "way-yō-mer", "traducao_palavra": "e disse" },
        { "hebraico": "קָחֶם־נָא", "transliteral": "qā-ḥem-nā", "traducao_palavra": "trazei-os peço" },
        { "hebraico": "אֵלַי", "transliteral": "ʾē-lay", "traducao_palavra": "a mim" },
        { "hebraico": "וַאֲבָרְכֵם׃", "transliteral": "wa-ʾă-ḇā-rə-ḵēm", "traducao_palavra": "e abençoarei a eles" }
      ]
    },
    "10": {
      "traducao_completa": "E os olhos de Israel estavam pesados de velhice, não podia ver; e José os fez chegar a ele, e ele os beijou e os abraçou.",
      "palavras": [
        { "hebraico": "וְעֵינֵי", "transliteral": "wə-ʿê-nê", "traducao_palavra": "e os olhos de" },
        { "hebraico": "יִשְׂרָאֵל", "transliteral": "yiś-rā-ʾēl", "traducao_palavra": "Israel" },
        { "hebraico": "כָּבְדוּ", "transliteral": "kā-ḇə-ḏû", "traducao_palavra": "pesaram [estavam pesados]" },
        { "hebraico": "מִזֹּקֶן", "transliteral": "miz-zō-qen", "traducao_palavra": "da velhice" },
        { "hebraico": "לֹא", "transliteral": "lō", "traducao_palavra": "não" },
        { "hebraico": "יוּכַל", "transliteral": "yû-ḵal", "traducao_palavra": "podia" },
        { "hebraico": "לִרְאוֹת", "transliteral": "lir-ʾôṯ", "traducao_palavra": "ver" },
        { "hebraico": "וַיַּגֵּשׁ", "transliteral": "way-yag-gēš", "traducao_palavra": "e fez chegar" },
        { "hebraico": "אֹתָם", "transliteral": "ʾō-ṯām", "traducao_palavra": "a eles" },
        { "hebraico": "אֵלָיו", "transliteral": "ʾē-lāw", "traducao_palavra": "a ele" },
        { "hebraico": "וַיִּשַּׁק", "transliteral": "way-yiš-šaq", "traducao_palavra": "e beijou" },
        { "hebraico": "לָהֶם", "transliteral": "lā-hem", "traducao_palavra": "a eles" },
        { "hebraico": "וַיְחַבֵּק", "transliteral": "way-ḥab-bēq", "traducao_palavra": "e abraçou" },
        { "hebraico": "לָהֶם׃", "transliteral": "lā-hem", "traducao_palavra": "a eles" }
      ]
    },
    "11": {
      "traducao_completa": "E disse Israel a José: Eu não esperava ver a tua face; e eis que Deus me fez ver também a tua descendência.",
