        { "hebraico": "הַזֶּה׃", "transliteral": "haz-zeh", "traducao_palavra": "este" }
      ]
    },
    "16": {
      "traducao_completa": "O anjo que me remiu de todo o mal, abençoe estes meninos; e seja chamado neles o meu nome e o nome de meus pais Abraão e Isaque; e multipliquem-se em multidão no meio da terra.",
      "palavras": [
