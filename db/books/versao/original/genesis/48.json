        { "hebraico": "יִהְיֶה־לְּעָם", "transliteral": "yih-yeh-lə-ʿām", "traducao_palavra": "será por povo" },
        { "hebraico": "וְגַם־הוּא", "transliteral": "wə-ḡam-hû", "traducao_palavra": "e também ele" },
        { "hebraico": "יִגְדָּל", "transliteral": "yiḡ-dāl", "traducao_palavra": "será grande" },
        { "hebraico": "וְאוּלָם", "transliteral": "wə-ʾû-lām", "traducao_palavra": "contudo/mas" },
        { "hebraico": "אָחִיו", "transliteral": "ʾā-ḥîw", "traducao_palavra": "seu irmão" },
        { "hebraico": "הַקָּטֹן", "transliteral": "haq-qā-ṭōn", "traducao_palavra": "o menor" },
