        { "hebraico": "חֹלֶה", "transliteral": "ḥō-leh", "traducao_palavra": "[está] doente" },
        { "hebraico": "וַיִּקַּח", "transliteral": "way-yiq-qaḥ", "traducao_palavra": "e tomou" },
        { "hebraico": "אֶת־שְׁנֵי", "transliteral": "ʾeṯ-šə-nê", "traducao_palavra": "[os] dois de" },
        { "hebraico": "בָנָיו", "transliteral": "ḇā-nāw", "traducao_palavra": "seus filhos" },
        { "hebraico": "עִמּוֹ", "transliteral": "ʿim-mô", "traducao_palavra": "com ele" },
        { "hebraico": "אֶת־מְנַשֶּׁה", "transliteral": "ʾeṯ-mə-naš-šeh", "traducao_palavra": "Manassés" },
        { "hebraico": "וְאֶת־אֶפְרָיִם׃", "transliteral": "wə-ʾeṯ-ʾep̄-rā-yim", "traducao_palavra": "e Efraim" }
      ]
    },
    "2": {
      "traducao_completa": "E foi anunciado a Jacó, e disse-lhe: Eis que o teu filho José vem a ti; e esforçou-se Israel e assentou-se sobre a cama.",
      "palavras": [
