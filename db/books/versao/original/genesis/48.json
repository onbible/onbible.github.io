        { "hebraico": "עַל־רֹאשׁ", "transliteral": "ʿal-rōš", "traducao_palavra": "para a cabeça de" },
        { "hebraico": "מְנַשֶּׁה׃", "transliteral": "mə-naš-šeh", "traducao_palavra": "Manassés" }
      ]
    },
    "18": {
