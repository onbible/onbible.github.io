{
  "livro": "Gênesis - בְּרֵאשִׁית - Bereshit",
  "capítulo": 48,
  "titulos": {},
  "versiculos": {
    "1": {
      "traducao_completa": "E aconteceu depois destas coisas que disseram a José: Eis que teu pai está doente; e ele tomou consigo os seus dois filhos, Manassés e Efraim.",
      "palavras": [
        { "hebraico": "וַיְהִי", "transliteral": "way-hî", "traducao_palavra": "e aconteceu" },
        { "hebraico": "אַחֲרֵי", "transliteral": "ʾa-ḥă-rê", "traducao_palavra": "depois de" },
        { "hebraico": "הַדְּבָרִים", "transliteral": "had-də-ḇā-rîm", "traducao_palavra": "as coisas" },
        { "hebraico": "הָאֵלֶּה", "transliteral": "hā-ʾēl-leh", "traducao_palavra": "estas" },
        { "hebraico": "וַיֹּאמֶר", "transliteral": "way-yō-mer", "traducao_palavra": "e disse [alguém]" },
        { "hebraico": "לְיוֹסֵף", "transliteral": "lə-yô-sēp̄", "traducao_palavra": "a José" },
        { "hebraico": "הִנֵּה", "transliteral": "hin-nēh", "traducao_palavra": "eis que" },
