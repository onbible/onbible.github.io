        { "hebraico": "עַל־הַמִּטָּה׃", "transliteral": "ʿal-ham-miṭ-ṭā", "traducao_palavra": "sobre a cama" }
      ]
    },
    "3": {
      "traducao_completa": "E disse Jacó a José: O Deus Todo-Poderoso apareceu-me em Luz, na terra de Canaã, e abençoou-me.",
      "palavras": [
        { "hebraico": "וַיֹּאמֶר", "transliteral": "way-yō-mer", "traducao_palavra": "e disse" },
        { "hebraico": "יַעֲקֹב", "transliteral": "ya-ʿă-qōḇ", "traducao_palavra": "Jacó" },
        { "hebraico": "אֶל־יוֹסֵף", "transliteral": "ʾel-yô-sēp̄", "traducao_palavra": "a José" },
        { "hebraico": "אֵל", "transliteral": "ʾēl", "traducao_palavra": "Deus" },
        { "hebraico": "שַׁדַּי", "transliteral": "šad-day", "traducao_palavra": "Todo-Poderoso" },
        { "hebraico": "נִרְאָה־אֵלַי", "transliteral": "nir-ʾā-ʾē-lay", "traducao_palavra": "apareceu a mim" },
        { "hebraico": "בְּלוּז", "transliteral": "bə-lûz", "traducao_palavra": "em Luz" },
        { "hebraico": "בְּאֶרֶץ", "transliteral": "bə-ʾe-reṣ", "traducao_palavra": "na terra de" },
        { "hebraico": "כְּנָעַן", "transliteral": "kə-nā-ʿan", "traducao_palavra": "Canaã" },
        { "hebraico": "וַיְבָרֶךְ", "transliteral": "way-ḇā-reḵ", "traducao_palavra": "e abençoou" },
        { "hebraico": "אֹתִי׃", "transliteral": "ʾō-ṯî", "traducao_palavra": "a mim" }
      ]
    },
    "4": {
      "traducao_completa": "E disse-me: Eis que eu te farei frutificar, e te multiplicarei, e te porei por multidão de povos; e darei esta terra à tua descendência depois de ti, em possessão eterna.",
      "palavras": [
        { "hebraico": "וַיֹּאמֶר", "transliteral": "way-yō-mer", "traducao_palavra": "e disse" },
        { "hebraico": "אֵלַי", "transliteral": "ʾē-lay", "traducao_palavra": "a mim" },
        { "hebraico": "הִנְנִי", "transliteral": "hin-nə-nî", "traducao_palavra": "eis que eu" },
        { "hebraico": "מַפְרְךָ", "transliteral": "map̄-rə-ḵā", "traducao_palavra": "te fazendo frutificar" },
        { "hebraico": "וְהִרְבִּיתִךָ", "transliteral": "wə-hir-bî-ṯî-ḵā", "traducao_palavra": "e te multiplicarei" },
        { "hebraico": "וּנְתַתִּיךָ", "transliteral": "û-nə-ṯat-tî-ḵā", "traducao_palavra": "e te porei" },
        { "hebraico": "לִקְהַל", "transliteral": "liq-hal", "traducao_palavra": "por assembleia/multidão de" },
        { "hebraico": "עַמִּים", "transliteral": "ʿam-mîm", "traducao_palavra": "povos" },
        { "hebraico": "וְנָתַתִּי", "transliteral": "wə-nā-ṯat-tî", "traducao_palavra": "e darei" },
        { "hebraico": "אֶת־הָאָרֶץ", "transliteral": "ʾeṯ-hā-ʾā-reṣ", "traducao_palavra": "a terra" },
        { "hebraico": "הַזֹּאת", "transliteral": "haz-zōṯ", "traducao_palavra": "esta" },
        { "hebraico": "לְזַרְעֲךָ", "transliteral": "lə-zar-ʿă-ḵā", "traducao_palavra": "à tua semente" },
        { "hebraico": "אַחֲרֶיךָ", "transliteral": "ʾa-ḥă-rê-ḵā", "traducao_palavra": "depois de ti" },
