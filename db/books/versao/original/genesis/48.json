        { "hebraico": "וְשֵׁם", "transliteral": "wə-šēm", "traducao_palavra": "e [o] nome de" },
        { "hebraico": "אֲבֹתַי", "transliteral": "ă-ḇō-ṯay", "traducao_palavra": "meus pais" },
        { "hebraico": "אַבְרָהָם", "transliteral": "ʾaḇ-rā-hām", "traducao_palavra": "Abraão" },
        { "hebraico": "וְיִצְחָק", "transliteral": "wə-yiṣ-ḥāq", "traducao_palavra": "e Isaque" },
        { "hebraico": "וְיִדְגּוּ", "transliteral": "wə-yiḏ-gû", "traducao_palavra": "e multipliquem-se [como peixes]" },
        { "hebraico": "לָרֹב", "transliteral": "lā-rōḇ", "traducao_palavra": "em multidão" },
