        { "hebraico": "וַיִּתְמֹךְ", "transliteral": "way-yiṯ-mōḵ", "traducao_palavra": "e segurou/tomou" },
        { "hebraico": "יַד־אָבִיו", "transliteral": "yaḏ-ʾā-ḇîw", "traducao_palavra": "[a] mão de seu pai" },
        { "hebraico": "לְהָסִיר", "transliteral": "lə-hā-śîr", "traducao_palavra": "para tirar" },
        { "hebraico": "אֹתָהּ", "transliteral": "ʾō-ṯāh", "traducao_palavra": "a ela [mão]" },
        { "hebraico": "מֵעַל", "transliteral": "mē-ʿal", "traducao_palavra": "de sobre" },
