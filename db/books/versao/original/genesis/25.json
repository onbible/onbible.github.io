        { "hebraico": "וְאֵ֨לֶּה", "transliteral": "wəʾēlleh", "traducao_palavra": "e estes" },
        { "hebraico": "שְׁמֹ֤ת", "transliteral": "šəmōṯ", "traducao_palavra": "nomes de" },
        { "hebraico": "בְּנֵי", "transliteral": "bənê", "traducao_palavra": "filhos de" },
