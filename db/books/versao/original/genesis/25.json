        { "hebraico": "וְאֶלְדָּעָ֑ה", "transliteral": "wəʾeldāʿâ", "traducao_palavra": "e Elda" },
        { "hebraico": "כָּל־אֵ֖לֶּה", "transliteral": "kāl-ʾēlleh", "traducao_palavra": "todos estes" },
        { "hebraico": "בְּנֵ֥י", "transliteral": "bənê", "traducao_palavra": "filhos de" },
        { "hebraico": "קְטוּרָֽה׃", "transliteral": "qəṭûrâ", "traducao_palavra": "Quetura" }
      ]
    },
    "5": {
      "traducao_completa": "E deu Abraão tudo o que a ele [pertencia] a Isaque.",
      "palavras": [
        { "hebraico": "וַיִּתֵּ֧ן", "transliteral": "wayyittēn", "traducao_palavra": "e deu" },
        { "hebraico": "אַבְרָהָ֛ם", "transliteral": "ʾaḇrāhām", "traducao_palavra": "Abraão" },
        { "hebraico": "אֶת־כָּל־אֲשֶׁר־ל֖וֹ", "transliteral": "ʾeṯ-kāl-ʾăšer-lô", "traducao_palavra": "tudo o que a ele" },
        { "hebraico": "לְיִצְחָֽק׃", "transliteral": "ləyiṣḥāq", "traducao_palavra": "a Isaque" }
      ]
    },
    "6": {
      "traducao_completa": "E aos filhos das concubinas que Abraão [tinha], deu Abraão presentes; e enviou-os de sobre Isaque, seu filho, enquanto ele [ainda] vivia, para o oriente, para a terra do oriente.",
      "palavras": [
        { "hebraico": "וְלִבְנֵ֤י", "transliteral": "wəliḇnê", "traducao_palavra": "e aos filhos de" },
        { "hebraico": "הַפִּֽילַגְשִׁים֙", "transliteral": "happîlaḡšîm", "traducao_palavra": "as concubinas" },
        { "hebraico": "אֲשֶׁ֣ר", "transliteral": "ʾăšer", "traducao_palavra": "que" },
        { "hebraico": "לְאַבְרָהָ֔ם", "transliteral": "ləʾaḇrāhām", "traducao_palavra": "a Abraão" },
        { "hebraico": "נָתַ֥ן", "transliteral": "nāṯan", "traducao_palavra": "deu" },
        { "hebraico": "אַבְרָהָ֖ם", "transliteral": "ʾaḇrāhām", "traducao_palavra": "Abraão" },
        { "hebraico": "מַתָּנֹ֑ת", "transliteral": "mattānōṯ", "traducao_palavra": "presentes" },
        { "hebraico": "וַֽיְשַׁלְּחֵ֞ם", "transliteral": "wayšalləḥēm", "traducao_palavra": "e enviou-os" },
        { "hebraico": "מֵעַ֨ל", "transliteral": "mēʿal", "traducao_palavra": "de sobre/afastado de" },
        { "hebraico": "יִצְחָ֤ק", "transliteral": "yiṣḥāq", "traducao_palavra": "Isaque" },
        { "hebraico": "בְּנוֹ֙", "transliteral": "bənô", "traducao_palavra": "seu filho" },
        { "hebraico": "בְּעוֹדֶ֣נּוּ", "transliteral": "bəʿôḏennû", "traducao_palavra": "em ainda ele/enquanto vivia" },
        { "hebraico": "חַ֔י", "transliteral": "ḥay", "traducao_palavra": "vivo" },
        { "hebraico": "קֵ֖דְמָה", "transliteral": "qēḏmâ", "traducao_palavra": "ao oriente" },
        { "hebraico": "אֶל־אֶ֥רֶץ", "transliteral": "ʾel-ʾereṣ", "traducao_palavra": "para terra de" },
        { "hebraico": "קֶֽדֶם׃", "transliteral": "qeḏem", "traducao_palavra": "oriente" }
      ]
    },
    "7": {
      "traducao_completa": "E estes [são] os dias dos anos da vida de Abraão que viveu: cem anos e setenta anos e cinco anos.",
      "palavras": [
        { "hebraico": "וְאֵ֗לֶּה", "transliteral": "wəʾēlleh", "traducao_palavra": "e estes" },
        { "hebraico": "יְמֵ֛י", "transliteral": "yəmê", "traducao_palavra": "dias de" },
        { "hebraico": "שְׁנֵ֥י", "transliteral": "šənê", "traducao_palavra": "anos de" },
        { "hebraico": "חַיֵּֽי־אַבְרָהָ֖ם", "transliteral": "ḥayyê-ʾaḇrāhām", "traducao_palavra": "vida de Abraão" },
        { "hebraico": "אֲשֶׁר־חָ֑י", "transliteral": "ʾăšer-ḥāy", "traducao_palavra": "que viveu" },
