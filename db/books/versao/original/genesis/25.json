        { "hebraico": "הִשָּׁבְעָה", "transliteral": "hiššāḇəʿâ", "traducao_palavra": "jura" },
        { "hebraico": "לִּי֙", "transliteral": "lî", "traducao_palavra": "a mim" },
        { "hebraico": "כַּיּ֔וֹם", "transliteral": "kayyôm", "traducao_palavra": "hoje" },
