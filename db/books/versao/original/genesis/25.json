        { "hebraico": "זָקֵ֣ן", "transliteral": "zāqēn", "traducao_palavra": "velho" },
        { "hebraico": "וְשָׂבֵ֑עַ", "transliteral": "wəśāḇēaʿ", "traducao_palavra": "e farto/satisfeito" },
