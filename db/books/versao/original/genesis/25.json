        { "hebraico": "עֵשָׂ֔ו", "transliteral": "ʿēśāw", "traducao_palavra": "Esaú" },
        { "hebraico": "הִנֵּ֛ה", "transliteral": "hinnē", "traducao_palavra": "eis" },
        { "hebraico": "אָנֹכִ֥י", "transliteral": "ʾānōḵî", "traducao_palavra": "eu" },
        { "hebraico": "הוֹלֵ֖ךְ", "transliteral": "hōlēḵ", "traducao_palavra": "indo" },
        { "hebraico": "לָמ֑וּת", "transliteral": "lāmûṯ", "traducao_palavra": "para morrer" },
        { "hebraico": "וְלָמָּה־זֶּ֥ה", "transliteral": "wəlāmmâ-zzeh", "traducao_palavra": "e para que isto" },
