      ]
    },
    "9": {
      "traducao_completa": "E sepultaram-no Isaque e Ismael, seus filhos, na caverna de Macpela; no campo de Efrom, filho de Zoar, o hitita, que [está] diante de Manre.",
      "palavras": [
        { "hebraico": "וַיִּקְבְּר֨וּ", "transliteral": "wayyiqbərû", "traducao_palavra": "e sepultaram" },
        { "hebraico": "אֹת֜וֹ", "transliteral": "ʾōṯô", "traducao_palavra": "o" },
        { "hebraico": "יִצְחָ֤ק", "transliteral": "yiṣḥāq", "traducao_palavra": "Isaque" },
        { "hebraico": "וְיִשְׁמָעֵאל֙", "transliteral": "wəyišmāʿēl", "traducao_palavra": "e Ismael" },
