      ]
    },
    "29": {
      "traducao_completa": "E cozinhou Jacó um cozido; e veio Esaú do campo, e ele [estava] exausto.",
      "palavras": [
        { "hebraico": "וַיָּ֥זֶד", "transliteral": "wayyāzeḏ", "traducao_palavra": "e cozinhou/ferveu" },
        { "hebraico": "יַעֲקֹ֖ב", "transliteral": "yaʿăqōḇ", "traducao_palavra": "Jacó" },
        { "hebraico": "נָזִ֑יד", "transliteral": "nāzîḏ", "traducao_palavra": "cozido" },
        { "hebraico": "וַיָּבֹ֥א", "transliteral": "wayyāḇōʾ", "traducao_palavra": "e veio" },
        { "hebraico": "עֵשָׂ֛ו", "transliteral": "ʿēśāw", "traducao_palavra": "Esaú" },
        { "hebraico": "מִן־הַשָּׂדֶ֖ה", "transliteral": "min-haśśāḏeh", "traducao_palavra": "do campo" },
        { "hebraico": "וְה֥וּא", "transliteral": "wəhûʾ", "traducao_palavra": "e ele" },
        { "hebraico": "עָיֵֽף׃", "transliteral": "ʿāyēp̄", "traducao_palavra": "exausto" }
      ]
    },
    "30": {
      "traducao_completa": "E disse Esaú a Jacó: Dá-me a engolir, rogo-te, desse vermelho, desse vermelho, pois exausto [estou] eu; por isso chamou seu nome Edom.",
      "palavras": [
        { "hebraico": "וַיֹּ֨אמֶר", "transliteral": "wayyōʾmer", "traducao_palavra": "e disse" },
        { "hebraico": "עֵשָׂ֜ו", "transliteral": "ʿēśāw", "traducao_palavra": "Esaú" },
        { "hebraico": "אֶל־יַעֲקֹ֗ב", "transliteral": "ʾel-yaʿăqōḇ", "traducao_palavra": "a Jacó" },
        { "hebraico": "הַלְעִיטֵ֤נִי", "transliteral": "halʿîṭēnî", "traducao_palavra": "dá-me a engolir" },
        { "hebraico": "נָא֙", "transliteral": "nāʾ", "traducao_palavra": "rogo-te" },
        { "hebraico": "מִן־הָאָדֹ֤ם", "transliteral": "min-hāʾāḏōm", "traducao_palavra": "do vermelho" },
        { "hebraico": "הָאָדֹם֙", "transliteral": "hāʾāḏōm", "traducao_palavra": "o vermelho" },
        { "hebraico": "הַזֶּ֔ה", "transliteral": "hazzeh", "traducao_palavra": "este" },
        { "hebraico": "כִּ֥י", "transliteral": "kî", "traducao_palavra": "pois" },
        { "hebraico": "עָיֵ֖ף", "transliteral": "ʿāyēp̄", "traducao_palavra": "exausto" },
        { "hebraico": "אָנֹ֑כִי", "transliteral": "ʾānōḵî", "traducao_palavra": "eu" },
        { "hebraico": "עַל־כֵּ֥ן", "transliteral": "ʿal-kēn", "traducao_palavra": "por isso" },
        { "hebraico": "קָרָֽא־שְׁמ֖וֹ", "transliteral": "qārāʾ-šəmô", "traducao_palavra": "chamou seu nome" },
        { "hebraico": "אֱדֽוֹם׃", "transliteral": "ʾĕḏôm", "traducao_palavra": "Edom" }
