{
  "livro": "Gênesis - בְּרֵאשִׁית - Bereshit",
  "capítulo": 25,
  "titulos": {},
  "versiculos": {
    "1": {
      "traducao_completa": "E acrescentou Abraão e tomou mulher, e seu nome [era] Quetura.",
      "palavras": [
        { "hebraico": "וַיֹּ֧סֶף", "transliteral": "wayyōsep̄", "traducao_palavra": "e acrescentou" },
        { "hebraico": "אַבְרָהָ֛ם", "transliteral": "ʾaḇrāhām", "traducao_palavra": "Abraão" },
        { "hebraico": "וַיִּקַּ֥ח", "transliteral": "wayyiqqaḥ", "traducao_palavra": "e tomou" },
        { "hebraico": "אִשָּׁ֖ה", "transliteral": "ʾiššâ", "traducao_palavra": "mulher" },
        { "hebraico": "וּשְׁמָ֥הּ", "transliteral": "ûšəmāh", "traducao_palavra": "e seu nome" },
        { "hebraico": "קְטוּרָֽה׃", "transliteral": "qəṭûrâ", "traducao_palavra": "Quetura" }
      ]
    },
    "2": {
      "traducao_completa": "E ela deu à luz para ele a Zinrã, e a Jocsã, e a Medã, e a Midiã, e a Isbaque, e a Suá.",
      "palavras": [
        { "hebraico": "וַתֵּ֨לֶד", "transliteral": "wattēleḏ", "traducao_palavra": "e ela deu à luz" },
        { "hebraico": "לּ֜וֹ", "transliteral": "lô", "traducao_palavra": "para ele" },
        { "hebraico": "אֶת־זִמְרָן֙", "transliteral": "ʾeṯ-zimrān", "traducao_palavra": "a Zinrã" },
        { "hebraico": "וְאֶת־יָקְשָׁ֔ן", "transliteral": "wəʾeṯ-yoqšān", "traducao_palavra": "e a Jocsã" },
        { "hebraico": "וְאֶת־מְדָ֖ן", "transliteral": "wəʾeṯ-məḏān", "traducao_palavra": "e a Medã" },
        { "hebraico": "וְאֶת־מִדְיָ֑ן", "transliteral": "wəʾeṯ-miḏyān", "traducao_palavra": "e a Midiã" },
        { "hebraico": "וְאֶת־יִשְׁבָּ֖ק", "transliteral": "wəʾeṯ-yišbāq", "traducao_palavra": "e a Isbaque" },
        { "hebraico": "וְאֶת־שֽׁוּחַ׃", "transliteral": "wəʾeṯ-šûaḥ", "traducao_palavra": "e a Suá" }
      ]
    },
    "3": {
      "traducao_completa": "E Jocsã gerou a Sebá e a Dedã; e os filhos de Dedã foram Assurim, e Letusim, e Leumim.",
      "palavras": [
        { "hebraico": "וְיָקְשָׁ֣ן", "transliteral": "wəyoqšān", "traducao_palavra": "e Jocsã" },
        { "hebraico": "יָלַ֔ד", "transliteral": "yālaḏ", "traducao_palavra": "gerou" },
        { "hebraico": "אֶת־שְׁבָ֖א", "transliteral": "ʾeṯ-šəḇāʾ", "traducao_palavra": "a Sebá" },
        { "hebraico": "וְאֶת־דְּדָ֑ן", "transliteral": "wəʾeṯ-dəḏān", "traducao_palavra": "e a Dedã" },
        { "hebraico": "וּבְנֵ֣י", "transliteral": "ûḇənê", "traducao_palavra": "e filhos de" },
        { "hebraico": "דְדָ֔ן", "transliteral": "dəḏān", "traducao_palavra": "Dedã" },
        { "hebraico": "הָי֥וּ", "transliteral": "hāyû", "traducao_palavra": "foram" },
        { "hebraico": "אַשּׁוּרִ֛ם", "transliteral": "ʾaššûrîm", "traducao_palavra": "Assurim" },
        { "hebraico": "וּלְטוּשִׁ֖ים", "transliteral": "ûləṭûšîm", "traducao_palavra": "e Letusim" },
        { "hebraico": "וּלְאֻמִּֽים׃", "transliteral": "ûləʾummîm", "traducao_palavra": "e Leumim" }
