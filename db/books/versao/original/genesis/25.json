    "11": {
      "traducao_completa": "E foi, depois da morte de Abraão, que abençoou Deus a Isaque, seu filho; e habitou Isaque com Beer-Laai-Roi.",
      "palavras": [
        { "hebraico": "וַיְהִ֗י", "transliteral": "wayhî", "traducao_palavra": "e foi" },
        { "hebraico": "אַחֲרֵי֙", "transliteral": "ʾaḥărê", "traducao_palavra": "depois de" },
        { "hebraico": "מ֣וֹת", "transliteral": "môṯ", "traducao_palavra": "morte de" },
        { "hebraico": "אַבְרָהָ֔ם", "transliteral": "ʾaḇrāhām", "traducao_palavra": "Abraão" },
        { "hebraico": "וַיְבָ֥רֶךְ", "transliteral": "wayḇāreḵ", "traducao_palavra": "e abençoou" },
        { "hebraico": "אֱלֹהִ֖ים", "transliteral": "ʾĕlōhîm", "traducao_palavra": "Deus" },
        { "hebraico": "אֶת־יִצְחָ֣ק", "transliteral": "ʾeṯ-yiṣḥāq", "traducao_palavra": "a Isaque" },
        { "hebraico": "בְּנ֑וֹ", "transliteral": "bənô", "traducao_palavra": "seu filho" },
        { "hebraico": "וַיֵּ֣שֶׁב", "transliteral": "wayyēšeḇ", "traducao_palavra": "e habitou" },
        { "hebraico": "יִצְחָ֔ק", "transliteral": "yiṣḥāq", "traducao_palavra": "Isaque" },
        { "hebraico": "עִם־בְּאֵ֥ר", "transliteral": "ʿim-bəʾēr", "traducao_palavra": "com poço de" },
        { "hebraico": "לַחַ֥י", "transliteral": "laḥay", "traducao_palavra": "o Vivo" },
        { "hebraico": "רֹאִֽי׃", "transliteral": "rōʾî", "traducao_palavra": "que me vê" }
