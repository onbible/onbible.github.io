    },
    "4": {
      "traducao_completa": "E os filhos de Midiã: Efá, e Efer, e Enoque, e Abida, e Elda; todos estes [foram] filhos de Quetura.",
      "palavras": [
        { "hebraico": "וּבְנֵ֣י", "transliteral": "ûḇənê", "traducao_palavra": "e filhos de" },
        { "hebraico": "מִדְיָ֗ן", "transliteral": "miḏyān", "traducao_palavra": "Midiã" },
        { "hebraico": "עֵיפָ֤ה", "transliteral": "ʿêp̄â", "traducao_palavra": "Efá" },
        { "hebraico": "וָעֵ֨פֶר֙", "transliteral": "wāʿēp̄er", "traducao_palavra": "e Efer" },
        { "hebraico": "וַחֲנֹ֔ךְ", "transliteral": "waḥănōḵ", "traducao_palavra": "e Enoque" },
