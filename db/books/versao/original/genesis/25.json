        { "hebraico": "שָׂרָ֔ה", "transliteral": "śārâ", "traducao_palavra": "Sara" },
        { "hebraico": "לְאַבְרָהָֽם׃", "transliteral": "ləʾaḇrāhām", "traducao_palavra": "para Abraão" }
      ]
    },
    "13": {
      "traducao_completa": "E estes [são] os nomes dos filhos de Ismael por seus nomes, pelas suas gerações: o primogênito de Ismael, Nebaiote; e Quedar, e Adbeel, e Mibsão.",
