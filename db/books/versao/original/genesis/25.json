        { "hebraico": "הַֽחִתִּ֔י", "transliteral": "haḥittî", "traducao_palavra": "o hitita" },
        { "hebraico": "אֲשֶׁ֖ר", "transliteral": "ʾăšer", "traducao_palavra": "que" },
        { "hebraico": "עַל־פְּנֵ֥י", "transliteral": "ʿal-pənê", "traducao_palavra": "diante de" },
        { "hebraico": "מַמְרֵֽא׃", "transliteral": "mamrē", "traducao_palavra": "Manre" }
      ]
    },
    "10": {
      "traducao_completa": "O campo que comprou Abraão dos filhos de Hete; ali foi sepultado Abraão e Sara, sua mulher.",
      "palavras": [
        { "hebraico": "הַשָּׂדֶ֛ה", "transliteral": "haśśāḏeh", "traducao_palavra": "o campo" },
        { "hebraico": "אֲשֶׁר־קָנָ֥ה", "transliteral": "ʾăšer-qānâ", "traducao_palavra": "que comprou" },
        { "hebraico": "אַבְרָהָ֖ם", "transliteral": "ʾaḇrāhām", "traducao_palavra": "Abraão" },
        { "hebraico": "מֵאֵ֣ת", "transliteral": "mēʾēṯ", "traducao_palavra": "de/da parte de" },
