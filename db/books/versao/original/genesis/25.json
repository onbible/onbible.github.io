        { "hebraico": "שָׁ֛מָּה", "transliteral": "šāmmâ", "traducao_palavra": "ali" },
        { "hebraico": "קֻבַּ֥ר", "transliteral": "qubbar", "traducao_palavra": "foi sepultado" },
