    "31": {
      "traducao_completa": "E disse Jacó: Vende-me hoje a tua primogenitura.",
      "palavras": [
        { "hebraico": "וַיֹּ֖אמֶר", "transliteral": "wayyōʾmer", "traducao_palavra": "e disse" },
        { "hebraico": "יַעֲקֹ֑ב", "transliteral": "yaʿăqōḇ", "traducao_palavra": "Jacó" },
        { "hebraico": "מִכְרָ֥ה", "transliteral": "miḵrâ", "traducao_palavra": "vende" },
        { "hebraico": "כַיּ֛וֹם", "transliteral": "ḵayyôm", "traducao_palavra": "hoje" },
        { "hebraico": "אֶת־בְּכֹרָתְךָ֖", "transliteral": "ʾeṯ-bəḵōrāṯəḵā", "traducao_palavra": "tua primogenitura" },
        { "hebraico": "לִֽי׃", "transliteral": "lî", "traducao_palavra": "a mim" }
