        { "hebraico": "אֶל־מְעָרַ֖ת", "transliteral": "ʾel-məʿāraṯ", "traducao_palavra": "na caverna de" },
        { "hebraico": "הַמַּכְפֵּלָ֑ה", "transliteral": "hammāḵpēlâ", "traducao_palavra": "Macpela" },
        { "hebraico": "אֶל־שְׂדֵ֞ה", "transliteral": "ʾel-śəḏē", "traducao_palavra": "no campo de" },
        { "hebraico": "עֶפְרֹ֤ן", "transliteral": "ʿep̄rōn", "traducao_palavra": "Efrom" },
