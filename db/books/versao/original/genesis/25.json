    "12": {
      "traducao_completa": "E estas [são] as gerações de Ismael, filho de Abraão, que deu à luz Agar, a egípcia, serva de Sara, para Abraão.",
      "palavras": [
        { "hebraico": "וְאֵ֨לֶּה", "transliteral": "wəʾēlleh", "traducao_palavra": "e estas" },
        { "hebraico": "תֹּלְדֹ֣ת", "transliteral": "tōləḏōṯ", "traducao_palavra": "gerações de" },
        { "hebraico": "יִשְׁמָעֵאל֮", "transliteral": "yišmāʿēl", "traducao_palavra": "Ismael" },
        { "hebraico": "בֶּן־אַבְרָהָם֒", "transliteral": "ben-ʾaḇrāhām", "traducao_palavra": "filho de Abraão" },
        { "hebraico": "אֲשֶׁ֨ר", "transliteral": "ʾăšer", "traducao_palavra": "que" },
        { "hebraico": "יָלְדָ֨ה", "transliteral": "yāləḏâ", "traducao_palavra": "deu à luz" },
        { "hebraico": "הָגָ֧ר", "transliteral": "hāḡār", "traducao_palavra": "Agar" },
        { "hebraico": "הַמִּצְרִית֙", "transliteral": "hammiṣrîṯ", "traducao_palavra": "a egípcia" },
