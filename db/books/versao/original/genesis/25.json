    },
    "26": {
      "traducao_completa": "E depois disso saiu o seu irmão, e sua mão agarrada no calcanhar de Esaú; e chamou seu nome Jacó; e Isaque [era] filho de sessenta anos no seu dar à luz eles.",
      "palavras": [
        { "hebraico": "וְאַחֲרֵי־כֵן֩", "transliteral": "wəʾaḥărê-ḵēn", "traducao_palavra": "e depois disso" },
        { "hebraico": "יָצָ֨א", "transliteral": "yāṣāʾ", "traducao_palavra": "saiu" },
        { "hebraico": "אָחִ֜יו", "transliteral": "ʾāḥîw", "traducao_palavra": "seu irmão" },
        { "hebraico": "וְיָד֣וֹ", "transliteral": "wəyāḏô", "traducao_palavra": "e sua mão" },
        { "hebraico": "אֹחֶזֶת֮", "transliteral": "ʾōḥezeṯ", "traducao_palavra": "agarrada/segurando" },
        { "hebraico": "בַּעֲקֵ֣ב", "transliteral": "baʿăqēḇ", "traducao_palavra": "no calcanhar de" },
        { "hebraico": "עֵשָׂו֒", "transliteral": "ʿēśāw", "traducao_palavra": "Esaú" },
        { "hebraico": "וַיִּקְרָ֥א", "transliteral": "wayyiqrāʾ", "traducao_palavra": "e chamou" },
        { "hebraico": "שְׁמ֖וֹ", "transliteral": "šəmô", "traducao_palavra": "seu nome" },
        { "hebraico": "יַעֲקֹ֑ב", "transliteral": "yaʿăqōḇ", "traducao_palavra": "Jacó" },
        { "hebraico": "וְיִצְחָ֛ק", "transliteral": "wəyiṣḥāq", "traducao_palavra": "e Isaque" },
        { "hebraico": "בֶּן־שִׁשִּׁ֥ים", "transliteral": "ben-šiššîm", "traducao_palavra": "filho de sessenta" },
        { "hebraico": "שָׁנָ֖ה", "transliteral": "šānâ", "traducao_palavra": "ano" },
        { "hebraico": "בְּלֶ֥דֶת", "transliteral": "beledeth", "traducao_palavra": "no dar à luz" },
        { "hebraico": "אֹתָֽם׃", "transliteral": "ʾōṯām", "traducao_palavra": "eles" }
      ]
    },
    "27": {
      "traducao_completa": "E cresceram os jovens; e era Esaú homem perito na caça, homem do campo; e Jacó homem íntegro, habitando [em] tendas.",
      "palavras": [
        { "hebraico": "וַֽיִּגְדְּלוּ֙", "transliteral": "wayyiḡdəlû", "traducao_palavra": "e cresceram" },
        { "hebraico": "הַנְּעָרִ֔ים", "transliteral": "hannəʿārîm", "traducao_palavra": "os jovens" },
        { "hebraico": "וַיְהִ֣י", "transliteral": "wayhî", "traducao_palavra": "e era" },
        { "hebraico": "עֵשָׂ֗ו", "transliteral": "ʿēśāw", "traducao_palavra": "Esaú" },
        { "hebraico": "אִ֛ישׁ", "transliteral": "ʾîš", "traducao_palavra": "homem" },
        { "hebraico": "יֹדֵ֥עַ", "transliteral": "yōḏēaʿ", "traducao_palavra": "conhecedor/perito em" },
        { "hebraico": "צַ֖יִד", "transliteral": "ṣayiḏ", "traducao_palavra": "caça" },
        { "hebraico": "אִ֣ישׁ", "transliteral": "ʾîš", "traducao_palavra": "homem de" },
        { "hebraico": "שָׂדֶ֑ה", "transliteral": "śāḏeh", "traducao_palavra": "campo" },
        { "hebraico": "וְיַעֲקֹב֙", "transliteral": "wəyaʿăqōḇ", "traducao_palavra": "e Jacó" },
        { "hebraico": "אִ֣ישׁ", "transliteral": "ʾîš", "traducao_palavra": "homem" },
        { "hebraico": "תָּ֔ם", "transliteral": "tām", "traducao_palavra": "íntegro/quieto" },
        { "hebraico": "יֹשֵׁ֖ב", "transliteral": "yōšēḇ", "traducao_palavra": "habitando" },
        { "hebraico": "אֹהָלִֽים׃", "transliteral": "ʾōhālîm", "traducao_palavra": "tendas" }
      ]
    },
    "28": {
      "traducao_completa": "E amava Isaque a Esaú, pois caça [estava] na sua boca; mas Rebeca amava a Jacó.",
      "palavras": [
        { "hebraico": "וַיֶּאֱהַ֥ב", "transliteral": "wayyeʾĕhaḇ", "traducao_palavra": "e amava" },
        { "hebraico": "יִצְחָ֛ק", "transliteral": "yiṣḥāq", "traducao_palavra": "Isaque" },
        { "hebraico": "אֶת־עֵשָׂ֖ו", "transliteral": "ʾeṯ-ʿēśāw", "traducao_palavra": "a Esaú" },
        { "hebraico": "כִּי־צַ֣יִד", "transliteral": "kî-ṣayiḏ", "traducao_palavra": "pois caça" },
        { "hebraico": "בְּפִ֑יו", "transliteral": "bəp̄îw", "traducao_palavra": "na sua boca" },
