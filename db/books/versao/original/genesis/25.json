        { "hebraico": "שָׁנָ֛ה", "transliteral": "šānâ", "traducao_palavra": "ano" },
        { "hebraico": "וְשִׁבְעִ֥ים", "transliteral": "wəšiḇʿîm", "traducao_palavra": "e setenta" },
        { "hebraico": "שָׁנָ֖ה", "transliteral": "šānâ", "traducao_palavra": "ano" },
        { "hebraico": "וְחָמֵ֥שׁ", "transliteral": "wəḥāmēš", "traducao_palavra": "e cinco" },
        { "hebraico": "שָׁנִֽים׃", "transliteral": "šānîm", "traducao_palavra": "anos" }
      ]
    },
    "8": {
      "traducao_completa": "E expirou e morreu Abraão em boa velhice, velho e farto; e foi reunido ao seu povo.",
      "palavras": [
        { "hebraico": "וַיִּגְוַ֨ע", "transliteral": "wayyiḡwaʿ", "traducao_palavra": "e expirou" },
        { "hebraico": "וַיָּ֧מָת", "transliteral": "wayyāmāṯ", "traducao_palavra": "e morreu" },
        { "hebraico": "אַבְרָהָ֛ם", "transliteral": "ʾaḇrāhām", "traducao_palavra": "Abraão" },
        { "hebraico": "בְּשֵׂיבָ֥ה", "transliteral": "bəśêḇâ", "traducao_palavra": "em velhice" },
