        { "hebraico": "בִּגְרָֽר׃", "transliteral": "biḡərār", "traducao_palavra": "em Gerar" }
      ]
    },
    "2": {
      "traducao_completa": "E disse Abraão de Sara, sua mulher: É minha irmã. Assim enviou Abimeleque, rei de Gerar, e tomou a Sara.",
      "palavras": [
        { "hebraico": "וַיֹּ֧אמֶר", "transliteral": "wayyōʾmer", "traducao_palavra": "E disse" },
        { "hebraico": "אַבְרָהָ֛ם", "transliteral": "ʾaḇrāhām", "traducao_palavra": "Abraão" },
        { "hebraico": "אֶל־שָׂרָ֥ה", "transliteral": "ʾel-śārâ", "traducao_palavra": "de/sobre Sara" },
        { "hebraico": "אִשְׁתֹּ֖ו", "transliteral": "ʾištô", "traducao_palavra": "sua mulher" },
        { "hebraico": "אֲחֹ֣תִי", "transliteral": "ʾăḥōṯî", "traducao_palavra": "Minha irmã" },
        { "hebraico": "הִ֑וא", "transliteral": "hîw", "traducao_palavra": "[é] ela" },
        { "hebraico": "וַיִּשְׁלַ֗ח", "transliteral": "wayyišlaḥ", "traducao_palavra": "E enviou" },
        { "hebraico": "אֲבִימֶ֙לֶךְ֙", "transliteral": "ʾăḇîmeleq", "traducao_palavra": "Abimeleque" },
