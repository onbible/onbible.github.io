        { "hebraico": "וַיֹּ֥אמֶר אֲבִימֶ֖לֶךְ", "transliteral": "wayyōʾmer ʾăḇîmeleq", "traducao_palavra": "E disse Abimeleque" },
        { "hebraico": "אֶל־אַבְרָהָ֑ם", "transliteral": "ʾel-ʾaḇrāhām", "traducao_palavra": "a Abraão" },
        { "hebraico": "מָ֣ה רָאִ֔יתָ", "transliteral": "mâ rāʾîṯā", "traducao_palavra": "Que viste" },
        { "hebraico": "כִּ֥י עָשִׂ֖יתָ", "transliteral": "kî ʿāśîṯā", "traducao_palavra": "que fizeste" },
        { "hebraico": "אֶת־הַדָּבָ֥ר הַזֶּֽה׃", "transliteral": "ʾeṯ-haddāḇār hazzeh", "traducao_palavra": "[obj] a coisa esta" }
      ]
    },
    "11": {
      "traducao_completa": "E disse Abraão: Porque eu dizia comigo: Certamente não há temor de Deus neste lugar, e eles me matarão por causa da minha mulher.",
      "palavras": [
        { "hebraico": "וַיֹּאמֶר֮ אַבְרָהָם֒", "transliteral": "wayyōʾmer ʾaḇrāhām", "traducao_palavra": "E disse Abraão" },
        { "hebraico": "כִּ֣י אָמַ֗רְתִּי", "transliteral": "kî ʾāmarətî", "traducao_palavra": "Porque eu disse" },
        { "hebraico": "רַ֚ק אֵין־יִרְאַ֣ת אֱלֹהִ֔ים", "transliteral": "raq ʾên-yirʾaṯ ʾĕlōhîm", "traducao_palavra": "apenas não há temor de Deus" },
        { "hebraico": "בַּמָּקֹ֖ום הַזֶּ֑ה", "transliteral": "bammāqôm hazzeh", "traducao_palavra": "no lugar este" },
        { "hebraico": "וַהֲרָג֖וּנִי", "transliteral": "wahărāḡûnî", "traducao_palavra": "e matar-me-ão" },
        { "hebraico": "עַל־דְּבַ֥ר אִשְׁתִּֽי׃", "transliteral": "ʿal-dəḇar ʾištî", "traducao_palavra": "por causa de minha mulher" }
      ]
    },
    "12": {
      "traducao_completa": "E além disso ela é verdadeiramente minha irmã, filha de meu pai, mas não filha de minha mãe; e veio a ser minha mulher.",
      "palavras": [
        { "hebraico": "וְגַם־אָמְנָ֕ה", "transliteral": "wəḡam-ʾāmənnâ", "traducao_palavra": "E também verdadeiramente" },
        { "hebraico": "אֲחֹתִ֥י בַת־אָבִ֖י הִ֑וא", "transliteral": "ʾăḥōṯî ḇaṯ-ʾāḇî hîw", "traducao_palavra": "minha irmã filha de meu pai [é] ela" },
        { "hebraico": "אַךְ֙ לֹ֣א ḇַת־אִמִּ֔י", "transliteral": "ʾak lōʾ ḇaṯ-ʾimmî", "traducao_palavra": "mas não filha de minha mãe" },
        { "hebraico": "וַתְּהִי־לִ֖י לְאִשָּֽׁה׃", "transliteral": "wattəhî-lî ləʾiššâ", "traducao_palavra": "e ela foi para mim por mulher" }
      ]
    },
    "13": {
      "traducao_completa": "E aconteceu que, fazendo-me Deus sair errante da casa de meu pai, eu lhe disse: Esta é a mercê que me farás: em todo o lugar onde chegarmos, dize de mim: É meu irmão.",
      "palavras": [
        { "hebraico": "וַיְהִ֞י", "transliteral": "wayəhî", "traducao_palavra": "E foi/aconteceu" },
        { "hebraico": "כַּאֲשֶׁ֧ר הִתְע֣וּ אֹתִ֗י אֱלֹהִים֮", "transliteral": "kaʾăšer hitəʿû ʾōṯî ʾĕlōhîm", "traducao_palavra": "quando fizeram-me errar Deus" },
        { "hebraico": "מִבֵּ֣ית אָבִי֒", "transliteral": "mibbêṯ ʾāḇî", "traducao_palavra": "da casa de meu pai" },
        { "hebraico": "וָאֹמַ֣ר לָ֔הּ", "transliteral": "wāʾōmar lāh", "traducao_palavra": "e eu disse a ela" },
        { "hebraico": "זֶ֣ה חַסְדֵּ֔ךְ", "transliteral": "zeh ḥasədēḵ", "traducao_palavra": "esta [é] tua bondade" },
        { "hebraico": "אֲשֶׁ֥ר תַּעֲשִׂ֖י עִמָּדִ֑י", "transliteral": "ʾăšer taʿăśî ʿimmāḏî", "traducao_palavra": "que farás comigo" },
        { "hebraico": "אֶ֤ל כָּל־הַמָּקֹום֙", "transliteral": "ʾel kāl-hammāqôm", "traducao_palavra": "para todo o lugar" },
        { "hebraico": "אֲשֶׁ֣ר נָבֹ֣וא שָׁ֔מָּה", "transliteral": "ʾăšer nāḇôʾ šāmmâ", "traducao_palavra": "que chegarmos lá" },
        { "hebraico": "אִמְרִי־לִ֖י אָחִ֥י הֽוּא׃", "transliteral": "ʾimərî-lî ʾāḥî hû", "traducao_palavra": "dize de mim: meu irmão [é] ele" }
      ]
    },
    "14": {
      "traducao_completa": "Então tomou Abimeleque ovelhas e vacas, e servos e servas, e os deu a Abraão; e restituiu-lhe Sara, sua mulher.",
      "palavras": [
        { "hebraico": "וַיִּקַּ֨ח אֲבִימֶ֜לֶךְ", "transliteral": "wayyiqqaḥ ʾăḇîmeleq", "traducao_palavra": "E tomou Abimeleque" },
        { "hebraico": "צֹ֣אן וּבָקָ֗ר", "transliteral": "ṣōn ûḇāqār", "traducao_palavra": "ovelhas e gado" },
        { "hebraico": "וַעֲבָדִים֙ וּשְׁפָחֹ֔ת", "transliteral": "waʿăḇāḏîm ûšəp̄āḥōṯ", "traducao_palavra": "e servos e servas" },
        { "hebraico": "וַיִּתֵּ֖ן לְאַבְרָהָ֑ם", "transliteral": "wayyittēn ləʾaḇrāhām", "traducao_palavra": "e deu a Abraão" },
        { "hebraico": "וַיָּ֣שֶׁב לֹ֔ו", "transliteral": "wayyāšeḇ lô", "traducao_palavra": "e devolveu a ele" },
        { "hebraico": "אֵ֖ת שָׂרָ֥ה אִשְׁתֹּֽו׃", "transliteral": "ʾeṯ śārâ ʾištô", "traducao_palavra": "[obj] Sara sua mulher" }
      ]
    },
    "15": {
      "traducao_completa": "E disse Abimeleque: Eis que a minha terra está diante de tua face; habita onde for bom aos teus olhos.",
      "palavras": [
        { "hebraico": "וַיֹּ֣אמֶר אֲבִימֶ֔לֶךְ", "transliteral": "wayyōʾmer ʾăḇîmeleq", "traducao_palavra": "E disse Abimeleque" },
        { "hebraico": "הִנֵּ֥ה אַרְצִ֖י לְפָנֶ֑יךָ", "transliteral": "hinnēh ʾarṣî ləp̄āneyḵā", "traducao_palavra": "Eis minha terra diante de ti" },
        { "hebraico": "בַּטֹּ֥וב בְּעֵינֶ֖יךָ שֵֽׁב׃", "transliteral": "baṭṭôḇ bəʿêneyḵā šēḇ", "traducao_palavra": "no bom em teus olhos habita" }
      ]
    },
    "16": {
      "traducao_completa": "E a Sara disse: Eis que tenho dado ao teu irmão mil peças de prata; eis que ele te serve de cobertura de olhos para com todos os que estão contigo, e perante todos estás justificada.",
      "palavras": [
        { "hebraico": "וּלְשָׂרָ֣ה אָמַ֗ר", "transliteral": "ûləśārâ ʾāmar", "traducao_palavra": "E a Sara disse" },
        { "hebraico": "הִנֵּ֨ה נָתַ֜תִּי אֶ֣לֶף כֶּ֮סֶף֮ לְאָחִיךָ֒", "transliteral": "hinnēh nāṯattî ʾelep̱ kesep̱ ləʾāḥîḵā", "traducao_palavra": "Eis que dei mil [peças de] prata ao teu irmão" },
        { "hebraico": "הִנֵּה֤ הוּא־לָךְ֙ כְּס֣וּת עֵינַ֔יִם", "transliteral": "hinnēh hû-lāḵ kəsûṯ ʿênayim", "traducao_palavra": "eis que ele [é] para ti cobertura de olhos" },
        { "hebraico": "לְכֹ֖ל אֲשֶׁ֣ר אִתָּ֑ךְ", "transliteral": "ləḵōl ʾăšer ʾit-tāḵ", "traducao_palavra": "para todos os que estão contigo" },
        { "hebraico": "וְאֶת־כֹּ֖ל וְנֹכָֽחַת׃", "transliteral": "wəʾeṯ-kōl wənōḵāḥaṯ", "traducao_palavra": "e perante todos estás justificada" }
      ]
    },
    "17": {
      "traducao_completa": "E orou Abraão a Deus, e sarou Deus a Abimeleque, e à sua mulher, e às suas servas, de maneira que tiveram filhos;",
      "palavras": [
        { "hebraico": "וַיִּתְפַּלֵּ֥ל אַבְרָהָ֖ם אֶל־הָאֱלֹהִ֑ים", "transliteral": "wayyiṯpallēl ʾaḇrāhām ʾel-hāʾĕlōhîm", "traducao_palavra": "E orou Abraão a Deus" },
        { "hebraico": "וַיִּרְפָּ֨א אֱלֹהִ֜ים", "transliteral": "wayyirpāʾ ʾĕlōhîm", "traducao_palavra": "e curou Deus" },
        { "hebraico": "אֶת־אֲבִימֶ֧לֶךְ", "transliteral": "ʾeṯ-ʾăḇîmeleq", "traducao_palavra": "[obj] Abimeleque" },
        { "hebraico": "וְאֶת־אִשְׁתֹּ֛ו וְאַמְהֹתָ֖יו", "transliteral": "wəʾeṯ-ʾištô wəʾaməhōṯāyw", "traducao_palavra": "e sua mulher e suas servas" },
        { "hebraico": "וַיֵּלֵֽדוּ׃", "transliteral": "wayyēlēḏû", "traducao_palavra": "e eles geraram/pariram" }
      ]
    },
    "18": {
      "traducao_completa": "porque o SENHOR havia fechado totalmente todas as madres da casa de Abimeleque, por causa de Sara, mulher de Abraão.",
      "palavras": [
        { "hebraico": "כִּֽי־עָצֹ֤ר עָצַ֧ר יְהוָ֛ה", "transliteral": "kî-ʿāṣōr ʿāṣar YHWH", "traducao_palavra": "Pois certamente fechara YHWH" },
        { "hebraico": "בְּעַ֥ד כָּל־רֶ֖חֶם", "transliteral": "bəʿaḏ kāl-reḥem", "traducao_palavra": "através de/sobre toda madre" },
        { "hebraico": "לְבֵ֣ית אֲבִימֶ֑לֶךְ", "transliteral": "ləḇêṯ ʾăḇîmeleq", "traducao_palavra": "da casa de Abimeleque" },
        { "hebraico": "עַל־דְּבַ֥ר שָׂרָ֖ה אֵ֥שֶׁת אַבְרָֽם׃", "transliteral": "ʿal-dəḇar śārâ ʾēšeṯ ʾaḇrām", "traducao_palavra": "por causa de Sara mulher de Abrão" }
      ]
    }
  }
