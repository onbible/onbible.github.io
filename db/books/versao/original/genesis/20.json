        { "hebraico": "לֹ֥א קָרַ֖ב", "transliteral": "lōʾ qāraḇ", "traducao_palavra": "não se aproximara" },
        { "hebraico": "אֵלֶ֑יהָ", "transliteral": "ʾēleyhā", "traducao_palavra": "a ela" },
        { "hebraico": "וַיֹּאמַ֕ר", "transliteral": "wayyōʾmar", "traducao_palavra": "e disse" },
        { "hebraico": "אֲדֹנָ֕י", "transliteral": "ʾăḏōnāy", "traducao_palavra": "Senhor" },
        { "hebraico": "הֲגֹ֥וי", "transliteral": "hăḡôy", "traducao_palavra": "Acaso nação" },
        { "hebraico": "גַּם־צַדִּ֖יק", "transliteral": "gam-ṣaddîq", "traducao_palavra": "também justa" },
        { "hebraico": "תַּהֲרֹֽג׃", "transliteral": "taharōḡ", "traducao_palavra": "matarás?" }
