        { "hebraico": "וְעַל־מַמְלַכְתִּ֖י", "transliteral": "wəʿal-maməlaḵətî", "traducao_palavra": "e sobre meu reino" },
        { "hebraico": "חֲטָאָ֣ה גְדֹלָ֑ה", "transliteral": "ḥăṭāʾâ ḡəḏōlâ", "traducao_palavra": "pecado grande" },
        { "hebraico": "מַעֲשִׂים֙", "transliteral": "maʿăśîm", "traducao_palavra": "atos" },
        { "hebraico": "אֲשֶׁ֣ר לֹא־יֵעָשׂ֔וּ", "transliteral": "ʾăšer lōʾ-yēʿāśû", "traducao_palavra": "que não devem ser feitos" },
        { "hebraico": "עָשִׂ֥יתָ עִמָּדִֽי׃", "transliteral": "ʿāśîṯā ʿimmāḏî", "traducao_palavra": "fizeste comigo" }
      ]
    },
    "10": {
      "traducao_completa": "Disse mais Abimeleque a Abraão: Que viste para fazeres tal coisa?",
