    "8": {
      "traducao_completa": "E levantou-se Abimeleque de madrugada e chamou a todos os seus servos, e falou todas estas palavras em seus ouvidos; e temeram muito aqueles homens.",
      "palavras": [
        { "hebraico": "וַיַּשְׁכֵּ֨ם", "transliteral": "wayyaškēm", "traducao_palavra": "E levantou-se cedo" },
        { "hebraico": "אֲבִימֶ֜לֶךְ", "transliteral": "ʾăḇîmeleq", "traducao_palavra": "Abimeleque" },
        { "hebraico": "בַּבֹּ֗קֶר", "transliteral": "babbōqer", "traducao_palavra": "pela manhã" },
        { "hebraico": "וַיִּקְרָא֙", "transliteral": "wayyiqrāʾ", "traducao_palavra": "e chamou" },
        { "hebraico": "לְכָל־עֲבָדָ֔יו", "transliteral": "ləḵāl-ʿăḇāḏāyw", "traducao_palavra": "a todos seus servos" },
