        { "hebraico": "וְאִם־אֵֽינְךָ֣ מֵשִׁ֗יב", "transliteral": "wəʾim-ʾênəḵā mēšîḇ", "traducao_palavra": "e se tu não devolves" },
        { "hebraico": "דַּ֚ע", "transliteral": "daʿ", "traducao_palavra": "sabe" },
        { "hebraico": "כִּי־מֹ֣ות תָּמ֔וּת", "transliteral": "kî-môṯ tāmûṯ", "traducao_palavra": "que certamente morrerás" },
        { "hebraico": "אַתָּ֖ה", "transliteral": "ʾattâ", "traducao_palavra": "tu" },
        { "hebraico": "וְכָל־אֲשֶׁר־לָֽךְ׃", "transliteral": "wəḵāl-ʾăšer-lāḵ", "traducao_palavra": "e tudo o que [é] teu" }
