        { "hebraico": "הָאֲנָשִׁ֖ים", "transliteral": "hāʾănāšîm", "traducao_palavra": "os homens" },
        { "hebraico": "מְאֹֽד׃", "transliteral": "məʾōḏ", "traducao_palavra": "muito" }
      ]
    },
    "9": {
      "traducao_completa": "Então chamou Abimeleque a Abraão e disse-lhe: Que nos fizeste? E em que pequei contra ti, para trazeres sobre mim e sobre o meu reino tamanho pecado? Fizeste-me coisas que não se devem fazer.",
      "palavras": [
        { "hebraico": "וַיִּקְרָ֨א אֲבִימֶ֜לֶךְ", "transliteral": "wayyiqrāʾ ʾăḇîmeleq", "traducao_palavra": "E chamou Abimeleque" },
        { "hebraico": "לְאַבְרָהָ֗ם", "transliteral": "ləʾaḇrāhām", "traducao_palavra": "a Abraão" },
        { "hebraico": "וַיֹּ֣אמֶר לֹו֮", "transliteral": "wayyōʾmer lô", "traducao_palavra": "e disse a ele" },
        { "hebraico": "מֶֽה־עָשִׂ֣יתָ לָּנוּ֒", "transliteral": "meh-ʿāśîṯā llānû", "traducao_palavra": "Que fizeste a nós?" },
        { "hebraico": "וּמֶה־חָטָ֣אתִי לָ֗ךְ", "transliteral": "ûmeh-ḥāṭāʾṯî lāḵ", "traducao_palavra": "e em que pequei contra ti" },
        { "hebraico": "כִּֽי־הֵבֵ֧אתָ", "transliteral": "kî-hēḇēʾṯā", "traducao_palavra": "que trouxeste" },
