        { "hebraico": "כִּ֤י", "transliteral": "kî", "traducao_palavra": "que" },
        { "hebraico": "בְתָם־לְבָבְךָ֖", "transliteral": "ḇəṯām-ləḇāḇəḵā", "traducao_palavra": "na integridade de teu coração" },
        { "hebraico": "עָשִׂ֣יתָ זֹּ֑את", "transliteral": "ʿāśîṯā zzōʾṯ", "traducao_palavra": "fizeste isto" },
        { "hebraico": "וָאֶחְשֹׂ֧ךְ", "transliteral": "wāʾeḥśōḵ", "traducao_palavra": "e detive" },
        { "hebraico": "גַּם־אָנֹכִ֛י", "transliteral": "gam-ʾānōḵî", "traducao_palavra": "também eu" },
        { "hebraico": "אֹותְךָ֖", "transliteral": "ʾôṯəḵā", "traducao_palavra": "te" },
        { "hebraico": "מֵחֲטֹו־לִ֑י", "transliteral": "mēḥăṭô-lî", "traducao_palavra": "de pecar contra mim" },
        { "hebraico": "עַל־כֵּ֥ן", "transliteral": "ʿal-kēn", "traducao_palavra": "por isso" },
        { "hebraico": "לֹא־נְתַתִּ֖יךָ", "transliteral": "lōʾ-nəṯattîḵā", "traducao_palavra": "não te permiti" },
        { "hebraico": "לִנְגֹּ֥עַ אֵלֶֽיהָ׃", "transliteral": "linəgōʿa ʾēleyhā", "traducao_palavra": "tocar nela" }
      ]
    },
    "7": {
      "traducao_completa": "Agora, pois, restitui a mulher ao homem, porque profeta é, e rogará por ti, para que vivas; mas se não a restituíres, sabe que certamente morrerás, tu e tudo o que é teu.",
      "palavras": [
        { "hebraico": "וְעַתָּ֗ה", "transliteral": "wəʿattâ", "traducao_palavra": "E agora" },
        { "hebraico": "הָשֵׁ֤ב", "transliteral": "hāšēḇ", "traducao_palavra": "devolve" },
        { "hebraico": "אֵֽשֶׁת־הָאִ֨ישׁ", "transliteral": "ʾēšeṯ-hāʾîš", "traducao_palavra": "mulher do homem" },
        { "hebraico": "כִּֽי־נָבִ֣יא ה֔וּא", "transliteral": "kî-nāḇîʾ hû", "traducao_palavra": "porque profeta [é] ele" },
        { "hebraico": "וְיִתְפַּלֵּ֥ל", "transliteral": "wəyiṯpallēl", "traducao_palavra": "e ele orará" },
