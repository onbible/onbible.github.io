        { "hebraico": "עַל־הָאִשָּׁ֥ה", "transliteral": "ʿal-hāʾiššâ", "traducao_palavra": "por causa da mulher" },
        { "hebraico": "אֲשֶׁר־לָקַ֖חְתָּ", "transliteral": "ʾăšer-lāqaḥtā", "traducao_palavra": "que tomaste" },
        { "hebraico": "וְהִ֖וא", "transliteral": "wəhîw", "traducao_palavra": "pois ela" },
        { "hebraico": "בְּעֻ֥לַת בָּֽעַל׃", "transliteral": "bəʿulaṯ bāʿal", "traducao_palavra": "[está] possuída por marido" }
