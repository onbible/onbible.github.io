        { "hebraico": "וַיִּקַּ֖ח", "transliteral": "wayyiqqaḥ", "traducao_palavra": "e tomou" },
        { "hebraico": "אֶת־שָׂרָֽה׃", "transliteral": "ʾeṯ-śārâ", "traducao_palavra": "[obj] Sara" }
      ]
    },
    "3": {
      "traducao_completa": "Veio, porém, Deus a Abimeleque em sonhos de noite, e disse-lhe: Eis que morto serás por causa da mulher que tomaste; porque ela está casada com marido.",
      "palavras": [
        { "hebraico": "וַיָּבֹ֧א", "transliteral": "wayyāḇôʾ", "traducao_palavra": "E veio" },
        { "hebraico": "אֱלֹהִ֛ים", "transliteral": "ʾĕlōhîm", "traducao_palavra": "Deus" },
        { "hebraico": "אֶל־אֲבִימֶ֖לֶךְ", "transliteral": "ʾel-ʾăḇîmeleq", "traducao_palavra": "a Abimeleque" },
        { "hebraico": "בַּחֲלֹ֣ום", "transliteral": "baḥălôm", "traducao_palavra": "em sonho" },
        { "hebraico": "הַלָּ֑יְלָה", "transliteral": "hallāyəlâ", "traducao_palavra": "da noite" },
        { "hebraico": "וַיֹּ֣אמֶר", "transliteral": "wayyōʾmer", "traducao_palavra": "e disse" },
        { "hebraico": "לֹ֗ו", "transliteral": "lô", "traducao_palavra": "lhe" },
        { "hebraico": "הִנְּךָ֥", "transliteral": "hinnəḵā", "traducao_palavra": "Eis que tu [serás]" },
