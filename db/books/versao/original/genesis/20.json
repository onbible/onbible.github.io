        { "hebraico": "אָֽמַר־לִִי֙", "transliteral": "ʾāmar-lî", "traducao_palavra": "disse-me" },
        { "hebraico": "אֲחֹ֣תִי הִ֔וא", "transliteral": "ʾăḥōṯî hîw", "traducao_palavra": "Minha irmã [é] ela" },
        { "hebraico": "וְהִֽיא־גַם־הִ֥וא", "transliteral": "wəhî-ḡam-hîw", "traducao_palavra": "e ela, também ela" },
        { "hebraico": "אָמְרָ֖ה", "transliteral": "ʾāmərâ", "traducao_palavra": "disse" },
        { "hebraico": "אָחִ֣י ה֑וּא", "transliteral": "ʾāḥî hû", "traducao_palavra": "Meu irmão [é] ele" },
        { "hebraico": "בְּתָם־לְבָבִ֥י", "transliteral": "bəṯām-ləḇāḇî", "traducao_palavra": "na integridade de meu coração" },
        { "hebraico": "וּבְנִקְיֹ֥ן", "transliteral": "ûḇəniqyōn", "traducao_palavra": "e na limpeza de" },
        { "hebraico": "כַּפַּ֖י", "transliteral": "kappay", "traducao_palavra": "minhas mãos" },
        { "hebraico": "עָשִׂ֥יתִי", "transliteral": "ʿāśîṯî", "traducao_palavra": "fiz" },
        { "hebraico": "זֹּֽאת׃", "transliteral": "zzōʾṯ", "traducao_palavra": "isto" }
      ]
    },
    "6": {
      "traducao_completa": "E disse-lhe Deus em sonhos: Bem sei eu que na integridade do teu coração fizeste isto; e também eu te detive de pecar contra mim; por isso não te permiti tocá-la.",
      "palavras": [
        { "hebraico": "וַיֹּאמֶר֩ אֵלָ֨יו", "transliteral": "wayyōʾmer ʾēlāyw", "traducao_palavra": "E disse a ele" },
        { "hebraico": "הָאֱלֹהִ֜ים", "transliteral": "hāʾĕlōhîm", "traducao_palavra": "Deus" },
        { "hebraico": "בַּחֲלֹ֗ם", "transliteral": "baḥălōm", "traducao_palavra": "no sonho" },
        { "hebraico": "גַּ֣ם אָנֹכִ֤י", "transliteral": "gam ʾānōḵî", "traducao_palavra": "Também eu" },
