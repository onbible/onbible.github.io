        { "hebraico": "מִקֶּ֑דֶם", "transliteral": "miqqedem", "traducao_palavra": "do oriente" },
        { "hebraico": "וַֽיִּמְצְא֥וּ", "transliteral": "wayyimṣəʾû", "traducao_palavra": "e acharam" },
        { "hebraico": "בִקְעָ֛ה", "transliteral": "ḇiqʿâ", "traducao_palavra": "um vale" },
        { "hebraico": "בְּאֶ֥רֶץ", "transliteral": "bəʾereṣ", "traducao_palavra": "na terra de" },
        { "hebraico": "שִׁנְעָ֖ר", "transliteral": "šinəʿār", "traducao_palavra": "Sinar" },
        { "hebraico": "וַיֵּ֥שְׁבוּ", "transliteral": "wayyēšəḇû", "traducao_palavra": "e habitaram" },
        { "hebraico": "שָֽׁם׃", "transliteral": "šām", "traducao_palavra": "ali" }
      ]
    },
    "3": {
      "traducao_completa": "E disseram uns aos outros: Eia, façamos tijolos e queimemo-los bem. E tiveram tijolo por pedra, e betume por argamassa.",
      "palavras": [
        { "hebraico": "וַיֹּאמְר֞וּ", "transliteral": "wayyōʾmərû", "traducao_palavra": "E disseram" },
        { "hebraico": "אִ֣ישׁ", "transliteral": "ʾîš", "traducao_palavra": "homem/cada um" },
        { "hebraico": "אֶל־רֵעֵ֗הוּ", "transliteral": "ʾel-rēʿēhû", "traducao_palavra": "ao seu próximo" },
        { "hebraico": "הָ֚בָה", "transliteral": "hāḇâ", "traducao_palavra": "Eia/Vinde" },
        { "hebraico": "נִלְבְּנָ֣ה", "transliteral": "nilbbənâ", "traducao_palavra": "façamos tijolos" },
        { "hebraico": "לְבֵנִ֔ים", "transliteral": "ləḇēnîm", "traducao_palavra": "tijolos" },
        { "hebraico": "וְנִשְׂרְפָ֖ה", "transliteral": "wəniśrəp̱â", "traducao_palavra": "e queimemos" },
        { "hebraico": "לִשְׂרֵפָ֑ה", "transliteral": "liśrēp̱â", "traducao_palavra": "para queima" },
        { "hebraico": "וַתְּהִ֨י", "transliteral": "wattəhî", "traducao_palavra": "e foi" },
