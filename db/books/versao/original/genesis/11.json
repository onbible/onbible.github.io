        { "hebraico": "לְאָ֔בֶן", "transliteral": "ləʾāḇen", "traducao_palavra": "por pedra" },
        { "hebraico": "וְהַחֵמָר", "transliteral": "wəhaḥēmār", "traducao_palavra": "e o betume" },
        { "hebraico": "הָיָ֥ה", "transliteral": "hāyâ", "traducao_palavra": "foi" },
        { "hebraico": "לָהֶ֖ם", "transliteral": "lāhem", "traducao_palavra": "para eles" },
        { "hebraico": "לַחֹֽמֶר׃", "transliteral": "laḥōmer", "traducao_palavra": "por argamassa/barro" }
      ]
    },
    "4": {
      "traducao_completa": "E disseram: Eia, edifiquemos para nós uma cidade e uma torre cujo cume toque nos céus, e façamos para nós um nome, para que não sejamos espalhados sobre a face de toda a terra.",
      "palavras": [
        { "hebraico": "וַיֹּאמְר֞וּ", "transliteral": "wayyōʾmərû", "traducao_palavra": "E disseram" },
        { "hebraico": "הָ֣בָה ׀", "transliteral": "hāḇâ", "traducao_palavra": "Eia/Vinde" },
        { "hebraico": "נִבְנֶה־לָּ֣נוּ", "transliteral": "niḇneh-llānû", "traducao_palavra": "edifiquemos para nós" },
        { "hebraico": "עִ֗יר", "transliteral": "ʿîr", "traducao_palavra": "uma cidade" },
        { "hebraico": "וּמִגְדָּל֙", "transliteral": "ûmiḡdāl", "traducao_palavra": "e uma torre" },
        { "hebraico": "וְרֹאשֹׁ֣ו", "transliteral": "wərōʾšô", "traducao_palavra": "e seu topo" },
        { "hebraico": "בַשָּׁמַ֔יִם", "transliteral": "ḇaššāmayim", "traducao_palavra": "nos céus" },
        { "hebraico": "וְנַעֲשֶׂה־לָּ֖נוּ", "transliteral": "wənaʿăśeh-llānû", "traducao_palavra": "e façamos para nós" },
        { "hebraico": "שֵׁ֑ם", "transliteral": "šēm", "traducao_palavra": "um nome" },
        { "hebraico": "פֶּן־נָפ֖וּץ", "transliteral": "pen-nāp̱ûṣ", "traducao_palavra": "para que não sejamos espalhados" },
        { "hebraico": "עַל־פְּנֵ֥י", "transliteral": "ʿal-pənê", "traducao_palavra": "sobre a face de" },
        { "hebraico": "כָל־הָאָֽרֶץ׃", "transliteral": "ḵāl-hāʾāreṣ", "traducao_palavra": "toda a terra" }
      ]
    },
    "5": {
      "traducao_completa": "Então desceu o SENHOR para ver a cidade e a torre que os filhos dos homens edificavam.",
      "palavras": [
        { "hebraico": "וַיֵּ֣רֶד", "transliteral": "wayyēreḏ", "traducao_palavra": "E desceu" },
        { "hebraico": "יְהוָ֔ה", "transliteral": "YHWH", "traducao_palavra": "YHWH" },
        { "hebraico": "לִרְאֹ֥ת", "transliteral": "lirʾōṯ", "traducao_palavra": "para ver" },
        { "hebraico": "אֶת־הָעִ֖יר", "transliteral": "ʾeṯ-hāʿîr", "traducao_palavra": "[obj] a cidade" },
        { "hebraico": "וֶאֶת־הַמִּגְדָּ֑ל", "transliteral": "wəʾeṯ-hammiḡdāl", "traducao_palavra": "e [obj] a torre" },
        { "hebraico": "אֲשֶׁ֥ר", "transliteral": "ʾăšer", "traducao_palavra": "que" },
        { "hebraico": "בָּנ֖וּ", "transliteral": "bānû", "traducao_palavra": "edificavam" },
