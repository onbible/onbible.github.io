        { "hebraico": "הָעִֽיר׃", "transliteral": "hāʿîr", "traducao_palavra": "a cidade" }
      ]
    },
    "9": {
      "traducao_completa": "Portanto se chamou o seu nome Babel, porquanto ali confundiu o SENHOR a língua de toda a terra, e dali os espalhou o SENHOR sobre a face de toda a terra.",
      "palavras": [
        { "hebraico": "עַל־כֵּן֙", "transliteral": "ʿal-kēn", "traducao_palavra": "Por isso" },
        { "hebraico": "קָרָ֣א", "transliteral": "qārāʾ", "traducao_palavra": "chamou" },
        { "hebraico": "שְׁמָהּ", "transliteral": "šəmāh", "traducao_palavra": "seu nome" },
        { "hebraico": "בָּבֶ֔ל", "transliteral": "bāḇel", "traducao_palavra": "Babel" },
