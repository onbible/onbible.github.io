{
  "livro": "Gênesis - בְּרֵאשִׁית - Bereshit",
  "capítulo": 11,
  "titulos": {},
  "versiculos": {
    "1": {
      "traducao_completa": "E era toda a terra de uma só língua e de um só vocabulário.",
      "palavras": [
        { "hebraico": "וַיְהִ֥י", "transliteral": "wayəhî", "traducao_palavra": "E foi/era" },
        { "hebraico": "כָל־הָאָ֖רֶץ", "transliteral": "ḵāl-hāʾāreṣ", "traducao_palavra": "toda a terra" },
        { "hebraico": "שָׂפָ֣ה", "transliteral": "śāp̱â", "traducao_palavra": "língua/lábio" },
        { "hebraico": "אֶחָ֑ת", "transliteral": "ʾeḥāṯ", "traducao_palavra": "uma" },
        { "hebraico": "וּדְבָרִ֖ים", "transliteral": "ûḏəḇārîm", "traducao_palavra": "e palavras/discursos" },
        { "hebraico": "אֲחָדִֽים׃", "transliteral": "ʾăḥāḏîm", "traducao_palavra": "únicos/uns" }
      ]
    },
    "2": {
      "traducao_completa": "E aconteceu que, partindo eles do oriente, acharam um vale na terra de Sinar; e habitaram ali.",
      "palavras": [
        { "hebraico": "וַֽיְהִ֖י", "transliteral": "wayəhî", "traducao_palavra": "E foi/aconteceu" },
