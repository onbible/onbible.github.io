        { "hebraico": "כָּל־הָאָ֑רֶץ", "transliteral": "kāl-hāʾāreṣ", "traducao_palavra": "toda a terra" },
        { "hebraico": "וּמִשָּׁם֙", "transliteral": "ûmiššām", "traducao_palavra": "e dali" },
        { "hebraico": "הֱפִיצָ֣ם", "transliteral": "hĕp̱îṣām", "traducao_palavra": "espalhou-os" },
        { "hebraico": "יְהוָ֔ה", "transliteral": "YHWH", "traducao_palavra": "YHWH" },
        { "hebraico": "עַל־פְּנֵ֖י", "transliteral": "ʿal-pənê", "traducao_palavra": "sobre a face de" },
        { "hebraico": "כָּל־הָאָֽרֶץ׃", "transliteral": "kāl-haʾāreṣ", "traducao_palavra": "toda a terra" }
      ]
    },
    "10": {
      "traducao_completa": "Estas são as gerações de Sem: Sem era da idade de cem anos e gerou a Arpaxade, dois anos depois do dilúvio.",
      "palavras": [
        { "hebraico": "אֵ֚לֶּה", "transliteral": "ʾēlleh", "traducao_palavra": "Estas [são]" },
        { "hebraico": "תּוֹלְדֹ֣ת", "transliteral": "ṯôləḏôṯ", "traducao_palavra": "as gerações de" },
        { "hebraico": "שֵׁ֔ם", "transliteral": "šēm", "traducao_palavra": "Sem" },
        { "hebraico": "שֵׁ֚ם", "transliteral": "šēm", "traducao_palavra": "Sem" },
        { "hebraico": "בֶּן־מְאַ֣ת", "transliteral": "ben-məʾaṯ", "traducao_palavra": "filho de cem" },
        { "hebraico": "שָׁנָ֔ה", "transliteral": "šānâ", "traducao_palavra": "anos" },
        { "hebraico": "וַיֹּ֖ולֶד", "transliteral": "wayyôled", "traducao_palavra": "e gerou" },
        { "hebraico": "אֶת־אַרְפַּכְשָׁ֑ד", "transliteral": "ʾeṯ-ʾarəpakašad", "traducao_palavra": "[obj] Arpaxade" },
        { "hebraico": "שְׁנָתַ֖יִם", "transliteral": "šənāṯayim", "traducao_palavra": "dois anos" },
        { "hebraico": "אַחַ֥ר", "transliteral": "ʾaḥar", "traducao_palavra": "depois de" },
        { "hebraico": "הַמַּבּֽוּל׃", "transliteral": "hammabbûl", "traducao_palavra": "o dilúvio" }
      ]
    },
    "11": { "traducao_completa": "E viveu Sem, depois que gerou a Arpaxade, quinhentos anos; e gerou filhos e filhas.", "palavras": [] },
    "12": { "traducao_completa": "E viveu Arpaxade trinta e cinco anos, e gerou a Selá.", "palavras": [] },
    "13": { "traducao_completa": "E viveu Arpaxade, depois que gerou a Selá, quatrocentos e três anos; e gerou filhos e filhas.", "palavras": [] },
    "14": { "traducao_completa": "E viveu Selá trinta anos, e gerou a Éber.", "palavras": [] },
    "15": { "traducao_completa": "E viveu Selá, depois que gerou a Éber, quatrocentos e três anos; e gerou filhos e filhas.", "palavras": [] },
    "16": { "traducao_completa": "E viveu Éber trinta e quatro anos, e gerou a Pelegue.", "palavras": [] },
    "17": { "traducao_completa": "E viveu Éber, depois que gerou a Pelegue, quatrocentos e trinta anos; e gerou filhos e filhas.", "palavras": [] },
    "18": { "traducao_completa": "E viveu Pelegue trinta anos, e gerou a Reú.", "palavras": [] },
    "19": { "traducao_completa": "E viveu Pelegue, depois que gerou a Reú, duzentos e nove anos; e gerou filhos e filhas.", "palavras": [] },
    "20": { "traducao_completa": "E viveu Reú trinta e dois anos, e gerou a Serugue.", "palavras": [] },
    "21": { "traducao_completa": "E viveu Reú, depois que gerou a Serugue, duzentos e sete anos; e gerou filhos e filhas.", "palavras": [] },
    "22": { "traducao_completa": "E viveu Serugue trinta anos, e gerou a Naor.", "palavras": [] },
    "23": { "traducao_completa": "E viveu Serugue, depois que gerou a Naor, duzentos anos; e gerou filhos e filhas.", "palavras": [] },
    "24": { "traducao_completa": "E viveu Naor vinte e nove anos, e gerou a Tera.", "palavras": [] },
    "25": { "traducao_completa": "E viveu Naor, depois que gerou a Tera, cento e dezenove anos; e gerou filhos e filhas.", "palavras": [] },
    "26": { "traducao_completa": "E viveu Tera setenta anos, e gerou a Abrão, a Naor e a Harã.", "palavras": [] },
    "27": {
      "traducao_completa": "E estas são as gerações de Tera: Tera gerou a Abrão, a Naor e a Harã; e Harã gerou a Ló.",
      "palavras": [
        { "hebraico": "וְאֵ֙לֶּה֙", "transliteral": "wəʾēlleh", "traducao_palavra": "E estas" },
