        { "hebraico": "הָאָדָֽם׃", "transliteral": "hāʾāḏām", "traducao_palavra": "o homem" }
      ]
    },
    "6": {
      "traducao_completa": "E disse o SENHOR: Eis que o povo é um, e todos têm uma mesma língua; e isto é o que começam a fazer; agora, não haverá restrição para tudo o que intentarem fazer.",
      "palavras": [
        { "hebraico": "וַיֹּ֣אמֶר", "transliteral": "wayyōʾmer", "traducao_palavra": "E disse" },
        { "hebraico": "יְהוָ֗ה", "transliteral": "YHWH", "traducao_palavra": "YHWH" },
        { "hebraico": "הֵ֣ן", "transliteral": "hēn", "traducao_palavra": "Eis que" },
        { "hebraico": "עַ֤ם", "transliteral": "ʿam", "traducao_palavra": "povo" },
        { "hebraico": "אֶחָד֙", "transliteral": "ʾeḥāḏ", "traducao_palavra": "um" },
        { "hebraico": "וְשָׂפָ֤ה", "transliteral": "wəśāp̱â", "traducao_palavra": "e língua" },
        { "hebraico": "אַחַת֙", "transliteral": "ʾaḥaṯ", "traducao_palavra": "uma" },
        { "hebraico": "לְכֻלָּ֔ם", "transliteral": "ləḵullām", "traducao_palavra": "para todos eles" },
        { "hebraico": "וְזֶ֖ה", "transliteral": "wəzeh", "traducao_palavra": "e isto" },
        { "hebraico": "הַחִלָּ֣ם", "transliteral": "haḥillām", "traducao_palavra": "[é] seu começar" },
        { "hebraico": "לַעֲשֹׂ֑ות", "transliteral": "laʿăśôṯ", "traducao_palavra": "a fazer" },
        { "hebraico": "וְעַתָּה֙", "transliteral": "wəʿattâ", "traducao_palavra": "e agora" },
        { "hebraico": "לֹֽא־יִבָּצֵ֣ר", "transliteral": "lōʾ-yibbāṣēr", "traducao_palavra": "não será impedido" },
        { "hebraico": "מֵהֶ֔ם", "transliteral": "mēhem", "traducao_palavra": "deles" },
        { "hebraico": "כֹּ֥ל", "transliteral": "kōl", "traducao_palavra": "tudo" },
        { "hebraico": "אֲשֶׁ֥ר", "transliteral": "ʾăšer", "traducao_palavra": "que" },
        { "hebraico": "יָזְמ֖וּ", "transliteral": "yāzəmû", "traducao_palavra": "intentarem" },
        { "hebraico": "לַעֲשֹֽׂות׃", "transliteral": "laʿăśôṯ", "traducao_palavra": "a fazer" }
      ]
    },
    "7": {
      "traducao_completa": "Eia, desçamos e confundamos ali a sua língua, para que não entenda um a língua do outro.",
      "palavras": [
        { "hebraico": "הָ֚בָה", "transliteral": "hāḇâ", "traducao_palavra": "Vinde/Eia" },
        { "hebraico": "נֵֽרְדָ֔ה", "transliteral": "nērəḏâ", "traducao_palavra": "desçamos" },
        { "hebraico": "וְנָבְלָ֥ה", "transliteral": "wənāḇəlâ", "traducao_palavra": "e confundamos" },
        { "hebraico": "שָׁ֖ם", "transliteral": "šām", "traducao_palavra": "ali" },
        { "hebraico": "שְׂפָתָ֑ם", "transliteral": "śəp̱āṯām", "traducao_palavra": "sua língua" },
        { "hebraico": "אֲשֶׁר֙", "transliteral": "ʾăšer", "traducao_palavra": "para que" },
        { "hebraico": "לֹ֣א", "transliteral": "lōʾ", "traducao_palavra": "não" },
        { "hebraico": "יִשְׁמְע֔וּ", "transliteral": "yišməʿû", "traducao_palavra": "entendam/ouçam" },
        { "hebraico": "אִ֖ישׁ", "transliteral": "ʾîš", "traducao_palavra": "homem/cada um" },
        { "hebraico": "שְׂפַ֥ת", "transliteral": "śəp̱aṯ", "traducao_palavra": "língua de" },
        { "hebraico": "רֵעֵֽהוּ׃", "transliteral": "rēʿēhû", "traducao_palavra": "seu próximo" }
      ]
    },
    "8": {
      "traducao_completa": "Assim o SENHOR os espalhou dali sobre a face de toda a terra; e cessaram de edificar a cidade.",
      "palavras": [
        { "hebraico": "וַיָּ֨פֶץ", "transliteral": "wayyāp̱eṣ", "traducao_palavra": "E espalhou" },
        { "hebraico": "יְהוָ֥ה", "transliteral": "YHWH", "traducao_palavra": "YHWH" },
        { "hebraico": "אֹתָ֛ם", "transliteral": "ʾōṯām", "traducao_palavra": "os" },
        { "hebraico": "מִשָּׁ֖ם", "transliteral": "miššām", "traducao_palavra": "dali" },
        { "hebraico": "עַל־פְּנֵ֣י", "transliteral": "ʿal-pənê", "traducao_palavra": "sobre a face de" },
        { "hebraico": "כָל־הָאָ֑רֶץ", "transliteral": "ḵāl-hāʾāreṣ", "traducao_palavra": "toda a terra" },
        { "hebraico": "וַֽיַּחְדְּל֖וּ", "transliteral": "wayyaḥdəlû", "traducao_palavra": "e cessaram" },
