  "versiculos": {
    "1": {
      "traducao_completa": "No princípio, criou Deus os céus e a terra.",
      "palavras": [
        { "hebraico": "בְּרֵאשִׁית", "transliteral": "bərēʾšîṯ", "traducao_palavra": "No princípio" },
        { "hebraico": "בָּרָא", "transliteral": "bārāʾ", "traducao_palavra": "criou" },
        { "hebraico": "אֱלֹהִים", "transliteral": "ʾĕlōhîm", "traducao_palavra": "Deus" },
        { "hebraico": "אֵת", "transliteral": "ʾēṯ", "traducao_palavra": "[marcador de objeto]" },
        { "hebraico": "הַשָּׁמַיִם", "transliteral": "haššāmayim", "traducao_palavra": "os céus" },
        { "hebraico": "וְאֵת", "transliteral": "wəʾēṯ", "traducao_palavra": "e [marcador de objeto]" },
        { "hebraico": "הָאָרֶץ", "transliteral": "hāʾāreṣ", "traducao_palavra": "a terra" }
      ]
    },
    "2": {
