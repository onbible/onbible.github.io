        { "hebraico": "אֶת־הָאוֹר", "transliteral": "ʾeṯ-hāʾôr", "traducao_palavra": "[obj] a luz" },
        { "hebraico": "כִּי־טוֹב", "transliteral": "kî-ṭôḇ", "traducao_palavra": "que [era] boa" },
        { "hebraico": "וַיַּבְדֵּל", "transliteral": "wayyaḇdēl", "traducao_palavra": "e separou" },
        { "hebraico": "אֱלֹהִים", "transliteral": "ʾĕlōhîm", "traducao_palavra": "Deus" },
        { "hebraico": "בֵּין", "transliteral": "bên", "traducao_palavra": "entre" },
        { "hebraico": "הָאוֹר", "transliteral": "hāʾôr", "traducao_palavra": "a luz" },
