        { "hebraico": "אֱלֹהִים", "transliteral": "ʾĕlōhîm", "traducao_palavra": "Deus" },
        { "hebraico": "יְהִי", "transliteral": "yəhî", "traducao_palavra": "haja" },
        { "hebraico": "אוֹר", "transliteral": "ʾôr", "traducao_palavra": "luz" },
