        { "hebraico": "וָבֹהוּ", "transliteral": "wāḇōhû", "traducao_palavra": "e vazia" },
        { "hebraico": "וְחֹשֶׁךְ", "transliteral": "wəḥōšeḵ", "traducao_palavra": "e trevas [havia]" },
        { "hebraico": "עַל־פְּנֵי", "transliteral": "ʿal-pənê", "traducao_palavra": "sobre a face de" },
