        { "hebraico": "עַל־פְּנֵי", "transliteral": "ʿal-pənê", "traducao_palavra": "sobre a face de" },
        { "hebraico": "כָל־הָאָרֶץ", "transliteral": "ḵāl-hāʾāreṣ", "traducao_palavra": "toda a terra" },
        { "hebraico": "וְאֶת־כָּל־הָעֵץ", "transliteral": "wəʾeṯ-kāl-hāʿēṣ", "traducao_palavra": "e toda árvore" },
        { "hebraico": "אֲשֶׁר־בּוֹ", "transliteral": "ʾăšer-bô", "traducao_palavra": "que nela" },
