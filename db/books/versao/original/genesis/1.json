        { "hebraico": "וְרוּחַ", "transliteral": "wərûaḥ", "traducao_palavra": "e o Espírito de" },
        { "hebraico": "אֱלֹהִים", "transliteral": "ʾĕlōhîm", "traducao_palavra": "Deus" },
        { "hebraico": "מְרַחֶפֶת", "transliteral": "mərāḥep̱eṯ", "traducao_palavra": "pairava" },
        { "hebraico": "עַל־פְּנֵי", "transliteral": "ʿal-pənê", "traducao_palavra": "sobre a face de" },
        { "hebraico": "הַמָּיִם", "transliteral": "hammāyim", "traducao_palavra": "as águas" }
      ]
    },
    "3": {
      "traducao_completa": "E disse Deus: Haja luz; e houve luz.",
