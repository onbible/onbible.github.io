      "traducao_completa": "E disse Deus: Façamos o homem à nossa imagem, conforme a nossa semelhança; e dominem sobre os peixes do mar, e sobre as aves dos céus, e sobre o gado, e sobre toda a terra, e sobre todo réptil que se move sobre a terra.",
      "palavras": [
        { "hebraico": "וַיֹּאמֶר", "transliteral": "wayyōʾmer", "traducao_palavra": "E disse" },
        { "hebraico": "אֱלֹהִים", "transliteral": "ʾĕlōhîm", "traducao_palavra": "Deus" },
        { "hebraico": "נַעֲשֶׂה", "transliteral": "naʿăśeh", "traducao_palavra": "Façamos" },
        { "hebraico": "אָדָם", "transliteral": "ʾāḏām", "traducao_palavra": "homem" },
        { "hebraico": "בְּצַלְמֵנוּ", "transliteral": "bəṣalmēnû", "traducao_palavra": "à nossa imagem" },
        { "hebraico": "כִּדְמוּתֵנוּ", "transliteral": "kiḏmûṯēnû", "traducao_palavra": "conforme a nossa semelhança" },
        { "hebraico": "וְיִרְדּוּ", "transliteral": "wəyirdû", "traducao_palavra": "e dominem" },
        { "hebraico": "בִדְגַת", "transliteral": "ḇiḏḡaṯ", "traducao_palavra": "sobre o peixe de" },
        { "hebraico": "הַיָּם", "transliteral": "hayyām", "traducao_palavra": "o mar" },
        { "hebraico": "וּבְעוֹף", "transliteral": "ûḇəʿôp̱", "traducao_palavra": "e sobre ave de" },
        { "hebraico": "הַשָּׁמַיִם", "transliteral": "haššāmayim", "traducao_palavra": "os céus" },
        { "hebraico": "וּבַבְּהֵמָה", "transliteral": "ûḇabbəhēmâ", "traducao_palavra": "e sobre o gado" },
        { "hebraico": "וּבְכָל־הָאָרֶץ", "transliteral": "ûḇəḵāl-hāʾāreṣ", "traducao_palavra": "e sobre toda a terra" },
        { "hebraico": "וּבְכָל־הָרֶמֶשׂ", "transliteral": "ûḇəḵāl-hāremeś", "traducao_palavra": "e sobre todo réptil" },
        { "hebraico": "הָרֹמֵשׂ", "transliteral": "hārōmēś", "traducao_palavra": "que se move" },
        { "hebraico": "עַל־הָאָרֶץ", "transliteral": "ʿal-hāʾāreṣ", "traducao_palavra": "sobre a terra" }
      ]
    },
    "27": {
