{
  "livro": "Gênesis - בְּרֵאשִׁית - Bereshit",
  "capítulo": 49,
  "titulos": {},
  "versiculos": {
    "1": {
      "traducao_completa": "E chamou Jacó a seus filhos e disse: Ajuntai-vos e anunciarei a vós o que vos acontecerá no fim dos dias.",
      "palavras": [
