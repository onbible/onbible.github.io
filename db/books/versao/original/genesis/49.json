        { "hebraico": "עִקְּרוּ־שׁוֹר׃", "transliteral": "ʿiq-qə-rû-šôr", "traducao_palavra": "desarretaram boi" }
      ]
    },
    "7": {
      "traducao_completa": "Maldita seja a sua ira, porque foi forte, e o seu furor, porque foi duro; dividi-los-ei em Jacó e espalhá-los-ei em Israel.",
      "palavras": [
        { "hebraico": "אָרוּר", "transliteral": "ʾā-rûr", "traducao_palavra": "maldita [seja]" },
        { "hebraico": "אַפָּם", "transliteral": "ʾap-pām", "traducao_palavra": "a ira deles" },
        { "hebraico": "כִּי", "transliteral": "kî", "traducao_palavra": "porque" },
        { "hebraico": "עָז", "transliteral": "ʿāz", "traducao_palavra": "[foi] forte" },
        { "hebraico": "וְעֶבְרָתָם", "transliteral": "wə-ʿeḇ-rā-ṯām", "traducao_palavra": "e o furor deles" },
        { "hebraico": "כִּי", "transliteral": "kî", "traducao_palavra": "porque" },
