        { "hebraico": "אֲחַלְּקֵם", "transliteral": "ʾă-ḥal-lə-qēm", "traducao_palavra": "dividi-los-ei" },
        { "hebraico": "בְּיַעֲקֹב", "transliteral": "bə-ya-ʿă-qōḇ", "traducao_palavra": "em Jacó" },
