        { "hebraico": "יַעֲקֹב", "transliteral": "ya-ʿă-qōḇ", "traducao_palavra": "Jacó" },
        { "hebraico": "אֶל־בָּנָיו", "transliteral": "ʾel-bā-nāw", "traducao_palavra": "a seus filhos" },
        { "hebraico": "וַיֹּאמֶר", "transliteral": "way-yō-mer", "traducao_palavra": "e disse" },
        { "hebraico": "הֵאָסְפוּ", "transliteral": "hē-ʾā-śə-p̄û", "traducao_palavra": "ajuntai-vos" },
        { "hebraico": "וְאַגִּידָה", "transliteral": "wə-ʾag-gî-ḏā", "traducao_palavra": "e anunciarei" },
        { "hebraico": "לָכֶם", "transliteral": "lā-ḵem", "traducao_palavra": "a vós" },
        { "hebraico": "אֵת", "transliteral": "ʾēṯ", "traducao_palavra": "[objeto]" },
        { "hebraico": "אֲשֶׁר־יִקְרָא", "transliteral": "ʾă-šer-yiq-rā", "traducao_palavra": "o que chamará/encontrará" },
        { "hebraico": "אֶתְכֶם", "transliteral": "ʾeṯ-ḵem", "traducao_palavra": "a vós" },
        { "hebraico": "בְּאַחֲרִית", "transliteral": "bə-ʾa-ḥă-rîṯ", "traducao_palavra": "no fim de" },
        { "hebraico": "הַיָּמִים׃", "transliteral": "hay-yā-mîm", "traducao_palavra": "os dias" }
      ]
    },
    "2": {
      "traducao_completa": "Reuni-vos e ouvi, filhos de Jacó; e ouvi a Israel, vosso pai.",
      "palavras": [
        { "hebraico": "הִקָּבְצוּ", "transliteral": "hiq-qā-ḇə-ṣû", "traducao_palavra": "reuni-vos" },
        { "hebraico": "וְשִׁמְעוּ", "transliteral": "wə-šim-ʿû", "traducao_palavra": "e ouvi" },
        { "hebraico": "בְּנֵי", "transliteral": "bə-nê", "traducao_palavra": "filhos de" },
        { "hebraico": "יַעֲקֹב", "transliteral": "ya-ʿă-qōḇ", "traducao_palavra": "Jacó" },
        { "hebraico": "וְשִׁמְעוּ", "transliteral": "wə-šim-ʿû", "traducao_palavra": "e ouvi" },
        { "hebraico": "אֶל־יִשְׂרָאֵל", "transliteral": "ʾel-yiś-rā-ʾēl", "traducao_palavra": "a Israel" },
        { "hebraico": "אֲבִיכֶם׃", "transliteral": "ă-ḇî-ḵem", "traducao_palavra": "vosso pai" }
      ]
    },
    "3": {
      "traducao_completa": "Rúben, meu primogênito és tu, minha força e primícia do meu vigor, excelência de dignidade e excelência de poder.",
      "palavras": [
        { "hebraico": "רְאוּבֵן", "transliteral": "rə-ʾû-ḇēn", "traducao_palavra": "Rúben" },
        { "hebraico": "בְּכֹרִי", "transliteral": "bə-ḵō-rî", "traducao_palavra": "meu primogênito" },
        { "hebraico": "אַתָּה", "transliteral": "ʾat-tā", "traducao_palavra": "[és] tu" },
        { "hebraico": "כֹּחִי", "transliteral": "kō-ḥî", "traducao_palavra": "minha força" },
        { "hebraico": "וְרֵאשִׁית", "transliteral": "wə-rê-šîṯ", "traducao_palavra": "e primícia de" },
        { "hebraico": "אוֹנִי", "transliteral": "ʾô-nî", "traducao_palavra": "meu vigor" },
        { "hebraico": "יֶתֶר", "transliteral": "ye-ṯer", "traducao_palavra": "excelência de" },
