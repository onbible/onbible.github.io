        { "hebraico": "בְּיִשְׂרָאֵל׃", "transliteral": "bə-yiś-rā-ʾēl", "traducao_palavra": "em Israel" }
      ]
    },
    "8": {
      "traducao_completa": "Judá, a ti louvarão os teus irmãos; a tua mão estará sobre a nuca de teus inimigos; prostrar-se-ão diante de ti os filhos de teu pai.",
      "palavras": [
        { "hebraico": "יְהוּדָה", "transliteral": "yə-hû-ḏā", "traducao_palavra": "Judá" },
        { "hebraico": "אַתָּה", "transliteral": "ʾat-tā", "traducao_palavra": "tu" },
        { "hebraico": "יוֹדוּךָ", "transliteral": "yô-ḏû-ḵā", "traducao_palavra": "louvarão a ti" },
        { "hebraico": "אַחֶיךָ", "transliteral": "ʾa-ḥe-ḵā", "traducao_palavra": "teus irmãos" },
        { "hebraico": "יָדְךָ", "transliteral": "yā-ḏə-ḵā", "traducao_palavra": "tua mão" },
        { "hebraico": "בְּעֹרֶף", "transliteral": "bə-ʿō-rep̄", "traducao_palavra": "na nuca de" },
        { "hebraico": "אֹיְבֶיךָ", "transliteral": "ʾō-yə-ḇe-ḵā", "traducao_palavra": "teus inimigos" },
        { "hebraico": "יִשְׁתַּחֲווּ", "transliteral": "yiš-ta-ḥă-wû", "traducao_palavra": "prostrar-se-ão" },
        { "hebraico": "לְךָ", "transliteral": "lə-ḵā", "traducao_palavra": "a ti" },
        { "hebraico": "בְּנֵי", "transliteral": "bə-nê", "traducao_palavra": "filhos de" },
        { "hebraico": "אָבִיךָ׃", "transliteral": "ʾā-ḇî-ḵā", "traducao_palavra": "teu pai" }
      ]
    },
    "9": {
      "traducao_completa": "Cachorro de leão é Judá; da presa, meu filho, subiste; encurvou-se, deitou-se como leão e como leoa; quem o despertará?",
      "palavras": [
        { "hebraico": "גּוּר", "transliteral": "ḡûr", "traducao_palavra": "filhote/cachorro" },
        { "hebraico": "אַרְיֵה", "transliteral": "ʾar-yē", "traducao_palavra": "[de] leão" },
        { "hebraico": "יְהוּדָה", "transliteral": "yə-hû-ḏā", "traducao_palavra": "Judá" },
        { "hebraico": "מִטֶּרֶף", "transliteral": "miṭ-ṭe-rep̄", "traducao_palavra": "da presa" },
        { "hebraico": "בְּנִי", "transliteral": "bə-nî", "traducao_palavra": "meu filho" },
        { "hebraico": "עָלִיתָ", "transliteral": "ʿā-lî-ṯā", "traducao_palavra": "subiste" },
        { "hebraico": "כָּרַע", "transliteral": "kā-raʿ", "traducao_palavra": "encurvou-se" },
        { "hebraico": "רָבַץ", "transliteral": "rā-ḇaṣ", "traducao_palavra": "deitou-se" },
        { "hebraico": "כְּאַרְיֵה", "transliteral": "kə-ʾar-yē", "traducao_palavra": "como leão" },
        { "hebraico": "וּכְלָבִיא", "transliteral": "û-ḵə-lā-ḇî", "traducao_palavra": "e como leoa" },
        { "hebraico": "מִי", "transliteral": "mî", "traducao_palavra": "quem" },
        { "hebraico": "יְקִימֶנּוּ׃", "transliteral": "yə-qî-men-nû", "traducao_palavra": "o levantará/despertará" }
      ]
    },
    "10": {
      "traducao_completa": "Não se apartará o cetro de Judá, nem o bastão de entre os seus pés, até que venha Shiloh; e a ele pertencerá a obediência dos povos.",
      "palavras": [
        { "hebraico": "לֹא־יָסוּר", "transliteral": "lō-yā-sûr", "traducao_palavra": "não se apartará" },
