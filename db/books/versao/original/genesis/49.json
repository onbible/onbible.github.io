        { "hebraico": "מִיהוּדָה", "transliteral": "mî-hû-ḏā", "traducao_palavra": "de Judá" },
        { "hebraico": "וּמְחֹקֵק", "transliteral": "û-mə-ḥō-qēq", "traducao_palavra": "e o legislador/bastão" },
        { "hebraico": "מִבֵּין", "transliteral": "mib-bên", "traducao_palavra": "de entre" },
        { "hebraico": "רַגְלָיו", "transliteral": "raḡ-lāw", "traducao_palavra": "seus pés" },
        { "hebraico": "עַד", "transliteral": "ʿaḏ", "traducao_palavra": "até" },
        { "hebraico": "כִּי־יָבֹא", "transliteral": "kî-yā-ḇō", "traducao_palavra": "que venha" },
        { "hebraico": "שִׁילה", "transliteral": "šî-lō", "traducao_palavra": "Shiloh" },
        { "hebraico": "וְלוֹ", "transliteral": "wə-lô", "traducao_palavra": "e a ele" },
        { "hebraico": "יִקְּהַת", "transliteral": "yiq-qə-haṯ", "traducao_palavra": "obediência de" },
        { "hebraico": "עַמִּים׃", "transliteral": "ʿam-mîm", "traducao_palavra": "povos" }
      ]
    },
    "11": {
      "traducao_completa": "Amarrando à vide o seu jumentinho, e à videira excelente o filho da sua jumenta, lavará em vinho as suas vestes, e em sangue de uvas a sua capa.",
      "palavras": [
        { "hebraico": "אֹסְרִי", "transliteral": "ʾō-śə-rî", "traducao_palavra": "amarrando" },
        { "hebraico": "לַגֶּפֶן", "transliteral": "lag-ge-p̄en", "traducao_palavra": "à vide" },
        { "hebraico": "עִירֹה", "transliteral": "ʿî-rō", "traducao_palavra": "seu jumentinho" },
        { "hebraico": "וְלַשֹּׂרֵקָה", "transliteral": "wə-laś-śō-rē-qā", "traducao_palavra": "e à videira excelente" },
        { "hebraico": "בְּנִי", "transliteral": "bə-nî", "traducao_palavra": "filho de" },
        { "hebraico": "אֲתֹנוֹ", "transliteral": "ă-ṯō-nô", "traducao_palavra": "sua jumenta" },
        { "hebraico": "כִּבֵּס", "transliteral": "kib-bēs", "traducao_palavra": "lavará" },
        { "hebraico": "בַּיַּיִן", "transliteral": "bay-ya-yin", "traducao_palavra": "em vinho" },
        { "hebraico": "לְבֻשׁוֹ", "transliteral": "lə-ḇu-šô", "traducao_palavra": "sua veste" },
        { "hebraico": "וּבְדַם־עֲנָבִים", "transliteral": "û-ḇə-ḏam-ʿă-nā-ḇîm", "traducao_palavra": "e em sangue de uvas" },
        { "hebraico": "סוּתֹה׃", "transliteral": "śû-ṯō", "traducao_palavra": "sua capa" }
      ]
    },
    "12": {
      "traducao_completa": "Os seus olhos são mais escuros que o vinho, e os seus dentes mais brancos que o leite.",
      "palavras": [
        { "hebraico": "חַכְלִילִי", "transliteral": "ḥaḵ-lî-lî", "traducao_palavra": "escuros/vermelhos" },
        { "hebraico": "עֵינַיִם", "transliteral": "ʿê-na-yim", "traducao_palavra": "olhos" },
        { "hebraico": "מִיָּיִן", "transliteral": "mi-yā-yin", "traducao_palavra": "de vinho" },
        { "hebraico": "וּלְבֶן־שִׁנַּיִם", "transliteral": "û-lə-ḇen-šin-na-yim", "traducao_palavra": "e brancos de dentes" },
        { "hebraico": "מֵחָלָב׃", "transliteral": "mē-ḥā-lāḇ", "traducao_palavra": "de leite" }
      ]
    },
    "13": {
      "traducao_completa": "Zebulom habitará na margem dos mares; e ele será para margem de navios, e o seu limite será até Sidom.",
