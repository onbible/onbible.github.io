        { "hebraico": "עָז׃", "transliteral": "ʿāz", "traducao_palavra": "poder" }
      ]
    },
    "4": {
      "traducao_completa": "Impetuoso como as águas, não terás a preeminência, porque subiste ao leito de teu pai; então o profanaste; subiu à minha cama.",
      "palavras": [
        { "hebraico": "פַּחַז", "transliteral": "pa-ḥaz", "traducao_palavra": "impetuoso/instável" },
        { "hebraico": "כַּמַּיִם", "transliteral": "kam-ma-yim", "traducao_palavra": "como as águas" },
        { "hebraico": "אַל־תּוֹתַר", "transliteral": "ʾal-tô-ṯar", "traducao_palavra": "não terás preeminência" },
        { "hebraico": "כִּי", "transliteral": "kî", "traducao_palavra": "porque" },
        { "hebraico": "עָלִיתָ", "transliteral": "ʿā-lî-ṯā", "traducao_palavra": "subiste" },
        { "hebraico": "מִשְׁכְּבֵי", "transliteral": "miš-kə-ḇê", "traducao_palavra": "leito de" },
        { "hebraico": "אָבִיךָ", "transliteral": "ʾā-ḇî-ḵā", "traducao_palavra": "teu pai" },
        { "hebraico": "אָז", "transliteral": "ʾāz", "traducao_palavra": "então" },
        { "hebraico": "חִלַּלְתָּ", "transliteral": "ḥil-lal-tā", "traducao_palavra": "profanaste" },
        { "hebraico": "יְצוּעִי", "transliteral": "yə-ṣû-ʿî", "traducao_palavra": "minha cama" },
        { "hebraico": "עָלָה׃", "transliteral": "ʿā-lā", "traducao_palavra": "subiu [ele]" }
      ]
    },
    "5": {
      "traducao_completa": "Simeão e Levi são irmãos; instrumentos de violência são as suas espadas.",
      "palavras": [
        { "hebraico": "שִׁמְעוֹן", "transliteral": "šim-ʿôn", "traducao_palavra": "Simeão" },
        { "hebraico": "וְלֵוִי", "transliteral": "wə-lē-wî", "traducao_palavra": "e Levi" },
        { "hebraico": "אַחִים", "transliteral": "ʾa-ḥîm", "traducao_palavra": "irmãos" },
        { "hebraico": "כְּלֵי", "transliteral": "kə-lê", "traducao_palavra": "instrumentos de" },
        { "hebraico": "חָמָס", "transliteral": "ḥā-mās", "traducao_palavra": "violência" },
        { "hebraico": "מְכֵרֹתֵיהֶם׃", "transliteral": "mə-ḵē-rō-ṯê-hem", "traducao_palavra": "suas armas/espadas" }
      ]
    },
    "6": {
      "traducao_completa": "No seu conselho não entre a minha alma, com a sua assembleia não se ajunte a minha glória; porque na sua ira mataram homens, e na sua vontade desarretaram bois.",
      "palavras": [
        { "hebraico": "בְּסֹדָם", "transliteral": "bə-sō-ḏām", "traducao_palavra": "no conselho deles" },
        { "hebraico": "אַל־תָּבֹא", "transliteral": "ʾal-tā-ḇō", "traducao_palavra": "não entre" },
        { "hebraico": "נַפְשִׁי", "transliteral": "nap̄-šî", "traducao_palavra": "minha alma" },
        { "hebraico": "בִּקְהָלָם", "transliteral": "biq-hā-lām", "traducao_palavra": "na assembleia deles" },
        { "hebraico": "אַל־תֵּחַד", "transliteral": "ʾal-tê-ḥaḏ", "traducao_palavra": "não se ajunte" },
        { "hebraico": "כְּבֹדִי", "transliteral": "kə-ḇō-ḏî", "traducao_palavra": "minha glória" },
