        { "hebraico": "זְבוּלֻן", "transliteral": "zə-ḇû-lun", "traducao_palavra": "Zebulom" },
        { "hebraico": "לְחוֹף", "transliteral": "lə-ḥôp̄", "traducao_palavra": "na margem de" },
        { "hebraico": "יַמִּים", "transliteral": "yam-mîm", "traducao_palavra": "mares" },
        { "hebraico": "יִשְׁכֹּן", "transliteral": "yiš-kōn", "traducao_palavra": "habitará" },
        { "hebraico": "וְהוּא", "transliteral": "wə-hû", "traducao_palavra": "e ele" },
        { "hebraico": "לְחוֹף", "transliteral": "lə-ḥôp̄", "traducao_palavra": "para margem de" },
        { "hebraico": "אֳנִיֹּת", "transliteral": "ʾo-nî-yôṯ", "traducao_palavra": "navios" },
        { "hebraico": "וְיַרְכָתוֹ", "transliteral": "wə-yar-ḵā-ṯô", "traducao_palavra": "e seu limite/flanco" },
        { "hebraico": "עַל־צִידֹן׃", "transliteral": "ʿal-ṣî-ḏōn", "traducao_palavra": "até Sidom" }
      ]
    },
    "14": {
      "traducao_completa": "Issacar é um jumento de ossos, repousando entre os currais.",
