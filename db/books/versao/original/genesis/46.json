        { "hebraico": "גֹּשְׁנָה", "transliteral": "ḡōš-nā", "traducao_palavra": "[a] Gósen" },
        { "hebraico": "וַיֵּרָא", "transliteral": "way-yē-rā", "traducao_palavra": "e apresentou-se" },
        { "hebraico": "אֵלָיו", "transliteral": "ʾē-lāw", "traducao_palavra": "a ele" },
        { "hebraico": "וַיִּפֹּל", "transliteral": "way-yip-pōl", "traducao_palavra": "e caiu/lançou-se" },
        { "hebraico": "עַל־צַוָּארָיו", "transliteral": "ʿal-ṣaw-wā-rāw", "traducao_palavra": "sobre seu pescoço" },
        { "hebraico": "וַיֵּבְךְּ", "transliteral": "way-yē-ḇək", "traducao_palavra": "e chorou" },
