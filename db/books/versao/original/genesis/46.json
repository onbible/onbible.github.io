        { "hebraico": "בַּעֲבוּר", "transliteral": "ba-ʿă-ḇûr", "traducao_palavra": "para que" },
        { "hebraico": "תֵּשְׁבוּ", "transliteral": "tê-šə-ḇû", "traducao_palavra": "habiteis" },
        { "hebraico": "בְּאֶרֶץ", "transliteral": "bə-ʾe-reṣ", "traducao_palavra": "na terra de" },
