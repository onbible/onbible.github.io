        { "hebraico": "וְאֹמְרָה", "transliteral": "wə-ʾō-mə-rā", "traducao_palavra": "e direi" },
        { "hebraico": "אֵלָיו", "transliteral": "ʾē-lāw", "traducao_palavra": "a ele" },
        { "hebraico": "אַחַי", "transliteral": "ʾa-ḥay", "traducao_palavra": "meus irmãos" },
        { "hebraico": "וּבֵית־אָבִי", "transliteral": "û-ḇêṯ-ʾā-ḇî", "traducao_palavra": "e a casa de meu pai" },
