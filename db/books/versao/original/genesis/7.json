        { "hebraico": "בַּיּ֣וֹם", "transliteral": "bayyôm", "traducao_palavra": "no dia" },
        { "hebraico": "הַזֶּ֗ה", "transliteral": "hazzeh", "traducao_palavra": "este" },
        { "hebraico": "נִבְקְעוּ֙", "transliteral": "niḇqəʿû", "traducao_palavra": "romperam-se" },
