        { "hebraico": "יְהוָה֙", "transliteral": "YHWH", "traducao_palavra": "YHWH" },
        { "hebraico": "לְנֹ֔חַ", "transliteral": "lənōḥa", "traducao_palavra": "a Noé" },
        { "hebraico": "בֹּֽא־אַתָּה֩", "transliteral": "bōʾ-ʾattâ", "traducao_palavra": "Entra tu" },
        { "hebraico": "וְכָל־בֵּיתְךָ֖", "transliteral": "wəḵāl-bêṯəḵā", "traducao_palavra": "e toda a tua casa" },
        { "hebraico": "אֶל־הַתֵּבָ֑ה", "transliteral": "ʾel-hattēḇâ", "traducao_palavra": "para a arca" },
        { "hebraico": "כִּֽי־אֹתְךָ֥", "transliteral": "kî-ʾōṯəḵā", "traducao_palavra": "porque a ti" },
        { "hebraico": "רָאִ֛יתִי", "transliteral": "rāʾîṯî", "traducao_palavra": "tenho visto" },
        { "hebraico": "צַדִּ֥ique", "transliteral": "ṣaddîq", "traducao_palavra": "justo" },
        { "hebraico": "לְפָנַ֖י", "transliteral": "ləp̱ānay", "traducao_palavra": "diante de mim" },
        { "hebraico": "בַּדּ֥וֹר", "transliteral": "baddôr", "traducao_palavra": "na geração" },
        { "hebraico": "הַזֶּֽה׃", "transliteral": "hazzeh", "traducao_palavra": "esta" }
      ]
    },
    "2": {
      "traducao_completa": "De todo animal limpo tomarás para ti sete e sete, macho e sua fêmea; mas dos animais que não são limpos, dois, macho e sua fêmea.",
