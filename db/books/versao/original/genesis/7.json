      ]
    },
    "4": {
      "traducao_completa": "Porque, daqui a sete dias, farei chover sobre a terra quarenta dias e quarenta noites; e apagarei de sobre a face da terra toda a substância que fiz.",
      "palavras": [
        { "hebraico": "כִּי֩", "transliteral": "kî", "traducao_palavra": "Porque" },
        { "hebraico": "לְיָמִ֨ים", "transliteral": "ləyāmîm", "traducao_palavra": "para dias" },
        { "hebraico": "עוֹד", "transliteral": "ʿôḏ", "traducao_palavra": "ainda" },
        { "hebraico": "שִׁבְעָ֜ה", "transliteral": "šiḇʿâ", "traducao_palavra": "sete" },
