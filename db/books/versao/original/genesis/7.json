        { "hebraico": "וּנְקֵבָ֑ה", "transliteral": "ûnəqēḇâ", "traducao_palavra": "e fêmea" },
        { "hebraico": "לְחַיֹּ֥ות", "transliteral": "ləḥayyôṯ", "traducao_palavra": "para manter vivo" },
