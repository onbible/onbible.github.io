        { "hebraico": "שָׁנָה֙", "transliteral": "šānâ", "traducao_palavra": "ano" },
        { "hebraico": "לְחַיֵּי־נֹ֔חַ", "transliteral": "ləḥayyê-nōḥa", "traducao_palavra": "para a vida de Noé" },
