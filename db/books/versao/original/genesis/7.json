{
  "livro": "Gênesis - בְּרֵאשִׁית - Bereshit",
  "capítulo": 7,
  "titulos": {},
  "versiculos": {
    "1": {
      "traducao_completa": "E disse o SENHOR a Noé: Entra tu e toda a tua casa na arca, porque a ti tenho visto justo diante de mim nesta geração.",
      "palavras": [
