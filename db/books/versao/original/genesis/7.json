        { "hebraico": "הַטְּהוֹרָ֗ה", "transliteral": "haṭṭəhôrâ", "traducao_palavra": "o limpo" },
        { "hebraico": "תִּֽקַּח־לְךָ֛", "transliteral": "tiqqaḥ-ləḵā", "traducao_palavra": "tomarás para ti" },
        { "hebraico": "שִׁבְעָ֥ה", "transliteral": "šiḇʿâ", "traducao_palavra": "sete" },
        { "hebraico": "שִׁבְעָ֖ה", "transliteral": "šiḇʿâ", "traducao_palavra": "sete" },
        { "hebraico": "אִ֣ישׁ", "transliteral": "ʾîš", "traducao_palavra": "macho [homem]" },
        { "hebraico": "וְאִשְׁתּ֑וֹ", "transliteral": "wəʾištô", "traducao_palavra": "e sua mulher" },
        { "hebraico": "וּמִן־הַבְּהֵמָ֡ה", "transliteral": "ûmin-habbəhēmâ", "traducao_palavra": "e do animal" },
        { "hebraico": "אֲ֠שֶׁר", "transliteral": "ʾăšer", "traducao_palavra": "que" },
