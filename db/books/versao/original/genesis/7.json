      ]
    },
    "3": {
      "traducao_completa": "Também das aves dos céus sete e sete, macho e fêmea, para conservar viva a semente sobre a face de toda a terra.",
      "palavras": [
        { "hebraico": "גַּ֣ם", "transliteral": "gam", "traducao_palavra": "Também" },
        { "hebraico": "מֵעוֹף", "transliteral": "mēʿôp̱", "traducao_palavra": "da ave de" },
        { "hebraico": "הַשָּׁמַ֗יִם", "transliteral": "haššāmayim", "traducao_palavra": "os céus" },
        { "hebraico": "שִׁבְעָ֥ה", "transliteral": "šiḇʿâ", "traducao_palavra": "sete" },
        { "hebraico": "שִׁבְעָ֖ה", "transliteral": "šiḇʿâ", "traducao_palavra": "sete" },
