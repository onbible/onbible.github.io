        { "hebraico": "לְמִינָ֗הּ", "transliteral": "ləmînāh", "traducao_palavra": "conforme sua espécie" },
        { "hebraico": "וְכָל־הַבְּהֵמָה֙", "transliteral": "wəḵāl-habbəhēmâ", "traducao_palavra": "e todo animal" },
