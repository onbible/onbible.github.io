      ]
    },
    "7": {
      "traducao_completa": "Depois voltaram e vieram a En-Mispate (que é Cades), e feriram toda a terra dos amalequitas, e também os amorreus, que habitavam em Hazazom-Tamar.",
      "palavras": [
        { "hebraico": "וַ֠יָּשֻׁבוּ", "transliteral": "wayyāšubû", "traducao_palavra": "E voltaram" },
        { "hebraico": "וַיָּבֹ֨אוּ", "transliteral": "wayyāḇōʾû", "traducao_palavra": "e vieram" },
        { "hebraico": "אֶל־עֵ֥ין מִשְׁפָּ֛ט", "transliteral": "ʾel-ʿên mišppāṭ", "traducao_palavra": "para En-Mispate" },
        { "hebraico": "הִ֥יא", "transliteral": "hî", "traducao_palavra": "ela [é]" },
        { "hebraico": "קָדֵ֑שׁ", "transliteral": "qāḏēš", "traducao_palavra": "Cades" },
        { "hebraico": "וַיַּכּוּ֙", "transliteral": "wayyakkû", "traducao_palavra": "e feriram" },
        { "hebraico": "אֶת־כָּל־שְׂדֵה֙", "transliteral": "ʾeṯ-kāl-śəḏēh", "traducao_palavra": "[obj] todo o campo de" },
        { "hebraico": "הָעֲמָלֵקִ֔י", "transliteral": "hāʿămālēqî", "traducao_palavra": "o amalequita" },
        { "hebraico": "וְגַם֙", "transliteral": "wəḡam", "traducao_palavra": "e também" },
        { "hebraico": "אֶת־הָאֱמֹרִ֔י", "transliteral": "ʾeṯ-hāʾĕmōrî", "traducao_palavra": "[obj] o amorreu" },
        { "hebraico": "הַיֹּשֵׁ֖ב", "transliteral": "hayyōšēḇ", "traducao_palavra": "o habitante" },
        { "hebraico": "בְּחַֽצֲצֹ֥ן תָּמָֽר׃", "transliteral": "bəḥaṣaṣōn tāmār", "traducao_palavra": "em Hazazom-Tamar" }
      ]
    },
    "8": {
      "traducao_completa": "Então saiu o rei de Sodoma, e o rei de Gomorra, e o rei de Admá, e o rei de Zeboim, e o rei de Bela (esta é Zoar), e ordenaram batalha contra eles no vale de Sidim,",
      "palavras": [
        { "hebraico": "וַיֵּצֵ֨א", "transliteral": "wayyēṣēʾ", "traducao_palavra": "E saiu" },
        { "hebraico": "מֶֽלֶךְ־סְדֹ֜ם", "transliteral": "meleḵ-səḏōm", "traducao_palavra": "rei de Sodoma" },
        { "hebraico": "וּמֶ֤לֶךְ עֲמֹרָה֙", "transliteral": "ûmeleḵ ʿămōrâ", "traducao_palavra": "e rei de Gomorra" },
        { "hebraico": "וּמֶ֣לֶךְ אַדְמָ֔ה", "transliteral": "ûmeleḵ ʾaḏmâ", "traducao_palavra": "e rei de Admá" },
        { "hebraico": "וּמֶ֥לֶךְ צְבֹיִ֖ים", "transliteral": "ûmeleḵ ṣəḇōyim", "traducao_palavra": "e rei de Zeboim" },
        { "hebraico": "וּמֶ֣לֶךְ בֶּ֔לַע", "transliteral": "ûmeleḵ belaʿ", "traducao_palavra": "e rei de Bela" },
        { "hebraico": "הִיא־צֹ֑עַר", "transliteral": "hî-ṣōʿar", "traducao_palavra": "esta [é] Zoar" },
        { "hebraico": "וַיַּעַרְכ֤וּ", "transliteral": "wayyaʿarḵû", "traducao_palavra": "e ordenaram" },
        { "hebraico": "אִתָּם֙", "transliteral": "ʾittām", "traducao_palavra": "com eles" },
        { "hebraico": "מִלְחָמָ֔ה", "transliteral": "milḥāmâ", "traducao_palavra": "batalha" },
        { "hebraico": "בְּעֵ֖מֶק", "transliteral": "bəʿēmeq", "traducao_palavra": "no vale de" },
        { "hebraico": "הַשִּׂדִּֽים׃", "transliteral": "haśśiddîm", "traducao_palavra": "Sidim" }
      ]
    },
    "9": {
      "traducao_completa": "contra Quedorlaomer, rei de Elão, e Tidal, rei de Goim, e Anrafel, rei de Sinar, e Arioque, rei de Elasar; quatro reis contra cinco.",
      "palavras": [
        { "hebraico": "אֵ֣ת", "transliteral": "ʾēṯ", "traducao_palavra": "com" },
        { "hebraico": "כְּדָרְלָעֹ֙מֶר֙", "transliteral": "kəḏārlāʿōmer", "traducao_palavra": "Quedorlaomer" },
        { "hebraico": "מֶ֣לֶךְ עֵילָ֔ם", "transliteral": "meleḵ ʿêlām", "traducao_palavra": "rei de Elão" },
        { "hebraico": "וְתִדְעָ֖ל", "transliteral": "wəṯiḏʿāl", "traducao_palavra": "e Tidal" },
        { "hebraico": "מֶ֥לֶךְ גֹּויִ֑ם", "transliteral": "meleḵ gôyim", "traducao_palavra": "rei de Goim" },
        { "hebraico": "וְאַמְרָפֶל֙", "transliteral": "wəʾamrāp̱el", "traducao_palavra": "e Anrafel" },
        { "hebraico": "מֶ֣לֶךְ שִׁנְעָ֔ר", "transliteral": "meleḵ šinəʿār", "traducao_palavra": "rei de Sinar" },
        { "hebraico": "וְאַרְיֹ֖וךְ", "transliteral": "wəʾaryôḵ", "traducao_palavra": "e Arioque" },
        { "hebraico": "מֶ֣לֶךְ אֶלָּסָ֑ר", "transliteral": "meleḵ ʾellāsār", "traducao_palavra": "rei de Elasar" },
        { "hebraico": "אַרְבָּעָ֥ה", "transliteral": "ʾarbbāʿâ", "traducao_palavra": "quatro" },
        { "hebraico": "מְלָכִ֖ים", "transliteral": "məlāḵîm", "traducao_palavra": "reis" },
        { "hebraico": "אֶת־הַחֲמִשָּֽׁה׃", "transliteral": "ʾeṯ-haḥămiššâ", "traducao_palavra": "contra os cinco" }
      ]
    },
    "10": {
      "traducao_completa": "E o vale de Sidim estava cheio de poços de betume; e fugiram os reis de Sodoma e de Gomorra, e caíram ali; e os restantes fugiram para o monte.",
      "palavras": [
        { "hebraico": "וְעֵ֣מֶק", "transliteral": "wəʿēmeq", "traducao_palavra": "E o vale de" },
        { "hebraico": "הַשִּׂדִּ֗ים", "transliteral": "haśśiddîm", "traducao_palavra": "Sidim" },
        { "hebraico": "בֶּאֱרֹ֤ת", "transliteral": "beʾĕrōṯ", "traducao_palavra": "poços de" },
        { "hebraico": "בֶּֽאֱרֹת֙", "transliteral": "beʾĕrōṯ", "traducao_palavra": "poços de" },
        { "hebraico": "חֵמָ֔ר", "transliteral": "ḥēmār", "traducao_palavra": "betume" },
        { "hebraico": "וַיָּנֻ֜סוּ", "transliteral": "wayyānūsû", "traducao_palavra": "e fugiram" },
        { "hebraico": "מֶֽלֶךְ־סְדֹ֤ם", "transliteral": "meleḵ-səḏōm", "traducao_palavra": "rei de Sodoma" },
        { "hebraico": "וַעֲמֹרָה֙", "transliteral": "waʿămōrâ", "traducao_palavra": "e Gomorra" },
        { "hebraico": "וַיִּפְּלוּ־שָׁ֑מָּה", "transliteral": "wayyippəlû-šāmmâ", "traducao_palavra": "e caíram lá" },
        { "hebraico": "וְהַנִּשְׁאָרִ֖ים", "transliteral": "wəhannišʾārîm", "traducao_palavra": "e os restantes" },
        { "hebraico": "הֶ֥רָה", "transliteral": "hērâ", "traducao_palavra": "para o monte" },
