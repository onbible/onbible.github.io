{
  "livro": "Gênesis - בְּרֵאשִׁית - Bereshit",
  "capítulo": 14,
  "titulos": {},
  "versiculos": {
    "1": {
      "traducao_completa": "E aconteceu nos dias de Anrafel, rei de Sinar, de Arioque, rei de Elasar, de Quedorlaomer, rei de Elão, e de Tidal, rei de Goim,",
      "palavras": [
        { "hebraico": "וַיְהִ֗י", "transliteral": "wayəhî", "traducao_palavra": "E aconteceu" },
        { "hebraico": "בִּימֵי֙", "transliteral": "bîmê", "traducao_palavra": "nos dias de" },
        { "hebraico": "אַמְרָפֶ֣ל", "transliteral": "ʾamrāp̱el", "traducao_palavra": "Anrafel" },
        { "hebraico": "מֶֽלֶךְ־שִׁנְעָ֔ר", "transliteral": "meleḵ-šinəʿār", "traducao_palavra": "rei de Sinar" },
        { "hebraico": "אַרְיֹ֖וךְ", "transliteral": "ʾaryôḵ", "traducao_palavra": "Arioque" },
        { "hebraico": "מֶ֣לֶךְ אֶלָּסָ֑ר", "transliteral": "meleḵ ʾellāsār", "traducao_palavra": "rei de Elasar" },
        { "hebraico": "כְּדָרְלָעֹ֙מֶר֙", "transliteral": "kəḏārlāʿōmer", "traducao_palavra": "Quedorlaomer" },
        { "hebraico": "מֶ֣לֶךְ עֵילָ֔ם", "transliteral": "meleḵ ʿêlām", "traducao_palavra": "rei de Elão" },
        { "hebraico": "וְתִדְעָ֖ל", "transliteral": "wəṯiḏʿāl", "traducao_palavra": "e Tidal" },
        { "hebraico": "מֶ֥לֶךְ גֹּויִֽם׃", "transliteral": "meleḵ gôyim", "traducao_palavra": "rei de Goim" }
      ]
    },
    "2": {
      "traducao_completa": "fizeram eles guerra contra Bera, rei de Sodoma, e contra Birsa, rei de Gomorra, Sinabe, rei de Admá, e Semeber, rei de Zeboim, e o rei de Bela (esta é Zoar).",
      "palavras": [
        { "hebraico": "עָשׂ֣וּ", "transliteral": "ʿāśû", "traducao_palavra": "fizeram" },
        { "hebraico": "מִלְחָמָ֗ה", "transliteral": "milḥāmâ", "traducao_palavra": "guerra" },
        { "hebraico": "אֶת־בֶּ֙רַע֙", "transliteral": "ʾeṯ-berʿa", "traducao_palavra": "com Bera" },
        { "hebraico": "מֶ֣לֶךְ סְדֹ֔ם", "transliteral": "meleḵ səḏōm", "traducao_palavra": "rei de Sodoma" },
        { "hebraico": "וְאֶת־בִּרְשַׁ֖ע", "transliteral": "wəʾeṯ-biršaʿ", "traducao_palavra": "e com Birsa" },
        { "hebraico": "מֶ֣לֶךְ עֲמֹרָ֑ה", "transliteral": "meleḵ ʿămōrâ", "traducao_palavra": "rei de Gomorra" },
        { "hebraico": "שִׁנְאָ֞ב", "transliteral": "šinʾāḇ", "traducao_palavra": "Sinabe" },
        { "hebraico": "מֶ֣לֶךְ אַדְמָ֗ה", "transliteral": "meleḵ ʾaḏmâ", "traducao_palavra": "rei de Admá" },
        { "hebraico": "וְשֶׁמְאֵ֙בֶר֙", "transliteral": "wəšeməʾēḇer", "traducao_palavra": "e Semeber" },
        { "hebraico": "מֶ֣לֶךְ צְבֹויִ֔ים", "transliteral": "meleḵ ṣəḇôyim", "traducao_palavra": "rei de Zeboim" },
        { "hebraico": "וּמֶ֥לֶךְ בֶּ֖לַע", "transliteral": "ûmeleḵ belaʿ", "traducao_palavra": "e o rei de Bela" },
        { "hebraico": "הִיא־צֹֽעַר׃", "transliteral": "hî-ṣōʿar", "traducao_palavra": "esta [é] Zoar" }
      ]
    },
    "3": {
      "traducao_completa": "Todos estes se ajuntaram no vale de Sidim (este é o Mar do Sal).",
      "palavras": [
        { "hebraico": "כָּל־אֵ֙לֶּה֙", "transliteral": "kāl-ʾēlleh", "traducao_palavra": "Todos estes" },
        { "hebraico": "חָבְר֔וּ", "transliteral": "ḥāḇərû", "traducao_palavra": "ajuntaram-se" },
        { "hebraico": "אֶל־עֵ֖מֶק", "transliteral": "ʾel-ʿēmeq", "traducao_palavra": "para o vale de" },
        { "hebraico": "הַשִּׂדִּ֑ים", "transliteral": "haśśiddîm", "traducao_palavra": "Sidim" },
        { "hebraico": "ה֖וּא", "transliteral": "hû", "traducao_palavra": "ele [é]" },
        { "hebraico": "יָ֥ם הַמֶּֽלַח׃", "transliteral": "yām hammelaḥ", "traducao_palavra": "Mar do Sal" }
      ]
    },
    "4": {
      "traducao_completa": "Doze anos serviram a Quedorlaomer, mas ao décimo terceiro ano rebelaram-se.",
      "palavras": [
        { "hebraico": "שְׁתֵּים־עֶשְׂרֵ֣ה", "transliteral": "šəttêm-ʿeśrēh", "traducao_palavra": "Doze" },
        { "hebraico": "שָׁנָ֔ה", "transliteral": "šānâ", "traducao_palavra": "anos" },
        { "hebraico": "עָבְד֖וּ", "transliteral": "ʿāḇəḏû", "traducao_palavra": "serviram" },
        { "hebraico": "אֶת־כְּדָרְלָעֹ֑מֶר", "transliteral": "ʾeṯ-kəḏārlāʿōmer", "traducao_palavra": "[obj] Quedorlaomer" },
        { "hebraico": "וּשְׁלֹשׁ־עֶשְׂרֵ֥ה", "transliteral": "ûšəlōš-ʿeśrēh", "traducao_palavra": "e treze" },
        { "hebraico": "שָׁנָ֖ה", "transliteral": "šānâ", "traducao_palavra": "anos" },
        { "hebraico": "מָרָֽדוּ׃", "transliteral": "mārāḏû", "traducao_palavra": "rebelaram-se" }
      ]
    },
    "5": {
      "traducao_completa": "E ao décimo quarto ano veio Quedorlaomer e os reis que estavam com ele, e feriram os refains em Asterote-Carnaim, e os zuzins em Ham, e os emins em Savé-Quiriataim,",
      "palavras": [
        { "hebraico": "וּבְאַרְבַּע־עֶשְׂרֵ֨ה", "transliteral": "ûḇəʾarbaʿ-ʿeśrēh", "traducao_palavra": "E no quatorze" },
        { "hebraico": "שָׁנָ֜ה", "transliteral": "šānâ", "traducao_palavra": "ano" },
        { "hebraico": "בָּ֣א", "transliteral": "bāʾ", "traducao_palavra": "veio" },
        { "hebraico": "כְדָרְלָעֹ֗מֶר", "transliteral": "ḵəḏārlāʿōmer", "traducao_palavra": "Quedorlaomer" },
        { "hebraico": "וְהַמְּלָכִים֙", "transliteral": "wəhamməlāḵîm", "traducao_palavra": "e os reis" },
        { "hebraico": "אֲשֶׁ֣ר", "transliteral": "ʾăšer", "traducao_palavra": "que" },
        { "hebraico": "אִתֹּ֔ו", "transliteral": "ʾittô", "traducao_palavra": "com ele" },
        { "hebraico": "וַיַּכּ֤וּ", "transliteral": "wayyakkû", "traducao_palavra": "e feriram" },
        { "hebraico": "אֶת־רְפָאִים֙", "transliteral": "ʾeṯ-rəp̱āʾîm", "traducao_palavra": "[obj] os refains" },
        { "hebraico": "בְּעַשְׁתְּרֹ֣ת", "transliteral": "bəʿašttərōṯ", "traducao_palavra": "em Asterote" },
        { "hebraico": "קַרְנַ֔יִם", "transliteral": "qarnayim", "traducao_palavra": "Carnaim" },
        { "hebraico": "וְאֶת־הַזּוּזִים֙", "transliteral": "wəʾeṯ-hazzûzîm", "traducao_palavra": "e [obj] os zuzins" },
        { "hebraico": "בְּהָ֑ם", "transliteral": "bəhām", "traducao_palavra": "em Ham" },
        { "hebraico": "וְאֵת֙", "transliteral": "wəʾēṯ", "traducao_palavra": "e [obj]" },
        { "hebraico": "הָֽאֵימִ֔ים", "transliteral": "hāʾêmîm", "traducao_palavra": "os emins" },
        { "hebraico": "בְּשָׁוֵ֖ה", "transliteral": "bəšāwēh", "traducao_palavra": "em Savé" },
        { "hebraico": "קִרְיָתָֽיִם׃", "transliteral": "qiryāṯāyim", "traducao_palavra": "Quiriataim" }
      ]
    },
    "6": {
      "traducao_completa": "E aos horeus no seu monte Seir, até El-Parã que está junto ao deserto.",
      "palavras": [
        { "hebraico": "וְאֶת־הַחֹרִ֖י", "transliteral": "wəʾeṯ-haḥōrî", "traducao_palavra": "e [obj] o horeu" },
        { "hebraico": "בְּהַרְרָ֣ם", "transliteral": "bəharərām", "traducao_palavra": "em seu monte" },
        { "hebraico": "שֵׂעִ֑יר", "transliteral": "śēʿîr", "traducao_palavra": "Seir" },
        { "hebraico": "עַ֚ד", "transliteral": "ʿaḏ", "traducao_palavra": "até" },
        { "hebraico": "אֵ֣יל פָּארָ֔ן", "transliteral": "ʾêl pāʾrān", "traducao_palavra": "El-Parã" },
        { "hebraico": "אֲשֶׁ֖ר", "transliteral": "ʾăšer", "traducao_palavra": "que" },
