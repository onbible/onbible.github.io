        { "hebraico": "מִן־הַמָּקֹ֖ום", "transliteral": "min-hammāqôm", "traducao_palavra": "desde o lugar" },
        { "hebraico": "אֲשֶׁר־אַתָּ֣ה", "transliteral": "ʾăšer-ʾattâ", "traducao_palavra": "onde tu" },
        { "hebraico": "שָׁ֑ם", "transliteral": "šām", "traducao_palavra": "[estás] lá" },
        { "hebraico": "צָפֹ֥נָה", "transliteral": "ṣāp̄ōnâ", "traducao_palavra": "ao norte" },
