        { "hebraico": "לָשֶׁ֣בֶת", "transliteral": "lāšeḇeṯ", "traducao_palavra": "para habitar" },
        { "hebraico": "יַחְדָּ֑ו", "transliteral": "yaḥdāw", "traducao_palavra": "juntos" },
