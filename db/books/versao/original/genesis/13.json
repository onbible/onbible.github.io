        { "hebraico": "יְהוָ֗ה", "transliteral": "YHWH", "traducao_palavra": "YHWH" },
        { "hebraico": "אֶת־סְדֹם֙", "transliteral": "ʾeṯ-səḏōm", "traducao_palavra": "[obj] Sodoma" },
