        { "hebraico": "אֶת־זַרְעֲךָ֖", "transliteral": "ʾeṯ-zarʿăḵā", "traducao_palavra": "[obj] tua semente" },
        { "hebraico": "כַּעֲפַ֣ר", "transliteral": "kaʿăp̄ar", "traducao_palavra": "como o pó de" },
        { "hebraico": "הָאָ֑רֶץ", "transliteral": "hāʾāreṣ", "traducao_palavra": "a terra" },
