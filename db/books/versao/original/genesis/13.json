        { "hebraico": "מֵֽעִמֹּ֑ו", "transliteral": "mēʿimmô", "traducao_palavra": "de com ele" },
        { "hebraico": "שָׂ֣א נָ֤א", "transliteral": "śāʾ nāʾ", "traducao_palavra": "Levanta, peço" },
