        { "hebraico": "עַל", "transliteral": "ʿal", "traducao_palavra": "contra" },
        { "hebraico": "שְׁנֵי", "transliteral": "šə-nê", "traducao_palavra": "dois de" },
        { "hebraico": "סָרִיסָיו", "transliteral": "sā-rî-śāw", "traducao_palavra": "seus oficiais" },
        { "hebraico": "עַל", "transliteral": "ʿal", "traducao_palavra": "contra" },
        { "hebraico": "שַׂר", "transliteral": "śar", "traducao_palavra": "o chefe de" },
        { "hebraico": "הַמַּשְׁקִים", "transliteral": "ham-maš-qîm", "traducao_palavra": "os copeiros" },
