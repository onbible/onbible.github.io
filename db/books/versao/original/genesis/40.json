        { "hebraico": "הַיּוֹם׃", "transliteral": "hay-yôm", "traducao_palavra": "hoje" }
      ]
    },
    "8": {
      "traducao_completa": "E eles lhe disseram: Sonhamos um sonho, e não há intérprete para ele. E disse-lhes José: Não pertencem a Deus as interpretações? Contai-mo, peço-vos.",
      "palavras": [
        { "hebraico": "וַיֹּאמְרוּ", "transliteral": "way-yō-mə-rû", "traducao_palavra": "e disseram" },
        { "hebraico": "אֵלָיו", "transliteral": "ʾē-lāw", "traducao_palavra": "a ele" },
        { "hebraico": "חֲלוֹם", "transliteral": "ḥă-lôm", "traducao_palavra": "um sonho" },
        { "hebraico": "חָלַמְנוּ", "transliteral": "ḥā-lam-nû", "traducao_palavra": "sonhamos" },
        { "hebraico": "וּפֹתֵר", "transliteral": "û-p̄ō-ṯēr", "traducao_palavra": "e intérprete" },
        { "hebraico": "אֵין", "transliteral": "ʾên", "traducao_palavra": "não há" },
