        { "hebraico": "וַיִּשְׁאַל", "transliteral": "way-yiš-ʾal", "traducao_palavra": "e perguntou" },
        { "hebraico": "אֶת־סְרִיסֵי", "transliteral": "ʾeṯ-śə-rî-śê", "traducao_palavra": "aos oficiais de" },
        { "hebraico": "פַּרְעֹה", "transliteral": "par-ʿōh", "traducao_palavra": "Faraó" },
        { "hebraico": "אֲשֶׁר", "transliteral": "ʾă-šer", "traducao_palavra": "que [estavam]" },
