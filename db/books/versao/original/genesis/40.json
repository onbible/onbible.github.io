        { "hebraico": "וַיֹּאמֶר", "transliteral": "way-yō-mer", "traducao_palavra": "e disse" },
        { "hebraico": "אֲלֵהֶם", "transliteral": "ʾă-lē-hem", "traducao_palavra": "a eles" },
        { "hebraico": "יוֹסֵף", "transliteral": "yô-sēp̄", "traducao_palavra": "José" },
        { "hebraico": "הֲלוֹא", "transliteral": "hă-lô", "traducao_palavra": "acaso não" },
        { "hebraico": "לֵאלֹהִים", "transliteral": "lē-lō-hîm", "traducao_palavra": "a Deus" },
        { "hebraico": "פִּתְרֹנִים", "transliteral": "piṯ-rō-nîm", "traducao_palavra": "[pertencem] as interpretações" },
        { "hebraico": "סַפְּרוּ־נָא", "transliteral": "sap-pə-rû-nā", "traducao_palavra": "contai peço" },
        { "hebraico": "לִי׃", "transliteral": "lî", "traducao_palavra": "a mim" }
      ]
    },
    "9": {
      "traducao_completa": "Então o copeiro-mor contou o seu sonho a José, e disse-lhe: No meu sonho, eis uma videira diante de mim.",
      "palavras": [
        { "hebraico": "וַיְסַפֵּר", "transliteral": "way-sap-pēr", "traducao_palavra": "e contou" },
        { "hebraico": "שַׂר־הַמַּשְׁקִים", "transliteral": "śar-ham-maš-qîm", "traducao_palavra": "o chefe dos copeiros" },
        { "hebraico": "אֶת־חֲלֹמוֹ", "transliteral": "ʾeṯ-ḥă-lō-mô", "traducao_palavra": "[o] seu sonho" },
        { "hebraico": "לְיוֹסֵף", "transliteral": "lə-yô-sēp̄", "traducao_palavra": "a José" },
        { "hebraico": "וַיֹּאמֶר", "transliteral": "way-yō-mer", "traducao_palavra": "e disse" },
        { "hebraico": "לוֹ", "transliteral": "lô", "traducao_palavra": "a ele" },
        { "hebraico": "בַּחֲלוֹמִי", "transliteral": "ba-ḥă-lō-mî", "traducao_palavra": "no meu sonho" },
        { "hebraico": "וְהִנֵּה־גֶפֶן", "transliteral": "wə-hin-nēh-ḡe-p̄en", "traducao_palavra": "e eis uma videira" },
        { "hebraico": "לְפָנָי׃", "transliteral": "lə-p̄ā-nāy", "traducao_palavra": "diante de mim" }
      ]
    },
    "10": {
      "traducao_completa": "E na videira três ramos; e ela, florescendo, brotava as suas flores, e os seus cachos amadureciam em uvas.",
      "palavras": [
        { "hebraico": "וּבַגֶּפֶן", "transliteral": "û-ḇaḡ-ge-p̄en", "traducao_palavra": "e na videira" },
        { "hebraico": "שְׁלֹשָׁה", "transliteral": "šə-lō-šāh", "traducao_palavra": "três de" },
        { "hebraico": "שָׂרִיגִם", "transliteral": "śā-rî-ḡim", "traducao_palavra": "ramos" },
        { "hebraico": "וְהִיא", "transliteral": "wə-hî", "traducao_palavra": "e ela" },
        { "hebraico": "כְפֹרַחַת", "transliteral": "ḵə-p̄ō-ra-ḥaṯ", "traducao_palavra": "como brotando" },
        { "hebraico": "עָלְתָה", "transliteral": "ʿā-lə-ṯā", "traducao_palavra": "subia" },
        { "hebraico": "נִצָּהּ", "transliteral": "niṣ-ṣāh", "traducao_palavra": "sua flor" },
        { "hebraico": "הִבְשִׁילוּ", "transliteral": "hiḇ-šî-lû", "traducao_palavra": "amadureciam" },
        { "hebraico": "אַשְׁכְּלֹתֶיהָ", "transliteral": "ʾaš-kə-lō-ṯe-hā", "traducao_palavra": "seus cachos" },
        { "hebraico": "עֲנָבִים׃", "transliteral": "ʿă-nā-ḇîm", "traducao_palavra": "uvas" }
      ]
    },
    "11": {
      "traducao_completa": "E o copo de Faraó estava na minha mão; e tomei as uvas, e as espremi no copo de Faraó, e dei o copo na mão de Faraó.",
      "palavras": [
        { "hebraico": "וְכוֹס", "transliteral": "wə-ḵôs", "traducao_palavra": "e o copo de" },
        { "hebraico": "פַּרְעֹה", "transliteral": "par-ʿōh", "traducao_palavra": "Faraó" },
        { "hebraico": "בְּיָדִי", "transliteral": "bə-yā-ḏî", "traducao_palavra": "em minha mão" },
        { "hebraico": "וָאֶקַּח", "transliteral": "wā-ʾeq-qaḥ", "traducao_palavra": "e tomei" },
        { "hebraico": "אֶת־הָעֲנָבִים", "transliteral": "ʾeṯ-hā-ʿă-nā-ḇîm", "traducao_palavra": "as uvas" },
        { "hebraico": "וָאֶשְׂחַט", "transliteral": "wā-ʾeś-ḥaṭ", "traducao_palavra": "e as espremi" },
        { "hebraico": "אֹתָם", "transliteral": "ʾō-ṯām", "traducao_palavra": "a elas" },
        { "hebraico": "אֶל־כּוֹס", "transliteral": "ʾel-kôs", "traducao_palavra": "no copo de" },
        { "hebraico": "פַּרְעֹה", "transliteral": "par-ʿōh", "traducao_palavra": "Faraó" },
        { "hebraico": "וָאֶתֵּן", "transliteral": "wā-ʾet-tēn", "traducao_palavra": "e dei" },
        { "hebraico": "אֶת־הַכּוֹס", "transliteral": "ʾeṯ-hak-kôs", "traducao_palavra": "o copo" },
        { "hebraico": "עַל־כַּף", "transliteral": "ʿal-kap̄", "traducao_palavra": "na palma de/mão de" },
        { "hebraico": "פַּרְעֹה׃", "transliteral": "par-ʿōh", "traducao_palavra": "Faraó" }
      ]
    },
    "12": {
      "traducao_completa": "Então disse-lhe José: Esta é a sua interpretação: Os três ramos são três dias.",
