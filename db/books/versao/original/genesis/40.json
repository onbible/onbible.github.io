        { "hebraico": "וְהִנָּם", "transliteral": "wə-hin-nām", "traducao_palavra": "e eis que eles" },
        { "hebraico": "זֹעֲפִים׃", "transliteral": "zō-ʿă-p̄îm", "traducao_palavra": "perturbados/abatidos" }
      ]
    },
    "7": {
      "traducao_completa": "E perguntou aos oficiais de Faraó que estavam com ele na prisão da casa de seu senhor, dizendo: Por que estão os vossos semblantes maus hoje?",
