        { "hebraico": "וְהָאֹפֶה", "transliteral": "wə-hā-ʾō-p̄eh", "traducao_palavra": "e o padeiro" },
        { "hebraico": "לַאֲדֹנֵיהֶם", "transliteral": "la-ʾă-ḏō-nê-hem", "traducao_palavra": "contra o senhor deles" },
        { "hebraico": "לְמֶלֶךְ", "transliteral": "lə-me-leḵ", "traducao_palavra": "contra o rei de" },
        { "hebraico": "מִצְרָיִם׃", "transliteral": "miṣ-rā-yim", "traducao_palavra": "Egito" }
      ]
    },
    "2": {
      "traducao_completa": "E indignou-se Faraó contra os seus dois oficiais: contra o copeiro-mor e contra o padeiro-mor.",
      "palavras": [
