    "5": {
      "traducao_completa": "E ambos sonharam um sonho, cada um o seu sonho na mesma noite, cada um conforme a interpretação do seu sonho, o copeiro e o padeiro do rei do Egito, que estavam presos na casa do cárcere.",
      "palavras": [
        { "hebraico": "וַיַּחַלְמוּ", "transliteral": "way-ya-ḥal-mû", "traducao_palavra": "e sonharam" },
        { "hebraico": "חֲלוֹם", "transliteral": "ḥă-lôm", "traducao_palavra": "um sonho" },
        { "hebraico": "שְׁנֵיהֶם", "transliteral": "šə-nê-hem", "traducao_palavra": "ambos" },
        { "hebraico": "אִישׁ", "transliteral": "ʾîš", "traducao_palavra": "cada um" },
        { "hebraico": "חֲלֹמוֹ", "transliteral": "ḥă-lō-mô", "traducao_palavra": "seu sonho" },
        { "hebraico": "בְּלַיְלָה", "transliteral": "bə-lay-lāh", "traducao_palavra": "numa noite" },
