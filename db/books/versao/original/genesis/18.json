{
  "livro": "Gênesis - בְּרֵאשִׁית - Bereshit",
  "capítulo": 18,
  "titulos": {},
  "versiculos": {
    "1": {
      "traducao_completa": "E apareceu-lhe o SENHOR nos carvalhais de Manre, estando ele assentado à porta da tenda, no calor do dia.",
      "palavras": [
        { "hebraico": "וַיֵּרָ֤א", "transliteral": "wayyērāʾ", "traducao_palavra": "E apareceu" },
        { "hebraico": "אֵלָיו֙", "transliteral": "ʾēlāyw", "traducao_palavra": "a ele" },
        { "hebraico": "יְהוָ֔ה", "transliteral": "YHWH", "traducao_palavra": "YHWH" },
        { "hebraico": "בְּאֵלֹנֵ֖י", "transliteral": "bəʾēlōnê", "traducao_palavra": "nos carvalhais de" },
        { "hebraico": "מַמְרֵ֑א", "transliteral": "mamərēʾ", "traducao_palavra": "Manre" },
        { "hebraico": "וְה֛וּא", "transliteral": "wəhû", "traducao_palavra": "e ele" },
        { "hebraico": "יֹשֵׁ֥ב", "transliteral": "yōšēḇ", "traducao_palavra": "estava sentado" },
        { "hebraico": "פֶּֽתַח־הָאֹ֖הֶל", "transliteral": "p̱eṯaḥ-hāʾōhel", "traducao_palavra": "à porta da tenda" },
        { "hebraico": "כְּחֹ֥ם", "transliteral": "kəḥōm", "traducao_palavra": "no calor de" },
        { "hebraico": "הַיֹּֽום׃", "transliteral": "hayyôm", "traducao_palavra": "o dia" }
      ]
    },
    "2": {
      "traducao_completa": "E levantou os seus olhos, e olhou, e eis três homens em pé defronte dele. E vendo-os, correu da porta da tenda ao seu encontro e inclinou-se à terra,",
      "palavras": [
        { "hebraico": "וַיִּשָּׂ֤א", "transliteral": "wayyiśśāʾ", "traducao_palavra": "E levantou" },
        { "hebraico": "עֵינָיו֙", "transliteral": "ʿênāyw", "traducao_palavra": "seus olhos" },
        { "hebraico": "וַיַּ֔רְא", "transliteral": "wayyarʾ", "traducao_palavra": "e viu" },
        { "hebraico": "וְהִנֵּה֙", "transliteral": "wəhinnēh", "traducao_palavra": "e eis" },
        { "hebraico": "שְׁלֹשָׁ֣ה", "transliteral": "šəlōšâ", "traducao_palavra": "três" },
        { "hebraico": "אֲנָשִׁ֔ים", "transliteral": "ʾănāšîm", "traducao_palavra": "homens" },
        { "hebraico": "נִצָּבִ֖ים", "transliteral": "niṣṣāḇîm", "traducao_palavra": "em pé" },
        { "hebraico": "עָלָ֑יו", "transliteral": "ʿālāyw", "traducao_palavra": "sobre ele" },
        { "hebraico": "וַיַּ֗רְא", "transliteral": "wayyarʾ", "traducao_palavra": "e vendo" },
        { "hebraico": "וַיָּ֤רָץ", "transliteral": "wayyāroṣ", "traducao_palavra": "e correu" },
        { "hebraico": "לִקְרָאתָם֙", "transliteral": "liqrāʾṯām", "traducao_palavra": "ao encontro deles" },
        { "hebraico": "מִפֶּ֣תַח", "transliteral": "mipp̱eṯaḥ", "traducao_palavra": "da porta de" },
        { "hebraico": "הָאֹ֔הֶל", "transliteral": "hāʾōhel", "traducao_palavra": "a tenda" },
        { "hebraico": "וַיִּשְׁת  ַּ֖חוּ", "transliteral": "wayyištāḥû", "traducao_palavra": "e inclinou-se" },
        { "hebraico": "אָֽרְצָה׃", "transliteral": "ʾārəṣâ", "traducao_palavra": "à terra" }
      ]
    },
    "3": {
      "traducao_completa": "e disse: Meu Senhor, se agora tenho achado graça aos teus olhos, rogo-te que não passes de teu servo.",
      "palavras": [
        { "hebraico": "וַיֹּאמַ֑ר", "transliteral": "wayyōʾmar", "traducao_palavra": "E disse" },
        { "hebraico": "אֲדֹנָ֗י", "transliteral": "ʾăḏōnāy", "traducao_palavra": "Meu Senhor" },
        { "hebraico": "אִם־נָ֨א", "transliteral": "ʾim-nāʾ", "traducao_palavra": "se agora" },
        { "hebraico": "מָצָ֤אתִי", "transliteral": "māṣāʾṯî", "traducao_palavra": "achei" },
        { "hebraico": "חֵן֙", "transliteral": "ḥēn", "traducao_palavra": "graça" },
        { "hebraico": "בְּעֵינֶ֔יךָ", "transliteral": "bəʿêneyḵā", "traducao_palavra": "em teus olhos" },
        { "hebraico": "אַל־נָ֥א", "transliteral": "ʾal-nāʾ", "traducao_palavra": "não, rogo" },
        { "hebraico": "תַעֲבֹ֖ר", "transliteral": "ṯaʿăḇōr", "traducao_palavra": "passes" },
        { "hebraico": "מֵעַ֥ל", "transliteral": "mēʿal", "traducao_palavra": "de sobre" },
        { "hebraico": "עַבְדֶּֽךָ׃", "transliteral": "ʿaḇdeḵā", "traducao_palavra": "teu servo" }
      ]
    },
    "4": {
      "traducao_completa": "Que se traga agora um pouco de água, e lavai os vossos pés, e recostai-vos debaixo desta árvore;",
      "palavras": [
        { "hebraico": "יֻקַּח־נָ֣א", "transliteral": "yuqqaḥ-nāʾ", "traducao_palavra": "Seja trazida, peço" },
        { "hebraico": "מְעַט־מַ֔יִם", "transliteral": "məʿaṭ-mayim", "traducao_palavra": "pouca água" },
        { "hebraico": "וְרַחֲצ֖וּ", "transliteral": "wəraḥăṣû", "traducao_palavra": "e lavai" },
        { "hebraico": "רַגְלֵיכֶ֑ם", "transliteral": "raḡlêḵem", "traducao_palavra": "vossos pés" },
        { "hebraico": "וְהִשָּׁעֲנ֖וּ", "transliteral": "wəhiššāʿănû", "traducao_palavra": "e recostai-vos" },
        { "hebraico": "תַּ֥חַת", "transliteral": "taḥaṯ", "traducao_palavra": "debaixo de" },
        { "hebraico": "הָעֵֽץ׃", "transliteral": "hāʿēṣ", "traducao_palavra": "a árvore" }
      ]
    },
    "5": {
      "traducao_completa": "e trarei um bocado de pão, para que escoreis o vosso coração; depois passareis adiante, porquanto por isso chegastes ao vosso servo. E disseram: Faze assim como disseste.",
      "palavras": [
        { "hebraico": "וְאֶקְחָ֨ה", "transliteral": "wəʾeqḥâ", "traducao_palavra": "E trarei" },
        { "hebraico": "פַת־לֶ֜חֶם", "transliteral": "p̱aṯ-leḥem", "traducao_palavra": "um bocado de pão" },
        { "hebraico": "וְסַעֲד֣וּ", "transliteral": "wəsaʿăḏû", "traducao_palavra": "e sustentai/escorai" },
        { "hebraico": "לִבְּכֶ֗ם", "transliteral": "libbəḵem", "traducao_palavra": "vosso coração" },
        { "hebraico": "אַחַר", "transliteral": "ʾaḥar", "traducao_palavra": "depois" },
        { "hebraico": "תַּעֲבֹ֔רוּ", "transliteral": "taʿăḇōrû", "traducao_palavra": "passareis" },
        { "hebraico": "כִּֽי־עַל־כֵּ֥ן", "transliteral": "kî-ʿal-kēn", "traducao_palavra": "pois por isso" },
        { "hebraico": "עֲבַרְתֶּ֖ם", "transliteral": "ʿăḇartem", "traducao_palavra": "passastes/viestes" },
        { "hebraico": "עַֽל־עַבְדְּכֶ֑ם", "transliteral": "ʿal-ʿaḇdəḵem", "traducao_palavra": "ao vosso servo" },
        { "hebraico": "וַיֹּאמְר֕וּ", "transliteral": "wayyōʾmərû", "traducao_palavra": "E disseram" },
        { "hebraico": "כֵּ֥ן", "transliteral": "kēn", "traducao_palavra": "assim" },
        { "hebraico": "תַּעֲשֶׂ֖ה", "transliteral": "taʿăśeh", "traducao_palavra": "faze" },
        { "hebraico": "כַּאֲשֶׁ֥ר", "transliteral": "kaʾăšer", "traducao_palavra": "conforme" },
        { "hebraico": "דִּבַּֽרְתָּ׃", "transliteral": "dibbartā", "traducao_palavra": "disseste" }
      ]
    },
    "6": {
      "traducao_completa": "E Abraão apressou-se a ir ter com Sara à tenda, e disse: Amassa depressa três medidas de flor de farinha, e faze bolos.",
      "palavras": [
        { "hebraico": "וַיְמַהֵ֧ר", "transliteral": "wayəmahēr", "traducao_palavra": "E apressou-se" },
        { "hebraico": "אַבְרָהָ֛ם", "transliteral": "ʾaḇrāhām", "traducao_palavra": "Abraão" },
        { "hebraico": "הָאֹ֥הֱלָה", "transliteral": "hāʾōhĕlâ", "traducao_palavra": "à tenda" },
        { "hebraico": "אֶל־שָׂרָ֑ה", "transliteral": "ʾel-śārâ", "traducao_palavra": "para Sara" },
        { "hebraico": "וַיֹּ֗אמֶר", "transliteral": "wayyōʾmer", "traducao_palavra": "e disse" },
        { "hebraico": "מַהֲרִ֞י", "transliteral": "mahărî", "traducao_palavra": "apressa-te" },
        { "hebraico": "שְׁלֹ֤שׁ", "transliteral": "šəlōš", "traducao_palavra": "três" },
        { "hebraico": "סְאִים֙", "transliteral": "śəʾîm", "traducao_palavra": "seás [medidas]" },
        { "hebraico": "סֹ֣לֶת", "transliteral": "sōleṯ", "traducao_palavra": "flor de farinha" },
        { "hebraico": "לוּשִׁ֖י", "transliteral": "lûšî", "traducao_palavra": "amassa" },
        { "hebraico": "וַעֲשִׂ֥י", "transliteral": "waʿăśî", "traducao_palavra": "e faze" },
        { "hebraico": "עֻגֹֽות׃", "transliteral": "ʿuḡôṯ", "traducao_palavra": "bolos" }
      ]
    },
    "7": {
      "traducao_completa": "E correu Abraão ao gado, e tomou um bezerro terno e bom, e deu-o ao jovem, que se apressou a prepará-lo.",
      "palavras": [
        { "hebraico": "וְאֶל־הַבָּקָ֖ר", "transliteral": "wəʾel-habbāqār", "traducao_palavra": "E para o gado" },
        { "hebraico": "רָ֣ץ", "transliteral": "rāṣ", "traducao_palavra": "correu" },
        { "hebraico": "אַבְרָהָ֑ם", "transliteral": "ʾaḇrāhām", "traducao_palavra": "Abraão" },
        { "hebraico": "וַיִּקַּ֨ח", "transliteral": "wayyiqqaḥ", "traducao_palavra": "e tomou" },
        { "hebraico": "בֶּן־בָּקָ֜ר", "transliteral": "ben-bāqār", "traducao_palavra": "um bezerro" },
        { "hebraico": "רַ֣ךְ", "transliteral": "raḵ", "traducao_palavra": "terno" },
        { "hebraico": "וָטֹוב֒", "transliteral": "wāṭôḇ", "traducao_palavra": "e bom" },
        { "hebraico": "וַיִּתֵּן֙", "transliteral": "wayyittēn", "traducao_palavra": "e deu" },
        { "hebraico": "אֶל־הַנַּ֔עַר", "transliteral": "ʾel-hannaʿar", "traducao_palavra": "ao jovem" },
        { "hebraico": "וַיְמַהֵ֖ר", "transliteral": "wayəmahēr", "traducao_palavra": "e apressou-se" },
        { "hebraico": "לַעֲשֹׂ֥ות", "transliteral": "laʿăśôṯ", "traducao_palavra": "em fazer/preparar" },
        { "hebraico": "אֹתֹֽו׃", "transliteral": "ʾōṯô", "traducao_palavra": "ele" }
      ]
    },
    "8": {
      "traducao_completa": "E tomou coalhada e leite, e o bezerro que tinha preparado, e pôs tudo diante deles; e ele estava em pé junto a eles debaixo da árvore; e comeram.",
      "palavras": [
        { "hebraico": "וַיִּקַּ֨ח", "transliteral": "wayyiqqaḥ", "traducao_palavra": "E tomou" },
        { "hebraico": "חֶמְאָ֣ה", "transliteral": "ḥemʾâ", "traducao_palavra": "coalhada/manteiga" },
        { "hebraico": "וְחָלָב֮", "transliteral": "wəḥālāḇ", "traducao_palavra": "e leite" },
        { "hebraico": "וּבֶן־הַבָּקָר֮", "transliteral": "ûḇen-habbāqār", "traducao_palavra": "e o bezerro" },
        { "hebraico": "אֲשֶׁ֣ר", "transliteral": "ʾăšer", "traducao_palavra": "que" },
        { "hebraico": "עָשָׂה֒", "transliteral": "ʿāśâ", "traducao_palavra": "preparara" },
        { "hebraico": "וַיִּתֵּן֙", "transliteral": "wayyittēn", "traducao_palavra": "e pôs" },
        { "hebraico": "לִפְנֵיהֶ֔ם", "transliteral": "lip̄nêhem", "traducao_palavra": "diante deles" },
        { "hebraico": "וְהֽוּא־עֹמֵ֧ד", "transliteral": "wəhû-ʿōmēḏ", "traducao_palavra": "e ele estava em pé" },
        { "hebraico": "עֲלֵיהֶ֛ם", "transliteral": "ʿălêhem", "traducao_palavra": "junto a eles" },
        { "hebraico": "תַּ֥חַת", "transliteral": "taḥaṯ", "traducao_palavra": "debaixo de" },
        { "hebraico": "הָעֵ֖ץ", "transliteral": "hāʿēṣ", "traducao_palavra": "a árvore" },
        { "hebraico": "וַיֹּאכֵֽלוּ׃", "transliteral": "wayyōʾḵēlû", "traducao_palavra": "e comeram" }
      ]
    },
    "9": {
      "traducao_completa": "E disseram-lhe: Onde está Sara, tua mulher? E ele disse: Ei-la aí na tenda.",
      "palavras": [
        { "hebraico": "וַיֹּאמְר֣וּ", "transliteral": "wayyōʾmərû", "traducao_palavra": "E disseram" },
        { "hebraico": "אֵלָ֔יו", "transliteral": "ʾēlāyw", "traducao_palavra": "a ele" },
        { "hebraico": "אַיֵּ֖ה", "transliteral": "ʾayyēh", "traducao_palavra": "Onde [está]" },
        { "hebraico": "שָׂרָ֣ה", "transliteral": "śārâ", "traducao_palavra": "Sara" },
        { "hebraico": "אִשְׁתֶּ֑ךָ", "transliteral": "ʾištəqā", "traducao_palavra": "tua mulher?" },
        { "hebraico": "וַיֹּ֖אמֶר", "transliteral": "wayyōʾmer", "traducao_palavra": "E disse" },
        { "hebraico": "הִנ  ֵּ֥ה", "transliteral": "hinnēh", "traducao_palavra": "Eis" },
        { "hebraico": "בָאֹֽהֶל׃", "transliteral": "ḇāʾōhel", "traducao_palavra": "na tenda" }
      ]
    },
    "10": {
      "traducao_completa": "E disse: Certamente tornarei a ti por este tempo da vida; e eis que Sara tua mulher terá um filho. E Sara escutava à porta da tenda, que estava atrás dele.",
      "palavras": [
        { "hebraico": "וַיֹּ֗אמֶר", "transliteral": "wayyōʾmer", "traducao_palavra": "E disse" },
        { "hebraico": "שֹׁ֣וב אָשׁ֤וּב", "transliteral": "šôḇ ʾāšûḇ", "traducao_palavra": "Voltando voltarei" },
        { "hebraico": "אֵלֶ֙יךָ֙", "transliteral": "ʾēleyḵā", "traducao_palavra": "a ti" },
        { "hebraico": "כָּעֵ֣ת", "transliteral": "kāʿēṯ", "traducao_palavra": "como ao tempo" },
        { "hebraico": "חַיָּ֔ה", "transliteral": "ḥayyâ", "traducao_palavra": "da vida/primavera" },
        { "hebraico": "וְהִנֵּה־בֵ֖ן", "transliteral": "wəhinnēh-ḇēn", "traducao_palavra": "e eis um filho" },
        { "hebraico": "לְשָׂרָ֣ה", "transliteral": "ləśārâ", "traducao_palavra": "para Sara" },
        { "hebraico": "אִשְׁתֶּ֑ךָ", "transliteral": "ʾištəqā", "traducao_palavra": "tua mulher" },
        { "hebraico": "וְשָׂרָ֥ה", "transliteral": "wəśārâ", "traducao_palavra": "e Sara" },
        { "hebraico": "שֹׁמַ֛עַת", "transliteral": "šōmaʿaṯ", "traducao_palavra": "estava ouvindo" },
        { "hebraico": "פֶּֽתַח־הָאֹ֖הֶל", "transliteral": "p̱eṯaḥ-hāʾōhel", "traducao_palavra": "à porta da tenda" },
        { "hebraico": "וְה֥וּא", "transliteral": "wəhû", "traducao_palavra": "e ela/ele" },
        { "hebraico": "אַחֲרָֽיו׃", "transliteral": "ʾaḥărāyw", "traducao_palavra": "atrás dele" }
      ]
    },
    "11": {
      "traducao_completa": "E eram Abraão e Sara já velhos, e adiantados em idade; já a Sara havia cessado o costume das mulheres.",
      "palavras": [
        { "hebraico": "וְאַבְרָהָ֤ם", "transliteral": "wəʾaḇrāhām", "traducao_palavra": "E Abraão" },
        { "hebraico": "וְשָׂרָה֙", "transliteral": "wəśārâ", "traducao_palavra": "e Sara" },
        { "hebraico": "זְקֵנִ֔ים", "transliteral": "zəqēnîm", "traducao_palavra": "[eram] velhos" },
        { "hebraico": "בָּאִ֖ים", "transliteral": "bāʾîm", "traducao_palavra": "entrados" },
        { "hebraico": "בַּיָּמִ֑ים", "transliteral": "bayyāmîm", "traducao_palavra": "nos dias/idade" },
        { "hebraico": "חָדַל֙", "transliteral": "ḥāḏal", "traducao_palavra": "cessara" },
        { "hebraico": "לִהְיֹ֣ות", "transliteral": "lihyôṯ", "traducao_palavra": "o haver" },
        { "hebraico": "לְשָׂרָ֔ה", "transliteral": "ləśārâ", "traducao_palavra": "para Sara" },
        { "hebraico": "אֹ֖רַח", "transliteral": "ʾōraḥ", "traducao_palavra": "o caminho/costume" },
        { "hebraico": "כַּנָּשִֽׁים׃", "transliteral": "kannāšîm", "traducao_palavra": "como das mulheres" }
      ]
    },
    "12": {
      "traducao_completa": "E riu-se Sara no seu íntimo, dizendo: Terei ainda deleite, depois de haver envelhecido, sendo também o meu senhor já velho?",
      "palavras": [
        { "hebraico": "וַתִּצְחַ֥ק", "transliteral": "wattisḥaq", "traducao_palavra": "E riu" },
        { "hebraico": "שָׂרָ֖ה", "transliteral": "śārâ", "traducao_palavra": "Sara" },
        { "hebraico": "בְּקִרְבָּ֣הּ", "transliteral": "bəqirbbāh", "traducao_palavra": "em seu íntimo" },
        { "hebraico": "לֵאמֹ֑ר", "transliteral": "lēʾmōr", "traducao_palavra": "dizendo" },
