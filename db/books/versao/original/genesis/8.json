        { "hebraico": "בַּתֵּבָ֑ה", "transliteral": "battēḇâ", "traducao_palavra": "na arca" },
        { "hebraico": "וַיַּעֲבֵ֨ר", "transliteral": "wayyaʿăḇēr", "traducao_palavra": "e fez passar" },
        { "hebraico": "אֱלֹהִ֥ים", "transliteral": "ʾĕlōhîm", "traducao_palavra": "Deus" },
        { "hebraico": "ר֨וּחַ֙", "transliteral": "rûaḥ", "traducao_palavra": "um vento" },
        { "hebraico": "עַל־הָאָ֔רֶץ", "transliteral": "ʿal-hāʾāreṣ", "traducao_palavra": "sobre a terra" },
