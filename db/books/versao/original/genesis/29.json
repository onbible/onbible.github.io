        { "hebraico": "וְהִשְׁק֖וּ", "transliteral": "wəhišqû", "traducao_palavra": "e davam de beber" },
        { "hebraico": "אֶת־הַצֹּ֑אן", "transliteral": "ʾeṯ-haṣṣōʾn", "traducao_palavra": "às ovelhas" },
        { "hebraico": "וְהֵשִׁ֧יבוּ", "transliteral": "wəhēšîḇû", "traducao_palavra": "e faziam retornar" },
