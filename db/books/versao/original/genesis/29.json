  "versiculos": {
    "1": {
      "traducao_completa": "E levantou Jacó os seus pés e foi para a terra dos filhos do Oriente.",
      "palavras": [
        { "hebraico": "וַיִּשָּׂ֥א", "transliteral": "wayyiśśāʾ", "traducao_palavra": "e levantou" },
