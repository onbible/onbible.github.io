    "7": {
      "traducao_completa": "E disse: Eis [que] ainda o dia [é] grande; não [é] tempo de recolher o gado; dai de beber às ovelhas e ide, pastoreai.",
      "palavras": [
        { "hebraico": "וַיֹּ֗אמֶר", "transliteral": "wayyōʾmer", "traducao_palavra": "e disse" },
