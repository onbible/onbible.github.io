        { "hebraico": "וַיֹּ֨אמֶר", "transliteral": "wayyōʾmer", "traducao_palavra": "e disse" },
        { "hebraico": "לָהֶ֤ם", "transliteral": "lāhem", "traducao_palavra": "a eles" },
