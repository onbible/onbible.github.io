        { "hebraico": "לָהֶ֖ם", "transliteral": "lāhem", "traducao_palavra": "a eles" },
        { "hebraico": "הֲשָׁלֹ֣ום", "transliteral": "hăšālôm", "traducao_palavra": "paz?" },
        { "hebraico": "לֹ֑ו", "transliteral": "lô", "traducao_palavra": "para ele" },
        { "hebraico": "וַיֹּאמְר֣וּ", "transliteral": "wayyōmərû", "traducao_palavra": "e disseram" },
