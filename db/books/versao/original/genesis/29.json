        { "hebraico": "בְרָחֵל֙", "transliteral": "ḇərāḥēl", "traducao_palavra": "por Raquel" },
        { "hebraico": "עָבַ֣דְתִּי", "transliteral": "ʿāḇaḏtî", "traducao_palavra": "servi" },
