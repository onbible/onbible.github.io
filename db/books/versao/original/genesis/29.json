        { "hebraico": "רֹבְצִ֣ים", "transliteral": "rōḇəṣîm", "traducao_palavra": "deitados" },
        { "hebraico": "עָלֶ֔יהָ", "transliteral": "ʿāleyhā", "traducao_palavra": "sobre ele" },
        { "hebraico": "כִּ֚י", "transliteral": "kî", "traducao_palavra": "pois" },
        { "hebraico": "מִן־הַבְּאֵ֣ר", "transliteral": "min-habbəʾēr", "traducao_palavra": "do poço" },
        { "hebraico": "הַהִ֔יא", "transliteral": "hahîʾ", "traducao_palavra": "aquele" },
        { "hebraico": "יַשְׁק֖וּ", "transliteral": "yašqû", "traducao_palavra": "davam de beber" },
        { "hebraico": "הָעֲדָרִ֑ים", "transliteral": "hāʿăḏārîm", "traducao_palavra": "aos rebanhos" },
        { "hebraico": "וְהָאֶ֥בֶן", "transliteral": "wəhāʾeḇen", "traducao_palavra": "e a pedra" },
