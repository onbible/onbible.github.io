        { "hebraico": "עַל־פִּ֥י", "transliteral": "ʿal-pî", "traducao_palavra": "sobre a boca de" },
        { "hebraico": "הַבְּאֵֽר׃", "transliteral": "habbəʾēr", "traducao_palavra": "o poço" }
      ]
    },
    "3": {
      "traducao_completa": "E ajuntavam-se ali todos os rebanhos; e removiam a pedra de sobre a boca do poço e davam de beber às ovelhas; e faziam retornar a pedra sobre a boca do poço para o seu lugar.",
      "palavras": [
