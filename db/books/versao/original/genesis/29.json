      ]
    },
    "2": {
      "traducao_completa": "E viu, e eis um poço no campo, e eis lá três rebanhos de ovelhas deitados sobre ele; pois daquele poço davam de beber aos rebanhos; e a pedra [era] grande sobre a boca do poço.",
      "palavras": [
        { "hebraico": "וַיַּ֞רְא", "transliteral": "wayyarʾ", "traducao_palavra": "e viu" },
        { "hebraico": "וְהִנֵּ֧ה", "transliteral": "wəhinnē", "traducao_palavra": "e eis" },
        { "hebraico": "בְאֵ֣ר", "transliteral": "ḇəʾēr", "traducao_palavra": "um poço" },
