        { "hebraico": "רַגְלָ֑יו", "transliteral": "raḡlāyw", "traducao_palavra": "seus pés" },
        { "hebraico": "וַיֵּ֖לֶךְ", "transliteral": "wayyēleḵ", "traducao_palavra": "e foi" },
        { "hebraico": "אַ֥רְצָה", "transliteral": "ʾarṣâ", "traducao_palavra": "para terra de" },
