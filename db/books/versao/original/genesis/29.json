        { "hebraico": "פִּ֣י", "transliteral": "pî", "traducao_palavra": "boca de" },
        { "hebraico": "הַבְּאֵ֔ר", "transliteral": "habbəʾēr", "traducao_palavra": "o poço" },
        { "hebraico": "וְהִשְׁקִ֖ינוּ", "transliteral": "wəhišqînû", "traducao_palavra": "e daremos de beber" },
