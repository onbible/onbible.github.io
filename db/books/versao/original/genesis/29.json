        { "hebraico": "אַחַ֔י", "transliteral": "ʾaḥay", "traducao_palavra": "meus irmãos" },
        { "hebraico": "מֵאַ֥יִן", "transliteral": "mēʾayin", "traducao_palavra": "de onde" },
        { "hebraico": "אַתֶּ֑ם", "transliteral": "ʾattem", "traducao_palavra": "vós [sois]" },
        { "hebraico": "וַיֹּאמְר֖וּ", "transliteral": "wayyōmərû", "traducao_palavra": "e disseram" },
