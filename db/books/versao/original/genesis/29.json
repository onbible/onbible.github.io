        { "hebraico": "עֹ֛וד", "transliteral": "ʿôḏ", "traducao_palavra": "ainda" },
        { "hebraico": "הַיֹּ֥ום", "transliteral": "hayyôm", "traducao_palavra": "o dia" },
        { "hebraico": "גָּדֹ֖ול", "transliteral": "gāḏôl", "traducao_palavra": "grande" },
