        { "hebraico": "וַיֹּ֣אמֶר", "transliteral": "wayyōʾmer", "traducao_palavra": "e disse" },
        { "hebraico": "לָהֶ֔ם", "transliteral": "lāhem", "traducao_palavra": "a eles" },
        { "hebraico": "הַיְדַעְתֶּ֖ם", "transliteral": "hayḏaʿttem", "traducao_palavra": "conheceis vós?" },
        { "hebraico": "אֶת־לָבָ֣ן", "transliteral": "ʾeṯ-lāḇān", "traducao_palavra": "a Labão" },
