        { "hebraico": "מִלֶּ֔דֶת", "transliteral": "milleḏeṯ", "traducao_palavra": "de gerar" },
        { "hebraico": "בֹּא־נָא֙", "transliteral": "bōʾ-nāʾ", "traducao_palavra": "entra, peço" },
        { "hebraico": "אֶל־שִׁפְחָתִ֔י", "transliteral": "ʾel-šip̱əḥāṯî", "traducao_palavra": "para minha serva" },
        { "hebraico": "א֧וּלַי", "transliteral": "ʾûlay", "traducao_palavra": "quem sabe/talvez" },
        { "hebraico": "אִבָּנֶ֖ה", "transliteral": "ʾibbāneh", "traducao_palavra": "serei edificada" },
        { "hebraico": "מִמֶּ֑נָּה", "transliteral": "mimmennâ", "traducao_palavra": "através dela" },
        { "hebraico": "וַיִּשְׁמַ֥ע", "transliteral": "wayyišmaʿ", "traducao_palavra": "e ouviu" },
