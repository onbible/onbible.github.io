  "versiculos": {
    "1": {
      "traducao_completa": "Ora Sarai, mulher de Abrão, não lhe gerava filhos, e ele tinha uma serva egípcia, cujo nome era Agar.",
      "palavras": [
        { "hebraico": "וְשָׂרַי֙", "transliteral": "wəśāray", "traducao_palavra": "E Sarai" },
