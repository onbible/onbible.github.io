        { "hebraico": "לֹ֥א", "transliteral": "lōʾ", "traducao_palavra": "não" },
        { "hebraico": "יָלְדָ֖ה", "transliteral": "yāləḏâ", "traducao_palavra": "gerou/dera à luz" },
