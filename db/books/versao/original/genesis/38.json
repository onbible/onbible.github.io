    "24": {
      "traducao_completa": "E aconteceu depois de quase três meses que foi anunciado a Judá, dizendo: Tamar, tua nora, prostituiu-se, e eis que também está grávida de prostituição. E disse Judá: Tirai-a para fora e que seja queimada.",
      "palavras": [
        { "hebraico": "וַיְהִי", "transliteral": "way-hî", "traducao_palavra": "e aconteceu" },
        { "hebraico": "כְּמִשְׁלֹשׁ", "transliteral": "kə-miš-lōš", "traducao_palavra": "como [que] três" },
