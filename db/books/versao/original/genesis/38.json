    "26": {
      "traducao_completa": "E reconheceu-os Judá e disse: Mais justa é ela do que eu, porquanto não a dei a Selá, meu filho. E não continuou mais a conhecê-la.",
      "palavras": [
        { "hebraico": "וַיַּכֵּר", "transliteral": "way-yak-kēr", "traducao_palavra": "e reconheceu" },
        { "hebraico": "יְהוּדָה", "transliteral": "yə-hû-ḏāh", "traducao_palavra": "Judá" },
        { "hebraico": "וַיֹּאמֶר", "transliteral": "way-yō-mer", "traducao_palavra": "e disse" },
        { "hebraico": "צָדְקָה", "transliteral": "ṣā-ḏə-qāh", "traducao_palavra": "justa é ela" },
        { "hebraico": "מִמֶּנִּי", "transliteral": "mim-men-nî", "traducao_palavra": "mais do que eu" },
        { "hebraico": "כִּי־עַל־כֵּן", "transliteral": "kî-ʿal-kēn", "traducao_palavra": "porquanto" },
        { "hebraico": "לֹא־נְתַתִּיהָ", "transliteral": "lō-nə-ṯat-tî-hā", "traducao_palavra": "não a dei" },
        { "hebraico": "לְשֵׁלָה", "transliteral": "lə-šē-lāh", "traducao_palavra": "a Selá" },
        { "hebraico": "בְנִי", "transliteral": "ḇə-nî", "traducao_palavra": "meu filho" },
        { "hebraico": "וְלֹא־יָסַף", "transliteral": "wə-lō-yā-sap̄", "traducao_palavra": "e não continuou" },
        { "hebraico": "עוֹד", "transliteral": "ʿôḏ", "traducao_palavra": "mais" },
        { "hebraico": "לְדַעְתָּהּ׃", "transliteral": "lə-ḏaʿ-tāh", "traducao_palavra": "a conhecê-la" }
      ]
    },
    "27": {
      "traducao_completa": "E aconteceu, no tempo de seu dar à luz, que eis gêmeos em seu ventre.",
      "palavras": [
        { "hebraico": "וַיְהִי", "transliteral": "way-hî", "traducao_palavra": "e aconteceu" },
        { "hebraico": "בְּעֵת", "transliteral": "bə-ʿēt", "traducao_palavra": "no tempo de" },
        { "hebraico": "לִדְתָּהּ", "transliteral": "liḏ-tāh", "traducao_palavra": "seu dar à luz" },
        { "hebraico": "וְהִנֵּה", "transliteral": "wə-hin-nēh", "traducao_palavra": "e eis" },
        { "hebraico": "תְאוֹמִים", "transliteral": "ṯə-ʾô-mîm", "traducao_palavra": "gêmeos" },
