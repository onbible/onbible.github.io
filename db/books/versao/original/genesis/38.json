        { "hebraico": "וַתֹּאמֶר", "transliteral": "wat-tō-mer", "traducao_palavra": "e disse" },
        { "hebraico": "הַכֶּר־נָא", "transliteral": "hak-ker-nā", "traducao_palavra": "reconhece peço" },
        { "hebraico": "לְמִי", "transliteral": "lə-mî", "traducao_palavra": "de quem" },
