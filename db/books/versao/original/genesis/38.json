        { "hebraico": "מוּצֵאת", "transliteral": "mû-ṣēṯ", "traducao_palavra": "[sendo] tirada" },
        { "hebraico": "וְהִיא", "transliteral": "wə-hî", "traducao_palavra": "e ela" },
        { "hebraico": "שָׁלְחָה", "transliteral": "šā-lə-ḥāh", "traducao_palavra": "enviou" },
