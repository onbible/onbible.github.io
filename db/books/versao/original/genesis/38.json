        { "hebraico": "וַיִּתֶּן־יָד", "transliteral": "way-yit-ten-yāḏ", "traducao_palavra": "e deu [pôs fora] a mão" },
        { "hebraico": "וַתִּקַּח", "transliteral": "wat-tiq-qaḥ", "traducao_palavra": "e tomou" },
