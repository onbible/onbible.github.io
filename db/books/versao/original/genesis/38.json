        { "hebraico": "הָרָה", "transliteral": "hā-rāh", "traducao_palavra": "grávida" },
        { "hebraico": "לִזְנוּנִים", "transliteral": "liz-nû-nîm", "traducao_palavra": "por prostituições" },
