        { "hebraico": "וַתִּקְשֹׁר", "transliteral": "wat-tiq-šōr", "traducao_palavra": "e atou" },
        { "hebraico": "עַל־יָדוֹ", "transliteral": "ʿal-yā-ḏô", "traducao_palavra": "sobre sua mão" },
        { "hebraico": "שָׁנִי", "transliteral": "šā-nî", "traducao_palavra": "[um fio] escarlate" },
        { "hebraico": "לֵאמֹר", "transliteral": "lē-mōr", "traducao_palavra": "dizendo" },
        { "hebraico": "זֶה", "transliteral": "zeh", "traducao_palavra": "este" },
        { "hebraico": "יָצָא", "transliteral": "yā-ṣā", "traducao_palavra": "saiu" },
        { "hebraico": "רִאשֹׁנָה׃", "transliteral": "ri-šō-nāh", "traducao_palavra": "primeiro" }
      ]
    },
    "29": {
      "traducao_completa": "E aconteceu que, ao recolher ele a sua mão, eis que saiu seu irmão; e ela disse: Como rompeste para ti uma fenda! E chamou o seu nome Perez.",
