        { "hebraico": "יְהוּדָה", "transliteral": "yə-hû-ḏāh", "traducao_palavra": "Judá" },
        { "hebraico": "לֵאמֹר", "transliteral": "lē-mōr", "traducao_palavra": "dizendo" },
        { "hebraico": "הָעֵד", "transliteral": "hā-ʿēḏ", "traducao_palavra": "advertindo" },
