    "8": {
      "traducao_completa": "E disse Judá a Israel, seu pai: Envia o menino comigo, e levantar-nos-emos e iremos, para que vivamos e não morramos, tanto nós, como tu, como também os nossos pequeninos.",
      "palavras": [
        { "hebraico": "וַיֹּאמֶר", "transliteral": "way-yō-mer", "traducao_palavra": "e disse" },
        { "hebraico": "יְהוּדָה", "transliteral": "yə-hû-ḏāh", "traducao_palavra": "Judá" },
        { "hebraico": "אֶל־יִשְׂרָאֵל", "transliteral": "ʾel-yiś-rā-ʾēl", "traducao_palavra": "a Israel" },
