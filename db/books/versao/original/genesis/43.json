        { "hebraico": "מִנְחָה", "transliteral": "min-ḥā", "traducao_palavra": "um presente" },
        { "hebraico": "מְעַט", "transliteral": "mə-ʿaṭ", "traducao_palavra": "um pouco de" },
        { "hebraico": "צֳרִי", "transliteral": "ṣo-rî", "traducao_palavra": "bálsamo" },
        { "hebraico": "וּמְעַט", "transliteral": "û-mə-ʿaṭ", "traducao_palavra": "e um pouco de" },
        { "hebraico": "דְּבַשׁ", "transliteral": "də-ḇaš", "traducao_palavra": "mel" },
        { "hebraico": "נְכֹאת", "transliteral": "nə-ḵōṯ", "traducao_palavra": "resina aromática" },
        { "hebraico": "וָלֹט", "transliteral": "wā-lōṭ", "traducao_palavra": "e mirra" },
        { "hebraico": "בָּטְנִים", "transliteral": "bā-ṭə-nîm", "traducao_palavra": "nozes de pistache" },
        { "hebraico": "וּשְׁקֵדִים׃", "transliteral": "û-šə-qē-ḏîm", "traducao_palavra": "e amêndoas" }
      ]
    },
    "12": {
      "traducao_completa": "E tomai dinheiro em dobro em vossa mão; e o dinheiro que foi devolvido na boca dos vossos sacos, levai-o de volta em vossa mão; talvez tenha sido um erro.",
      "palavras": [
        { "hebraico": "וְכֶסֶף", "transliteral": "wə-ḵe-sep̄", "traducao_palavra": "e dinheiro" },
        { "hebraico": "מִשְׁנֶה", "transliteral": "miš-neh", "traducao_palavra": "dobro" },
        { "hebraico": "קְחוּ", "transliteral": "qə-ḥû", "traducao_palavra": "tomai" },
        { "hebraico": "בְיֶדְכֶם", "transliteral": "ḇə-yeḏ-ḵem", "traducao_palavra": "em vossa mão" },
        { "hebraico": "וְאֶת־הַכֶּסֶף", "transliteral": "wə-ʾeṯ-hak-ke-sep̄", "traducao_palavra": "e o dinheiro" },
        { "hebraico": "הַמּוּשָׁב", "transliteral": "ham-mû-šāḇ", "traducao_palavra": "devolvido" },
        { "hebraico": "בְּפִי", "transliteral": "bə-p̄î", "traducao_palavra": "na boca de" },
        { "hebraico": "אַמְתְּחֹתֵיכֶם", "transliteral": "ʾam-tə-ḥō-ṯê-ḵem", "traducao_palavra": "vossos sacos" },
        { "hebraico": "תָּשִׁיבוּ", "transliteral": "tā-šî-ḇû", "traducao_palavra": "levareis de volta" },
        { "hebraico": "בְיֶדְכֶם", "transliteral": "ḇə-yeḏ-ḵem", "traducao_palavra": "em vossa mão" },
        { "hebraico": "אוּלַי", "transliteral": "ʾû-lay", "traducao_palavra": "talvez" },
        { "hebraico": "מִשְׁגֶּה", "transliteral": "miš-geh", "traducao_palavra": "um erro" },
        { "hebraico": "הוּא׃", "transliteral": "hû", "traducao_palavra": "[seja] ele" }
      ]
    },
    "13": {
      "traducao_completa": "E tomai o vosso irmão, e levantai-vos, voltai ao homem.",
      "palavras": [
        { "hebraico": "וְאֶת־אֲחִיכֶם", "transliteral": "wə-ʾeṯ-ʾă-ḥî-ḵem", "traducao_palavra": "e vosso irmão" },
        { "hebraico": "קָחוּ", "transliteral": "qā-ḥû", "traducao_palavra": "tomai" },
        { "hebraico": "וְקוּמוּ", "transliteral": "wə-qû-mû", "traducao_palavra": "e levantai-vos" },
        { "hebraico": "שׁוּבוּ", "transliteral": "šû-ḇû", "traducao_palavra": "voltai" },
        { "hebraico": "אֶל־הָאִישׁ׃", "transliteral": "ʾel-hā-ʾîš", "traducao_palavra": "ao homem" }
      ]
    },
    "14": {
      "traducao_completa": "E o Deus Todo-Poderoso vos dê misericórdia diante do homem, para que ele solte o vosso outro irmão e a Benjamim; e eu, se for desfilhado, desfilhado ficarei.",
      "palavras": [
        { "hebraico": "וְאֵל", "transliteral": "wə-ʾēl", "traducao_palavra": "e Deus" },
        { "hebraico": "שַׁדַּי", "transliteral": "šad-day", "traducao_palavra": "Todo-Poderoso" },
        { "hebraico": "יִתֵּן", "transliteral": "yit-tēn", "traducao_palavra": "dê" },
        { "hebraico": "לָכֶם", "transliteral": "lā-ḵem", "traducao_palavra": "a vós" },
        { "hebraico": "רַחֲמִים", "transliteral": "ra-ḥă-mîm", "traducao_palavra": "misericórdia" },
        { "hebraico": "לִפְנֵי", "transliteral": "lip̄-nê", "traducao_palavra": "diante de" },
        { "hebraico": "הָאִישׁ", "transliteral": "hā-ʾîš", "traducao_palavra": "o homem" },
        { "hebraico": "וְשִׁלַּח", "transliteral": "wə-šil-laḥ", "traducao_palavra": "e solte" },
        { "hebraico": "לָכֶם", "transliteral": "lā-ḵem", "traducao_palavra": "para vós" },
        { "hebraico": "אֶת־אֲחִיכֶם", "transliteral": "ʾeṯ-ʾă-ḥî-ḵem", "traducao_palavra": "o vosso irmão" },
        { "hebraico": "אַחֵר", "transliteral": "ʾa-ḥēr", "traducao_palavra": "outro" },
        { "hebraico": "וְאֶת־בִּנְיָמִין", "transliteral": "wə-ʾeṯ-bin-yā-mîn", "traducao_palavra": "e a Benjamim" },
        { "hebraico": "וַאֲנִי", "transliteral": "wa-ʾă-nî", "traducao_palavra": "e eu" },
        { "hebraico": "כַּאֲשֶׁר", "transliteral": "ka-ʾă-šer", "traducao_palavra": "conforme" },
        { "hebraico": "שָׁכֹלְתִּי", "transliteral": "šā-ḵōl-tî", "traducao_palavra": "fui desfilhado" },
        { "hebraico": "שָׁכָלְתִּי׃", "transliteral": "šā-ḵāl-tî", "traducao_palavra": "desfilhado ficarei" }
      ]
    },
    "15": {
      "traducao_completa": "E tomaram os homens este presente, e tomaram o dinheiro em dobro em sua mão, e a Benjamim; e levantaram-se, e desceram ao Egito, e puseram-se diante da face de José.",
      "palavras": [
        { "hebraico": "וַיִּקְחוּ", "transliteral": "way-yiq-ḥû", "traducao_palavra": "e tomaram" },
        { "hebraico": "הָאֲנָשִׁים", "transliteral": "hā-ʾă-nā-šîm", "traducao_palavra": "os homens" },
        { "hebraico": "אֶת־הַמִּנְחָה", "transliteral": "ʾeṯ-ham-min-ḥā", "traducao_palavra": "o presente" },
        { "hebraico": "הַזֹּאת", "transliteral": "haz-zōṯ", "traducao_palavra": "este" },
        { "hebraico": "וּמִשְׁנֶה־כֶּסֶף", "transliteral": "û-miš-neh-ke-sep̄", "traducao_palavra": "e dobro de dinheiro" },
        { "hebraico": "לָקְחוּ", "transliteral": "lā-qə-ḥû", "traducao_palavra": "tomaram" },
        { "hebraico": "בְיָדָם", "transliteral": "ḇə-yā-ḏām", "traducao_palavra": "em sua mão" },
        { "hebraico": "וְאֶת־בִּנְיָמִן", "transliteral": "wə-ʾeṯ-bin-yā-min", "traducao_palavra": "e a Benjamim" },
        { "hebraico": "וַיָּקֻמוּ", "transliteral": "way-yā-qu-mû", "traducao_palavra": "e levantaram-se" },
        { "hebraico": "וַיֵּרְדוּ", "transliteral": "way-yē-rə-ḏû", "traducao_palavra": "e desceram" },
        { "hebraico": "מִצְרַיִם", "transliteral": "miṣ-ra-yim", "traducao_palavra": "[ao] Egito" },
        { "hebraico": "וַיַּעַמְדוּ", "transliteral": "way-ya-ʿam-ḏû", "traducao_palavra": "e puseram-se" },
        { "hebraico": "לִפְנֵי", "transliteral": "lip̄-nê", "traducao_palavra": "diante de" },
        { "hebraico": "יוֹסֵף׃", "transliteral": "yô-sēp̄", "traducao_palavra": "José" }
      ]
    },
    "16": {
      "traducao_completa": "E viu José com eles a Benjamim, e disse ao que estava sobre a sua casa: Leva estes homens para casa, e mata animais e prepara; porque comigo comerão estes homens ao meio-dia.",
      "palavras": [
        { "hebraico": "וַיַּרְא", "transliteral": "way-yarʾ", "traducao_palavra": "e viu" },
        { "hebraico": "יוֹסֵף", "transliteral": "yô-sēp̄", "traducao_palavra": "José" },
        { "hebraico": "אִתָּם", "transliteral": "ʾit-tām", "traducao_palavra": "com eles" },
        { "hebraico": "אֶת־בִּנְיָמִין", "transliteral": "ʾeṯ-bin-yā-mîn", "traducao_palavra": "a Benjamim" },
        { "hebraico": "וַיֹּאמֶר", "transliteral": "way-yō-mer", "traducao_palavra": "e disse" },
        { "hebraico": "לַאֲשֶׁר", "transliteral": "la-ʾă-šer", "traducao_palavra": "ao que [estava]" },
        { "hebraico": "עַל־בֵּיתוֹ", "transliteral": "ʿal-bê-ṯô", "traducao_palavra": "sobre sua casa" },
        { "hebraico": "הָבֵא", "transliteral": "hā-ḇē", "traducao_palavra": "leva" },
        { "hebraico": "אֶת־הָאֲנָשִׁים", "transliteral": "ʾeṯ-hā-ʾă-nā-šîm", "traducao_palavra": "[os] homens" },
        { "hebraico": "הַבָּיְתָה", "transliteral": "hab-bay-ṯāh", "traducao_palavra": "para casa" },
        { "hebraico": "וּטְבֹחַ", "transliteral": "û-ṭə-ḇō-aḥ", "traducao_palavra": "e mata" },
        { "hebraico": "טֶבַח", "transliteral": "ṭe-ḇaḥ", "traducao_palavra": "animal [carne]" },
        { "hebraico": "וְהָכֵן", "transliteral": "wə-hā-ḵēn", "traducao_palavra": "e prepara" },
        { "hebraico": "כִּי", "transliteral": "kî", "traducao_palavra": "porque" },
        { "hebraico": "אִתִּי", "transliteral": "ʾit-tî", "traducao_palavra": "comigo" },
        { "hebraico": "יֹאכְלוּ", "transliteral": "yō-ḵə-lû", "traducao_palavra": "comerão" },
        { "hebraico": "הָאֲנָשִׁים", "transliteral": "hā-ʾă-nā-šîm", "traducao_palavra": "os homens" },
        { "hebraico": "בַּצָּהֳרָיִם׃", "transliteral": "baṣ-ṣā-ho-rā-yim", "traducao_palavra": "ao meio-dia" }
      ]
    },
    "17": {
      "traducao_completa": "E fez o homem como dissera José; e levou o homem os homens para a casa de José.",
      "palavras": [
        { "hebraico": "וַיַּעַשׂ", "transliteral": "way-ya-ʿaś", "traducao_palavra": "e fez" },
        { "hebraico": "הָאִישׁ", "transliteral": "hā-ʾîš", "traducao_palavra": "o homem" },
        { "hebraico": "כַּאֲשֶׁר", "transliteral": "ka-ʾă-šer", "traducao_palavra": "conforme" },
        { "hebraico": "אָמַר", "transliteral": "אָמַר", "traducao_palavra": "dissera" },
        { "hebraico": "יוֹסֵף", "transliteral": "yô-sēp̄", "traducao_palavra": "José" },
        { "hebraico": "וַיָּבֵא", "transliteral": "way-yā-ḇē", "traducao_palavra": "e trouxe" },
        { "hebraico": "הָאִישׁ", "transliteral": "hā-ʾîš", "traducao_palavra": "o homem" },
        { "hebraico": "אֶת־הָאֲנָשִׁים", "transliteral": "ʾeṯ-hā-ʾă-nā-šîm", "traducao_palavra": "[os] homens" },
        { "hebraico": "בֵּיתָה", "transliteral": "bê-ṯā", "traducao_palavra": "[para] a casa de" },
        { "hebraico": "יוֹסֵף׃", "transliteral": "yô-sēp̄", "traducao_palavra": "José" }
      ]
    },
    "18": {
      "traducao_completa": "E os homens temeram, porque foram levados para a casa de José, e diziam: Por causa do dinheiro que voltou nos nossos sacos no princípio fomos levados, para que se lance sobre nós, e caia sobre nós, e nos tome por servos, e aos nossos jumentos.",
      "palavras": [
        { "hebraico": "וַיִּירְאוּ", "transliteral": "way-yî-rə-ʾû", "traducao_palavra": "e temeram" },
        { "hebraico": "הָאֲנָשִׁים", "transliteral": "hā-ʾă-nā-šîm", "traducao_palavra": "os homens" },
        { "hebraico": "כִּי", "transliteral": "kî", "traducao_palavra": "porque" },
        { "hebraico": "הוּבָאוּ", "transliteral": "hû-ḇā-ʾû", "traducao_palavra": "foram trazidos" },
        { "hebraico": "בֵּית", "transliteral": "bêṯ", "traducao_palavra": "[para a] casa de" },
        { "hebraico": "יוֹסֵף", "transliteral": "yô-sēp̄", "traducao_palavra": "José" },
        { "hebraico": "וַיֹּאמְרוּ", "transliteral": "way-yō-mə-rû", "traducao_palavra": "e disseram" },
        { "hebraico": "עַל־דְּבַר", "transliteral": "ʿal-də-ḇar", "traducao_palavra": "por causa de" },
        { "hebraico": "הַכֶּסֶף", "transliteral": "hak-ke-sep̄", "traducao_palavra": "o dinheiro" },
        { "hebraico": "הַשָּׁב", "transliteral": "haš-šāḇ", "traducao_palavra": "que voltou" },
        { "hebraico": "בְּאַמְתְּחֹתֵינוּ", "transliteral": "bə-ʾam-tə-ḥō-ṯê-nû", "traducao_palavra": "em nossos sacos" },
        { "hebraico": "בַּתְּחִלָּה", "transliteral": "bat-tə-ḥil-lāh", "traducao_palavra": "no princípio" },
        { "hebraico": "אֲנַחְנוּ", "transliteral": "ʾă-naḥ-nû", "traducao_palavra": "nós" },
        { "hebraico": "מוּבָאִים", "transliteral": "mû-ḇā-ʾîm", "traducao_palavra": "somos trazidos" },
        { "hebraico": "לְהִתְגֹּלֵל", "transliteral": "lə-hiṯ-gō-lēl", "traducao_palavra": "para lançar-se" },
        { "hebraico": "עָלֵינוּ", "transliteral": "ʿā-lê-nû", "traducao_palavra": "sobre nós" },
        { "hebraico": "וּלְהִתְנַפֵּל", "transliteral": "û-lə-hiṯ-nap-pēl", "traducao_palavra": "e para cair" },
        { "hebraico": "עָלֵינוּ", "transliteral": "ʿā-lê-nû", "traducao_palavra": "sobre nós" },
        { "hebraico": "וְלָקַחַת", "transliteral": "wə-lā-qa-ḥaṯ", "traducao_palavra": "e para tomar" },
        { "hebraico": "אֹתָנוּ", "transliteral": "ʾō-ṯā-nû", "traducao_palavra": "a nós" },
        { "hebraico": "לַעֲבָדִים", "transliteral": "la-ʿă-ḇā-ḏîm", "traducao_palavra": "por servos" },
        { "hebraico": "וְאֶת־חֲמֹרֵינוּ׃", "transliteral": "wə-ʾeṯ-ḥă-mō-rê-nû", "traducao_palavra": "e os nossos jumentos" }
      ]
    },
    "19": {
      "traducao_completa": "E aproximaram-se do homem que estava sobre a casa de José, e falaram-lhe à porta da casa.",
      "palavras": [
        { "hebraico": "וַיִּגְּשׁוּ", "transliteral": "way-yiḡ-gə-šû", "traducao_palavra": "e aproximaram-se" },
        { "hebraico": "אֶל־הָאִישׁ", "transliteral": "ʾel-hā-ʾîš", "traducao_palavra": "do homem" },
        { "hebraico": "אֲשֶׁר", "transliteral": "ʾă-šer", "traducao_palavra": "que [estava]" },
        { "hebraico": "עַל־בֵּית", "transliteral": "ʿal-bêṯ", "traducao_palavra": "sobre casa de" },
        { "hebraico": "יוֹסֵף", "transliteral": "yô-sēp̄", "traducao_palavra": "José" },
        { "hebraico": "וַיְדַבְּרוּ", "transliteral": "way-ḏab-bə-rû", "traducao_palavra": "e falaram" },
        { "hebraico": "אֵלָיו", "transliteral": "ʾē-lāw", "traducao_palavra": "a ele" },
        { "hebraico": "פֶּתַח", "transliteral": "pe-ṯaḥ", "traducao_palavra": "[à] porta de" },
        { "hebraico": "הַבָּיִת׃", "transliteral": "hab-bā-yiṯ", "traducao_palavra": "a casa" }
      ]
    },
    "20": {
      "traducao_completa": "E disseram: Ai, meu senhor! Certamente descemos no princípio para comprar mantimento.",
      "palavras": [
        { "hebraico": "וַיֹּאמְרוּ", "transliteral": "way-yō-mə-rû", "traducao_palavra": "e disseram" },
        { "hebraico": "בִּי", "transliteral": "bî", "traducao_palavra": "oh/por favor" },
        { "hebraico": "אֲדֹנִי", "transliteral": "ʾă-ḏō-nî", "traducao_palavra": "meu senhor" },
        { "hebraico": "יָרֹד", "transliteral": "yā-rōḏ", "traducao_palavra": "descendo" },
        { "hebraico": "יָרַדְנוּ", "transliteral": "yā-raḏ-nû", "traducao_palavra": "descemos" },
        { "hebraico": "בַּתְּחִלָּה", "transliteral": "bat-tə-ḥil-lāh", "traducao_palavra": "no princípio" },
        { "hebraico": "לִשְׁבָּר־אֹכֶל׃", "transliteral": "liš-bār-ʾō-ḵel", "traducao_palavra": "para comprar mantimento" }
      ]
    },
    "21": {
      "traducao_completa": "E aconteceu que, quando chegamos à estalagem e abrimos os nossos sacos, eis que o dinheiro de cada um estava na boca do seu saco, o nosso dinheiro pelo seu peso; e trouxemo-lo de volta em nossa mão.",
      "palavras": [
        { "hebraico": "וַיְהִי", "transliteral": "way-hî", "traducao_palavra": "e aconteceu" },
        { "hebraico": "כִּי־בָאנוּ", "transliteral": "kî-ḇā-nû", "traducao_palavra": "que chegamos" },
        { "hebraico": "אֶל־הַמָּלוֹן", "transliteral": "ʾel-ham-mā-lôn", "traducao_palavra": "à estalagem" },
        { "hebraico": "וַנִּפְתְּחָה", "transliteral": "wan-nip̄-tə-ḥā", "traducao_palavra": "e abrimos" },
        { "hebraico": "אֶת־אַמְתְּחֹתֵינוּ", "transliteral": "ʾeṯ-ʾam-tə-ḥō-ṯê-nû", "traducao_palavra": "os nossos sacos" },
        { "hebraico": "וְהִנֵּה", "transliteral": "wə-hin-nēh", "traducao_palavra": "e eis que" },
        { "hebraico": "כֶסֶף־אִישׁ", "transliteral": "ḵe-sep̄-ʾîš", "traducao_palavra": "dinheiro de cada um" },
        { "hebraico": "בְּפִי", "transliteral": "bə-p̄î", "traducao_palavra": "na boca de" },
        { "hebraico": "אַמְתַּחְתּוֹ", "transliteral": "ʾam-taḥ-tô", "traducao_palavra": "seu saco" },
        { "hebraico": "כַּסְפֵּנוּ", "transliteral": "kas-pê-nû", "traducao_palavra": "nosso dinheiro" },
        { "hebraico": "בְּמִשְׁקָלוֹ", "transliteral": "bə-miš-qā-lô", "traducao_palavra": "pelo seu peso" },
        { "hebraico": "וַנָּשֶׁב", "transliteral": "wan-nā-šeḇ", "traducao_palavra": "e trouxemos de volta" },
        { "hebraico": "אֹתוֹ", "transliteral": "ʾō-ṯô", "traducao_palavra": "ele" },
        { "hebraico": "בְּיָדֵנוּ׃", "transliteral": "bə-yā-ḏē-nû", "traducao_palavra": "em nossa mão" }
      ]
    },
    "22": {
      "traducao_completa": "E outro dinheiro trouxemos em nossa mão para comprar mantimento; não sabemos quem pôs o nosso dinheiro nos nossos sacos.",
      "palavras": [
        { "hebraico": "וְכֶסֶף", "transliteral": "wə-ḵe-sep̄", "traducao_palavra": "e dinheiro" },
        { "hebraico": "אַחֵר", "transliteral": "ʾa-ḥēr", "traducao_palavra": "outro" },
        { "hebraico": "הוֹרַדְנוּ", "transliteral": "hô-raḏ-nû", "traducao_palavra": "fizemos descer/trouxemos" },
        { "hebraico": "בְיָדֵנוּ", "transliteral": "ḇə-yā-ḏê-nû", "traducao_palavra": "em nossa mão" },
        { "hebraico": "לִשְׁבָּר־אֹכֶל", "transliteral": "liš-bār-ʾō-ḵel", "traducao_palavra": "para comprar mantimento" },
        { "hebraico": "לֹא", "transliteral": "lō", "traducao_palavra": "não" },
        { "hebraico": "יָדַעְנוּ", "transliteral": "yā-ḏaʿ-nû", "traducao_palavra": "sabemos" },
        { "hebraico": "מִי־שָׂם", "transliteral": "mî-śām", "traducao_palavra": "quem pôs" },
        { "hebraico": "כַּסְפֵּנוּ", "transliteral": "kas-pê-nû", "traducao_palavra": "nosso dinheiro" },
        { "hebraico": "בְּאַמְתְּחֹתֵינוּ׃", "transliteral": "bə-ʾam-tə-ḥō-ṯê-nû", "traducao_palavra": "em nossos sacos" }
      ]
    },
    "23": {
      "traducao_completa": "E ele disse: Paz seja convosco, não temais; o vosso Deus e o Deus de vosso pai vos deu um tesouro nos vossos sacos; o vosso dinheiro veio a mim. E trouxe-lhes Simeão.",
      "palavras": [
        { "hebraico": "וַיֹּאמֶר", "transliteral": "way-yō-mer", "traducao_palavra": "e disse" },
        { "hebraico": "שָׁלוֹם", "transliteral": "šā-lôm", "traducao_palavra": "paz" },
        { "hebraico": "לָכֶם", "transliteral": "lā-ḵem", "traducao_palavra": "[seja] para vós" },
        { "hebraico": "אַל־תִּירָאוּ", "transliteral": "ʾal-tî-rā-ʾû", "traducao_palavra": "não temais" },
        { "hebraico": "אֱלֹהֵיכֶם", "transliteral": "ʾĕ-lō-hê-ḵem", "traducao_palavra": "vosso Deus" },
        { "hebraico": "וֵאלֹהֵי", "transliteral": "wē-lō-hê", "traducao_palavra": "e Deus de" },
        { "hebraico": "אֲבִיכֶם", "transliteral": "ă-ḇî-ḵem", "traducao_palavra": "vosso pai" },
        { "hebraico": "נָתַן", "transliteral": "nā-ṯān", "traducao_palavra": "deu" },
        { "hebraico": "לָכֶם", "transliteral": "lā-ḵem", "traducao_palavra": "a vós" },
        { "hebraico": "מַטְמוֹן", "transliteral": "maṭ-môn", "traducao_palavra": "um tesouro" },
        { "hebraico": "בְּאַמְתְּחֹתֵיכֶם", "transliteral": "bə-ʾam-tə-ḥō-ṯê-ḵem", "traducao_palavra": "em vossos sacos" },
        { "hebraico": "כַּסְפְּכֶם", "transliteral": "kas-pə-ḵem", "traducao_palavra": "vosso dinheiro" },
        { "hebraico": "בָּא", "transliteral": "bā", "traducao_palavra": "veio" },
        { "hebraico": "אֵלָי", "transliteral": "ʾē-lāy", "traducao_palavra": "a mim" },
        { "hebraico": "וַיּוֹצֵא", "transliteral": "way-yô-ṣē", "traducao_palavra": "e trouxe para fora" },
        { "hebraico": "אֲלֵיהֶם", "transliteral": "ʾă-lê-hem", "traducao_palavra": "a eles" },
        { "hebraico": "אֶת־שִׁמְעוֹן׃", "transliteral": "ʾeṯ-šim-ʿôn", "traducao_palavra": "a Simeão" }
      ]
    },
    "24": {
      "traducao_completa": "E levou o homem os homens para a casa de José, e deu-lhes água, e lavaram os seus pés; e deu forragem aos seus jumentos.",
      "palavras": [
        { "hebraico": "וַיָּבֵא", "transliteral": "way-yā-ḇē", "traducao_palavra": "e trouxe" },
        { "hebraico": "הָאִישׁ", "transliteral": "hā-ʾîš", "traducao_palavra": "o homem" },
        { "hebraico": "אֶת־הָאֲנָשִׁים", "transliteral": "ʾeṯ-hā-ʾă-nā-šîm", "traducao_palavra": "[os] homens" },
        { "hebraico": "בֵּיתָה", "transliteral": "bê-ṯā", "traducao_palavra": "[para] a casa de" },
        { "hebraico": "יוֹסֵף", "transliteral": "yô-sēp̄", "traducao_palavra": "José" },
        { "hebraico": "וַיִּתֶּן־מַיִם", "transliteral": "way-yit-ten-ma-yim", "traducao_palavra": "e deu água" },
        { "hebraico": "וַיִּרְחֲצוּ", "transliteral": "way-yir-ḥă-ṣû", "traducao_palavra": "e lavaram" },
        { "hebraico": "רַגְלֵיהֶם", "transliteral": "raḡ-lê-hem", "traducao_palavra": "seus pés" },
        { "hebraico": "וַיִּתֵּן", "transliteral": "way-yit-tēn", "traducao_palavra": "e deu" },
        { "hebraico": "מִסְפּוֹא", "transliteral": "mis-pô", "traducao_palavra": "forragem" },
        { "hebraico": "לַחֲמֹרֵיהֶם׃", "transliteral": "la-ḥă-mō-rê-hem", "traducao_palavra": "aos seus jumentos" }
      ]
    },
    "25": {
      "traducao_completa": "E prepararam o presente para quando José viesse ao meio-dia; porque ouviram que ali haviam de comer pão.",
      "palavras": [
        { "hebraico": "וַיָּכִינוּ", "transliteral": "way-yā-ḵî-nû", "traducao_palavra": "e prepararam" },
        { "hebraico": "אֶת־הַמִּנְחָה", "transliteral": "ʾeṯ-ham-min-ḥā", "traducao_palavra": "o presente" },
        { "hebraico": "עַד־בּוֹא", "transliteral": "ʿaḏ-bô", "traducao_palavra": "até a vinda de" },
        { "hebraico": "יוֹסֵף", "transliteral": "yô-sēp̄", "traducao_palavra": "José" },
        { "hebraico": "בַּצָּהֳרָיִם", "transliteral": "baṣ-ṣā-ho-rā-yim", "traducao_palavra": "ao meio-dia" },
        { "hebraico": "כִּי", "transliteral": "kî", "traducao_palavra": "porque" },
        { "hebraico": "שָׁמְעוּ", "transliteral": "šā-mə-ʿû", "traducao_palavra": "ouviram" },
        { "hebraico": "כִּי־שָׁם", "transliteral": "kî-šām", "traducao_palavra": "que ali" },
        { "hebraico": "יֹאכְלוּ", "transliteral": "yō-ḵə-lû", "traducao_palavra": "comeriam" },
        { "hebraico": "לָחֶם׃", "transliteral": "lā-ḥem", "traducao_palavra": "pão" }
      ]
    },
    "26": {
      "traducao_completa": "E veio José para casa, e trouxeram-lhe o presente que estava em sua mão, para dentro da casa; e prostraram-se diante dele em terra.",
      "palavras": [
        { "hebraico": "וַיָּבֹא", "transliteral": "way-yā-ḇō", "traducao_palavra": "e veio" },
        { "hebraico": "יוֹסֵף", "transliteral": "yô-sēp̄", "traducao_palavra": "José" },
        { "hebraico": "הַבַּיְתָה", "transliteral": "hab-bay-ṯāh", "traducao_palavra": "para casa" },
        { "hebraico": "וַיָּבִיאּוּ־לוֹ", "transliteral": "way-yā-ḇî-ʾû-lô", "traducao_palavra": "e trouxeram a ele" },
        { "hebraico": "אֶת־הַמִּנְחָה", "transliteral": "ʾeṯ-ham-min-ḥā", "traducao_palavra": "o presente" },
        { "hebraico": "אֲשֶׁר־בְּיָדָם", "transliteral": "ʾă-šer-bə-yā-ḏām", "traducao_palavra": "que [estava] na mão deles" },
        { "hebraico": "הַבַּיְתָה", "transliteral": "hab-bay-ṯāh", "traducao_palavra": "[para dentro] da casa" },
        { "hebraico": "וַיִּשְׁתַּחֲווּ־לוֹ", "transliteral": "way-yiš-ta-ḥă-wû-lô", "traducao_palavra": "e prostraram-se a ele" },
        { "hebraico": "אָרְצָה׃", "transliteral": "ʾār-ṣā", "traducao_palavra": "em terra" }
      ]
    },
    "27": {
      "traducao_completa": "E ele perguntou-lhes pela sua paz, e disse: Tem paz o vosso pai, o ancião de quem falastes? Ainda vive?",
      "palavras": [
        { "hebraico": "וַיִּשְׁאַל", "transliteral": "way-yiš-ʾal", "traducao_palavra": "e perguntou" },
        { "hebraico": "לָהֶם", "transliteral": "lā-hem", "traducao_palavra": "a eles" },
        { "hebraico": "לְשָׁלוֹם", "transliteral": "lə-šā-lôm", "traducao_palavra": "pela paz" },
        { "hebraico": "וַיֹּאמֶר", "transliteral": "way-yō-mer", "traducao_palavra": "e disse" },
        { "hebraico": "הֲשָׁלוֹם", "transliteral": "hă-šā-lôm", "traducao_palavra": "[há] paz para" },
        { "hebraico": "אֲבִיכֶם", "transliteral": "ă-ḇî-ḵem", "traducao_palavra": "vosso pai" },
        { "hebraico": "הַזָּקֵן", "transliteral": "haz-zā-qēn", "traducao_palavra": "o ancião" },
        { "hebraico": "אֲשֶׁר", "transliteral": "ʾă-šer", "traducao_palavra": "de quem" },
        { "hebraico": "אֲמַרְתֶּם", "transliteral": "ă-mar-tem", "traducao_palavra": "falastes" },
        { "hebraico": "הַעוֹדֶנּוּ", "transliteral": "ha-ʿô-ḏen-nû", "traducao_palavra": "acaso ainda ele" },
        { "hebraico": "חָי׃", "transliteral": "ḥāy", "traducao_palavra": "vive" }
      ]
    },
    "28": {
      "traducao_completa": "E disseram: Tem paz o teu servo, o nosso pai; ainda vive. E inclinaram a cabeça e prostraram-se.",
      "palavras": [
        { "hebraico": "וַיֹּאמְרוּ", "transliteral": "way-yō-mə-rû", "traducao_palavra": "e disseram" },
        { "hebraico": "שָׁלוֹם", "transliteral": "šā-lôm", "traducao_palavra": "paz" },
        { "hebraico": "לְעַבְדְּךָ", "transliteral": "lə-ʿaḇ-də-ḵā", "traducao_palavra": "[há] para o teu servo" },
        { "hebraico": "לְאָבִינוּ", "transliteral": "lə-ʾā-ḇî-nû", "traducao_palavra": "[para] o nosso pai" },
        { "hebraico": "עוֹדֶנּוּ", "transliteral": "ʿô-ḏen-nû", "traducao_palavra": "ainda ele" },
        { "hebraico": "חָי", "transliteral": "ḥāy", "traducao_palavra": "vive" },
        { "hebraico": "וַיִּקְּדוּ", "transliteral": "way-yiq-qə-ḏû", "traducao_palavra": "e inclinaram" },
        { "hebraico": "וַיִּשְׁתַּחֲווּ׃", "transliteral": "way-yiš-ta-ḥă-wû", "traducao_palavra": "e prostraram-se" }
      ]
    },
    "29": {
      "traducao_completa": "E levantou os seus olhos e viu a Benjamim, seu irmão, filho de sua mãe, e disse: É este o vosso irmão mais novo, de quem me falastes? E disse: Deus te seja gracioso, meu filho.",
      "palavras": [
        { "hebraico": "וַיִּשָּׂא", "transliteral": "way-yiś-śā", "traducao_palavra": "e levantou" },
        { "hebraico": "עֵינָיו", "transliteral": "ʿê-nāw", "traducao_palavra": "seus olhos" },
        { "hebraico": "וַיַּרְא", "transliteral": "way-yarʾ", "traducao_palavra": "e viu" },
        { "hebraico": "אֶת־בִּנְיָמִין", "transliteral": "ʾeṯ-bin-yā-mîn", "traducao_palavra": "a Benjamim" },
        { "hebraico": "אָחִיו", "transliteral": "ʾā-ḥîw", "traducao_palavra": "seu irmão" },
        { "hebraico": "בֶּן־אִמּוֹ", "transliteral": "ben-ʾim-mô", "traducao_palavra": "filho de sua mãe" },
        { "hebraico": "וַיֹּאמֶר", "transliteral": "way-yō-mer", "traducao_palavra": "e disse" },
        { "hebraico": "הֲזֶה", "transliteral": "hă-zeh", "traducao_palavra": "acaso este" },
        { "hebraico": "אֲחִיכֶם", "transliteral": "ă-ḥî-ḵem", "traducao_palavra": "vosso irmão" },
        { "hebraico": "הַקָּטֹן", "transliteral": "haq-qā-ṭōn", "traducao_palavra": "o mais novo" },
        { "hebraico": "אֲשֶׁר", "transliteral": "ʾă-šer", "traducao_palavra": "de quem" },
        { "hebraico": "אֲמַרְתֶּם", "transliteral": "ă-mar-tem", "traducao_palavra": "falastes" },
        { "hebraico": "אֵלָי", "transliteral": "ʾē-lay", "traducao_palavra": "a mim" },
        { "hebraico": "וַיֹּאמַר", "transliteral": "way-yō-mer", "traducao_palavra": "e disse" },
        { "hebraico": "אֱלֹהִים", "transliteral": "ʾĕ-lō-hîm", "traducao_palavra": "Deus" },
        { "hebraico": "יָחְנְךָ", "transliteral": "yā-ḥən-ə-ḵā", "traducao_palavra": "te conceda graça" },
        { "hebraico": "בְּנִי׃", "transliteral": "bə-nî", "traducao_palavra": "meu filho" }
      ]
    },
    "30": {
      "traducao_completa": "E José apressou-se, porque o seu íntimo se comovera por causa de seu irmão, e procurou onde chorar; e entrou no quarto e chorou ali.",
      "palavras": [
        { "hebraico": "וַיְמַהֵר", "transliteral": "way-mə-ma-hēr", "traducao_palavra": "e apressou-se" },
        { "hebraico": "יוֹסֵף", "transliteral": "yô-sēp̄", "traducao_palavra": "José" },
        { "hebraico": "כִּי־נִכְמְרוּ", "transliteral": "kî-niḵ-mə-rû", "traducao_palavra": "porque se comoveram" },
        { "hebraico": "רַחֲמָיו", "transliteral": "ra-ḥă-māw", "traducao_palavra": "suas entranhas/misericórdias" },
        { "hebraico": "אֶל־אָחִיו", "transliteral": "ʾel-ʾā-ḥîw", "traducao_palavra": "para com seu irmão" },
        { "hebraico": "וַיְבַקֵּשׁ", "transliteral": "way-ḇaq-qēš", "traducao_palavra": "e procurou" },
        { "hebraico": "לִבְכּוֹת", "transliteral": "liḇ-kôṯ", "traducao_palavra": "chorar" },
        { "hebraico": "וַיָּבֹא", "transliteral": "way-yā-ḇō", "traducao_palavra": "e entrou" },
        { "hebraico": "הַחַדְרָה", "transliteral": "ha-ḥaḏ-rā", "traducao_palavra": "[no] quarto" },
        { "hebraico": "וַיֵּבְךְּ", "transliteral": "way-yē-ḇək", "traducao_palavra": "e chorou" },
        { "hebraico": "שָׁמָּה׃", "transliteral": "šām-mā", "traducao_palavra": "ali" }
      ]
    },
    "31": {
      "traducao_completa": "E lavou o seu rosto e saiu; e conteve-se e disse: Servi o pão.",
      "palavras": [
        { "hebraico": "וַיִּרְחַץ", "transliteral": "way-yir-ḥaṣ", "traducao_palavra": "e lavou" },
        { "hebraico": "פָּנָיו", "transliteral": "pā-nāw", "traducao_palavra": "seu rosto" },
        { "hebraico": "וַיֵּצֵא", "transliteral": "way-yē-ṣē", "traducao_palavra": "e saiu" },
        { "hebraico": "וַיִּתְאַפַּק", "transliteral": "way-yiṯ-ʾap-paq", "traducao_palavra": "e conteve-se" },
        { "hebraico": "וַיֹּאמֶר", "transliteral": "way-yō-mer", "traducao_palavra": "e disse" },
        { "hebraico": "שִׂימוּ", "transliteral": "śî-mû", "traducao_palavra": "servi/ponde" },
        { "hebraico": "לָחֶם׃", "transliteral": "lā-ḥem", "traducao_palavra": "pão" }
      ]
    },
    "32": {
      "traducao_completa": "E serviram-lhe a ele à parte, e a eles à parte, e aos egípcios que comiam com ele à parte; porque os egípcios não podem comer pão com os hebreus, porquanto é abominação para os egípcios.",
      "palavras": [
        { "hebraico": "וַיָּשִׂימוּ", "transliteral": "way-yā-śî-mû", "traducao_palavra": "e serviram" },
        { "hebraico": "לוֹ", "transliteral": "lô", "traducao_palavra": "a ele" },
        { "hebraico": "לְבַדּוֹ", "transliteral": "lə-ḇad-dô", "traducao_palavra": "à parte" },
        { "hebraico": "וְלָהֶם", "transliteral": "wə-lā-hem", "traducao_palavra": "e a eles" },
        { "hebraico": "לְבַדָּם", "transliteral": "lə-ḇad-dām", "traducao_palavra": "à parte" },
