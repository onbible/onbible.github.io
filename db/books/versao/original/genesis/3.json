    "4": {
      "traducao_completa": "Então disse a serpente à mulher: Certamente não morrereis.",
      "palavras": [
        { "hebraico": "וַיֹּ֥אמֶר", "transliteral": "wayyōʾmer", "traducao_palavra": "E disse" },
        { "hebraico": "הַנָּחָ֖שׁ", "transliteral": "hannāḥāš", "traducao_palavra": "a serpente" },
        { "hebraico": "אֶל־הָאִשָּׁ֑ה", "transliteral": "ʾel-hāʾiššâ", "traducao_palavra": "à mulher" },
        { "hebraico": "לֹא־מ֖וֹת", "transliteral": "lōʾ-môṯ", "traducao_palavra": "não morrendo" },
        { "hebraico": "תְּמֻתֽוּן׃", "transliteral": "təmutûn", "traducao_palavra": "morrereis" }
      ]
    },
    "5": {
      "traducao_completa": "Porque Deus sabe que no dia em que dele comerdes se abrirão os vossos olhos, e sereis como Deus, sabendo o bem e o mal.",
      "palavras": [
        { "hebraico": "כִּ֚י", "transliteral": "kî", "traducao_palavra": "Porque" },
        { "hebraico": "יֹדֵ֣עַ", "transliteral": "yōḏēaʿ", "traducao_palavra": "sabe" },
        { "hebraico": "אֱלֹהִ֔ים", "transliteral": "ʾĕlōhîm", "traducao_palavra": "Deus" },
        { "hebraico": "כִּ֗י", "transliteral": "kî", "traducao_palavra": "que" },
        { "hebraico": "בְּיוֹם֙", "transliteral": "bəyôm", "traducao_palavra": "no dia" },
        { "hebraico": "אֲכָלְכֶ֣ם", "transliteral": "ʾăḵāləḵem", "traducao_palavra": "de vosso comer" },
        { "hebraico": "מִמֶּ֔נּוּ", "transliteral": "mimmennû", "traducao_palavra": "dele" },
        { "hebraico": "וְנִפְקְח֖וּ", "transliteral": "wənip̱qəḥû", "traducao_palavra": "e se abrirão" },
