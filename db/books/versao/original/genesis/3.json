        { "hebraico": "כֵּֽאלֹהִ֔ים", "transliteral": "kēʾlōhîm", "traducao_palavra": "como Deus" },
        { "hebraico": "יֹדְעֵ֖י", "transliteral": "yōḏəʿê", "traducao_palavra": "sabedores de" },
        { "hebraico": "ט֥וֹב", "transliteral": "ṭôḇ", "traducao_palavra": "bem" },
        { "hebraico": "וָרָֽע׃", "transliteral": "wārāʿ", "traducao_palavra": "e mal" }
      ]
