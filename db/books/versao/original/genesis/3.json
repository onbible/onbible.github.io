        { "hebraico": "לָעֵינַ֗יִם", "transliteral": "lāʿênayim", "traducao_palavra": "para os olhos" },
        { "hebraico": "וְנֶחְמָ֤ד", "transliteral": "wəneḥmāḏ", "traducao_palavra": "e cobiçável" },
