        { "hebraico": "לָהֶ֖ם", "transliteral": "lāhem", "traducao_palavra": "para si" },
        { "hebraico": "חֲגֹרֹֽת׃", "transliteral": "ḥăḡōrōṯ", "traducao_palavra": "cintas/aventais" }
      ]
