        { "hebraico": "לְךָ֔", "transliteral": "ləḵā", "traducao_palavra": "te" },
        { "hebraico": "כִּ֥י", "transliteral": "kî", "traducao_palavra": "que" },
        { "hebraico": "עֵירֹ֖ם", "transliteral": "ʿêrōm", "traducao_palavra": "nu" },
