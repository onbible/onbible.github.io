        { "hebraico": "אֶל־הַנָּחָ֑שׁ", "transliteral": "ʾel-hannāḥāš", "traducao_palavra": "à serpente" },
        { "hebraico": "מִפְּרִ֥י", "transliteral": "mippərî", "traducao_palavra": "do fruto de" },
        { "hebraico": "עֵץ־הַגָּ֖ן", "transliteral": "ʿēṣ-haggān", "traducao_palavra": "árvores do jardim" },
        { "hebraico": "נֹאכֵֽל׃", "transliteral": "nōʾḵēl", "traducao_palavra": "comeremos" }
      ]
