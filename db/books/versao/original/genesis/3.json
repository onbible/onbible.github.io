    "7": {
      "traducao_completa": "Então foram abertos os olhos de ambos, e conheceram que estavam nus; e coseram folhas de figueira, e fizeram para si cintas.",
      "palavras": [
        { "hebraico": "וַתִּפָּקַ֙חְנָה֙", "transliteral": "wattippāqaḥnâ", "traducao_palavra": "Então foram abertos" },
