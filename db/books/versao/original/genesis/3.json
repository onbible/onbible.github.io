  "versiculos": {
    "1": {
      "traducao_completa": "E a serpente era mais astuta que todo animal do campo que o SENHOR Deus tinha feito; e disse à mulher: É assim que Deus disse: Não comereis de toda árvore do jardim?",
      "palavras": [
        { "hebraico": "וְהַנָּחָשׁ֙", "transliteral": "wəhannāḥāš", "traducao_palavra": "E a serpente" },
        { "hebraico": "הָיָ֣ה", "transliteral": "hāyâ", "traducao_palavra": "era" },
        { "hebraico": "עָר֔וּם", "transliteral": "ʿārûm", "traducao_palavra": "astuta" },
        { "hebraico": "מִכֹּל֙", "transliteral": "mikkōl", "traducao_palavra": "mais que todo" },
        { "hebraico": "חַיַּ֣ת", "transliteral": "ḥayyaṯ", "traducao_palavra": "animal de" },
        { "hebraico": "הַשָּׂדֶ֔ה", "transliteral": "haśśāḏeh", "traducao_palavra": "o campo" },
        { "hebraico": "אֲשֶׁ֥ר", "transliteral": "ʾăšer", "traducao_palavra": "que" },
        { "hebraico": "עָשָׂ֖ה", "transliteral": "ʿāśâ", "traducao_palavra": "tinha feito" },
