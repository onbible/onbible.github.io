        { "hebraico": "לְהַשְׂכִּ֔יל", "transliteral": "ləhaśkîl", "traducao_palavra": "para dar entendimento" },
        { "hebraico": "וַתִּקַּ֥ח", "transliteral": "wattiqqaḥ", "traducao_palavra": "e tomou" },
        { "hebraico": "מִפִּרְי֖וֹ", "transliteral": "mippiryô", "traducao_palavra": "do seu fruto" },
        { "hebraico": "וַתֹּאכַ֑ל", "transliteral": "wattōʾḵal", "traducao_palavra": "e comeu" },
        { "hebraico": "וַתִּתֵּ֧ן", "transliteral": "wattittēn", "traducao_palavra": "e deu" },
        { "hebraico": "גַּם־לְאִישָׁ֛הּ", "transliteral": "gam-ləʾîšāh", "traducao_palavra": "também a seu marido" },
        { "hebraico": "עִמָּ֖הּ", "transliteral": "ʿimmāh", "traducao_palavra": "com ela" },
