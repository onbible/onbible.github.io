        { "hebraico": "אֱלֹהִ֑ים", "transliteral": "ʾĕlōhîm", "traducao_palavra": "Deus" },
        { "hebraico": "וַיֹּ֙אמֶר֙", "transliteral": "wayyōʾmer", "traducao_palavra": "e disse" },
        { "hebraico": "אֶל־הָאִשָּׁ֔ה", "transliteral": "ʾel-hāʾiššâ", "traducao_palavra": "à mulher" },
        { "hebraico": "אַ֚ף", "transliteral": "ʾap̱", "traducao_palavra": "É verdade/ainda" },
        { "hebraico": "כִּֽי־אָמַ֣ר", "transliteral": "kî-ʾāmar", "traducao_palavra": "que disse" },
        { "hebraico": "אֱלֹהִ֔ים", "transliteral": "ʾĕlōhîm", "traducao_palavra": "Deus" },
        { "hebraico": "לֹ֣א", "transliteral": "lōʾ", "traducao_palavra": "Não" },
        { "hebraico": "תֹֽאכְל֔וּ", "transliteral": "ṯōʾḵəlû", "traducao_palavra": "comereis" },
        { "hebraico": "מִכֹּ֖ל", "transliteral": "mikkōl", "traducao_palavra": "de toda" },
        { "hebraico": "עֵ֥ץ", "transliteral": "ʿēṣ", "traducao_palavra": "árvore de" },
        { "hebraico": "הַגָּֽן׃", "transliteral": "haggān", "traducao_palavra": "o jardim" }
      ]
    },
    "2": {
      "traducao_completa": "E disse a mulher à serpente: Do fruto das árvores do jardim comeremos;",
      "palavras": [
        { "hebraico": "וַתֹּ֥אמֶר", "transliteral": "wattōʾmer", "traducao_palavra": "E disse" },
