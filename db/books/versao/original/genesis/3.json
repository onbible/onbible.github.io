        { "hebraico": "בּ֑וֹ", "transliteral": "bô", "traducao_palavra": "nele" },
        { "hebraico": "פֶּן־תְּמֻתֽוּן׃", "transliteral": "pen-təmutûn", "traducao_palavra": "para que não morrais" }
      ]
