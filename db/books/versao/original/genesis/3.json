        { "hebraico": "מִפְּנֵי֙", "transliteral": "mippənê", "traducao_palavra": "da face de" },
        { "hebraico": "יְהוָ֣ה", "transliteral": "YHWH", "traducao_palavra": "YHWH" },
        { "hebraico": "אֱלֹהִ֔ים", "transliteral": "ʾĕlōhîm", "traducao_palavra": "Deus" },
        { "hebraico": "בְּת֖וֹךְ", "transliteral": "bəṯôḵ", "traducao_palavra": "no meio de" },
        { "hebraico": "עֵ֥ץ", "transliteral": "ʿēṣ", "traducao_palavra": "árvores de" },
        { "hebraico": "הַגָּֽן׃", "transliteral": "haggān", "traducao_palavra": "o jardim" }
      ]
    },
    "9": {
      "traducao_completa": "E chamou o SENHOR Deus ao homem, e disse-lhe: Onde estás?",
