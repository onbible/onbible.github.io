        { "hebraico": "הָאִשָּׁ֡ה", "transliteral": "hāʾiššâ", "traducao_palavra": "a mulher" },
        { "hebraico": "כִּ֣י", "transliteral": "kî", "traducao_palavra": "que" },
        { "hebraico": "טֹוב֩", "transliteral": "ṭôḇ", "traducao_palavra": "boa" },
        { "hebraico": "הָעֵ֨ץ", "transliteral": "hāʿēṣ", "traducao_palavra": "a árvore" },
        { "hebraico": "לְמַאֲכָ֜ל", "transliteral": "ləmaʾăḵāl", "traducao_palavra": "para comida" },
        { "hebraico": "וְכִ֧י", "transliteral": "wəḵî", "traducao_palavra": "e que" },
