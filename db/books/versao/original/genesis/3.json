        { "hebraico": "תְּשׁוּקָתֵ֔ךְ", "transliteral": "təšûqāṯēḵ", "traducao_palavra": "teu desejo" },
        { "hebraico": "וְה֖וּא", "transliteral": "wəhû", "traducao_palavra": "e ele" },
