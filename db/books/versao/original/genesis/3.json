    "8": {
      "traducao_completa": "E ouviram a voz do SENHOR Deus, que passeava no jardim à brisa do dia; e esconderam-se o homem e sua mulher da face do SENHOR Deus, no meio das árvores do jardim.",
      "palavras": [
        { "hebraico": "וַֽיִּשְׁמְע֞וּ", "transliteral": "wayyišməʿû", "traducao_palavra": "E ouviram" },
