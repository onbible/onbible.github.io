        { "hebraico": "עַל־הַפְּגָרִ֑ים", "transliteral": "ʿal-happəḡārîm", "traducao_palavra": "sobre os cadáveres" },
        { "hebraico": "וַיַּשֵּׁ֥ב", "transliteral": "wayyaššēḇ", "traducao_palavra": "e soprou/afastou" },
