        { "hebraico": "וַיֹּ֣אמֶר", "transliteral": "wayyōʾmer", "traducao_palavra": "E disse" },
        { "hebraico": "אֵלָ֗יו", "transliteral": "ʾēlāyw", "traducao_palavra": "a ele" },
        { "hebraico": "קְחָ֥ה", "transliteral": "qəḥâ", "traducao_palavra": "toma" },
        { "hebraico": "לִּי֙", "transliteral": "llî", "traducao_palavra": "para mim" },
        { "hebraico": "עֶגְלָ֣ה", "transliteral": "ʿeḡlâ", "traducao_palavra": "uma bezerra" },
        { "hebraico": "מְשֻׁלֶּ֔שֶׁת", "transliteral": "məšullešeṯ", "traducao_palavra": "de três anos" },
        { "hebraico": "וְעֵ֥ז", "transliteral": "wəʿēz", "traducao_palavra": "e cabra" },
        { "hebraico": "מְשֻׁלֶּ֖שֶׁת", "transliteral": "məšullešeṯ", "traducao_palavra": "de três anos" },
        { "hebraico": "וְאַ֣יִל", "transliteral": "wəʾayil", "traducao_palavra": "e carneiro" },
        { "hebraico": "מְשֻׁלָּ֑שׁ", "transliteral": "məšullāš", "traducao_palavra": "de três anos" },
        { "hebraico": "וְתֹ֖ר", "transliteral": "wəṯōr", "traducao_palavra": "e rola" },
        { "hebraico": "וְגוֹזָֽל׃", "transliteral": "wəḡôzāl", "traducao_palavra": "e pombinho" }
      ]
    },
    "10": {
      "traducao_completa": "E trouxe-lhe todos estes, e partiu-os pelo meio, e pôs cada parte defronte da outra; mas as aves não partiu.",
      "palavras": [
        { "hebraico": "וַיִּקַּֽח־לֹ֣ו", "transliteral": "wayyiqqaḥ-lô", "traducao_palavra": "E tomou para ele" },
