    "6": {
      "traducao_completa": "E creu ele no SENHOR, e imputou-lhe isto por justiça.",
      "palavras": [
        { "hebraico": "וְהֶאֱמִ֖ן", "transliteral": "wəheʾĕmin", "traducao_palavra": "E creu" },
        { "hebraico": "בַּֽיהוָ֑ה", "transliteral": "baYHWH", "traducao_palavra": "em YHWH" },
        { "hebraico": "וַיַּחְשְׁבֶ֥הָ", "transliteral": "wayyaḥšəḇehā", "traducao_palavra": "e imputou ela [a fé]" },
        { "hebraico": "לֹּ֖ו", "transliteral": "llô", "traducao_palavra": "para ele" },
        { "hebraico": "צְדָקָֽה׃", "transliteral": "ṣəḏāqâ", "traducao_palavra": "por justiça" }
      ]
    },
    "7": {
      "traducao_completa": "Disse-lhe mais: Eu sou o SENHOR, que te tirei de Ur dos Caldeus, para dar-te a ti esta terra, para a herdares.",
      "palavras": [
        { "hebraico": "וַיֹּ֖אמֶר", "transliteral": "wayyōʾmer", "traducao_palavra": "E disse" },
        { "hebraico": "אֵלָ֑יו", "transliteral": "ʾēlāyw", "traducao_palavra": "a ele" },
        { "hebraico": "אֲנִ֣י", "transliteral": "ʾănî", "traducao_palavra": "Eu [sou]" },
        { "hebraico": "יְהוָ֗ה", "transliteral": "YHWH", "traducao_palavra": "YHWH" },
        { "hebraico": "אֲשֶׁ֤ר", "transliteral": "ʾăšer", "traducao_palavra": "que" },
        { "hebraico": "הֹוצֵאתִ֙יךָ֙", "transliteral": "hôṣēʾṯîḵā", "traducao_palavra": "tirei-te" },
        { "hebraico": "מֵא֥וּר", "transliteral": "mēʾûr", "traducao_palavra": "de Ur" },
        { "hebraico": "כַּשְׂדִּ֔ים", "transliteral": "kaśdîm", "traducao_palavra": "dos Caldeus" },
        { "hebraico": "לָ֧תֶת", "transliteral": "lāṯeṯ", "traducao_palavra": "para dar" },
        { "hebraico": "לְךָ֛", "transliteral": "ləḵā", "traducao_palavra": "a ti" },
        { "hebraico": "אֶת־הָאָ֥רֶץ", "transliteral": "ʾeṯ-hāʾāreṣ", "traducao_palavra": "[obj] a terra" },
        { "hebraico": "הַזֹּ֖את", "transliteral": "hazzōʾṯ", "traducao_palavra": "esta" },
        { "hebraico": "לְרִשְׁתָּֽהּ׃", "transliteral": "lərištāh", "traducao_palavra": "para herdá-la" }
      ]
    },
    "8": {
      "traducao_completa": "E disse ele: Senhor DEUS, como saberei que hei de herdá-la?",
      "palavras": [
        { "hebraico": "וַיֹּאמַ֑ר", "transliteral": "wayyōʾmar", "traducao_palavra": "E disse" },
        { "hebraico": "אֲדֹנָ֣י", "transliteral": "ʾăḏōnāy", "traducao_palavra": "Senhor" },
