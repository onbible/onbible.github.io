        { "hebraico": "בַּֽמַּחֲזֶ֖ה", "transliteral": "bammaḥăzeh", "traducao_palavra": "na visão" },
        { "hebraico": "לֵאמֹ֑ר", "transliteral": "lēʾmōr", "traducao_palavra": "dizendo" },
