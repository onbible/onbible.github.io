        { "hebraico": "וַיְבַתֵּ֤ר", "transliteral": "wayəḇattēr", "traducao_palavra": "e dividiu/partiu" },
        { "hebraico": "אֹתָם֙", "transliteral": "ʾōṯām", "traducao_palavra": "eles" },
        { "hebraico": "בַּתָּ֔וֶךְ", "transliteral": "battāweḵ", "traducao_palavra": "no meio" },
        { "hebraico": "וַיִּתֵּ֥ן", "transliteral": "wayyittēn", "traducao_palavra": "e pôs" },
        { "hebraico": "אִשׁ־בִּתְרֹ֖ו", "transliteral": "ʾîš-biṯrô", "traducao_palavra": "cada parte de seu pedaço" },
        { "hebraico": "לִקְרַ֣את", "transliteral": "liqrʾaṯ", "traducao_palavra": "ao encontro de" },
        { "hebraico": "רֵעֵ֑הוּ", "transliteral": "rēʿēhû", "traducao_palavra": "seu próximo/outro" },
        { "hebraico": "וְאֶת־הַצִּפֹּ֖ר", "transliteral": "wəʾeṯ-haṣippōr", "traducao_palavra": "mas a ave" },
        { "hebraico": "לֹ֥א", "transliteral": "lōʾ", "traducao_palavra": "não" },
        { "hebraico": "בָתָֽר׃", "transliteral": "ḇāṯār", "traducao_palavra": "partiu" }
      ]
    },
    "11": {
      "traducao_completa": "E as aves de rapina desciam sobre os cadáveres; Abrão, porém, as enxotava.",
      "palavras": [
        { "hebraico": "וַיֵּ֥רֶד", "transliteral": "wayyēreḏ", "traducao_palavra": "E desceu" },
