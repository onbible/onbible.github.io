  "versiculos": {
    "1": {
      "traducao_completa": "Depois destas coisas veio a palavra do SENHOR a Abrão em visão, dizendo: Não temas, Abrão, eu sou o teu escudo, o teu galardão será muito grande.",
      "palavras": [
        { "hebraico": "אַחַ֣ר", "transliteral": "ʾaḥar", "traducao_palavra": "Depois de" },
        { "hebraico": "הַדְּבָרִ֣ים", "transliteral": "haddəḇārîm", "traducao_palavra": "as coisas/palavras" },
        { "hebraico": "הָאֵ֗לֶּה", "transliteral": "hāʾēlleh", "traducao_palavra": "estas" },
        { "hebraico": "הָיָ֤ה", "transliteral": "hāyâ", "traducao_palavra": "veio/foi" },
