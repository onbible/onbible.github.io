        { "hebraico": "אֵימָ֛ה", "transliteral": "ʾêmâ", "traducao_palavra": "pavor" },
        { "hebraico": "חֲשֵׁכָ֥ה", "transliteral": "ḥăšēḵâ", "traducao_palavra": "escuridão" },
        { "hebraico": "גְדֹלָ֖ה", "transliteral": "ḡəḏōlâ", "traducao_palavra": "grande" },
        { "hebraico": "נֹפֶ֥לֶת", "transliteral": "nōp̱eleṯ", "traducao_palavra": "caindo" },
        { "hebraico": "עָלָֽיו׃", "transliteral": "ʿālāyw", "traducao_palavra": "sobre ele" }
      ]
    },
    "13": {
      "traducao_completa": "Então disse a Abrão: Sabe, com certeza, que a tua semente será peregrina em terra alheia, e servi-los-á, e afligi-la-ão quatrocentos anos.",
      "palavras": [
        { "hebraico": "וַיֹּ֣אמֶר", "transliteral": "wayyōʾmer", "traducao_palavra": "E disse" },
        { "hebraico": "לְאַבְרָ֗ם", "transliteral": "ləʾaḇrām", "traducao_palavra": "a Abrão" },
        { "hebraico": "יָדֹ֨עַ תֵּדַ֜ע", "transliteral": "yāḏōaʿ tēḏaʿ", "traducao_palavra": "sabendo saberás" },
        { "hebraico": "כִּי־גֵ֣ר", "transliteral": "kî-ḡēr", "traducao_palavra": "que estrangeira/peregrina" },
        { "hebraico": "יִהְיֶ֣ה", "transliteral": "yihyeh", "traducao_palavra": "será" },
        { "hebraico": "זַרְעֲךָ֮", "transliteral": "zarʿăḵā", "traducao_palavra": "tua semente" },
        { "hebraico": "בְּאֶ֣רֶץ", "transliteral": "bəʾereṣ", "traducao_palavra": "numa terra" },
        { "hebraico": "לֹ֣א לָהֶם֒", "transliteral": "lōʾ lāhem", "traducao_palavra": "[que] não [é] deles" },
        { "hebraico": "וַעֲבָד֗וּם", "transliteral": "waʿăḇāḏûm", "traducao_palavra": "e servi-los-ão" },
        { "hebraico": "וְעִנּ֥וּ", "transliteral": "wəʿinnû", "traducao_palavra": "e afligi-los-ão" },
        { "hebraico": "אֹתָ֖ם", "transliteral": "ʾōṯām", "traducao_palavra": "eles" },
        { "hebraico": "אַרְבַּ֥ע מֵאֹ֖ות", "transliteral": "ʾarbaʿ mēʾôṯ", "traducao_palavra": "quatrocentas" },
        { "hebraico": "שָׁנָֽה׃", "transliteral": "šānâ", "traducao_palavra": "anos" }
      ]
    },
    "14": {
      "traducao_completa": "Mas também a nação, a que servirem, eu julgarei, e depois sairão com grandes bens.",
      "palavras": [
        { "hebraico": "וְגַ֧ם", "transliteral": "wəḡam", "traducao_palavra": "E também" },
        { "hebraico": "אֶת־הַגֹּ֛וי", "transliteral": "ʾeṯ-haggôy", "traducao_palavra": "[obj] a nação" },
        { "hebraico": "אֲשֶׁ֥ר", "transliteral": "ʾăšer", "traducao_palavra": "que" },
        { "hebraico": "יַעֲבֹ֖דוּ", "transliteral": "yaʿăḇōḏû", "traducao_palavra": "servirem" },
        { "hebraico": "דָּ֣ן אָנֹ֑כִי", "transliteral": "dān ʾānōḵî", "traducao_palavra": "julgador [sou] eu" },
        { "hebraico": "וְאַחֲרֵי־כֵ֥ן", "transliteral": "wəʾaḥărê-ḵēn", "traducao_palavra": "e depois disso" },
        { "hebraico": "יֵצְא֖וּ", "transliteral": "yēṣəʾû", "traducao_palavra": "sairão" },
        { "hebraico": "בִּרְכֻ֥שׁ", "transliteral": "birḵuš", "traducao_palavra": "com bem/possessão" },
        { "hebraico": "גָּדֹֽול׃", "transliteral": "ḡāḏôl", "traducao_palavra": "grande" }
      ]
    },
    "15": {
      "traducao_completa": "E tu irás a teus pais em paz; em boa velhice serás sepultado.",
      "palavras": [
        { "hebraico": "וְאַתָּ֛ה", "transliteral": "wəʾattâ", "traducao_palavra": "E tu" },
        { "hebraico": "תָּבֹ֥וא", "transliteral": "tāḇôʾ", "traducao_palavra": "irás/virás" },
        { "hebraico": "אֶל־אֲבֹתֶ֖יךָ", "transliteral": "ʾel-ʾăḇōṯeyḵā", "traducao_palavra": "a teus pais" },
        { "hebraico": "בְּשָׁלֹ֑ום", "transliteral": "bəšālôm", "traducao_palavra": "em paz" },
        { "hebraico": "תִּקָּבֵ֖ר", "transliteral": "tiqqāḇēr", "traducao_palavra": "serás sepultado" },
        { "hebraico": "בְּשֵׂיבָ֥ה", "transliteral": "bəśêḇâ", "traducao_palavra": "em velhice" },
        { "hebraico": "טֹובָֽה׃", "transliteral": "ṭôḇâ", "traducao_palavra": "boa" }
      ]
    },
    "16": {
      "traducao_completa": "E a quarta geração tornará para cá; porque a medida da injustiça dos amorreus não está ainda cheia.",
      "palavras": [
        { "hebraico": "וְדֹ֥ור", "transliteral": "wəḏôr", "traducao_palavra": "E geração" },
        { "hebraico": "רְבִיעִ֖י", "transliteral": "rəḇîʿî", "traducao_palavra": "quarta" },
        { "hebraico": "יָשׁ֣וּבוּ", "transliteral": "yāšûḇû", "traducao_palavra": "voltarão" },
        { "hebraico": "הֵ֑נָּה", "transliteral": "hēnnâ", "traducao_palavra": "para cá" },
        { "hebraico": "כִּ֧י", "transliteral": "kî", "traducao_palavra": "porque" },
        { "hebraico": "לֹא־שָׁלֵ֛ם", "transliteral": "lōʾ-šālēm", "traducao_palavra": "não completa [está]" },
        { "hebraico": "עֲוֹ֥ן", "transliteral": "ʿăwōn", "traducao_palavra": "a iniquidade de" },
        { "hebraico": "הָאֱמֹרִ֖י", "transliteral": "hāʾĕmōrî", "traducao_palavra": "o amorreu" },
        { "hebraico": "עַד־הֵֽנָּה׃", "transliteral": "ʿaḏ-hēnnâ", "traducao_palavra": "até agora" }
      ]
    },
    "17": {
      "traducao_completa": "E sucedeu que, posto o sol, houve trevas, e eis um forno fumegante e uma tocha de fogo, que passou por entre aquelas metades.",
      "palavras": [
        { "hebraico": "וַיְהִ֤י", "transliteral": "wayəhî", "traducao_palavra": "E foi/aconteceu" },
        { "hebraico": "הַשֶּׁ֙מֶשׁ֙", "transliteral": "haššemeš", "traducao_palavra": "o sol" },
        { "hebraico": "בָּ֔אָה", "transliteral": "bāʾâ", "traducao_palavra": "entrou/se pôs" },
        { "hebraico": "וַעֲלָטָ֖ה", "transliteral": "waʿălāṭâ", "traducao_palavra": "e escuridão" },
        { "hebraico": "הָיָ֑ה", "transliteral": "hāyâ", "traducao_palavra": "houve" },
        { "hebraico": "וְהִנֵּ֨ה", "transliteral": "wəhinnēh", "traducao_palavra": "e eis" },
        { "hebraico": "תַנּ֤וּר", "transliteral": "ṯannûr", "traducao_palavra": "um forno de" },
        { "hebraico": "עָשָׁן֙", "transliteral": "ʿāšān", "traducao_palavra": "fumaça" },
        { "hebraico": "וְלַפִּ֣יד", "transliteral": "wəlappîḏ", "traducao_palavra": "e uma tocha de" },
        { "hebraico": "אֵ֔שׁ", "transliteral": "ʾēš", "traducao_palavra": "fogo" },
        { "hebraico": "אֲשֶׁ֣ר", "transliteral": "ʾăšer", "traducao_palavra": "que" },
        { "hebraico": "עָבַ֔ר", "transliteral": "ʿāḇar", "traducao_palavra": "passou" },
        { "hebraico": "בֵּ֥ין", "transliteral": "bên", "traducao_palavra": "entre" },
        { "hebraico": "הַבְּתָרִ֖ים", "transliteral": "habbəṯārîm", "traducao_palavra": "os pedaços" },
        { "hebraico": "הָאֵֽלֶּה׃", "transliteral": "hāʾēlleh", "traducao_palavra": "estes" }
      ]
    },
    "18": {
      "traducao_completa": "Naquele mesmo dia fez o SENHOR uma aliança com Abrão, dizendo: À tua semente tenho dado esta terra, desde o rio do Egito até ao grande rio Eufrates;",
      "palavras": [
        { "hebraico": "בַּיֹּ֣ום", "transliteral": "bayyôm", "traducao_palavra": "No dia" },
        { "hebraico": "הַה֗וּא", "transliteral": "hahû", "traducao_palavra": "aquele" },
        { "hebraico": "כָּרַ֧ת", "transliteral": "kāraṯ", "traducao_palavra": "cortou/fez" },
        { "hebraico": "יְהוָ֛ה", "transliteral": "YHWH", "traducao_palavra": "YHWH" },
        { "hebraico": "אֶת־אַבְרָ֖ם", "transliteral": "ʾeṯ-ʾaḇrām", "traducao_palavra": "com Abrão" },
        { "hebraico": "בְּרִ֣ית", "transliteral": "bərîṯ", "traducao_palavra": "uma aliança" },
        { "hebraico": "לֵאמֹ֑ר", "transliteral": "lēʾmōr", "traducao_palavra": "dizendo" },
        { "hebraico": "לְזַרְעֲךָ֮", "transliteral": "ləzarʿăḵā", "traducao_palavra": "à tua semente" },
        { "hebraico": "נָתַ֣תִּי", "transliteral": "nāṯattî", "traducao_palavra": "tenho dado" },
        { "hebraico": "אֶת־הָאָ֣רֶץ", "transliteral": "ʾeṯ-hāʾāreṣ", "traducao_palavra": "[obj] a terra" },
        { "hebraico": "הַזֹּאת֒", "transliteral": "hazzōʾṯ", "traducao_palavra": "esta" },
        { "hebraico": "מִנְּהַ֣ר", "transliteral": "minnəhar", "traducao_palavra": "desde o rio de" },
        { "hebraico": "מִצְרַ֔יִם", "transliteral": "miṣrayim", "traducao_palavra": "Egito" },
        { "hebraico": "עַד־הַנָּהָ֥ר", "transliteral": "ʿaḏ-hannāhār", "traducao_palavra": "até o rio" },
        { "hebraico": "הַגָּדֹ֖ל", "transliteral": "haggāḏōl", "traducao_palavra": "o grande" },
        { "hebraico": "נְהַר־פְּרָֽת׃", "transliteral": "nəhar-pərāṯ", "traducao_palavra": "rio Eufrates" }
      ]
    },
    "19": {
      "traducao_completa": "e o queneu, e o quenezeu, e o cadmoneu,",
      "palavras": [
        { "hebraico": "אֶת־הַקֵּינִ֕י", "transliteral": "ʾeṯ-haqqênî", "traducao_palavra": "[obj] o queneu" },
        { "hebraico": "וְאֶת־הַקְּנִזִּ֖י", "transliteral": "wəʾeṯ-haqqənizzî", "traducao_palavra": "e o quenezeu" },
        { "hebraico": "וְאֵ֥ת", "transliteral": "wəʾēṯ", "traducao_palavra": "e" },
        { "hebraico": "הַקַּדְמֹנִֽי׃", "transliteral": "haqqadmōnî", "traducao_palavra": "o cadmoneu" }
      ]
    },
    "20": {
      "traducao_completa": "e o heteu, e o ferezeu, e os refains,",
      "palavras": [
        { "hebraico": "וְאֶת־הַחִתִּ֥י", "transliteral": "wəʾeṯ-haḥittî", "traducao_palavra": "e o heteu" },
        { "hebraico": "וְאֶת־הַפְּרִזִּ֑י", "transliteral": "wəʾeṯ-happərizzî", "traducao_palavra": "e o ferezeu" },
        { "hebraico": "וְאֶת־רְפָאִֽים׃", "transliteral": "wəʾeṯ-rəp̱āʾîm", "traducao_palavra": "e os refains" }
      ]
    },
    "21": {
      "traducao_completa": "e o amorreu, e o cananeu, e o girgaseu, e o jebuseu.",
      "palavras": [
        { "hebraico": "וְאֶת־הָאֱמֹרִ֖י", "transliteral": "wəʾeṯ-hāʾĕmōrî", "traducao_palavra": "e o amorreu" },
        { "hebraico": "וְאֶת־הַכְּנַעֲנִ֑י", "transliteral": "wəʾeṯ-hakkənaʿănî", "traducao_palavra": "e o cananeu" },
        { "hebraico": "וְאֶת־הַגִּרְגָּשִׁ֖י", "transliteral": "wəʾeṯ-haggirggāšî", "traducao_palavra": "e o girgaseu" },
        { "hebraico": "וְאֶת־הַיְבוּסִֽי׃", "transliteral": "wəʾeṯ-hayəḇûsî", "traducao_palavra": "e o jebuseu" }
      ]
    }
  }
}