        { "hebraico": "אָנֹכִי֙", "transliteral": "ʾānōḵî", "traducao_palavra": "eu [sou]" },
        { "hebraico": "מָגֵ֣ן", "transliteral": "māḡēn", "traducao_palavra": "escudo" },
        { "hebraico": "לָ֔ךְ", "transliteral": "lāḵ", "traducao_palavra": "para ti" },
        { "hebraico": "שְׂכָרְךָ֖", "transliteral": "śəḵārəḵā", "traducao_palavra": "teu galardão" },
        { "hebraico": "הַרְבֵּ֥ה", "transliteral": "harbbēh", "traducao_palavra": "muito" },
        { "hebraico": "מְאֹֽד׃", "transliteral": "məʾōḏ", "traducao_palavra": "grande" }
      ]
    },
    "2": {
      "traducao_completa": "E disse Abrão: Senhor DEUS, que me darás, visto que ando sem filhos, e o herdeiro de minha casa é o damasceno Eliézer?",
      "palavras": [
        { "hebraico": "וַיֹּ֣אמֶר", "transliteral": "wayyōʾmer", "traducao_palavra": "E disse" },
        { "hebraico": "אַבְרָ֗ם", "transliteral": "ʾaḇrām", "traducao_palavra": "Abrão" },
        { "hebraico": "אֲדֹנָ֤י", "transliteral": "ʾăḏōnāy", "traducao_palavra": "Senhor" },
        { "hebraico": "יְהוִה֙", "transliteral": "YHWH", "traducao_palavra": "DEUS" },
        { "hebraico": "מַה־תִּתֶּן־לִ֔י", "transliteral": "mah-titten-lî", "traducao_palavra": "o que darás a mim" },
        { "hebraico": "וְאָנֹכִ֖י", "transliteral": "wəʾānōḵî", "traducao_palavra": "visto que eu" },
        { "hebraico": "הֹולֵ֣ךְ", "transliteral": "hôlēḵ", "traducao_palavra": "ando/vou" },
        { "hebraico": "עֲרִירִ֑י", "transliteral": "ʿărîrî", "traducao_palavra": "solitário/sem filhos" },
        { "hebraico": "וּבֶן־מֶ֣שֶׁק", "transliteral": "ûḇen-mešeq", "traducao_palavra": "e o filho da posse de" },
        { "hebraico": "בֵּיתִ֔י", "transliteral": "bêṯî", "traducao_palavra": "minha casa" },
        { "hebraico": "ה֖וּא", "transliteral": "hû", "traducao_palavra": "ele [é]" },
        { "hebraico": "דַּמֶּ֥שֶׂק", "transliteral": "dammeśeq", "traducao_palavra": "o damasceno" },
        { "hebraico": "אֱלִיעֶֽזֶר׃", "transliteral": "ʾĕlîʿezer", "traducao_palavra": "Eliézer" }
      ]
    },
    "3": {
      "traducao_completa": "Disse mais Abrão: Eis que não me tens dado semente, e eis que um nascido na minha casa será o meu herdeiro.",
      "palavras": [
        { "hebraico": "וַיֹּ֣אמֶר", "transliteral": "wayyōʾmer", "traducao_palavra": "E disse" },
        { "hebraico": "אַבְרָ֔ם", "transliteral": "ʾaḇrām", "traducao_palavra": "Abrão" },
        { "hebraico": "הֵ֣ן", "transliteral": "hēn", "traducao_palavra": "Eis" },
        { "hebraico": "לִ֔י", "transliteral": "lî", "traducao_palavra": "para mim" },
        { "hebraico": "לֹ֥א", "transliteral": "lōʾ", "traducao_palavra": "não" },
        { "hebraico": "נָתַ֖תָּה", "transliteral": "nāṯattâ", "traducao_palavra": "deste" },
        { "hebraico": "זָ֑רַע", "transliteral": "zāraʿ", "traducao_palavra": "semente" },
        { "hebraico": "וְהִנֵּ֥ה", "transliteral": "wəhinnēh", "traducao_palavra": "e eis que" },
        { "hebraico": "בֶן־בֵּיתִ֖י", "transliteral": "ben-bêṯî", "traducao_palavra": "um filho de minha casa" },
        { "hebraico": "יֹורֵ֥שׁ", "transliteral": "yôrēš", "traducao_palavra": "herda/herdeiro" },
        { "hebraico": "אֹתִֽי׃", "transliteral": "ʾōṯî", "traducao_palavra": "me" }
      ]
    },
    "4": {
      "traducao_completa": "E eis que veio a palavra do SENHOR a ele, dizendo: Este não será o teu herdeiro; mas aquele que de tuas entranhas sair, este será o teu herdeiro.",
      "palavras": [
        { "hebraico": "וְהִנֵּ֨ה", "transliteral": "wəhinnēh", "traducao_palavra": "E eis que" },
        { "hebraico": "דְבַר־יְהוָ֤ה", "transliteral": "dəḇar-YHWH", "traducao_palavra": "a palavra de YHWH" },
        { "hebraico": "אֵלָיו֙", "transliteral": "ʾēlāyw", "traducao_palavra": "para ele" },
        { "hebraico": "לֵאמֹ֔ר", "transliteral": "lēʾmōr", "traducao_palavra": "dizendo" },
        { "hebraico": "לֹ֥א", "transliteral": "lōʾ", "traducao_palavra": "Não" },
        { "hebraico": "יִֽירָשְׁךָ֖", "transliteral": "yîrāšəḵā", "traducao_palavra": "herdará de ti" },
        { "hebraico": "זֶ֑ה", "transliteral": "zeh", "traducao_palavra": "este" },
        { "hebraico": "כִּי־אִם֙", "transliteral": "kî-ʾim", "traducao_palavra": "senão" },
        { "hebraico": "אֲשֶׁ֣ר", "transliteral": "ʾăšer", "traducao_palavra": "que" },
        { "hebraico": "יֵצֵ֣א", "transliteral": "yēṣēʾ", "traducao_palavra": "sairá" },
        { "hebraico": "מִמֵּעֶ֔יךָ", "transliteral": "mimmēʿeyḵā", "traducao_palavra": "de tuas entranhas" },
        { "hebraico": "ה֖וּא", "transliteral": "hû", "traducao_palavra": "ele" },
        { "hebraico": "יִֽירָשֶֽׁךָ׃", "transliteral": "yîrāšeḵā", "traducao_palavra": "herdará de ti" }
      ]
    },
    "5": {
      "traducao_completa": "Então o levou fora, e disse: Olha agora para os céus, e conta as estrelas, se as podes contar. E disse-lhe: Assim será a tua semente.",
      "palavras": [
        { "hebraico": "וַיֹּוצֵ֨א", "transliteral": "wayyôṣēʾ", "traducao_palavra": "E o levou" },
        { "hebraico": "אֹתֹ֜ו", "transliteral": "ʾōṯô", "traducao_palavra": "ele" },
        { "hebraico": "הַח֗וּצָה", "transliteral": "haḥûṣâ", "traducao_palavra": "para fora" },
        { "hebraico": "וַיֹּ֙אמֶר֙", "transliteral": "wayyōʾmer", "traducao_palavra": "e disse" },
        { "hebraico": "הַבֶּט־נָ֣א", "transliteral": "habbeṭ-nāʾ", "traducao_palavra": "olha, peço" },
        { "hebraico": "הַשָּׁמַ֔יְמָה", "transliteral": "haššāmayəmâ", "traducao_palavra": "para os céus" },
        { "hebraico": "וּסְפֹ֥ר", "transliteral": "ûsəp̱ōr", "traducao_palavra": "e conta" },
        { "hebraico": "הַכֹּוכָבִ֖ים", "transliteral": "hakkôḵāḇîm", "traducao_palavra": "as estrelas" },
        { "hebraico": "אִם־תּוּכַ֖ל", "transliteral": "ʾim-tûḵal", "traducao_palavra": "se puderes" },
        { "hebraico": "לִסְפֹּ֣ר", "transliteral": "lispppōr", "traducao_palavra": "contar" },
        { "hebraico": "אֹתָ֑ם", "transliteral": "ʾōṯām", "traducao_palavra": "elas" },
        { "hebraico": "וַיֹּ֥אמֶר", "transliteral": "wayyōʾmer", "traducao_palavra": "e disse" },
        { "hebraico": "לֹ֖ו", "transliteral": "lô", "traducao_palavra": "lhe" },
        { "hebraico": "כֹּ֥ה", "transliteral": "kōh", "traducao_palavra": "assim" },
        { "hebraico": "יִהְיֶ֥ה", "transliteral": "yihyeh", "traducao_palavra": "será" },
        { "hebraico": "זַרְעֶֽךָ׃", "transliteral": "zarʿeḵā", "traducao_palavra": "tua semente" }
      ]
