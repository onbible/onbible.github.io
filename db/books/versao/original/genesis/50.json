        { "hebraico": "לֵאמֹר׃", "transliteral": "lē-mōr", "traducao_palavra": "dizendo" }
      ]
    },
    "5": {
      "traducao_completa": "Meu pai me fez jurar, dizendo: Eis que eu morro; na minha sepultura, que cavei para mim na terra de Canaã, ali me sepultarás. Agora, pois, subirei eu, peço-te, e sepultarei meu pai, e voltarei.",
      "palavras": [
        { "hebraico": "אָבִי", "transliteral": "ʾā-ḇî", "traducao_palavra": "meu pai" },
        { "hebraico": "הִשְׁבִּיעַנִי", "transliteral": "hiš-bî-ʿa-nî", "traducao_palavra": "fez-me jurar" },
        { "hebraico": "לֵאמֹר", "transliteral": "lē-mōr", "traducao_palavra": "dizendo" },
        { "hebraico": "הִנֵּה", "transliteral": "hin-nēh", "traducao_palavra": "eis" },
        { "hebraico": "אָנֹכִי", "transliteral": "ʾā-nō-ḵî", "traducao_palavra": "eu" },
        { "hebraico": "מֵת", "transliteral": "mēṯ", "traducao_palavra": "morrendo" },
        { "hebraico": "בְּקִבְרִי", "transliteral": "bə-qiḇ-rî", "traducao_palavra": "na minha sepultura" },
        { "hebraico": "אֲשֶׁר", "transliteral": "ʾă-šer", "traducao_palavra": "que" },
        { "hebraico": "כָּרִיתִי", "transliteral": "kā-rî-ṯî", "traducao_palavra": "cavei" },
