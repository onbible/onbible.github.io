        { "hebraico": "מִצְרָיִם׃", "transliteral": "miṣ-rā-yim", "traducao_palavra": "Egito" }
      ]
    },
    "8": {
      "traducao_completa": "Como também toda a casa de José, e os seus irmãos, e a casa de seu pai; somente os seus pequeninos, e as suas ovelhas, e as suas vacas deixaram na terra de Gósen.",
      "palavras": [
        { "hebraico": "וְכֹל", "transliteral": "wə-ḵōl", "traducao_palavra": "e toda" },
        { "hebraico": "בֵּית", "transliteral": "bêṯ", "traducao_palavra": "casa de" },
        { "hebraico": "יוֹסֵף", "transliteral": "yô-sēp̄", "traducao_palavra": "José" },
        { "hebraico": "וְאֶחָיו", "transliteral": "wə-ʾe-ḥāw", "traducao_palavra": "e seus irmãos" },
        { "hebraico": "וּבֵית", "transliteral": "û-ḇêṯ", "traducao_palavra": "e casa de" },
