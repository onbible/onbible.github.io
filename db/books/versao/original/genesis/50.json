        { "hebraico": "בְּגֹרֶן", "transliteral": "bə-ḡō-ren", "traducao_palavra": "na eira de" },
        { "hebraico": "הָאָטָד", "transliteral": "hā-ʾā-ṭāḏ", "traducao_palavra": "Atade" },
        { "hebraico": "וַיֹּאמְרוּ", "transliteral": "way-yō-mərû", "traducao_palavra": "e disseram" },
        { "hebraico": "אֵבֶל־כָּבֵד", "transliteral": "ʾē-ḇel-kā-ḇēḏ", "traducao_palavra": "luto pesado" },
        { "hebraico": "זֶה", "transliteral": "zeh", "traducao_palavra": "[é] este" },
        { "hebraico": "לְמִצְרָיִם", "transliteral": "lə-miṣ-rā-yim", "traducao_palavra": "para os egípcios" },
        { "hebraico": "עַל־כֵּן", "transliteral": "ʿal-kēn", "traducao_palavra": "por isso" },
        { "hebraico": "קָרָא", "transliteral": "qā-rā", "traducao_palavra": "chamou-se" },
        { "hebraico": "שְׁמָהּ", "transliteral": "šə-māh", "traducao_palavra": "seu nome" },
        { "hebraico": "אָבֵל מִצְרַיִם", "transliteral": "ʾā-ḇēl miṣ-ra-yim", "traducao_palavra": "Abel-Mizraim" },
        { "hebraico": "אֲשֶׁר", "transliteral": "ʾă-šer", "traducao_palavra": "que [está]" },
        { "hebraico": "בְּעֵבֶר", "transliteral": "bə-ʿē-ḇer", "traducao_palavra": "além de" },
        { "hebraico": "הַיַּרְדֵּן׃", "transliteral": "hay-yar-dēn", "traducao_palavra": "o Jordão" }
      ]
    },
    "12": {
      "traducao_completa": "E fizeram-lhe os seus filhos assim como ele lhes ordenara.",
      "palavras": [
        { "hebraico": "וַיַּעֲשׂוּ", "transliteral": "way-ya-ʿă-śû", "traducao_palavra": "e fizeram" },
        { "hebraico": "בָנָיו", "transliteral": "ḇā-nāw", "traducao_palavra": "seus filhos" },
        { "hebraico": "לוֹ", "transliteral": "lô", "traducao_palavra": "a ele" },
        { "hebraico": "כֵּן", "transliteral": "kēn", "traducao_palavra": "assim" },
        { "hebraico": "כַּאֲשֶׁר", "transliteral": "ka-ʾă-šer", "traducao_palavra": "conforme" },
        { "hebraico": "צִוָּם׃", "transliteral": "ṣiw-wām", "traducao_palavra": "ordenara a eles" }
      ]
    },
    "13": {
      "traducao_completa": "Pois os seus filhos o levaram à terra de Canaã, e o sepultaram na caverna do campo de Macpela, a qual Abraão comprara com o campo para possessão de sepultura, de Efrom, o hitita, diante de Manre.",
      "palavras": [
