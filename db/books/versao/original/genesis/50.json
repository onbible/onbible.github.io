        { "hebraico": "אֹתוֹ", "transliteral": "ʾō-ṯô", "traducao_palavra": "a ele" },
        { "hebraico": "בָנָיו", "transliteral": "ḇā-nāw", "traducao_palavra": "seus filhos" },
        { "hebraico": "אַרְצָה", "transliteral": "ʾār-ṣā", "traducao_palavra": "[à] terra de" },
        { "hebraico": "כְּנַעַן", "transliteral": "kə-na-ʿan", "traducao_palavra": "Canaã" },
        { "hebraico": "וַיִּקְבְּרוּ", "transliteral": "way-yiq-bə-rû", "traducao_palavra": "e sepultaram" },
        { "hebraico": "אֹתוֹ", "transliteral": "ʾō-ṯô", "traducao_palavra": "a ele" },
        { "hebraico": "בִּמְעָרַת", "transliteral": "bim-ʿā-raṯ", "traducao_palavra": "na caverna de" },
        { "hebraico": "שְׂדֵה", "transliteral": "śə-ḏēh", "traducao_palavra": "campo de" },
        { "hebraico": "הַמַּכְפֵּלָה", "transliteral": "ham-maḵ-pē-lā", "traducao_palavra": "Macpela" },
        { "hebraico": "אֲשֶׁר", "transliteral": "ʾă-šer", "traducao_palavra": "que" },
        { "hebraico": "קָנָה", "transliteral": "qā-nā", "traducao_palavra": "comprara" },
        { "hebraico": "אַבְרָהָם", "transliteral": "ʾaḇ-rā-hām", "traducao_palavra": "Abraão" },
        { "hebraico": "אֶת־הַשָּׂדֶה", "transliteral": "ʾeṯ-haś-śā-ḏeh", "traducao_palavra": "o campo" },
        { "hebraico": "לַאֲחֻזַּת־קֶבֶר", "transliteral": "la-ʾă-ḥuz-zaṯ-qe-ḇer", "traducao_palavra": "para possessão de sepultura" },
        { "hebraico": "מֵאֵת", "transliteral": "mē-ʾēṯ", "traducao_palavra": "de" },
        { "hebraico": "עֶפְרֹן", "transliteral": "ʿep̄-rōn", "traducao_palavra": "Efrom" },
        { "hebraico": "הַחִתִּי", "transliteral": "ha-ḥit-tî", "traducao_palavra": "o hitita" },
        { "hebraico": "עַל־פְּנֵי", "transliteral": "ʿal-pə-nê", "traducao_palavra": "diante de" },
        { "hebraico": "מַמְרֵא׃", "transliteral": "mam-rē", "traducao_palavra": "Manre" }
      ]
    },
    "14": {
      "traducao_completa": "E voltou José ao Egito, ele e seus irmãos, e todos os que subiram com ele para sepultar o seu pai, depois de haver sepultado o seu pai.",
      "palavras": [
        { "hebraico": "וַיָּשָׁב", "transliteral": "way-yā-šāḇ", "traducao_palavra": "e voltou" },
        { "hebraico": "יוֹסֵף", "transliteral": "yô-sēp̄", "traducao_palavra": "José" },
        { "hebraico": "מִצְרַיְמָה", "transliteral": "miṣ-ray-mā", "traducao_palavra": "[ao] Egito" },
        { "hebraico": "הוּא", "transliteral": "hû", "traducao_palavra": "ele" },
        { "hebraico": "וְאֶחָיו", "transliteral": "wə-ʾe-ḥāw", "traducao_palavra": "e seus irmãos" },
        { "hebraico": "וְכָל־הָעֹלִים", "transliteral": "wə-ḵāl-hā-ʿō-lîm", "traducao_palavra": "e todos os subindo" },
        { "hebraico": "אִתּוֹ", "transliteral": "ʾit-tô", "traducao_palavra": "com ele" },
        { "hebraico": "לִקְבֹּר", "transliteral": "liq-bōr", "traducao_palavra": "para sepultar" },
        { "hebraico": "אֶת־אָבִיו", "transliteral": "ʾeṯ-ʾā-ḇîw", "traducao_palavra": "a seu pai" },
        { "hebraico": "אַחֲרֵי", "transliteral": "ʾa-ḥă-rê", "traducao_palavra": "depois de" },
        { "hebraico": "קָבְרוֹ", "transliteral": "qā-ḇə-rô", "traducao_palavra": "seu sepultar" },
        { "hebraico": "אֶת־אָבִיו׃", "transliteral": "ʾeṯ-ʾā-ḇîw", "traducao_palavra": "a seu pai" }
      ]
    },
    "15": {
      "traducao_completa": "E viram os irmãos de José que seu pai morrera, e disseram: Talvez José nos guarde rancor e certamente nos retribua todo o mal que lhe fizemos.",
      "palavras": [
        { "hebraico": "וַיִּרְאוּ", "transliteral": "way-yir-ʾû", "traducao_palavra": "e viram" },
        { "hebraico": "אֲחֵי־יוֹסֵף", "transliteral": "ʾă-ḥê-yô-sēp̄", "traducao_palavra": "os irmãos de José" },
        { "hebraico": "כִּי־מֵת", "transliteral": "kî-mēṯ", "traducao_palavra": "que morrera" },
        { "hebraico": "אֲבִיהֶם", "transliteral": "ʾă-ḇî-hem", "traducao_palavra": "o pai deles" },
        { "hebraico": "וַיֹּאמְרוּ", "transliteral": "way-yō-mərû", "traducao_palavra": "e disseram" },
        { "hebraico": "לוּ", "transliteral": "lû", "traducao_palavra": "talvez/se" },
        { "hebraico": "יִשְׂטְמֵנוּ", "transliteral": "yiś-ṭə-mê-nû", "traducao_palavra": "nos odeie/guarde rancor" },
        { "hebraico": "יוֹסֵף", "transliteral": "yô-sēp̄", "traducao_palavra": "José" },
        { "hebraico": "וְהָשֵׁב", "transliteral": "wə-hā-šēḇ", "traducao_palavra": "e retribuindo" },
        { "hebraico": "יָשִׁיב", "transliteral": "yā-šîḇ", "traducao_palavra": "retribua" },
        { "hebraico": "לָנוּ", "transliteral": "lā-nû", "traducao_palavra": "a nós" },
        { "hebraico": "אֵת", "transliteral": "ʾēṯ", "traducao_palavra": "[objeto]" },
        { "hebraico": "כָּל־הָרָעָה", "transliteral": "kāl-hā-rā-ʿā", "traducao_palavra": "todo o mal" },
        { "hebraico": "אֲשֶׁר", "transliteral": "ʾă-šer", "traducao_palavra": "que" },
        { "hebraico": "גָּמַלְנוּ", "transliteral": "gā-mal-nû", "traducao_palavra": "fizemos/causamos" },
        { "hebraico": "אֹתוֹ׃", "transliteral": "ʾō-ṯô", "traducao_palavra": "a ele" }
      ]
    },
    "16": {
      "traducao_completa": "E mandaram dizer a José: Teu pai ordenou antes da sua morte, dizendo:",
      "palavras": [
        { "hebraico": "וַיְצַוּוּ", "transliteral": "way-ṣaw-wû", "traducao_palavra": "e ordenaram/mandaram" },
        { "hebraico": "אֶל־יוֹסֵף", "transliteral": "ʾel-yô-sēp̄", "traducao_palavra": "a José" },
        { "hebraico": "לֵאמֹר", "transliteral": "lē-mōr", "traducao_palavra": "dizendo" },
        { "hebraico": "אָבִיךָ", "transliteral": "ʾā-ḇî-ḵā", "traducao_palavra": "teu pai" },
        { "hebraico": "צִוָּה", "transliteral": "ṣiw-wā", "traducao_palavra": "ordenou" },
        { "hebraico": "לִפְנֵי", "transliteral": "lip̄-nê", "traducao_palavra": "antes de" },
        { "hebraico": "מוֹתוֹ", "transliteral": "mô-ṯô", "traducao_palavra": "sua morte" },
        { "hebraico": "לֵאמֹר׃", "transliteral": "lē-mōr", "traducao_palavra": "dizendo" }
      ]
    },
    "17": {
      "traducao_completa": "Assim direis a José: Rogo-te, perdoa a transgressão de teus irmãos e o seu pecado, porque te fizeram mal; agora, pois, perdoa a transgressão dos servos do Deus de teu pai. E José chorou quando lhe falavam.",
      "palavras": [
        { "hebraico": "כֹּה־תֹאמְרוּ", "transliteral": "kō-ṯō-mərû", "traducao_palavra": "assim direis" },
        { "hebraico": "לְיוֹסֵף", "transliteral": "lə-yô-sēp̄", "traducao_palavra": "a José" },
        { "hebraico": "אָנָּא", "transliteral": "ʾān-nā", "traducao_palavra": "rogo-te" },
        { "hebraico": "שָׂא", "transliteral": "śā", "traducao_palavra": "perdoa/levanta" },
        { "hebraico": "נָא", "transliteral": "nā", "traducao_palavra": "peço" },
        { "hebraico": "פֶּשַׁע", "transliteral": "pe-šaʿ", "traducao_palavra": "[a] transgressão de" },
        { "hebraico": "אַחֶיךָ", "transliteral": "ʾa-ḥe-ḵā", "traducao_palavra": "teus irmãos" },
        { "hebraico": "וְחַטָּאתָם", "transliteral": "wə-ḥaṭ-ṭā-ṯām", "traducao_palavra": "e o pecado deles" },
        { "hebraico": "כִּי־רָעָה", "transliteral": "kî-rā-ʿā", "traducao_palavra": "porque mal" },
        { "hebraico": "גְמָלוּךָ", "transliteral": "gə-mā-lû-ḵā", "traducao_palavra": "fizeram a ti" },
        { "hebraico": "וְעַתָּה", "transliteral": "wə-ʿat-tā", "traducao_palavra": "e agora" },
        { "hebraico": "שָׂא", "transliteral": "śā", "traducao_palavra": "perdoa" },
        { "hebraico": "נָא", "transliteral": "nā", "traducao_palavra": "peço" },
        { "hebraico": "לְפֶּשַׁע", "transliteral": "lə-pe-šaʿ", "traducao_palavra": "a transgressão de" },
        { "hebraico": "עַבְדֵי", "transliteral": "ʿaḇ-ḏê", "traducao_palavra": "[os] servos de" },
        { "hebraico": "אֱלֹהֵי", "transliteral": "ʾĕ-lō-hê", "traducao_palavra": "Deus de" },
        { "hebraico": "אָבִיךָ", "transliteral": "ʾā-ḇî-ḵā", "traducao_palavra": "teu pai" },
        { "hebraico": "וַיֵּבְךְּ", "transliteral": "way-yē-ḇək", "traducao_palavra": "e chorou" },
        { "hebraico": "יוֹסֵף", "transliteral": "yô-sēp̄", "traducao_palavra": "José" },
        { "hebraico": "בְּדַבְּרָם", "transliteral": "bə-ḏab-bə-rām", "traducao_palavra": "ao falarem eles" },
        { "hebraico": "אֵלָיו׃", "transliteral": "ʾē-lāw", "traducao_palavra": "a ele" }
      ]
    },
    "18": {
      "traducao_completa": "E vieram também seus irmãos e prostraram-se diante dele, e disseram: Eis que somos teus servos.",
      "palavras": [
        { "hebraico": "וַיֵּלְכוּ", "transliteral": "way-yê-lə-ḵû", "traducao_palavra": "e foram/vieram" },
        { "hebraico": "גַּם־אֶחָיו", "transliteral": "gam-ʾe-ḥāw", "traducao_palavra": "também seus irmãos" },
        { "hebraico": "וַיִּפְּלוּ", "transliteral": "way-yip-pə-lû", "traducao_palavra": "e caíram/prostraram-se" },
        { "hebraico": "לְפָנָיו", "transliteral": "lə-p̄ā-nāw", "traducao_palavra": "diante dele" },
        { "hebraico": "וַיֹּאמְרוּ", "transliteral": "way-yō-mərû", "traducao_palavra": "e disseram" },
        { "hebraico": "הִנֶּנּוּ", "transliteral": "hin-nen-nû", "traducao_palavra": "eis-nos" },
        { "hebraico": "לְךָ", "transliteral": "lə-ḵā", "traducao_palavra": "a ti" },
        { "hebraico": "לַעֲבָדִים׃", "transliteral": "la-ʿă-ḇā-ḏîm", "traducao_palavra": "por servos" }
      ]
    },
    "19": {
      "traducao_completa": "E disse-lhes José: Não temais; acaso estou eu no lugar de Deus?",
      "palavras": [
        { "hebraico": "וַיֹּאמֶר", "transliteral": "way-yō-mer", "traducao_palavra": "e disse" },
        { "hebraico": "אֲלֵהֶם", "transliteral": "ʾă-lē-hem", "traducao_palavra": "a eles" },
        { "hebraico": "יוֹסֵף", "transliteral": "yô-sēp̄", "traducao_palavra": "José" },
        { "hebraico": "אַל־תִּירָאוּ", "transliteral": "ʾal-tî-rā-ʾû", "traducao_palavra": "não temais" },
        { "hebraico": "כִּי", "transliteral": "kî", "traducao_palavra": "pois" },
        { "hebraico": "הֲתַחַת", "transliteral": "hă-ṯa-ḥaṯ", "traducao_palavra": "acaso em lugar de" },
        { "hebraico": "אֱלֹהִים", "transliteral": "ʾĕ-lō-hîm", "traducao_palavra": "Deus" },
        { "hebraico": "אָנִי׃", "transliteral": "ʾā-nî", "traducao_palavra": "[estou] eu?" }
      ]
    },
    "20": {
      "traducao_completa": "Vós, na verdade, intentastes mal contra mim; Deus intentou para o bem, para fazer como se vê neste dia, para preservar a vida de um povo numeroso.",
      "palavras": [
        { "hebraico": "וְאַתֶּם", "transliteral": "wə-ʾat-tem", "traducao_palavra": "e vós" },
        { "hebraico": "חֲשַׁבְתֶּם", "transliteral": "ḥă-šaḇ-tem", "traducao_palavra": "pensastes/intentastes" },
        { "hebraico": "עָלַי", "transliteral": "ʿā-lay", "traducao_palavra": "contra mim" },
        { "hebraico": "רָעָה", "transliteral": "rā-ʿā", "traducao_palavra": "mal" },
        { "hebraico": "אֱלֹהִים", "transliteral": "ʾĕ-lō-hîm", "traducao_palavra": "Deus" },
        { "hebraico": "חֲשָׁבָהּ", "transliteral": "ḥă-šā-ḇāh", "traducao_palavra": "intentou-o" },
        { "hebraico": "לְטֹבָה", "transliteral": "lə-ṭō-ḇā", "traducao_palavra": "para o bem" },
        { "hebraico": "לְמַעַן", "transliteral": "lə-ma-ʿan", "traducao_palavra": "para" },
        { "hebraico": "עֲשֹׂה", "transliteral": "ʿă-śō", "traducao_palavra": "fazer" },
        { "hebraico": "כַּיּוֹם", "transliteral": "kay-yôm", "traducao_palavra": "como [neste] dia" },
        { "hebraico": "הַזֶּה", "transliteral": "haz-zeh", "traducao_palavra": "este" },
        { "hebraico": "לְהַחֲיֹת", "transliteral": "lə-ha-ḥă-yōṯ", "traducao_palavra": "para preservar/vivificar" },
        { "hebraico": "עַם־רָב׃", "transliteral": "ʿam-rāḇ", "traducao_palavra": "um povo numeroso" }
      ]
    },
    "21": {
      "traducao_completa": "Agora, pois, não temais; eu vos sustentarei, a vós e a vossos pequeninos. Assim os consolou e falou ao coração deles.",
      "palavras": [
        { "hebraico": "וְעַתָּה", "transliteral": "wə-ʿat-tā", "traducao_palavra": "e agora" },
        { "hebraico": "אַל־תִּירָאוּ", "transliteral": "ʾal-tî-rā-ʾû", "traducao_palavra": "não temais" },
        { "hebraico": "אָנֹכִי", "transliteral": "ʾā-nō-ḵî", "traducao_palavra": "eu" },
        { "hebraico": "אֲכַלְכֵּל", "transliteral": "ʾă-ḵal-kēl", "traducao_palavra": "sustentarei" },
        { "hebraico": "אֶתְכֶם", "transliteral": "ʾeṯ-kem", "traducao_palavra": "a vós" },
        { "hebraico": "וְאֶת־טַפְּכֶם", "transliteral": "wə-ʾeṯ-ṭap-pə-ḵem", "traducao_palavra": "e vossos pequeninos" },
        { "hebraico": "וַיְנַחֵם", "transliteral": "way-na-ḥēm", "traducao_palavra": "e consolou" },
        { "hebraico": "אוֹתָם", "transliteral": "ʾô-ṯām", "traducao_palavra": "a eles" },
        { "hebraico": "וַיְדַבֵּר", "transliteral": "way-ḏab-bēr", "traducao_palavra": "e falou" },
        { "hebraico": "עַל־לִבָּם׃", "transliteral": "ʿal-lib-bām", "traducao_palavra": "sobre o coração deles" }
      ]
    },
    "22": {
      "traducao_completa": "E habitou José no Egito, ele e a casa de seu pai; e viveu José cento e dez anos.",
      "palavras": [
        { "hebraico": "וַיֵּשֶׁב", "transliteral": "way-yē-šeḇ", "traducao_palavra": "e habitou" },
