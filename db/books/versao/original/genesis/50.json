        { "hebraico": "יִמְלְאוּ", "transliteral": "yim-lə-ʾû", "traducao_palavra": "se cumprem" },
        { "hebraico": "יְמֵי", "transliteral": "yə-mê", "traducao_palavra": "dias de" },
        { "hebraico": "הַחֲנֻטִים", "transliteral": "ha-ḥă-nu-ṭîm", "traducao_palavra": "os embalsamados" },
        { "hebraico": "וַיִּבְכּוּ", "transliteral": "way-yiḇ-kû", "traducao_palavra": "e choraram" },
        { "hebraico": "אֹתוֹ", "transliteral": "ʾō-ṯô", "traducao_palavra": "a ele" },
        { "hebraico": "מִצְרַיִם", "transliteral": "miṣ-ra-yim", "traducao_palavra": "egípcios" },
        { "hebraico": "שִׁבְעִים", "transliteral": "šiḇ-ʿîm", "traducao_palavra": "setenta" },
        { "hebraico": "יוֹם׃", "transliteral": "yôm", "traducao_palavra": "dia" }
      ]
    },
    "4": {
      "traducao_completa": "E passados os dias de seu choro, falou José à casa de Faraó, dizendo: Se agora achei graça em vossos olhos, falai, peço-vos, aos ouvidos de Faraó, dizendo:",
      "palavras": [
        { "hebraico": "וַיַּעַבְרוּ", "transliteral": "way-ya-ʿaḇ-rû", "traducao_palavra": "e passaram" },
        { "hebraico": "יְמֵי", "transliteral": "yə-mê", "traducao_palavra": "dias de" },
        { "hebraico": "בְכִיתוֹ", "transliteral": "ḇə-ḵî-ṯô", "traducao_palavra": "seu choro" },
        { "hebraico": "וַיְדַבֵּר", "transliteral": "way-ḏab-bēr", "traducao_palavra": "e falou" },
        { "hebraico": "יוֹסֵף", "transliteral": "yô-sēp̄", "traducao_palavra": "José" },
        { "hebraico": "אֶל־בֵּית", "transliteral": "ʾel-bêṯ", "traducao_palavra": "à casa de" },
        { "hebraico": "פַּרְעֹה", "transliteral": "par-ʿōh", "traducao_palavra": "Faraó" },
        { "hebraico": "לֵאמֹר", "transliteral": "lē-mōr", "traducao_palavra": "dizendo" },
        { "hebraico": "אִם־נָא", "transliteral": "ʾim-nā", "traducao_palavra": "se agora" },
        { "hebraico": "מָצָאתִי", "transliteral": "mā-ṣā-ṯî", "traducao_palavra": "achei" },
        { "hebraico": "חֵן", "transliteral": "ḥēn", "traducao_palavra": "graça" },
        { "hebraico": "בְּעֵינֵיכֶם", "transliteral": "bə-ʿê-nê-ḵem", "traducao_palavra": "em vossos olhos" },
        { "hebraico": "דַּבְּרוּ־נָא", "transliteral": "dab-bə-rû-nā", "traducao_palavra": "falai peço" },
        { "hebraico": "בְּאָזְנֵי", "transliteral": "bə-ʾā-zə-nê", "traducao_palavra": "nos ouvidos de" },
