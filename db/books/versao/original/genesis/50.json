        { "hebraico": "וְאָשׁוּבָה׃", "transliteral": "wə-ʾā-šû-ḇā", "traducao_palavra": "e voltarei" }
      ]
    },
    "6": {
      "traducao_completa": "E disse Faraó: Sobe e sepulta o teu pai, como ele te fez jurar.",
      "palavras": [
        { "hebraico": "וַיֹּאמֶר", "transliteral": "way-yō-mer", "traducao_palavra": "e disse" },
        { "hebraico": "פַּרְעֹה", "transliteral": "par-ʿōh", "traducao_palavra": "Faraó" },
        { "hebraico": "עֲלֵה", "transliteral": "ʿă-lēh", "traducao_palavra": "suba" },
        { "hebraico": "וּקְבֹר", "transliteral": "û-qə-ḇōr", "traducao_palavra": "e sepulta" },
        { "hebraico": "אֶת־אָבִיךָ", "transliteral": "ʾeṯ-ʾā-ḇî-ḵā", "traducao_palavra": "a teu pai" },
        { "hebraico": "כַּאֲשֶׁר", "transliteral": "ka-ʾă-šer", "traducao_palavra": "conforme" },
        { "hebraico": "הִשְׁבִּיעֶךָ׃", "transliteral": "hiš-bî-ʿe-ḵā", "traducao_palavra": "fez-te jurar" }
      ]
    },
    "7": {
      "traducao_completa": "E subiu José para sepultar o seu pai; e subiram com ele todos os servos de Faraó, os anciãos da sua casa, e todos os anciãos da terra do Egito;",
      "palavras": [
        { "hebraico": "וַיַּעַל", "transliteral": "way-ya-ʿal", "traducao_palavra": "e subiu" },
        { "hebraico": "יוֹסֵף", "transliteral": "yô-sēp̄", "traducao_palavra": "José" },
        { "hebraico": "לִקְבֹּר", "transliteral": "liq-bōr", "traducao_palavra": "para sepultar" },
        { "hebraico": "אֶת־אָבִיו", "transliteral": "ʾeṯ-ʾā-ḇîw", "traducao_palavra": "a seu pai" },
