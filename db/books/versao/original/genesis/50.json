    "9": {
      "traducao_completa": "E subiram com ele tanto carros como cavaleiros; e o acampamento foi muito grande.",
      "palavras": [
        { "hebraico": "וַיַּעַל", "transliteral": "way-ya-ʿal", "traducao_palavra": "e subiu" },
        { "hebraico": "עִמּוֹ", "transliteral": "ʿim-mô", "traducao_palavra": "com ele" },
        { "hebraico": "גַּם־רֶכֶב", "transliteral": "gam-re-ḵeḇ", "traducao_palavra": "tanto carro" },
        { "hebraico": "גַּם־פָּרָשִׁים", "transliteral": "gam-pā-rā-šîm", "traducao_palavra": "como cavaleiros" },
        { "hebraico": "וַיְהִי", "transliteral": "way-hî", "traducao_palavra": "e foi" },
        { "hebraico": "הַמַּחֲנֶה", "transliteral": "ham-ma-ḥă-neh", "traducao_palavra": "o acampamento" },
        { "hebraico": "כָּבֵד", "transliteral": "kā-ḇēḏ", "traducao_palavra": "pesado [grande]" },
        { "hebraico": "מְאֹד׃", "transliteral": "mə-ʾōḏ", "traducao_palavra": "muito" }
      ]
    },
    "10": {
      "traducao_completa": "E vieram até à eira de Atade, que está além do Jordão, e prantearam ali um pranto grande e muito pesado; e ele fez a seu pai um luto de sete dias.",
      "palavras": [
        { "hebraico": "וַיָּבֹאוּ", "transliteral": "way-yā-ḇō-ʾû", "traducao_palavra": "e vieram" },
        { "hebraico": "עַד־גֹּרֶן", "transliteral": "ʿaḏ-gō-ren", "traducao_palavra": "até a eira de" },
        { "hebraico": "הָאָטָד", "transliteral": "hā-ʾā-ṭāḏ", "traducao_palavra": "Atade" },
