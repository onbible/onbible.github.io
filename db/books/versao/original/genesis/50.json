        { "hebraico": "פַרְעֹה", "transliteral": "p̄ar-ʿōh", "traducao_palavra": "Faraó" },
        { "hebraico": "זִקְנֵי", "transliteral": "ziq-nê", "traducao_palavra": "[os] anciãos de" },
