        { "hebraico": "יוֹשֵׁב", "transliteral": "yô-šēḇ", "traducao_palavra": "o habitante de" },
        { "hebraico": "הָאָרֶץ", "transliteral": "hā-ʾā-reṣ", "traducao_palavra": "a terra" },
        { "hebraico": "הַכְּנַעֲנִי", "transliteral": "hak-kə-na-ʿă-nî", "traducao_palavra": "o cananeu" },
