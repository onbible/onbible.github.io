{
  "livro": "Gênesis - בְּרֵאשִׁית - Bereshit",
  "capítulo": 50,
  "titulos": {},
  "versiculos": {
    "1": {
      "traducao_completa": "E caiu José sobre a face de seu pai, e chorou sobre ele, e o beijou.",
      "palavras": [
        { "hebraico": "וַיִּפֹּל", "transliteral": "way-yip-pōl", "traducao_palavra": "e caiu" },
        { "hebraico": "יוֹסֵף", "transliteral": "yô-sēp̄", "traducao_palavra": "José" },
        { "hebraico": "עַל־פְּנֵי", "transliteral": "ʿal-pə-nê", "traducao_palavra": "sobre a face de" },
        { "hebraico": "אָבִיו", "transliteral": "ʾā-ḇîw", "traducao_palavra": "seu pai" },
        { "hebraico": "וַיֵּבְךְּ", "transliteral": "way-yē-ḇək", "traducao_palavra": "e chorou" },
        { "hebraico": "עָלָיו", "transliteral": "ʿā-lāw", "traducao_palavra": "sobre ele" },
        { "hebraico": "וַיִּשַּׁק־לוֹ׃", "transliteral": "way-yiš-šaq-lô", "traducao_palavra": "e beijou a ele" }
      ]
    },
    "2": {
      "traducao_completa": "E ordenou José aos seus servos, os médicos, que embalsamassem a seu pai; e os médicos embalsamaram a Israel.",
      "palavras": [
        { "hebraico": "וַיְצַו", "transliteral": "way-ṣaw", "traducao_palavra": "e ordenou" },
        { "hebraico": "יוֹסֵף", "transliteral": "yô-sēp̄", "traducao_palavra": "José" },
        { "hebraico": "אֶת־עֲבָדָיו", "transliteral": "ʾeṯ-ʿă-ḇā-ḏāw", "traducao_palavra": "a seus servos" },
        { "hebraico": "אֶת־הָרֹפְאִים", "transliteral": "ʾeṯ-hā-rō-p̄ə-ʾîm", "traducao_palavra": "[os] médicos" },
        { "hebraico": "לַחֲנֹט", "transliteral": "la-ḥă-nōṭ", "traducao_palavra": "para embalsamar" },
        { "hebraico": "אֶת־אָבִיו", "transliteral": "ʾeṯ-ʾā-ḇîw", "traducao_palavra": "a seu pai" },
        { "hebraico": "וַיַּחַנְטוּ", "transliteral": "way-ya-ḥan-ṭû", "traducao_palavra": "e embalsamaram" },
        { "hebraico": "הָרֹפְאִים", "transliteral": "hā-rō-p̄ə-ʾîm", "traducao_palavra": "os médicos" },
        { "hebraico": "אֶת־יִשְׂרָאֵל׃", "transliteral": "ʾeṯ-yiś-rā-ʾēl", "traducao_palavra": "a Israel" }
      ]
    },
    "3": {
      "traducao_completa": "E cumpriram-se-lhe quarenta dias, porque assim se cumprem os dias dos embalsamados; e os egípcios o choraram setenta dias.",
      "palavras": [
        { "hebraico": "וַיִּמְלְאוּ־לוֹ", "transliteral": "way-yim-lə-ʾû-lô", "traducao_palavra": "e cumpriram-se para ele" },
        { "hebraico": "אַרְבָּעִים", "transliteral": "ʾar-bā-ʿîm", "traducao_palavra": "quarenta" },
        { "hebraico": "יוֹם", "transliteral": "yôm", "traducao_palavra": "dias" },
        { "hebraico": "כִּי", "transliteral": "kî", "traducao_palavra": "porque" },
