        { "hebraico": "רַק", "transliteral": "raq", "traducao_palavra": "somente" },
        { "hebraico": "טַפָּם", "transliteral": "ṭap-pām", "traducao_palavra": "seus pequeninos" },
        { "hebraico": "וְצֹאנָם", "transliteral": "wə-ṣō-nām", "traducao_palavra": "e seu rebanho" },
