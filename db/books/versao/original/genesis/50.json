        { "hebraico": "מִסְפֵּד", "transliteral": "mis-pēḏ", "traducao_palavra": "um pranto" },
        { "hebraico": "גָּדוֹל", "transliteral": "gā-ḏôl", "traducao_palavra": "grande" },
        { "hebraico": "וְכָבֵד", "transliteral": "wə-ḵā-ḇēḏ", "traducao_palavra": "e pesado" },
        { "hebraico": "מְאֹד", "transliteral": "mə-ʾōḏ", "traducao_palavra": "muito" },
        { "hebraico": "וַיַּעַשׂ", "transliteral": "way-ya-ʿaś", "traducao_palavra": "e ele fez" },
        { "hebraico": "לְאָבִיו", "transliteral": "lə-ʾā-ḇîw", "traducao_palavra": "para seu pai" },
        { "hebraico": "אֵבֶל", "transliteral": "ʾē-ḇel", "traducao_palavra": "luto de" },
        { "hebraico": "שִׁבְעַת", "transliteral": "šiḇ-ʿaṯ", "traducao_palavra": "sete de" },
        { "hebraico": "יָמִים׃", "transliteral": "yā-mîm", "traducao_palavra": "dias" }
      ]
    },
    "11": {
      "traducao_completa": "E vendo o morador da terra, o cananeu, o luto na eira de Atade, disseram: Luto pesado é este para os egípcios; por isso se chamou o seu nome Abel-Mizraim, que está além do Jordão.",
