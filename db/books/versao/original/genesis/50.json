        { "hebraico": "כְּנַעַן", "transliteral": "kə-na-ʿan", "traducao_palavra": "Canaã" },
        { "hebraico": "שָׁמָּה", "transliteral": "šām-mā", "traducao_palavra": "ali" },
        { "hebraico": "תִּקְבְּרֵנִי", "transliteral": "tiq-bə-rē-nî", "traducao_palavra": "sepultar-me-ás" },
        { "hebraico": "וְעַתָּה", "transliteral": "wə-ʿat-tāh", "traducao_palavra": "e agora" },
        { "hebraico": "אֶעֱלֶה־נָּא", "transliteral": "ʾe-ʿĕ-leh-nā", "traducao_palavra": "subirei eu peço" },
        { "hebraico": "וְאֶקְבְּרָה", "transliteral": "wə-ʾeq-bə-rā", "traducao_palavra": "e sepultarei" },
