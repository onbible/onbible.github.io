      ]
    },
    "6": {
      "traducao_completa": "Então se aproximaram as servas, elas e seus filhos, e inclinaram-se.",
      "palavras": [
        { "hebraico": "וַתִּגַּ֧שְׁןָ", "transliteral": "wa-tig-gaš-nā", "traducao_palavra": "então se aproximaram" },
