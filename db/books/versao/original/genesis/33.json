        { "hebraico": "הֵ֥נָּה", "transliteral": "hēn-nā", "traducao_palavra": "elas" },
        { "hebraico": "וְיַלְדֵיהֶ֖ן", "transliteral": "wĕ-yal-ḏê-hen", "traducao_palavra": "e seus filhos" },
        { "hebraico": "וַתִּשְׁתַּחֲוֶֽיןָ׃", "transliteral": "wa-tiš-ta-ḥă-we-nā", "traducao_palavra": "e inclinaram-se" }
      ]
    },
    "7": {
      "traducao_completa": "E aproximou-se também Lia com seus filhos e inclinaram-se; e depois aproximaram-se José e Raquel e inclinaram-se.",
      "palavras": [
        { "hebraico": "וַתִּגַּ֧שׁ", "transliteral": "wa-tig-gaš", "traducao_palavra": "e aproximou-se" },
