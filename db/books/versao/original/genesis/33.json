      ]
    },
    "8": {
      "traducao_completa": "E disse: Que te é todo este acampamento que encontrei? E ele disse: Para achar graça nos olhos do meu senhor.",
      "palavras": [
        { "hebraico": "וַיֹּ֕אמֶר", "transliteral": "wa-yō-mer", "traducao_palavra": "e disse" },
