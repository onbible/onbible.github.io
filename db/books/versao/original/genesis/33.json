        { "hebraico": "אֱלֹהִ֛ים", "transliteral": "ʾĔ-lō-hîm", "traducao_palavra": "Deus" },
        { "hebraico": "וַתִּרְצֵֽנִי׃", "transliteral": "wa-tir-ṣê-nî", "traducao_palavra": "e te agradaste de mim" }
      ]
    },
    "11": {
      "traducao_completa": "Recebe, peço-te, a minha bênção que te foi trazida; porque Deus me tem favorecido e porque tenho de tudo. E insistiu com ele, e ele a recebeu.",
