    },
    "5": {
      "traducao_completa": "E levantou seus olhos e viu as mulheres e os meninos, e disse: Quem são estes para ti? E ele disse: Os meninos que Deus graciosamente deu ao teu servo.",
      "palavras": [
        { "hebraico": "וַיִּשָּׂ֣א", "transliteral": "wa-yiś-śā", "traducao_palavra": "e levantou" },
        { "hebraico": "אֶת־", "transliteral": "ʾeṯ-", "traducao_palavra": "-" },
        { "hebraico": "עֵינָ֗יו", "transliteral": "ʿê-nāw", "traducao_palavra": "seus olhos" },
        { "hebraico": "וַיַּרְא֙", "transliteral": "wa-yar", "traducao_palavra": "e viu" },
        { "hebraico": "אֶת־", "transliteral": "ʾeṯ-", "traducao_palavra": "-" },
        { "hebraico": "הַנָּשִׁ֣ים", "transliteral": "ha-nā-šîm", "traducao_palavra": "as mulheres" },
        { "hebraico": "וְאֶת־", "transliteral": "wĕ-ʾeṯ-", "traducao_palavra": "e os" },
        { "hebraico": "הַיְלָדִ֔ים", "transliteral": "ha-yĕ-lā-ḏîm", "traducao_palavra": "meninos" },
        { "hebraico": "וַיֹּ֕אמֶר", "transliteral": "wa-yō-mer", "traducao_palavra": "e disse" },
        { "hebraico": "מִי־", "transliteral": "mî-", "traducao_palavra": "quem [são]" },
        { "hebraico": "אֵ֖לֶּה", "transliteral": "ʾēl-leh", "traducao_palavra": "estes" },
        { "hebraico": "לָּ֑ךְ", "transliteral": "lāḵ", "traducao_palavra": "para ti" },
        { "hebraico": "וַיֹּאמַ֕ר", "transliteral": "wa-yō-mar", "traducao_palavra": "e ele disse" },
        { "hebraico": "הַיְלָדִ֕ים", "transliteral": "ha-yĕ-lā-ḏîm", "traducao_palavra": "os meninos" },
        { "hebraico": "אֲשֶׁר־", "transliteral": "ʾă-šer-", "traducao_palavra": "que" },
        { "hebraico": "חָנַ֥ן", "transliteral": "ḥā-nan", "traducao_palavra": "graciosamente deu" },
        { "hebraico": "אֱלֹהִ֖ים", "transliteral": "ʾĔ-lō-hîm", "traducao_palavra": "Deus" },
        { "hebraico": "אֶת־", "transliteral": "ʾeṯ-", "traducao_palavra": "-" },
