        { "hebraico": "וַיַּ֧חַץ", "transliteral": "wa-ya-ḥaṣ", "traducao_palavra": "e ele dividiu" },
        { "hebraico": "אֶת־", "transliteral": "ʾeṯ-", "traducao_palavra": "[sinal de objeto direto]" },
        { "hebraico": "הַיְלָדִ֛ים", "transliteral": "ha-yĕ-lā-ḏîm", "traducao_palavra": "os filhos" },
