        { "hebraico": "וַיִּשְׁתַּחֲו֑וּ", "transliteral": "wa-yiš-ta-ḥă-wū", "traducao_palavra": "e inclinaram-se" },
        { "hebraico": "וְאַחַ֗ר", "transliteral": "wĕ-ʾa-ḥar", "traducao_palavra": "e depois" },
        { "hebraico": "נִגַּ֧שׁ", "transliteral": "nig-gaš", "traducao_palavra": "aproximou-se" },
        { "hebraico": "יוֹסֵ֛ף", "transliteral": "Yō-sēp̄", "traducao_palavra": "José" },
