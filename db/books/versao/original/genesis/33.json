        { "hebraico": "לֵאָ֥ה", "transliteral": "Lē-ʾāh", "traducao_palavra": "Lia" },
        { "hebraico": "וְעַל־", "transliteral": "wĕ-ʿal-", "traducao_palavra": "e sobre" },
        { "hebraico": "רָחֵ֖ל", "transliteral": "Rā-ḥēl", "traducao_palavra": "Raquel" },
        { "hebraico": "וְעַ֥ל", "transliteral": "wĕ-ʿal", "traducao_palavra": "e sobre" },
        { "hebraico": "שְׁתֵּ֥י", "transliteral": "šĕ-tê", "traducao_palavra": "as duas" },
        { "hebraico": "הַשְּׁפָחֽוֹת׃", "transliteral": "ha-šĕ-p̄ā-ḥōṯ", "traducao_palavra": "as servas" }
      ]
    },
    "2": {
      "traducao_completa": "E pôs as servas e seus filhos à frente, e Lia e seus filhos atrás, e Raquel e José por últimos.",
