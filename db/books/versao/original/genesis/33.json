        { "hebraico": "לְךָ֛", "transliteral": "lĕ-ḵā", "traducao_palavra": "para ti" },
        { "hebraico": "כָּל־", "transliteral": "kāl-", "traducao_palavra": "todo" },
        { "hebraico": "הַמַּחֲנֶ֥ה", "transliteral": "ha-ma-ḥă-neh", "traducao_palavra": "o acampamento" },
        { "hebraico": "הַזֶּ֖ה", "transliteral": "ha-zeh", "traducao_palavra": "este" },
        { "hebraico": "אֲשֶׁ֣ר", "transliteral": "ʾă-šer", "traducao_palavra": "que" },
        { "hebraico": "פָּגָ֑שְׁתִּי", "transliteral": "pā-ḡāš-tî", "traducao_palavra": "encontrei" },
        { "hebraico": "וַיֹּ֕אמֶר", "transliteral": "wa-yō-mer", "traducao_palavra": "e ele disse" },
        { "hebraico": "לִמְצֹא־", "transliteral": "lim-ṣō-", "traducao_palavra": "para achar" },
        { "hebraico": "חֵ֖ן", "transliteral": "ḥēn", "traducao_palavra": "graça" },
        { "hebraico": "בְּעֵינֵ֥י", "transliteral": "bĕ-ʿê-nê", "traducao_palavra": "nos olhos de" },
        { "hebraico": "אֲדֹנִֽי׃", "transliteral": "ʾă-ḏō-nî", "traducao_palavra": "meu senhor" }
      ]
    },
    "9": {
      "traducao_completa": "E disse Esaú: Tenho muito, meu irmão; seja para ti o que é teu.",
      "palavras": [
        { "hebraico": "וַיֹּ֥אמֶר", "transliteral": "wa-yō-mer", "traducao_palavra": "e disse" },
        { "hebraico": "עֵשָׂ֖ו", "transliteral": "ʿĒ-śāw", "traducao_palavra": "Esaú" },
        { "hebraico": "יֶשׁ־", "transliteral": "yeš-", "traducao_palavra": "tenho" },
        { "hebraico": "לִ֣י", "transliteral": "lî", "traducao_palavra": "para mim" },
        { "hebraico": "רָ֑ב", "transliteral": "rāḇ", "traducao_palavra": "muito" },
        { "hebraico": "אָחִ֕י", "transliteral": "ʾā-ḥî", "traducao_palavra": "meu irmão" },
        { "hebraico": "יְהִ֥י", "transliteral": "yĕ-hî", "traducao_palavra": "seja" },
        { "hebraico": "לְךָ֖", "transliteral": "lĕ-ḵā", "traducao_palavra": "para ti" },
        { "hebraico": "אֲשֶׁר־", "transliteral": "ʾă-šer-", "traducao_palavra": "o que [é]" },
        { "hebraico": "לָֽךְ׃", "transliteral": "lāḵ", "traducao_palavra": "teu" }
      ]
    },
    "10": {
      "traducao_completa": "E disse Jacó: Não, rogo-te; se agora achei graça em teus olhos, então recebe o meu presente da minha mão; porquanto vi o teu rosto, como quem vê o rosto de Deus, e te agradaste de mim.",
      "palavras": [
        { "hebraico": "וַיֹּ֣אמֶר", "transliteral": "wa-yō-mer", "traducao_palavra": "e disse" },
        { "hebraico": "יַעֲקֹ֗ב", "transliteral": "Ya-ʿă-qōḇ", "traducao_palavra": "Jacó" },
        { "hebraico": "אַל־", "transliteral": "ʾal-", "traducao_palavra": "não" },
        { "hebraico": "נָא֙", "transliteral": "nā", "traducao_palavra": "rogo-te" },
        { "hebraico": "אִם־", "transliteral": "ʾim-", "traducao_palavra": "se" },
        { "hebraico": "נָ֨א", "transliteral": "nā", "traducao_palavra": "agora" },
        { "hebraico": "מָצָ֤אתִי", "transliteral": "mā-ṣā-ṯî", "traducao_palavra": "achei" },
        { "hebraico": "חֵן֙", "transliteral": "ḥēn", "traducao_palavra": "graça" },
        { "hebraico": "בְּעֵינֶ֔יךָ", "transliteral": "bĕ-ʿê-ne-ḵā", "traducao_palavra": "em teus olhos" },
        { "hebraico": "וְלָקַחְתָּ֥", "transliteral": "wĕ-lā-qaḥ-tā", "traducao_palavra": "então recebe" },
        { "hebraico": "מִנְחָתִ֖י", "transliteral": "min-ḥā-ṯî", "traducao_palavra": "meu presente" },
        { "hebraico": "מִיָּדִ֑י", "transliteral": "mi-yā-dî", "traducao_palavra": "de minha mão" },
        { "hebraico": "כִּ֣י", "transliteral": "kî", "traducao_palavra": "porque" },
        { "hebraico": "עַל־", "transliteral": "ʿal-", "traducao_palavra": "sobre" },
        { "hebraico": "כֵּן֩", "transliteral": "kēn", "traducao_palavra": "isso" },
        { "hebraico": "רָאִ֨יתִי", "transliteral": "rā-ʾî-ṯî", "traducao_palavra": "vi" },
        { "hebraico": "פָנֶ֜יךָ", "transliteral": "pā-ne-ḵā", "traducao_palavra": "teu rosto" },
        { "hebraico": "כִּרְאֹ֨ת", "transliteral": "kir-ʾōṯ", "traducao_palavra": "como o ver de" },
