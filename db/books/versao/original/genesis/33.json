        { "hebraico": "שֶׁ֣בַע", "transliteral": "še-ḇaʿ", "traducao_palavra": "sete" },
        { "hebraico": "פְּעָמִ֔ים", "transliteral": "pĕ-ʿā-mîm", "traducao_palavra": "vezes" },
        { "hebraico": "עַד־", "transliteral": "ʿad-", "traducao_palavra": "até" },
        { "hebraico": "גִּשְׁתּ֖וֹ", "transliteral": "giš-tō", "traducao_palavra": "sua aproximação" },
        { "hebraico": "עַד־", "transliteral": "ʿad-", "traducao_palavra": "de" },
        { "hebraico": "אָחִֽיו׃", "transliteral": "ʾā-ḥîw", "traducao_palavra": "seu irmão" }
      ]
    },
    "4": {
      "traducao_completa": "E correu Esaú ao seu encontro e o abraçou, e caiu sobre o seu pescoço e o beijou; e choraram.",
