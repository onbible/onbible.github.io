    "20": {
      "traducao_completa": "E o homem deu nomes a todo o gado, e às aves dos céus, e a todo o animal do campo; mas para o homem não se achava ajuda que lhe fosse adequada.",
      "palavras": [
        { "hebraico": "וַיִּקְרָ֨א", "transliteral": "wayyiqrāʾ", "traducao_palavra": "E deu/chamou" },
        { "hebraico": "הָאָדָ֜ם", "transliteral": "hāʾāḏām", "traducao_palavra": "o homem" },
        { "hebraico": "שֵׁמ֗וֹת", "transliteral": "šēmôṯ", "traducao_palavra": "nomes" },
        { "hebraico": "לְכָל־הַבְּהֵמָה֙", "transliteral": "ləḵāl-habbəhēmâ", "traducao_palavra": "a todo o gado" },
