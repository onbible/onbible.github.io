        { "hebraico": "אֱלֹהִ֧ים", "transliteral": "ʾĕlōhîm", "traducao_palavra": "Deus" },
        { "hebraico": "תַּרְדֵּמָ֛ה", "transliteral": "ṯardēmâ", "traducao_palavra": "um sono profundo" },
        { "hebraico": "עַל־הָאָדָ֖ם", "transliteral": "ʿal-hāʾāḏām", "traducao_palavra": "sobre o homem" },
        { "hebraico": "וַיִּישָׁ֑ן", "transliteral": "wayyîšān", "traducao_palavra": "e ele dormiu" },
        { "hebraico": "וַיִּקַּ֗ח", "transliteral": "wayyiqqaḥ", "traducao_palavra": "e tomou" },
        { "hebraico": "אַחַת֙", "transliteral": "ʾaḥaṯ", "traducao_palavra": "uma de" },
        { "hebraico": "מִצַּלְעֹתָ֔יו", "transliteral": "miṣṣalʿōṯāyw", "traducao_palavra": "suas costelas" },
        { "hebraico": "וַיִּסְגֹּ֥ר", "transliteral": "wayyisgōr", "traducao_palavra": "e cerrou/fechou" },
        { "hebraico": "בָּשָׂ֖ר", "transliteral": "bāśār", "traducao_palavra": "carne" },
        { "hebraico": "תַּחְתֶּֽנָּה׃", "transliteral": "ṯaḥtennâ", "traducao_palavra": "embaixo dela/em seu lugar" }
      ]
    },
    "22": {
      "traducao_completa": "E da costela que o SENHOR Deus tomara do homem, formou uma mulher, e trouxe-a ao homem.",
