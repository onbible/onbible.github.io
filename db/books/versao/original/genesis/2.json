        { "hebraico": "וְאֵת֙", "transliteral": "wəʾēṯ", "traducao_palavra": "e [obj]" },
        { "hebraico": "כָּל־ע֣וֹף", "transliteral": "kāl-ʿôp̱", "traducao_palavra": "toda ave de" },
        { "hebraico": "הַשָּׁמַ֔יִם", "transliteral": "haššāmayim", "traducao_palavra": "os céus" },
        { "hebraico": "וַיָּבֵא֙", "transliteral": "wayyāḇēʾ", "traducao_palavra": "e trouxe" },
        { "hebraico": "אֶל־הָאָדָ֔ם", "transliteral": "ʾel-hāʾāḏām", "traducao_palavra": "ao homem" },
        { "hebraico": "לִרְא֖וֹת", "transliteral": "lirʾôṯ", "traducao_palavra": "para ver" },
        { "hebraico": "מַה־יִּקְרָא־ל֑וֹ", "transliteral": "mah-yyiqrā-llô", "traducao_palavra": "o que chamaria a ele" },
        { "hebraico": "וְכֹל֩", "transliteral": "wəḵōl", "traducao_palavra": "e tudo" },
