        { "hebraico": "אֱלֹהִ֧ים", "transliteral": "ʾĕlōhîm", "traducao_palavra": "Deus" },
        { "hebraico": "אֶת־הַצֵּלָ֛ע", "transliteral": "ʾeṯ-haṣṣēlāʿ", "traducao_palavra": "[obj] a costela" },
