        { "hebraico": "וּבָשָׂר֮", "transliteral": "ûḇāśār", "traducao_palavra": "e carne de" },
        { "hebraico": "מִבְּשָׂרִי֒", "transliteral": "mib-bəśārî", "traducao_palavra": "minha carne" },
        { "hebraico": "לְזֹאת֙", "transliteral": "ləzōʾṯ", "traducao_palavra": "para esta" },
