        { "hebraico": "אֲכָלְךָ֥", "transliteral": "ʾăḵāləḵā", "traducao_palavra": "em que comeres" },
        { "hebraico": "מִמֶּ֖נּוּ", "transliteral": "mimmennû", "traducao_palavra": "dele" },
        { "hebraico": "מ֥וֹת", "transliteral": "môṯ", "traducao_palavra": "morrendo" },
        { "hebraico": "תָּמֽוּת׃", "transliteral": "ṯāmûṯ", "traducao_palavra": "morrerás" }
