        { "hebraico": "הַפַּעַם֮", "transliteral": "happ-aʿam", "traducao_palavra": "agora/desta vez" },
        { "hebraico": "עֶ֣צֶם", "transliteral": "ʿeṣem", "traducao_palavra": "osso de" },
