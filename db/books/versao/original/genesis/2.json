        { "hebraico": "תֹּאכֵֽל׃", "transliteral": "ṯōʾḵēl", "traducao_palavra": "comerás" }
      ]
    },
    "17": {
      "traducao_completa": "Mas da árvore do conhecimento do bem e do mal, dela não comerás; porque no dia em que dela comeres, certamente morrerás.",
      "palavras": [
        { "hebraico": "וּמֵעֵ֗ץ", "transliteral": "ûmēʿēṣ", "traducao_palavra": "Mas da árvore de" },
        { "hebraico": "הַדַּ֙עַת֙", "transliteral": "had-daʿaṯ", "traducao_palavra": "o conhecimento" },
        { "hebraico": "ט֣וֹב", "transliteral": "ṭôḇ", "traducao_palavra": "bem" },
        { "hebraico": "וָרָ֔ע", "transliteral": "wārāʿ", "traducao_palavra": "e mal" },
        { "hebraico": "לֹ֥א", "transliteral": "lōʾ", "traducao_palavra": "não" },
        { "hebraico": "תֹאכַ֖ל", "transliteral": "ṯōʾḵal", "traducao_palavra": "comerás" },
        { "hebraico": "מִמֶּ֑נּוּ", "transliteral": "mimmennû", "traducao_palavra": "dele" },
        { "hebraico": "כִּ֗י", "transliteral": "kî", "traducao_palavra": "porque" },
