        { "hebraico": "אֱלֹהִ֔ים", "transliteral": "ʾĕlōhîm", "traducao_palavra": "Deus" },
        { "hebraico": "עַל־הָאָדָ֖ם", "transliteral": "ʿal-hāʾāḏām", "traducao_palavra": "sobre o homem" },
        { "hebraico": "לֵאמֹ֑ר", "transliteral": "lēʾmōr", "traducao_palavra": "dizendo" },
        { "hebraico": "מִכֹּ֥ל", "transliteral": "mikkōl", "traducao_palavra": "de toda" },
        { "hebraico": "עֵץ־הַגָּ֖ן", "transliteral": "ʿēṣ-haggān", "traducao_palavra": "árvore do jardim" },
