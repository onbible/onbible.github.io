        { "hebraico": "עֵ֖זֶר", "transliteral": "ʿēzer", "traducao_palavra": "uma ajuda" },
        { "hebraico": "כְּנֶגְדּֽוֹ׃", "transliteral": "kəneḡdô", "traducao_palavra": "que lhe corresponda" }
      ]
    },
    "19": {
      "traducao_completa": "E o SENHOR Deus formou da terra todo o animal do campo, e toda a ave dos céus, e os trouxe ao homem, para ver como lhes chamaria; e tudo o que o homem chamou a toda a alma vivente, isso foi o seu nome.",
      "palavras": [
