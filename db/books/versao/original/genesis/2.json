    "23": {
      "traducao_completa": "E disse o homem: Esta é agora osso dos meus ossos, e carne da minha carne; esta será chamada mulher, porquanto do homem foi tomada.",
      "palavras": [
        { "hebraico": "וַיֹּ֣אמֶר", "transliteral": "wayyōʾmer", "traducao_palavra": "E disse" },
        { "hebraico": "הָאָדָם֮", "transliteral": "hāʾāḏām", "traducao_palavra": "o homem" },
