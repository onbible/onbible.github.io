        { "hebraico": "מִן־הָאָדָ֖ם", "transliteral": "min-hāʾāḏām", "traducao_palavra": "do homem" },
        { "hebraico": "לְאִשָּׁ֑ה", "transliteral": "ləʾiššâ", "traducao_palavra": "para mulher" },
        { "hebraico": "וַיְבִאֶ֖הָ", "transliteral": "wayəḇiʾehā", "traducao_palavra": "e a trouxe" },
