        { "hebraico": "בַּיּ֣וֹם", "transliteral": "bayyôm", "traducao_palavra": "no dia" },
        { "hebraico": "הַשְּׁבִיעִ֔י", "transliteral": "haššəḇîʿî", "traducao_palavra": "sétimo" },
