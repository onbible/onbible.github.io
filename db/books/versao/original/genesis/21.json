        { "hebraico": "עִם־יִצְחָֽק׃", "transliteral": "ʿim-yiṣḥāq", "traducao_palavra": "com Isaque" }
      ]
    },
    "11": {
      "traducao_completa": "E pareceu esta palavra muito má aos olhos de Abraão, por causa de seu filho.",
      "palavras": [
        { "hebraico": "וַיֵּ֧רַע", "transliteral": "wayyēraʿ", "traducao_palavra": "E foi mau" },
