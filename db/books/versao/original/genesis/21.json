        { "hebraico": "אַבְרָהָ֣ם", "transliteral": "ʾaḇrāhām", "traducao_palavra": "Abraão" },
        { "hebraico": "בַּבֹּקֶר֮", "transliteral": "babbōqer", "traducao_palavra": "pela manhã" },
        { "hebraico": "וַיִּֽקַּֽח־לֶחֶם֮", "transliteral": "wayyiqqaḥ-leḥem", "traducao_palavra": "e tomou pão" },
        { "hebraico": "וְחֵ֣מַת מַיִם֮", "transliteral": "wəḥēmaṯ mayim", "traducao_palavra": "e um odre de água" },
        { "hebraico": "וַיִּתֵּ֣ן", "transliteral": "wayyittēn", "traducao_palavra": "e deu" },
        { "hebraico": "אֶל־הָגָר֒", "transliteral": "ʾel-hāḡār", "traducao_palavra": "a Agar" },
        { "hebraico": "שָׂ֧ם", "transliteral": "śām", "traducao_palavra": "pondo" },
        { "hebraico": "עַל־שִׁכְמָ֛הּ", "transliteral": "ʿal-šiḵəmāh", "traducao_palavra": "sobre seu ombro" },
        { "hebraico": "וְאֶת־הַיֶּ֖לֶד", "transliteral": "wəʾeṯ-hayyeleḏ", "traducao_palavra": "e [obj] o menino" },
        { "hebraico": "וַֽיְשַׁלְּחֶ֑הָ", "transliteral": "wayəšalləḥehā", "traducao_palavra": "e despediu-a" },
        { "hebraico": "וַתֵּ֣לֶךְ", "transliteral": "wattēleḵ", "traducao_palavra": "e ela foi" },
        { "hebraico": "וַתֵּ֔תַע", "transliteral": "wattēṯaʿ", "traducao_palavra": "e errou/vagou" },
        { "hebraico": "בְּמִדְבַּ֖ר", "transliteral": "bəmiḏbar", "traducao_palavra": "no deserto de" },
        { "hebraico": "בְּאֵ֥ר שָֽׁבַע׃", "transliteral": "bəʾēr šāḇaʿ", "traducao_palavra": "Berseba" }
