        { "hebraico": "הַשִּׂיחִֽם׃", "transliteral": "haśśîḥim", "traducao_palavra": "os arbustos" }
      ]
    },
    "16": {
      "traducao_completa": "E foi-se, e assentou-se defronte, afastando-se à distância de um tiro de arco; porque dizia: Que eu não veja morrer o menino. E assentou-se defronte, e levantou a sua voz, e chorou.",
      "palavras": [
        { "hebraico": "וַתֵּ֨לֶךְ", "transliteral": "wattēleḵ", "traducao_palavra": "E ela foi" },
        { "hebraico": "וַתֵּ֤שֶׁב", "transliteral": "wattēšeḇ", "traducao_palavra": "e assentou-se" },
        { "hebraico": "לָהּ֙", "transliteral": "lāh", "traducao_palavra": "para si" },
        { "hebraico": "מִנֶּ֔גֶד", "transliteral": "minneḡeḏ", "traducao_palavra": "defronte" },
        { "hebraico": "הַרְחֵק֙", "transliteral": "harḥēq", "traducao_palavra": "afastando-se" },
        { "hebraico": "כִּמְטַחֲוֵ֣י", "transliteral": "kimṭaḥăwê", "traducao_palavra": "como tiro de" },
        { "hebraico": "קֶ֔שֶׁת", "transliteral": "qešeṯ", "traducao_palavra": "arco" },
        { "hebraico": "כִּ֣י", "transliteral": "kî", "traducao_palavra": "pois" },
        { "hebraico": "אָמְרָ֔ה", "transliteral": "ʾāmərâ", "traducao_palavra": "disse" },
        { "hebraico": "אַל־אֶרְאֶ֖ה", "transliteral": "ʾal-ʾerʾeh", "traducao_palavra": "não veja eu" },
        { "hebraico": "בְּמֹ֣ות", "transliteral": "bəmôṯ", "traducao_palavra": "na morte de" },
        { "hebraico": "הַיָּ֑לֶד", "transliteral": "hayyāleḏ", "traducao_palavra": "o menino" },
        { "hebraico": "וַתֵּ֤שֶׁב", "transliteral": "wattēšeḇ", "traducao_palavra": "e assentou-se" },
        { "hebraico": "מִנֶּ֔גֶד", "transliteral": "minneḡeḏ", "traducao_palavra": "defronte" },
        { "hebraico": "וַתִּשָּׂ֥א", "transliteral": "wattiśśāʾ", "traducao_palavra": "e levantou" },
        { "hebraico": "אֶת־קֹלָ֖הּ", "transliteral": "ʾeṯ-qōlāh", "traducao_palavra": "[obj] sua voz" },
        { "hebraico": "וַתֵּֽבְךְּ׃", "transliteral": "wattēḇək", "traducao_palavra": "e chorou" }
      ]
    },
    "17": {
      "traducao_completa": "E ouviu Deus a voz do menino, e o anjo de Deus chamou a Agar desde os céus, e disse-lhe: Que tens, Agar? Não temas, porque Deus ouviu a voz do menino onde ele está.",
      "palavras": [
        { "hebraico": "וַיִּשְׁמַ֣ע", "transliteral": "wayyišmaʿ", "traducao_palavra": "E ouviu" },
        { "hebraico": "אֱלֹהִים֮", "transliteral": "ʾĕlōhîm", "traducao_palavra": "Deus" },
        { "hebraico": "אֶת־קֹ֣ול", "transliteral": "ʾeṯ-qôl", "traducao_palavra": "[obj] a voz de" },
        { "hebraico": "הַנַּעַר֒", "transliteral": "hannaʿar", "traducao_palavra": "o moço" },
        { "hebraico": "וַיִּקְרָא֩", "transliteral": "wayyiqrāʾ", "traducao_palavra": "e chamou" },
        { "hebraico": "מַלְאַ֨ךְ", "transliteral": "malʾaḵ", "traducao_palavra": "o anjo de" },
        { "hebraico": "אֱלֹהִ֤ים ׀", "transliteral": "ʾĕlōhîm", "traducao_palavra": "Deus" },
        { "hebraico": "אֶל־הָגָר֙", "transliteral": "ʾel-hāḡār", "traducao_palavra": "a Agar" },
        { "hebraico": "מִן־הַשָּׁמַ֔יִם", "transliteral": "min-haššāmayim", "traducao_palavra": "desde os céus" },
        { "hebraico": "וַיֹּ֥אמֶר", "transliteral": "wayyōʾmer", "traducao_palavra": "e disse" },
        { "hebraico": "לָ֖הּ", "transliteral": "lāh", "traducao_palavra": "lhe" },
        { "hebraico": "מַה־לָּ֣ךְ", "transliteral": "mah-llāḵ", "traducao_palavra": "Que tens" },
        { "hebraico": "הָגָ֑ר", "transliteral": "hāḡār", "traducao_palavra": "Agar?" },
        { "hebraico": "אַל־תִּ֣ירְאִ֔י", "transliteral": "ʾal-tîrəʾî", "traducao_palavra": "não temas" },
        { "hebraico": "כִּֽי־שָׁמַ֧ע", "transliteral": "kî-šāmaʿ", "traducao_palavra": "pois ouviu" },
        { "hebraico": "אֱלֹהִ֛ים", "transliteral": "ʾĕlōhîm", "traducao_palavra": "Deus" },
