    "12": {
      "traducao_completa": "Porém Deus disse a Abraão: Não te pareça mal aos teus olhos acerca do moço e acerca da tua serva; em tudo o que Sara te diz, ouve a sua voz; porque em Isaque será chamada a tua semente.",
      "palavras": [
        { "hebraico": "וַיֹּ֨אמֶר", "transliteral": "wayyōʾmer", "traducao_palavra": "E disse" },
        { "hebraico": "אֱלֹהִ֜ים", "transliteral": "ʾĕlōhîm", "traducao_palavra": "Deus" },
        { "hebraico": "אֶל־אַבְרָהָ֗ם", "transliteral": "ʾel-ʾaḇrāhām", "traducao_palavra": "a Abraão" },
        { "hebraico": "אַל־יֵרַ֤ע", "transliteral": "ʾal-yēraʿ", "traducao_palavra": "não seja mau" },
        { "hebraico": "בְּעֵינֶ֙יךָ֙", "transliteral": "bəʿêneyḵā", "traducao_palavra": "em teus olhos" },
        { "hebraico": "עַל־הַנַּ֣עַר", "transliteral": "ʿal-hannaʿar", "traducao_palavra": "sobre o moço" },
