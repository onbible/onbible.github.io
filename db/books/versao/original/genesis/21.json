        { "hebraico": "אֲשֶׁ֨ר", "transliteral": "ʾăšer", "traducao_palavra": "que" },
        { "hebraico": "תֹּאמַ֨ר", "transliteral": "tōʾmar", "traducao_palavra": "disser" },
        { "hebraico": "אֵלֶ֤יךָ", "transliteral": "ʾēleyḵā", "traducao_palavra": "a ti" },
        { "hebraico": "שָׂרָה֙", "transliteral": "śārâ", "traducao_palavra": "Sara" },
        { "hebraico": "שְׁמַ֣ע", "transliteral": "šəmaʿ", "traducao_palavra": "ouve" },
