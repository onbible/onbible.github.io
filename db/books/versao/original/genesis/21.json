        { "hebraico": "הַנַּ֖עַר", "transliteral": "hannaʿar", "traducao_palavra": "o moço" },
        { "hebraico": "בַּאֲשֶׁ֥ר", "transliteral": "baʾăšer", "traducao_palavra": "no [lugar] que" },
        { "hebraico": "הוּא־שָֽׁם׃", "transliteral": "hû-šām", "traducao_palavra": "ele [está] lá" }
      ]
    },
    "18": {
      "traducao_completa": "Levanta-te, ergue o menino e pega-lhe pela mão, porque dele farei uma grande nação.",
      "palavras": [
        { "hebraico": "ק֚וּמִי", "transliteral": "qûmî", "traducao_palavra": "Levanta-te" },
        { "hebraico": "שְׂאִ֣י", "transliteral": "śəʾî", "traducao_palavra": "ergue" },
        { "hebraico": "אֶת־הַנַּ֔עַר", "transliteral": "ʾeṯ-hannaʿar", "traducao_palavra": "[obj] o moço" },
        { "hebraico": "וְהַחֲזִ֥יקִי", "transliteral": "wəhaḥăzîqî", "traducao_palavra": "e segura" },
        { "hebraico": "אֶת־יָדֵ֖ךְ", "transliteral": "ʾeṯ-yāḏēḵ", "traducao_palavra": "[obj] tua mão" },
        { "hebraico": "בֹּ֑ו", "transliteral": "bô", "traducao_palavra": "nele" },
        { "hebraico": "כִּֽי־לְגֹ֥וי", "transliteral": "kî-ləḡôy", "traducao_palavra": "pois em nação" },
        { "hebraico": "גָּדֹ֖ול", "transliteral": "ḡāḏôl", "traducao_palavra": "grande" },
        { "hebraico": "אֲשִׂימֶֽנּוּ׃", "transliteral": "ʾăśîmennû", "traducao_palavra": "farei dele" }
      ]
    },
    "19": {
      "traducao_completa": "E abriu-lhe Deus os olhos, e viu um poço de água; e foi-se, e encheu o odre de água, e deu de beber ao menino.",
      "palavras": [
        { "hebraico": "וַיִּפְקַ֤ח", "transliteral": "wayyip̱qaḥ", "traducao_palavra": "E abriu" },
        { "hebraico": "אֱלֹהִים֙", "transliteral": "ʾĕlōhîm", "traducao_palavra": "Deus" },
        { "hebraico": "אֶת־עֵינֶ֔יהָ", "transliteral": "ʾeṯ-ʿêneyhā", "traducao_palavra": "[obj] seus olhos" },
        { "hebraico": "וַתֵּ֖רֶא", "transliteral": "wattēreʾ", "traducao_palavra": "e ela viu" },
        { "hebraico": "בְּאֵ֣ר מָ֑יִם", "transliteral": "bəʾēr mayim", "traducao_palavra": "um poço de água" },
        { "hebraico": "וַתֵּ֜לֶךְ", "transliteral": "wattēleḵ", "traducao_palavra": "e ela foi" },
        { "hebraico": "וַתְּמַלֵּ֤א", "transliteral": "wattəmalleʾ", "traducao_palavra": "e encheu" },
        { "hebraico": "אֶת־הַחֵ֙מֶת֙", "transliteral": "ʾeṯ-haḥēmeṯ", "traducao_palavra": "[obj] o odre" },
        { "hebraico": "מַ֔יִם", "transliteral": "mayim", "traducao_palavra": "água" },
        { "hebraico": "וַתַּ֖שְׁקְ", "transliteral": "wattašəq", "traducao_palavra": "e deu de beber" },
        { "hebraico": "אֶת־הַנָּֽעַר׃", "transliteral": "ʾeṯ-hannāʿar", "traducao_palavra": "[obj] o moço" }
      ]
    },
    "20": {
      "traducao_completa": "E era Deus com o menino, que cresceu; e habitou no deserto, e foi atirador de arco.",
      "palavras": [
        { "hebraico": "וַיְהִ֧י", "transliteral": "wayəhî", "traducao_palavra": "E foi/era" },
        { "hebraico": "אֱלֹהִ֛ים", "transliteral": "ʾĕlōhîm", "traducao_palavra": "Deus" },
        { "hebraico": "אֶת־הַנַּ֖עַר", "transliteral": "ʾeṯ-hannaʿar", "traducao_palavra": "com o moço" },
        { "hebraico": "וַיִּגְדָּ֑ל", "transliteral": "wayyiḡdāl", "traducao_palavra": "e ele cresceu" },
        { "hebraico": "וַיֵּ֙שֶׁב֙", "transliteral": "wayyēšeḇ", "traducao_palavra": "e habitou" },
        { "hebraico": "בַּמִּדְבָּ֔ר", "transliteral": "bammiḏbār", "traducao_palavra": "no deserto" },
        { "hebraico": "וַיְהִ֖י", "transliteral": "wayəhî", "traducao_palavra": "e tornou-se" },
        { "hebraico": "רֹבֶ֥ה קַשָּֽׁת׃", "transliteral": "rōḇeh qaššāṯ", "traducao_palavra": "atirador de arco" }
      ]
    },
    "21": {
      "traducao_completa": "E habitou no deserto de Parã; e sua mãe tomou-lhe mulher da terra do Egito.",
      "palavras": [
        { "hebraico": "וַיֵּ֖שֶׁב", "transliteral": "wayyēšeḇ", "traducao_palavra": "E habitou" },
        { "hebraico": "בְּמִדְבַּ֣ר פָּארָ֑ן", "transliteral": "bəmiḏbar pāʾrān", "traducao_palavra": "no deserto de Parã" },
        { "hebraico": "וַתִּֽקַּֽח־לֹ֥ו", "transliteral": "wattiqqaḥ-lô", "traducao_palavra": "e tomou para ele" },
        { "hebraico": "אִמֹּ֛ו", "transliteral": "ʾimmô", "traducao_palavra": "sua mãe" },
        { "hebraico": "אִשָּׁ֖ה", "transliteral": "ʾiššâ", "traducao_palavra": "uma mulher" },
        { "hebraico": "מֵאֶ֥רֶץ מִצְרָֽיִם׃", "transliteral": "mēʾereṣ miṣrāyim", "traducao_palavra": "da terra do Egito" }
      ]
    },
    "22": {
      "traducao_completa": "E aconteceu, naquele mesmo tempo, que Abimeleque, com Ficol, príncipe do seu exército, falou a Abraão, dizendo: Deus é contigo em tudo o que fazes.",
      "palavras": [
        { "hebraico": "וַֽיְהִי֙", "transliteral": "wayəhî", "traducao_palavra": "E aconteceu" },
        { "hebraico": "בָּעֵ֣ת", "transliteral": "bāʿēṯ", "traducao_palavra": "no tempo" },
        { "hebraico": "הַהִ֔וא", "transliteral": "hahîw", "traducao_palavra": "aquele" },
        { "hebraico": "וַיֹּ֣אמֶר", "transliteral": "wayyōʾmer", "traducao_palavra": "e disse" },
        { "hebraico": "אֲבִימֶ֜לֶךְ", "transliteral": "ʾăḇîmeleq", "traducao_palavra": "Abimeleque" },
        { "hebraico": "וּפִיכֹ֤ל", "transliteral": "ûp̱îḵōl", "traducao_palavra": "e Ficol" },
        { "hebraico": "שַׂר־צְבָאֹו֙", "transliteral": "śar-ṣəḇāʾô", "traducao_palavra": "príncipe de seu exército" },
        { "hebraico": "אֶל־אַבְרָהָ֖ם", "transliteral": "ʾel-ʾaḇrāhām", "traducao_palavra": "a Abraão" },
        { "hebraico": "לֵאמֹ֑ר", "transliteral": "lēʾmōr", "traducao_palavra": "dizendo" },
        { "hebraico": "אֱלֹהִ֣ים עִמְּךָ֔", "transliteral": "ʾĕlōhîm ʿimməḵā", "traducao_palavra": "Deus [é] contigo" },
        { "hebraico": "בְּכֹ֥ל", "transliteral": "bəḵōl", "traducao_palavra": "em tudo" },
        { "hebraico": "אֲשֶׁר־אַתָּ֥ה", "transliteral": "ʾăšer-ʾattâ", "traducao_palavra": "que tu" },
        { "hebraico": "עֹשֶֽׂה׃", "transliteral": "ʿōśeh", "traducao_palavra": "fazes" }
      ]
    },
    "23": {
      "traducao_completa": "Agora, pois, jura-me aqui por Deus que não mentirás a mim, nem a meu filho, nem a meu neto; conforme a beneficência que te fiz, farás comigo e com a terra em que peregrinaste.",
      "palavras": [
        { "hebraico": "וְעַתָּ֗ה", "transliteral": "wəʿattâ", "traducao_palavra": "E agora" },
        { "hebraico": "הִשָּׁ֨בְעָה", "transliteral": "hiššāḇəʿâ", "traducao_palavra": "jura" },
        { "hebraico": "לִּ֧י", "transliteral": "llî", "traducao_palavra": "para mim" },
        { "hebraico": "בֵאלֹהִ֛ים", "transliteral": "ḇēʾlōhîm", "traducao_palavra": "por Deus" },
        { "hebraico": "הֵ֑נָּה", "transliteral": "hēnnâ", "traducao_palavra": "aqui" },
        { "hebraico": "אִם־תִּשְׁקֹ֣ר", "transliteral": "ʾim-tišqōr", "traducao_palavra": "se mentires" },
        { "hebraico": "לִ֗י", "transliteral": "lî", "traducao_palavra": "para mim" },
        { "hebraico": "וּלְנִינִ֥י", "transliteral": "ûlənînî", "traducao_palavra": "e para minha descendência" },
        { "hebraico": "וּלְנֶכְדִּ֑י", "transliteral": "ûləneḵədî", "traducao_palavra": "e para minha posteridade" },
        { "hebraico": "כַּחֶ֨סֶד֙", "transliteral": "kaḥeseḏ", "traducao_palavra": "conforme a bondade" },
        { "hebraico": "אֲשֶׁר־עָשִׂ֣יתִי", "transliteral": "ʾăšer-ʿāśîṯî", "traducao_palavra": "que fiz" },
        { "hebraico": "עִמְּךָ֔", "transliteral": "ʿimməḵā", "traducao_palavra": "contigo" },
        { "hebraico": "תַּעֲשֶׂ֣ה", "transliteral": "taʿăśeh", "traducao_palavra": "farás" },
        { "hebraico": "עִמָּדִ֔י", "transliteral": "ʿimmāḏî", "traducao_palavra": "comigo" },
        { "hebraico": "וְעִם־הָאָ֖רֶץ", "transliteral": "wəʿim-hāʾāreṣ", "traducao_palavra": "e com a terra" },
        { "hebraico": "אֲשֶׁר־גַּ֥רְתָּה", "transliteral": "ʾăšer-gartâ", "traducao_palavra": "que peregrinaste" },
        { "hebraico": "בָּֽהּ׃", "transliteral": "bāh", "traducao_palavra": "nela" }
      ]
    },
    "24": {
      "traducao_completa": "E disse Abraão: Eu jurarei.",
      "palavras": [
        { "hebraico": "וַיֹּ֖אמֶר", "transliteral": "wayyōʾmer", "traducao_palavra": "E disse" },
        { "hebraico": "אַבְרָהָ֑ם", "transliteral": "ʾaḇrāhām", "traducao_palavra": "Abraão" },
        { "hebraico": "אָנֹכִ֖י", "transliteral": "ʾānōḵî", "traducao_palavra": "Eu" },
        { "hebraico": "אִשָּׁבֵֽעַ׃", "transliteral": "ʾiššāḇēaʿ", "traducao_palavra": "jurarei" }
      ]
    },
    "25": {
      "traducao_completa": "Abraão, porém, repreendeu a Abimeleque por causa de um poço de água que os servos de Abimeleque haviam tomado por força.",
      "palavras": [
        { "hebraico": "וְהֹוכִ֥חַ", "transliteral": "wəhôḵîaḥ", "traducao_palavra": "E repreendeu" },
        { "hebraico": "אַבְרָהָ֖ם", "transliteral": "ʾaḇrāhām", "traducao_palavra": "Abraão" },
        { "hebraico": "אֶת־אֲבִימֶ֑לֶךְ", "transliteral": "ʾeṯ-ʾăḇîmeleq", "traducao_palavra": "[obj] Abimeleque" },
        { "hebraico": "עַל־אֹודֹות֙", "transliteral": "ʿal-ʾôḏôṯ", "traducao_palavra": "sobre assunto de" },
        { "hebraico": "בְּאֵ֣ר הַמַּ֔יִם", "transliteral": "bəʾēr hammayim", "traducao_palavra": "poço de água" },
        { "hebraico": "אֲשֶׁ֥ר", "transliteral": "ʾăšer", "traducao_palavra": "que" },
        { "hebraico": "גָּזְל֖וּ", "transliteral": "ḡāzlû", "traducao_palavra": "roubaram/tomaram" },
        { "hebraico": "עַבְדֵ֥י", "transliteral": "ʿaḇḏê", "traducao_palavra": "servos de" },
        { "hebraico": "אֲבִימֶֽלֶךְ׃", "transliteral": "ʾăḇîmeleq", "traducao_palavra": "Abimeleque" }
      ]
    },
    "26": {
      "traducao_completa": "E disse Abimeleque: Não sei quem fez isto; e também tu não mo fizeste saber, nem eu o ouvi senão hoje.",
      "palavras": [
        { "hebraico": "וַיֹּ֣אמֶר", "transliteral": "wayyōʾmer", "traducao_palavra": "E disse" },
        { "hebraico": "אֲבִימֶ֔לֶךְ", "transliteral": "ʾăḇîmeleq", "traducao_palavra": "Abimeleque" },
        { "hebraico": "לֹ֣א יָדַ֔עְתִּי", "transliteral": "lōʾ yāḏaʿttî", "traducao_palavra": "não soube" },
        { "hebraico": "מִ֥י", "transliteral": "mî", "traducao_palavra": "quem" },
        { "hebraico": "עָשָׂ֖ה", "transliteral": "ʿāśâ", "traducao_palavra": "fez" },
        { "hebraico": "אֶת־הַדָּבָ֣ר", "transliteral": "ʾeṯ-haddāḇār", "traducao_palavra": "[obj] a coisa" },
        { "hebraico": "הַזֶּ֑ה", "transliteral": "hazzeh", "traducao_palavra": "esta" },
        { "hebraico": "וְגַם־אַתָּה֙", "transliteral": "wəḡam-ʾattâ", "traducao_palavra": "e também tu" },
        { "hebraico": "לֹא־הִגַּ֣דְתָּ לִּ֔י", "transliteral": "lōʾ-higgaḏtā llî", "traducao_palavra": "não contaste para mim" },
        { "hebraico": "וְגַם֙ אָנֹכִ֣י", "transliteral": "wəḡam ʾānōḵî", "traducao_palavra": "e também eu" },
        { "hebraico": "לֹ֣א שָׁמַ֔עְתִּי", "transliteral": "lōʾ šāmaʿttî", "traducao_palavra": "não ouvi" },
        { "hebraico": "בִּלְתִּ֖י", "transliteral": "bilttî", "traducao_palavra": "exceto" },
        { "hebraico": "הַיֹּֽום׃", "transliteral": "hayyôm", "traducao_palavra": "hoje" }
      ]
    },
    "27": {
      "traducao_completa": "E tomou Abraão ovelhas e vacas, e deu-as a Abimeleque; e fizeram ambos uma aliança.",
      "palavras": [
        { "hebraico": "וַיִּקַּ֤ח", "transliteral": "wayyiqqaḥ", "traducao_palavra": "E tomou" },
        { "hebraico": "אַבְרָהָם֙", "transliteral": "ʾaḇrāhām", "traducao_palavra": "Abraão" },
        { "hebraico": "צֹ֣אן וּבָקָ֔ר", "transliteral": "ṣōn ûḇāqār", "traducao_palavra": "ovelhas e gado" },
        { "hebraico": "וַיִּתֵּ֖ן", "transliteral": "wayyittēn", "traducao_palavra": "e deu" },
        { "hebraico": "לַאֲבִימֶ֑לֶךְ", "transliteral": "laʾăḇîmeleq", "traducao_palavra": "a Abimeleque" },
        { "hebraico": "וַיִּכְרְת֥וּ", "transliteral": "wayyiḵrəṯû", "traducao_palavra": "e cortaram/fizeram" },
        { "hebraico": "שְׁנֵיהֶ֖ם", "transliteral": "šənêhem", "traducao_palavra": "ambos eles" },
        { "hebraico": "בְּרִֽית׃", "transliteral": "bərîṯ", "traducao_palavra": "uma aliança" }
      ]
    },
    "28": {
      "traducao_completa": "Pôs Abraão também à parte sete cordeiras do rebanho.",
      "palavras": [
        { "hebraico": "וַיַּצֵּ֣ב", "transliteral": "wayyaṣṣēḇ", "traducao_palavra": "E pôs" },
        { "hebraico": "אַבְרָהָ֗ם", "transliteral": "ʾaḇrāhām", "traducao_palavra": "Abraão" },
        { "hebraico": "אֶת־שֶׁ֛בַע", "transliteral": "ʾeṯ-šebaʿ", "traducao_palavra": "[obj] sete" },
        { "hebraico": "כִּבְשֹׂ֥ת", "transliteral": "kiḇśōṯ", "traducao_palavra": "cordeiras de" },
        { "hebraico": "הַצֹּ֖אן", "transliteral": "haṣṣōn", "traducao_palavra": "o rebanho" },
        { "hebraico": "לְבַדְּהֶֽן׃", "transliteral": "ləḇaddəhen", "traducao_palavra": "sozinhas/à parte" }
      ]
    },
    "29": {
      "traducao_completa": "E disse Abimeleque a Abraão: Para que servem estas sete cordeiras que puseste à parte?",
      "palavras": [
        { "hebraico": "וַיֹּ֥אמֶר", "transliteral": "wayyōʾmer", "traducao_palavra": "E disse" },
        { "hebraico": "אֲבִימֶ֖לֶךְ", "transliteral": "ʾăḇîmeleq", "traducao_palavra": "Abimeleque" },
        { "hebraico": "אֶל־אַבְרָהָ֑ם", "transliteral": "ʾel-ʾaḇrāhām", "traducao_palavra": "a Abraão" },
        { "hebraico": "מָ֣ה הֵ֗נָּה", "transliteral": "mâ hēnnâ", "traducao_palavra": "O que [são] elas" },
        { "hebraico": "שֶׁ֤בַע", "transliteral": "šebaʿ", "traducao_palavra": "sete" },
        { "hebraico": "כְּבָשֹׂת֙", "transliteral": "kəḇāśōṯ", "traducao_palavra": "cordeiras" },
        { "hebraico": "הָאֵ֔לֶּה", "transliteral": "hāʾēlleh", "traducao_palavra": "estas" },
        { "hebraico": "אֲשֶׁ֥ר", "transliteral": "ʾăšer", "traducao_palavra": "que" },
        { "hebraico": "הִצַּ֖בְתָּ", "transliteral": "hiṣṣaḇttā", "traducao_palavra": "puseste" },
        { "hebraico": "לְבַדָּֽנָה׃", "transliteral": "ləḇaddānâ", "traducao_palavra": "à parte" }
      ]
    },
    "30": {
      "traducao_completa": "E disse ele: Pois estas sete cordeiras tomarás de minha mão, para que isto me seja por testemunho de que eu cavei este poço.",
      "palavras": [
        { "hebraico": "וַיֹּ֕אמֶר", "transliteral": "wayyōʾmer", "traducao_palavra": "E disse" },
        { "hebraico": "כִּ֚י", "transliteral": "kî", "traducao_palavra": "Pois" },
        { "hebraico": "אֶת־שֶׁ֣בַע", "transliteral": "ʾeṯ-šebaʿ", "traducao_palavra": "[obj] as sete" },
        { "hebraico": "כְּבָשֹׂ֔ת", "transliteral": "kəḇāśōṯ", "traducao_palavra": "cordeiras" },
        { "hebraico": "תִּקַּ֖ח", "transliteral": "tiqqaḥ", "traducao_palavra": "tomarás" },
        { "hebraico": "מִיָּדִ֑י", "transliteral": "miyyāḏî", "traducao_palavra": "de minha mão" },
        { "hebraico": "בַּעֲבוּר", "transliteral": "baʿăḇûr", "traducao_palavra": "para que" },
        { "hebraico": "תִּהְיֶה־לִּ֣י", "transliteral": "tihyeh-llî", "traducao_palavra": "seja para mim" },
        { "hebraico": "לְעֵדָ֔ה", "transliteral": "ləʿēḏâ", "traducao_palavra": "por testemunho" },
        { "hebraico": "כִּ֥י", "transliteral": "kî", "traducao_palavra": "que" },
        { "hebraico": "חָפַ֖רְתִּי", "transliteral": "ḥāp̱arəttî", "traducao_palavra": "cavei" },
        { "hebraico": "אֶת־הַבְּאֵ֥ר", "transliteral": "ʾeṯ-habbəʾēr", "traducao_palavra": "[obj] o poço" },
        { "hebraico": "הַזֹּֽאת׃", "transliteral": "hazzōʾṯ", "traducao_palavra": "este" }
      ]
    },
    "31": {
      "traducao_completa": "Por isso se chamou aquele lugar Berseba, porquanto ambos juraram ali.",
      "palavras": [
        { "hebraico": "עַל־כֵּ֗ן", "transliteral": "ʿal-kēn", "traducao_palavra": "Por isso" },
        { "hebraico": "קָרָא֙", "transliteral": "qārāʾ", "traducao_palavra": "chamou" },
        { "hebraico": "לַמָּקֹ֣ום", "transliteral": "lammāqôm", "traducao_palavra": "ao lugar" },
        { "hebraico": "הַה֔וּא", "transliteral": "hahû", "traducao_palavra": "aquele" },
        { "hebraico": "בְּאֵ֣ר שָׁ֑בַע", "transliteral": "bəʾēr šāḇaʿ", "traducao_palavra": "Berseba" },
        { "hebraico": "כִּ֛י", "transliteral": "kî", "traducao_palavra": "porque" },
        { "hebraico": "שָׁ֥ם", "transliteral": "šām", "traducao_palavra": "lá" },
        { "hebraico": "נִשְׁבְּע֖וּ", "transliteral": "nišbbəʿû", "traducao_palavra": "juraram" },
        { "hebraico": "שְׁנֵיהֶֽם׃", "transliteral": "šənêhem", "traducao_palavra": "ambos eles" }
      ]
    },
    "32": {
      "traducao_completa": "Assim fizeram uma aliança em Berseba. Depois levantou-se Abimeleque com Ficol, príncipe do seu exército, e tornaram para a terra dos filisteus.",
      "palavras": [
        { "hebraico": "וַיִּכְרְת֥וּ", "transliteral": "wayyiḵrəṯû", "traducao_palavra": "E cortaram/fizeram" },
        { "hebraico": "בְרִ֖ית", "transliteral": "ḇərîṯ", "traducao_palavra": "uma aliança" },
        { "hebraico": "בִּבְאֵ֣ר שָׁ֑בַע", "transliteral": "biḇəʾēr šāḇaʿ", "traducao_palavra": "em Berseba" },
        { "hebraico": "וַיָּ֣קָם", "transliteral": "wayyāqām", "traducao_palavra": "e levantou-se" },
        { "hebraico": "אֲבִימֶ֗לֶךְ", "transliteral": "ʾăḇîmeleq", "traducao_palavra": "Abimeleque" },
        { "hebraico": "וּפִיכֹל֙", "transliteral": "ûp̱îḵōl", "traducao_palavra": "e Ficol" },
        { "hebraico": "שַׂר־צְבָאֹ֔ו", "transliteral": "śar-ṣəḇāʾô", "traducao_palavra": "príncipe de seu exército" },
        { "hebraico": "וַיָּשֻׁ֖בוּ", "transliteral": "wayyāšubû", "traducao_palavra": "e voltaram" },
        { "hebraico": "אֶל־אֶ֥רֶץ", "transliteral": "ʾel-ʾereṣ", "traducao_palavra": "para a terra de" },
        { "hebraico": "פְּלִשְׁתִּים׃", "transliteral": "pəlištîm", "traducao_palavra": "filisteus" }
      ]
    },
    "33": {
      "traducao_completa": "E plantou um tamargueiro em Berseba, e invocou ali o nome do SENHOR, o Deus Eterno.",
      "palavras": [
        { "hebraico": "וַיִּטַּ֥ע", "transliteral": "wayyiṭṭaʿ", "traducao_palavra": "E plantou" },
        { "hebraico": "אֶ֖שֶׁל", "transliteral": "ʾešel", "traducao_palavra": "um tamargueiro" },
        { "hebraico": "בִּבְאֵ֣ר שָׁ֑בַע", "transliteral": "biḇəʾēr šāḇaʿ", "traducao_palavra": "em Berseba" },
        { "hebraico": "וַיִּקְרָא־שָׁ֣ם", "transliteral": "wayyiqrāʾ-šām", "traducao_palavra": "e invocou lá" },
        { "hebraico": "בְּשֵׁ֥ם", "transliteral": "bəšēm", "traducao_palavra": "no nome de" },
        { "hebraico": "יְהוָ֖ה", "transliteral": "YHWH", "traducao_palavra": "YHWH" },
        { "hebraico": "אֵ֥ל", "transliteral": "ʾēl", "traducao_palavra": "Deus" },
        { "hebraico": "עוֹלָֽם׃", "transliteral": "ʿôlām", "traducao_palavra": "Eterno" }
      ]
    },
    "34": {
      "traducao_completa": "E peregrinou Abraão na terra dos filisteus muitos dias.",
      "palavras": [
        { "hebraico": "וַיָּ֧גָר", "transliteral": "wayyāḡār", "traducao_palavra": "E peregrinou" },
        { "hebraico": "אַבְרָהָ֛ם", "transliteral": "ʾaḇrāhām", "traducao_palavra": "Abraão" },
        { "hebraico": "בְּאֶ֥רֶץ", "transliteral": "bəʾereṣ", "traducao_palavra": "na terra de" },
        { "hebraico": "פְּלִשְׁתִּ֖ים", "transliteral": "pəlištîm", "traducao_palavra": "filisteus" },
        { "hebraico": "יָמִ֥ים", "transliteral": "yāmîm", "traducao_palavra": "dias" },
        { "hebraico": "רַבִּֽים׃", "transliteral": "rabbîm", "traducao_palavra": "muitos" }
      ]
    }
  }
