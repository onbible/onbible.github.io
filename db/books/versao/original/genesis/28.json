        { "hebraico": "וּלְזַרְעֲךָ֣", "transliteral": "ûləzarʿăḵā", "traducao_palavra": "e à tua semente" },
        { "hebraico": "אִתָּ֑ךְ", "transliteral": "ʾittāḵ", "traducao_palavra": "contigo" },
