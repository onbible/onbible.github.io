        { "hebraico": "פַּדֶּ֣נָה", "transliteral": "paddenâ", "traducao_palavra": "para Padã" },
        { "hebraico": "אֲרָ֔ם", "transliteral": "ʾărām", "traducao_palavra": "Arã" },
        { "hebraico": "בֵּ֥יתָה", "transliteral": "bêṯâ", "traducao_palavra": "para casa de" },
