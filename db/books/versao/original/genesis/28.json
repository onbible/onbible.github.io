        { "hebraico": "לֹֽא־תִקַּ֥ח", "transliteral": "lōʾ-tiqqaḥ", "traducao_palavra": "não tomarás" },
        { "hebraico": "אִשָּׁ֖ה", "transliteral": "ʾiššâ", "traducao_palavra": "mulher" },
        { "hebraico": "מִבְּנוֹת֙", "transliteral": "mibbbənôṯ", "traducao_palavra": "das filhas de" },
        { "hebraico": "כְּנָֽעַן׃", "transliteral": "kənāʿan", "traducao_palavra": "Canaã" }
      ]
    },
    "2": {
      "traducao_completa": "Levanta-te, vai para Padã-Arã, à casa de Betuel, pai de tua mãe; e toma para ti de lá mulher das filhas de Labão, irmão de tua mãe.",
