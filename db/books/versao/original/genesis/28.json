        { "hebraico": "יְבָרֵ֣ךְ", "transliteral": "yəḇārēḵ", "traducao_palavra": "abençoe" },
        { "hebraico": "אֹתְךָ֔", "transliteral": "ʾōṯəḵā", "traducao_palavra": "a ti" },
