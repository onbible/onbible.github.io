        { "hebraico": "וְאֶת־כָּֽלַח׃", "transliteral": "wəʾeṯ-kālaḥ", "traducao_palavra": "e [obj] Calá" }
      ]
    },
    "12": {
      "traducao_completa": "e Resem, entre Nínive e Calá (esta é a grande cidade).",
      "palavras": [
        { "hebraico": "וְאֶת־רֶ֙סֶן֙", "transliteral": "wəʾeṯ-resen", "traducao_palavra": "e [obj] Resem" },
        { "hebraico": "בֵּ֥ין", "transliteral": "bên", "traducao_palavra": "entre" },
        { "hebraico": "נִֽינְוֵ֖ה", "transliteral": "nînəwēh", "traducao_palavra": "Nínive" },
        { "hebraico": "וּבֵ֣ין", "transliteral": "ûḇên", "traducao_palavra": "e entre" },
        { "hebraico": "כָּ֑לַח", "transliteral": "kālaḥ", "traducao_palavra": "Calá" },
        { "hebraico": "הִ֖וא", "transliteral": "hîw", "traducao_palavra": "esta [é]" },
        { "hebraico": "הָעִ֥יר", "transliteral": "hāʿîr", "traducao_palavra": "a cidade" },
