        { "hebraico": "יֶ֔פֶת", "transliteral": "yep̱eṯ", "traducao_palavra": "Jafé" },
        { "hebraico": "גֹּ֣מֶר", "transliteral": "ḡōmer", "traducao_palavra": "Gomer" },
        { "hebraico": "וּמָגֹ֔וג", "transliteral": "ûmāḡôḡ", "traducao_palavra": "e Magogue" },
        { "hebraico": "וּמָדַ֖י", "transliteral": "ûmāḏay", "traducao_palavra": "e Madai" },
        { "hebraico": "וְיָוָ֣ן", "transliteral": "wəyāwān", "traducao_palavra": "e Javã" },
        { "hebraico": "וְתֻבָ֑ל", "transliteral": "wəṯuḇāl", "traducao_palavra": "e Tubal" },
        { "hebraico": "וּמֶ֖שֶׁךְ", "transliteral": "ûmešeḵ", "traducao_palavra": "e Meseque" },
        { "hebraico": "וְתִירָֽס׃", "transliteral": "wəṯîrās", "traducao_palavra": "e Tiras" }
      ]
    },
    "3": {
      "traducao_completa": "E os filhos de Gomer são: Asquenaz, Rifate e Togarma.",
      "palavras": [
        { "hebraico": "וּבְנֵ֖י", "transliteral": "ûḇənê", "traducao_palavra": "E filhos de" },
        { "hebraico": "גֹּ֑מֶר", "transliteral": "ḡōmer", "traducao_palavra": "Gomer" },
        { "hebraico": "אַשְׁכֲּנַ֥ז", "transliteral": "ʾaškănaz", "traducao_palavra": "Asquenaz" },
        { "hebraico": "וְרִיפַ֖ת", "transliteral": "wərîp̱aṯ", "traducao_palavra": "e Rifate" },
        { "hebraico": "וְתֹגַרְמָֽה׃", "transliteral": "wəṯōḡarmâ", "traducao_palavra": "e Togarma" }
      ]
    },
    "4": {
      "traducao_completa": "E os filhos de Javã são: Elisá, Társis, Quitim e Dodanim.",
      "palavras": [
        { "hebraico": "וּבְנֵ֥י", "transliteral": "ûḇənê", "traducao_palavra": "E filhos de" },
        { "hebraico": "יָוָ֖ן", "transliteral": "yāwān", "traducao_palavra": "Javã" },
        { "hebraico": "אֱלִישָׁ֣ה", "transliteral": "ʾĕlîšâ", "traducao_palavra": "Elisá" },
        { "hebraico": "וְתַרְשִׁ֑ישׁ", "transliteral": "wəṯarəšîš", "traducao_palavra": "e Társis" },
        { "hebraico": "כִּתִּ֖ים", "transliteral": "kittîm", "traducao_palavra": "Quitim" },
