        { "hebraico": "אֲשֶׁ֨ר", "transliteral": "ʾăšer", "traducao_palavra": "que" },
        { "hebraico": "יָצְא֥וּ", "transliteral": "yāṣəʾû", "traducao_palavra": "saíram" },
        { "hebraico": "מִשָּׁם֙", "transliteral": "miššām", "traducao_palavra": "dali" },
        { "hebraico": "פְּלִשְׁתִּ֔ים", "transliteral": "pəlištîm", "traducao_palavra": "filisteus" },
        { "hebraico": "וְאֶת־כַּפְתֹּרִֽים׃", "transliteral": "wəʾeṯ-kap̱ətōrîm", "traducao_palavra": "e [obj] Caftorim" }
      ]
    },
    "15": {
      "traducao_completa": "E Canaã gerou a Sidom, seu primogênito, e a Hete,",
      "palavras": [
        { "hebraico": "וּכְנַ֖עַן", "transliteral": "ûḵənaʿan", "traducao_palavra": "E Canaã" },
        { "hebraico": "יָלַ֣ד", "transliteral": "yālaḏ", "traducao_palavra": "gerou" },
        { "hebraico": "אֶת־צִידֹ֧ן", "transliteral": "ʾeṯ-ṣîḏōn", "traducao_palavra": "[obj] Sidom" },
        { "hebraico": "בְּכֹרֹ֑ו", "transliteral": "bəḵōrô", "traducao_palavra": "seu primogênito" },
        { "hebraico": "וְאֶת־חֵֽת׃", "transliteral": "wəʾeṯ-ḥēṯ", "traducao_palavra": "e Hete" }
