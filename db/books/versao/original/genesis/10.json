        { "hebraico": "וְכַלְנֵ֑ה", "transliteral": "wəḵalnēh", "traducao_palavra": "e Calné" },
        { "hebraico": "בְּאֶ֖רֶץ", "transliteral": "bəʾereṣ", "traducao_palavra": "na terra de" },
        { "hebraico": "שִׁנְעָֽר׃", "transliteral": "šinəʿār", "traducao_palavra": "Sinar" }
      ]
    },
    "11": {
      "traducao_completa": "Desta terra saiu ele para a Assíria, e edificou Nínive, Reobote-Ir e Calá,",
      "palavras": [
        { "hebraico": "מִן־הָאָ֥רֶץ", "transliteral": "min-hāʾāreṣ", "traducao_palavra": "Desta terra" },
        { "hebraico": "הַהִ֖וא", "transliteral": "hahîw", "traducao_palavra": "aquela" },
        { "hebraico": "יָצָ֣א", "transliteral": "yāṣāʾ", "traducao_palavra": "saiu" },
        { "hebraico": "אַשּׁ֑וּר", "transliteral": "ʾaššûr", "traducao_palavra": "Assur/Assíria" },
