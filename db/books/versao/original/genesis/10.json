      "palavras": [
        { "hebraico": "וְאֶת־הַיְבוּסִ֔י", "transliteral": "wəʾeṯ-hayəḇûsî", "traducao_palavra": "e o jebuseu" },
        { "hebraico": "וְאֶת־הָאֱמֹרִ֖י", "transliteral": "wəʾeṯ-hāʾĕmōrî", "traducao_palavra": "e o amorreu" },
