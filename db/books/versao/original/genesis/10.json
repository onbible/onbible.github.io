{
  "livro": "Gênesis - בְּרֵאשִׁית - Bereshit",
  "capítulo": 10,
  "titulos": {},
  "versiculos": {
    "1": {
      "traducao_completa": "E estas são as gerações dos filhos de Noé: Sem, Cam e Jafé; e nasceram-lhes filhos depois do dilúvio.",
      "palavras": [
        { "hebraico": "וְאֵ֙לֶּה֙", "transliteral": "wəʾēlleh", "traducao_palavra": "E estas" },
        { "hebraico": "תּוֹלְדֹ֣ת", "transliteral": "ṯôləḏôṯ", "traducao_palavra": "as gerações de" },
        { "hebraico": "בְּנֵי־נֹ֔חַ", "transliteral": "ḇənê-nōḥa", "traducao_palavra": "filhos de Noé" },
        { "hebraico": "שֵׁ֖ם", "transliteral": "šēm", "traducao_palavra": "Sem" },
        { "hebraico": "חָ֣ם", "transliteral": "ḥām", "traducao_palavra": "Cam" },
        { "hebraico": "וָיָ֑פֶת", "transliteral": "wāyāp̄eṯ", "traducao_palavra": "e Jafé" },
        { "hebraico": "וַיִּוָּלְד֧וּ", "transliteral": "wayyiwwāləḏû", "traducao_palavra": "e nasceram" },
        { "hebraico": "לָהֶ֛ם", "transliteral": "lāhem", "traducao_palavra": "para eles" },
        { "hebraico": "בָּנִ֖ים", "transliteral": "bānîm", "traducao_palavra": "filhos" },
        { "hebraico": "אַחַ֥ר", "transliteral": "ʾaḥar", "traducao_palavra": "depois de" },
        { "hebraico": "הַמַּבּֽוּל׃", "transliteral": "hammabbûl", "traducao_palavra": "o dilúvio" }
      ]
    },
    "2": {
      "traducao_completa": "Os filhos de Jafé são: Gomer, Magogue, Madai, Javã, Tubal, Meseque e Tiras.",
      "palavras": [
