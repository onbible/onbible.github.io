      ]
    },
    "13": {
      "traducao_completa": "E Mizraim gerou a Ludim, a Anamim, a Leabim, a Naftuim,",
      "palavras": [
        { "hebraico": "וּמִצְרַ֡יִם", "transliteral": "ûmiṣərayim", "traducao_palavra": "E Mizraim" },
        { "hebraico": "יָלַ֧ד", "transliteral": "yālaḏ", "traducao_palavra": "gerou" },
        { "hebraico": "אֶת־לוּדִ֛ים", "transliteral": "ʾeṯ-lûḏîm", "traducao_palavra": "[obj] Ludim" },
        { "hebraico": "וְאֶת־עֲנָמִ֥ים", "transliteral": "wəʾeṯ-ʿănāmîm", "traducao_palavra": "e Anamim" },
        { "hebraico": "וְאֶת־לְהָבִ֖ים", "transliteral": "wəʾeṯ-ləhāḇîm", "traducao_palavra": "e Leabim" },
        { "hebraico": "וְאֶת־נַפְתֻּחִֽים׃", "transliteral": "wəʾeṯ-nap̱ətuḥîm", "traducao_palavra": "e Naftuim" }
      ]
    },
    "14": {
      "traducao_completa": "a Patrusim e a Casluim (donde saíram os filisteus) e a Caftorim.",
