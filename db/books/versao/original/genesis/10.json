        { "hebraico": "צַ֖יִד", "transliteral": "ṣayiḏ", "traducao_palavra": "caçador" },
        { "hebraico": "לִפְנֵ֥י", "transliteral": "lip̄nê", "traducao_palavra": "diante de" },
        { "hebraico": "יְהוָֽה׃", "transliteral": "YHWH", "traducao_palavra": "YHWH" }
      ]
    },
    "10": {
      "traducao_completa": "E o princípio do seu reino foi Babel, Ereque, Acade e Calné, na terra de Sinar.",
      "palavras": [
        { "hebraico": "וַתְּהִ֨י", "transliteral": "wattəhî", "traducao_palavra": "E foi" },
        { "hebraico": "רֵאשִׁ֤ית", "transliteral": "rēʾšîṯ", "traducao_palavra": "o princípio de" },
        { "hebraico": "מַמְלַכְתֹּו֙", "transliteral": "maməlaḵətô", "traducao_palavra": "seu reino" },
        { "hebraico": "בָּבֶ֣ל", "transliteral": "bāḇel", "traducao_palavra": "Babel" },
        { "hebraico": "וְאֶ֔רֶךְ", "transliteral": "wəʾereḵ", "traducao_palavra": "e Ereque" },
