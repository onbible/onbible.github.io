      ]
    },
    "9": {
      "traducao_completa": "Este era poderoso caçador diante do SENHOR; pelo que se diz: Como Ninrode, poderoso caçador diante do SENHOR.",
      "palavras": [
        { "hebraico": "הֽוּא־הָיָ֥ה", "transliteral": "hû-hāyâ", "traducao_palavra": "Ele era" },
        { "hebraico": "גִבֹּֽר־צַ֖יִד", "transliteral": "gibbōr-ṣayiḏ", "traducao_palavra": "poderoso caçador" },
        { "hebraico": "לִפְנֵ֣י", "transliteral": "lip̄nê", "traducao_palavra": "diante de" },
        { "hebraico": "יְהוָ֑ה", "transliteral": "YHWH", "traducao_palavra": "YHWH" },
        { "hebraico": "עַל־כֵּן֙", "transliteral": "ʿal-kēn", "traducao_palavra": "por isso" },
        { "hebraico": "יֵֽאָמַ֔ר", "transliteral": "yēʾāmar", "traducao_palavra": "se diz" },
        { "hebraico": "כְּנִמְרֹ֛ד", "transliteral": "kənimərōḏ", "traducao_palavra": "como Ninrode" },
