      ]
    },
    "5": {
      "traducao_completa": "Por estes foram repartidas as ilhas das nações em suas terras, cada qual segundo a sua língua, segundo as suas famílias, em suas nações.",
      "palavras": [
        { "hebraico": "מֵ֠אֵלֶּה", "transliteral": "mēʾēlleh", "traducao_palavra": "Destes" },
        { "hebraico": "נִפְרְד֞וּ", "transliteral": "nip̱rəḏû", "traducao_palavra": "repartiram-se" },
        { "hebraico": "אִיֵּ֤י", "transliteral": "ʾiyyê", "traducao_palavra": "as ilhas de" },
        { "hebraico": "הַגּוֹיִם֙", "transliteral": "haggôyim", "traducao_palavra": "as nações" },
        { "hebraico": "בְּאַרְצֹתָ֔ם", "transliteral": "bəʾarəṣōṯām", "traducao_palavra": "em suas terras" },
        { "hebraico": "אִ֖ישׁ", "transliteral": "ʾîš", "traducao_palavra": "cada um" },
        { "hebraico": "לִלְשֹׁנֹ֑ו", "transliteral": "liləšōnô", "traducao_palavra": "segundo sua língua" },
        { "hebraico": "לְמִשְׁפְּחֹתָ֖ם", "transliteral": "ləmišpəḥōṯām", "traducao_palavra": "segundo suas famílias" },
        { "hebraico": "בְּגוֹיֵהֶֽם׃", "transliteral": "bəḡôyēhem", "traducao_palavra": "em suas nações" }
      ]
    },
    "6": {
      "traducao_completa": "E os filhos de Cam são: Cuxe, Mizraim, Pute e Canaã.",
      "palavras": [
        { "hebraico": "וּבְנֵ֖י", "transliteral": "ûḇənê", "traducao_palavra": "E filhos de" },
        { "hebraico": "חָ֑ם", "transliteral": "ḥām", "traducao_palavra": "Cam" },
        { "hebraico": "כּ֥וּשׁ", "transliteral": "kûš", "traducao_palavra": "Cuxe" },
        { "hebraico": "וּמִצְרַ֖יִם", "transliteral": "ûmiṣərayim", "traducao_palavra": "e Mizraim" },
        { "hebraico": "וּפ֥וּט", "transliteral": "ûp̱ûṭ", "traducao_palavra": "e Pute" },
        { "hebraico": "וּכְנָֽעַן׃", "transliteral": "ûḵənāʿan", "traducao_palavra": "e Canaã" }
      ]
    },
    "7": {
      "traducao_completa": "E os filhos de Cuxe são: Sebá, Havilá, Sabtá, Raamá e Sabtecá; e os filhos de Raamá: Sabá e Dedã.",
      "palavras": [
        { "hebraico": "וּבְנֵ֣י", "transliteral": "ûḇənê", "traducao_palavra": "E filhos de" },
        { "hebraico": "כ֔וּשׁ", "transliteral": "kûš", "traducao_palavra": "Cuxe" },
        { "hebraico": "סְבָ֡א", "transliteral": "səḇāʾ", "traducao_palavra": "Sebá" },
        { "hebraico": "וַֽחֲוִילָה֙", "transliteral": "waḥăwîlâ", "traducao_palavra": "e Havilá" },
        { "hebraico": "וְסַבְתָּ֣ה", "transliteral": "wəsaḇətâ", "traducao_palavra": "e Sabtá" },
        { "hebraico": "וְרַעְמָ֣ה", "transliteral": "wəraʿəmâ", "traducao_palavra": "e Raamá" },
        { "hebraico": "וְסַבְתְּכָ֑א", "transliteral": "wəsaḇətəḵāʾ", "traducao_palavra": "e Sabtecá" },
        { "hebraico": "וּבְנֵ֥י", "transliteral": "ûḇənê", "traducao_palavra": "e filhos de" },
        { "hebraico": "רַעְמָ֖ה", "transliteral": "raʿəmâ", "traducao_palavra": "Raamá" },
        { "hebraico": "שְׁבָ֥א", "transliteral": "šəḇāʾ", "traducao_palavra": "Sabá" },
        { "hebraico": "וּדְדָֽן׃", "transliteral": "ûḏəḏān", "traducao_palavra": "e Dedã" }
      ]
    },
    "8": {
      "traducao_completa": "E Cuxe gerou a Ninrode; este começou a ser poderoso na terra.",
      "palavras": [
        { "hebraico": "וְכ֖וּשׁ", "transliteral": "wəḵûš", "traducao_palavra": "E Cuxe" },
        { "hebraico": "יָלַ֣ד", "transliteral": "yālaḏ", "traducao_palavra": "gerou" },
        { "hebraico": "אֶת־נִמְרֹ֑ד", "transliteral": "ʾeṯ-nimərōḏ", "traducao_palavra": "[obj] Ninrode" },
        { "hebraico": "ה֣וּא", "transliteral": "hû", "traducao_palavra": "ele" },
        { "hebraico": "הֵחֵ֔ל", "transliteral": "hēḥēl", "traducao_palavra": "começou" },
        { "hebraico": "לִֽהְיֹ֥ות", "transliteral": "lihyôṯ", "traducao_palavra": "a ser" },
