{
  "livro": "Gênesis - בְּרֵאשִׁית - Bereshit",
  "capítulo": 45,
  "titulos": {},
  "versiculos": {
    "1": {
      "traducao_completa": "E não pôde José se conter diante de todos os que estavam em pé junto a ele, e clamou: Fazei sair a todo homem de junto de mim! E não ficou ninguém com ele quando José se deu a conhecer aos seus irmãos.",
      "palavras": [
        { "hebraico": "וְלֹא־יָכֹל", "transliteral": "wə-lō-yā-ḵōl", "traducao_palavra": "e não pôde" },
        { "hebraico": "יוֹסֵף", "transliteral": "yô-sēp̄", "traducao_palavra": "José" },
        { "hebraico": "לְהִתְאַפֵּק", "transliteral": "lə-hiṯ-ʾap-pēq", "traducao_palavra": "se conter" },
        { "hebraico": "לְכֹל", "transliteral": "lə-ḵōl", "traducao_palavra": "diante de todos" },
        { "hebraico": "הַנִּצָּבִים", "transliteral": "han-niṣ-ṣā-ḇîm", "traducao_palavra": "os que estavam em pé" },
        { "hebraico": "עָלָיו", "transliteral": "ʿā-lāw", "traducao_palavra": "junto a ele" },
        { "hebraico": "וַיִּקְרָא", "transliteral": "way-yiq-rā", "traducao_palavra": "e clamou" },
        { "hebraico": "הוֹצִיאוּ", "transliteral": "hô-ṣî-ʾû", "traducao_palavra": "fazei sair" },
        { "hebraico": "כָל־אִישׁ", "transliteral": "ḵāl-ʾîš", "traducao_palavra": "todo homem" },
        { "hebraico": "מֵעָלָי", "transliteral": "mē-ʿā-lāy", "traducao_palavra": "de junto de mim" },
        { "hebraico": "וְלֹא־עָמַד", "transliteral": "wə-lō-ʿā-maḏ", "traducao_palavra": "e não ficou/parou" },
        { "hebraico": "אִישׁ", "transliteral": "ʾîš", "traducao_palavra": "homem [ninguém]" },
        { "hebraico": "אִתּוֹ", "transliteral": "ʾit-tô", "traducao_palavra": "com ele" },
        { "hebraico": "בְּהִתְוַדַּע", "transliteral": "bə-hiṯ-wad-daʿ", "traducao_palavra": "ao dar-se a conhecer" },
        { "hebraico": "יוֹסֵף", "transliteral": "yô-sēp̄", "traducao_palavra": "José" },
        { "hebraico": "אֶל־אֶחָיו׃", "transliteral": "ʾel-ʾe-ḥāw", "traducao_palavra": "aos seus irmãos" }
      ]
    },
    "2": {
      "traducao_completa": "E levantou a sua voz com choro; e ouviram os egípcios, e ouviu a casa de Faraó.",
      "palavras": [
        { "hebraico": "וַיִּתֵּן", "transliteral": "way-yit-tēn", "traducao_palavra": "e levantou/deu" },
        { "hebraico": "אֶת־קֹלוֹ", "transliteral": "ʾeṯ-qō-lô", "traducao_palavra": "[a] sua voz" },
        { "hebraico": "בִּבְכִי", "transliteral": "biḇ-ḵî", "traducao_palavra": "em choro" },
        { "hebraico": "וַיִּשְׁמְעוּ", "transliteral": "way-yiš-mə-ʿû", "traducao_palavra": "e ouviram" },
        { "hebraico": "מִצְרַיִם", "transliteral": "miṣ-ra-yim", "traducao_palavra": "[os] egípcios" },
        { "hebraico": "וַיִּשְׁמַע", "transliteral": "way-yiš-maʿ", "traducao_palavra": "e ouviu" },
        { "hebraico": "בֵּית", "transliteral": "bêṯ", "traducao_palavra": "[a] casa de" },
        { "hebraico": "פַּרְעֹה׃", "transliteral": "par-ʿōh", "traducao_palavra": "Faraó" }
      ]
    },
    "3": {
      "traducao_completa": "E disse José aos seus irmãos: Eu sou José; ainda vive meu pai? E os seus irmãos não puderam responder-lhe, porque ficaram pasmados diante dele.",
      "palavras": [
        { "hebraico": "וַיֹּאמֶר", "transliteral": "way-yō-mer", "traducao_palavra": "e disse" },
        { "hebraico": "יוֹסֵף", "transliteral": "yô-sēp̄", "traducao_palavra": "José" },
        { "hebraico": "אֶל־אֶחָיו", "transliteral": "ʾel-ʾe-ḥāw", "traducao_palavra": "aos seus irmãos" },
        { "hebraico": "אֲנִי", "transliteral": "ʾă-nî", "traducao_palavra": "eu [sou]" },
        { "hebraico": "יוֹסֵף", "transliteral": "yô-sēp̄", "traducao_palavra": "José" },
        { "hebraico": "הַעוֹד", "transliteral": "ha-ʿôḏ", "traducao_palavra": "acaso ainda" },
        { "hebraico": "אָבִי", "transliteral": "ʾā-ḇî", "traducao_palavra": "meu pai" },
        { "hebraico": "חָי", "transliteral": "ḥāy", "traducao_palavra": "vive?" },
        { "hebraico": "וְלֹא־יָכְלוּ", "transliteral": "wə-lō-yā-ḵə-lû", "traducao_palavra": "e não puderam" },
        { "hebraico": "אֶחָיו", "transliteral": "ʾe-ḥāw", "traducao_palavra": "seus irmãos" },
        { "hebraico": "לַעֲנוֹת", "transliteral": "la-ʿă-nôṯ", "traducao_palavra": "responder" },
        { "hebraico": "אֹתוֹ", "transliteral": "ʾō-ṯô", "traducao_palavra": "a ele" },
        { "hebraico": "כִּי", "transliteral": "kî", "traducao_palavra": "porque" },
        { "hebraico": "נִבְהֲלוּ", "transliteral": "niḇ-hă-lû", "traducao_palavra": "ficaram pasmados" },
        { "hebraico": "מִפָּנָיו׃", "transliteral": "mip-pā-nāw", "traducao_palavra": "diante de sua face" }
      ]
    },
    "4": {
      "traducao_completa": "E disse José aos seus irmãos: Aproximai-vos de mim, peço-vos. E aproximaram-se. E disse: Eu sou José, vosso irmão, a quem vendestes para o Egito.",
      "palavras": [
        { "hebraico": "וַיֹּאמֶר", "transliteral": "way-yō-mer", "traducao_palavra": "e disse" },
        { "hebraico": "יוֹסֵף", "transliteral": "yô-sēp̄", "traducao_palavra": "José" },
        { "hebraico": "אֶל־אֶחָיו", "transliteral": "ʾel-ʾe-ḥāw", "traducao_palavra": "aos seus irmãos" },
        { "hebraico": "גְּשׁוּ־נָא", "transliteral": "gə-šû-nā", "traducao_palavra": "aproximai-vos peço" },
        { "hebraico": "אֵלַי", "transliteral": "ʾē-lay", "traducao_palavra": "de mim" },
        { "hebraico": "וַיִּגָּשׁוּ", "transliteral": "way-yiḡ-gā-šû", "traducao_palavra": "e aproximaram-se" },
        { "hebraico": "וַיֹּאמֶר", "transliteral": "way-yō-mer", "traducao_palavra": "e disse" },
        { "hebraico": "אֲנִי", "transliteral": "ʾă-nî", "traducao_palavra": "eu [sou]" },
        { "hebraico": "יוֹסֵף", "transliteral": "yô-sēp̄", "traducao_palavra": "José" },
        { "hebraico": "אֲחִיכֶם", "transliteral": "ă-ḥî-ḵem", "traducao_palavra": "vosso irmão" },
        { "hebraico": "אֲשֶׁר־מְכַרְתֶּם", "transliteral": "ʾă-šer-mə-ḵar-tem", "traducao_palavra": "a quem vendestes" },
        { "hebraico": "אֹתִי", "transliteral": "ʾō-ṯî", "traducao_palavra": "a mim" },
        { "hebraico": "מִצְרָיְמָה׃", "transliteral": "miṣ-rā-yə-mā", "traducao_palavra": "para o Egito" }
      ]
    },
    "5": {
      "traducao_completa": "E agora, não vos entristeçais, nem se acenda a vossa ira por me haverdes vendido para cá; porque para preservação de vida Deus me enviou diante de vós.",
      "palavras": [
        { "hebraico": "וְעַתָּה", "transliteral": "wə-ʿat-tāh", "traducao_palavra": "e agora" },
        { "hebraico": "אַל־תֵּעָצְבוּ", "transliteral": "ʾal-tê-ʿā-ṣə-ḇû", "traducao_palavra": "não vos entristeçais" },
        { "hebraico": "וְאַל־יִחַר", "transliteral": "wə-ʾal-yi-ḥar", "traducao_palavra": "e não se acenda" },
        { "hebraico": "בְּעֵינֵיכֶם", "transliteral": "bə-ʿê-nê-ḵem", "traducao_palavra": "em vossos olhos [ira]" },
        { "hebraico": "כִּי־מְכַרְתֶּם", "transliteral": "kî-mə-ḵar-tem", "traducao_palavra": "porque vendestes" },
        { "hebraico": "אֹתִי", "transliteral": "ʾō-ṯî", "traducao_palavra": "a mim" },
        { "hebraico": "הֵנָּה", "transliteral": "hēn-nā", "traducao_palavra": "para cá" },
        { "hebraico": "כִּי", "transliteral": "kî", "traducao_palavra": "porque" },
        { "hebraico": "לְמִחְיָה", "transliteral": "lə-miḥ-yā", "traducao_palavra": "para preservação de vida" },
        { "hebraico": "שְׁלָחַנִי", "transliteral": "šə-lā-ḥa-nî", "traducao_palavra": "enviou-me" },
        { "hebraico": "אֱלֹהִים", "transliteral": "ʾĕ-lō-hîm", "traducao_palavra": "Deus" },
        { "hebraico": "לִפְנֵיכֶם׃", "transliteral": "lip̄-nê-ḵem", "traducao_palavra": "diante de vós" }
      ]
    },
    "6": {
      "traducao_completa": "Pois já houve dois anos de fome no meio da terra, e ainda há cinco anos em que não haverá lavoura nem colheita.",
      "palavras": [
        { "hebraico": "כִּי־זֶה", "transliteral": "kî-zeh", "traducao_palavra": "pois estes" },
        { "hebraico": "שְׁנָתַיִם", "transliteral": "šə-nā-ṯa-yim", "traducao_palavra": "dois anos" },
        { "hebraico": "הָרָעָב", "transliteral": "hā-rā-ʿāḇ", "traducao_palavra": "[da] fome" },
        { "hebraico": "בְּקֶרֶב", "transliteral": "bə-qe-reḇ", "traducao_palavra": "no meio de" },
        { "hebraico": "הָאָרֶץ", "transliteral": "hā-ʾā-reṣ", "traducao_palavra": "a terra" },
        { "hebraico": "וְעוֹד", "transliteral": "wə-ʿôḏ", "traducao_palavra": "e ainda" },
        { "hebraico": "חָמֵשׁ", "transliteral": "ḥā-mēš", "traducao_palavra": "cinco" },
        { "hebraico": "שָׁנִים", "transliteral": "šā-nîm", "traducao_palavra": "anos" },
        { "hebraico": "אֲשֶׁר", "transliteral": "ʾă-šer", "traducao_palavra": "nos quais" },
        { "hebraico": "אֵין־חָרִישׁ", "transliteral": "ʾên-ḥā-rîš", "traducao_palavra": "não [haverá] lavoura" },
        { "hebraico": "וְקָצִיר׃", "transliteral": "wə-qā-ṣîr", "traducao_palavra": "nem colheita" }
      ]
    },
    "7": {
      "traducao_completa": "E Deus enviou-me diante de vós para estabelecer para vós um remanescente na terra e para preservar-vos a vida por um grande livramento.",
      "palavras": [
        { "hebraico": "וַיִּשְׁלָחֵנִי", "transliteral": "way-yiš-lā-ḥê-nî", "traducao_palavra": "e enviou-me" },
        { "hebraico": "אֱלֹהִים", "transliteral": "ʾĕ-lō-hîm", "traducao_palavra": "Deus" },
        { "hebraico": "לִפְנֵיכֶם", "transliteral": "lip̄-nê-ḵem", "traducao_palavra": "diante de vós" },
        { "hebraico": "לָשׂוּם", "transliteral": "lā-śûm", "traducao_palavra": "para pôr/estabelecer" },
        { "hebraico": "לָכֶם", "transliteral": "lā-ḵem", "traducao_palavra": "para vós" },
        { "hebraico": "שְׁאֵרִית", "transliteral": "šə-ʾē-rîṯ", "traducao_palavra": "um remanescente" },
        { "hebraico": "בָּאָרֶץ", "transliteral": "bā-ʾā-reṣ", "traducao_palavra": "na terra" },
        { "hebraico": "וּלְהַחֲיוֹת", "transliteral": "û-lə-ha-ḥă-yôṯ", "traducao_palavra": "e para vivificar/preservar" },
        { "hebraico": "לָכֶם", "transliteral": "lā-ḵem", "traducao_palavra": "para vós" },
        { "hebraico": "לִפְלֵיטָה", "transliteral": "lip̄-lê-ṭā", "traducao_palavra": "por um livramento" },
        { "hebraico": "גְּדֹלָה׃", "transliteral": "gə-ḏō-lā", "traducao_palavra": "grande" }
      ]
    },
    "8": {
      "traducao_completa": "E agora, não fostes vós que me enviastes para cá, mas sim Deus, que me pôs por pai de Faraó, e por senhor de toda a sua casa, e por governador em toda a terra do Egito.",
      "palavras": [
        { "hebraico": "וְעַתָּה", "transliteral": "wə-ʿat-tāh", "traducao_palavra": "e agora" },
        { "hebraico": "לֹא־אַתֶּם", "transliteral": "lō-ʾat-tem", "traducao_palavra": "não [fostes] vós" },
        { "hebraico": "שְׁלַחְתֶּם", "transliteral": "šə-laḥ-tem", "traducao_palavra": "que enviastes" },
        { "hebraico": "אֹתִי", "transliteral": "ʾō-ṯî", "traducao_palavra": "a mim" },
        { "hebraico": "הֵנָּה", "transliteral": "hēn-nā", "traducao_palavra": "para cá" },
        { "hebraico": "כִּי", "transliteral": "kî", "traducao_palavra": "mas sim" },
        { "hebraico": "הָאֱלֹהִים", "transliteral": "hā-ʾĕ-lō-hîm", "traducao_palavra": "o Deus" },
        { "hebraico": "וַיְשִׂימֵנִי", "transliteral": "way-śî-mê-nî", "traducao_palavra": "e me pôs" },
        { "hebraico": "לְאָב", "transliteral": "lə-ʾāḇ", "traducao_palavra": "por pai" },
        { "hebraico": "לְפַרְעֹה", "transliteral": "lə-p̄ar-ʿōh", "traducao_palavra": "de Faraó" },
        { "hebraico": "וּלְאָדוֹן", "transliteral": "û-lə-ʾā-ḏôn", "traducao_palavra": "e por senhor" },
        { "hebraico": "לְכָל־בֵּיתוֹ", "transliteral": "lə-ḵāl-bê-ṯô", "traducao_palavra": "de toda a sua casa" },
        { "hebraico": "וּמֹשֵׁל", "transliteral": "û-mō-šēl", "traducao_palavra": "e governador" },
        { "hebraico": "בְּכָל־אֶרֶץ", "transliteral": "bə-ḵāl-ʾe-reṣ", "traducao_palavra": "em toda terra de" },
        { "hebraico": "מִצְרָיִם׃", "transliteral": "miṣ-rā-yim", "traducao_palavra": "Egito" }
      ]
    },
    "9": {
      "traducao_completa": "Apressai-vos e subi ao meu pai, e dizei-lhe: Assim disse o teu filho José: Deus me pôs por senhor de todo o Egito; desce a mim, não te demores.",
      "palavras": [
        { "hebraico": "מַהֲרוּ", "transliteral": "ma-hă-rû", "traducao_palavra": "apressai-vos" },
        { "hebraico": "וַעֲלוּ", "transliteral": "wa-ʿă-lû", "traducao_palavra": "e subi" },
        { "hebraico": "אֶל־אָבִי", "transliteral": "ʾel-ʾā-ḇî", "traducao_palavra": "ao meu pai" },
        { "hebraico": "וַאֲמַרְתֶּם", "transliteral": "wa-ʾă-mar-tem", "traducao_palavra": "e dizei" },
        { "hebraico": "לוֹ", "transliteral": "lô", "traducao_palavra": "a ele" },
        { "hebraico": "כֹּה", "transliteral": "kō", "traducao_palavra": "assim" },
        { "hebraico": "אָמַר", "transliteral": "ʾā-mar", "traducao_palavra": "disse" },
        { "hebraico": "בִּנְךָ", "transliteral": "bin-ḵā", "traducao_palavra": "teu filho" },
        { "hebraico": "יוֹסֵף", "transliteral": "yô-sēp̄", "traducao_palavra": "José" },
        { "hebraico": "שָׂמַנִי", "transliteral": "śā-ma-nî", "traducao_palavra": "pôs-me" },
        { "hebraico": "אֱלֹהִים", "transliteral": "ʾĕ-lō-hîm", "traducao_palavra": "Deu" },
        { "hebraico": "לְאָדוֹן", "transliteral": "lə-ʾā-ḏôn", "traducao_palavra": "por senhor" },
        { "hebraico": "לְכָל־מִצְרָיִם", "transliteral": "lə-ḵāl-miṣ-rā-yim", "traducao_palavra": "de todo Egito" },
        { "hebraico": "רְדָה", "transliteral": "rə-ḏā", "traducao_palavra": "desce" },
        { "hebraico": "אֵלַי", "transliteral": "ʾē-lay", "traducao_palavra": "a mim" },
        { "hebraico": "אַל־תַּעֲמֹד׃", "transliteral": "ʾal-ta-ʿă-mōḏ", "traducao_palavra": "não te demores/pares" }
      ]
    },
    "10": {
      "traducao_completa": "E habitarás na terra de Gósen, e estarás perto de mim, tu e os teus filhos, e os filhos de teus filhos, e as tuas ovelhas, e as tuas vacas, e tudo o que tens.",
      "palavras": [
        { "hebraico": "וְיָשַׁבְתָּ", "transliteral": "wə-yā-šaḇ-tā", "traducao_palavra": "e habitarás" },
        { "hebraico": "בְאֶרֶץ־גֹּשֶׁן", "transliteral": "ḇə-ʾe-reṣ-gō-šen", "traducao_palavra": "na terra de Gósen" },
        { "hebraico": "וְהָיִיתָ", "transliteral": "wə-hā-yî-ṯā", "traducao_palavra": "e estarás" },
        { "hebraico": "קָרוֹב", "transliteral": "qā-rôḇ", "traducao_palavra": "perto" },
        { "hebraico": "אֵלַי", "transliteral": "ʾē-lay", "traducao_palavra": "de mim" },
        { "hebraico": "אַתָּה", "transliteral": "ʾat-tā", "traducao_palavra": "tu" },
        { "hebraico": "וּבָנֶיךָ", "transliteral": "û-ḇā-ne-ḵā", "traducao_palavra": "e teus filhos" },
        { "hebraico": "וּבְנֵי", "transliteral": "û-ḇə-nê", "traducao_palavra": "e filhos de" },
        { "hebraico": "בָנֶיךָ", "transliteral": "ḇā-ne-ḵā", "traducao_palavra": "teus filhos" },
        { "hebraico": "וְצֹאנְךָ", "transliteral": "wə-ṣōn-ḵā", "traducao_palavra": "e tuas ovelhas" },
        { "hebraico": "וּבְקָרְךָ", "transliteral": "û-ḇə-qār-ḵā", "traducao_palavra": "e tuas vacas" },
        { "hebraico": "וְכָל־אֲשֶׁר־לָךְ׃", "transliteral": "wə-ḵāl-ʾă-šer-lāḵ", "traducao_palavra": "e tudo que [é] teu" }
      ]
    },
    "11": {
      "traducao_completa": "E sustentar-te-ei ali, porque ainda haverá cinco anos de fome; para que não sejas reduzido à pobreza, tu e a tua casa, e tudo o que tens.",
      "palavras": [
        { "hebraico": "וְכִלְכַּלְתִּי", "transliteral": "wə-ḵil-kal-tî", "traducao_palavra": "e sustentarei" },
        { "hebraico": "אֹתְךָ", "transliteral": "ʾō-ṯə-ḵā", "traducao_palavra": "a ti" },
        { "hebraico": "שָׁם", "transliteral": "šām", "traducao_palavra": "ali" },
        { "hebraico": "כִּי־עוֹד", "transliteral": "kî-ʿôḏ", "traducao_palavra": "porque ainda" },
        { "hebraico": "חָמֵשׁ", "transliteral": "ḥā-mēš", "traducao_palavra": "cinco" },
        { "hebraico": "שָׁנִים", "transliteral": "šā-nîm", "traducao_palavra": "anos" },
        { "hebraico": "רָעָב", "transliteral": "rā-ʿāḇ", "traducao_palavra": "[de] fome" },
        { "hebraico": "פֶּן־תִּוָּרֵשׁ", "transliteral": "pen-tiw-wā-rēš", "traducao_palavra": "para que não sejas empobrecido" },
        { "hebraico": "אַתָּה", "transliteral": "ʾat-tā", "traducao_palavra": "tu" },
        { "hebraico": "וּבֵיתְךָ", "transliteral": "û-ḇê-ṯə-ḵā", "traducao_palavra": "e tua casa" },
        { "hebraico": "וְכָל־אֲשֶׁר־לָךְ׃", "transliteral": "wə-ḵāl-ʾă-šer-lāḵ", "traducao_palavra": "e tudo que [é] teu" }
      ]
    },
    "12": {
      "traducao_completa": "E eis que os vossos olhos veem, e os olhos do meu irmão Benjamim, que é a minha boca que fala convosco.",
      "palavras": [
        { "hebraico": "וְהִנֵּה", "transliteral": "wə-hin-nēh", "traducao_palavra": "e eis que" },
        { "hebraico": "עֵינֵיכֶם", "transliteral": "ʿê-nê-ḵem", "traducao_palavra": "vossos olhos" },
        { "hebraico": "רֹאוֹת", "transliteral": "rō-ʾôṯ", "traducao_palavra": "veem" },
        { "hebraico": "וְעֵינֵי", "transliteral": "wə-ʿê-nê", "traducao_palavra": "e os olhos de" },
        { "hebraico": "אָחִי", "transliteral": "ʾā-ḥî", "traducao_palavra": "meu irmão" },
        { "hebraico": "בִנְיָמִין", "transliteral": "ḇin-yā-mîn", "traducao_palavra": "Benjamim" },
        { "hebraico": "כִּי־פִי", "transliteral": "kî-p̄î", "traducao_palavra": "que minha boca" },
        { "hebraico": "הַמְדַבֵּר", "transliteral": "ham-ḏab-bēr", "traducao_palavra": "[é] que fala" },
        { "hebraico": "אֲלֵיכֶם׃", "transliteral": "ă-lê-ḵem", "traducao_palavra": "a vós" }
      ]
    },
    "13": {
      "traducao_completa": "E anunciai ao meu pai toda a minha glória no Egito, e tudo o que vistes; e apressai-vos e fazei descer o meu pai para cá.",
      "palavras": [
        { "hebraico": "וְהִגַּדְתֶּם", "transliteral": "wə-hig-gaḏ-tem", "traducao_palavra": "e anunciai" },
        { "hebraico": "לְאָבִי", "transliteral": "lə-ʾā-ḇî", "traducao_palavra": "ao meu pai" },
        { "hebraico": "אֶת־כָּל־כְּבוֹדִי", "transliteral": "ʾeṯ-kāl-kə-ḇô-ḏî", "traducao_palavra": "[a] toda minha glória" },
        { "hebraico": "בְּמִצְרַיִם", "transliteral": "bə-miṣ-ra-yim", "traducao_palavra": "no Egito" },
        { "hebraico": "וְאֵת", "transliteral": "wə-ʾēṯ", "traducao_palavra": "e" },
        { "hebraico": "כָּל־אֲשֶׁר", "transliteral": "kāl-ʾă-šer", "traducao_palavra": "tudo o que" },
        { "hebraico": "רְאִיתֶם", "transliteral": "rə-ʾî-ṯem", "traducao_palavra": "vistes" },
        { "hebraico": "וּמִהַרְתֶּם", "transliteral": "û-mi-har-tem", "traducao_palavra": "e apressai-vos" },
        { "hebraico": "וְהוֹרַדְתֶּם", "transliteral": "wə-hô-raḏ-tem", "traducao_palavra": "e fazei descer" },
        { "hebraico": "אֶת־אָבִי", "transliteral": "ʾeṯ-ʾā-ḇî", "traducao_palavra": "o meu pai" },
        { "hebraico": "הֵנָּה׃", "transliteral": "hēn-nā", "traducao_palavra": "para cá" }
      ]
    },
    "14": {
      "traducao_completa": "E lançou-se sobre o pescoço de Benjamim, seu irmão, e chorou; e Benjamim chorou sobre o seu pescoço.",
      "palavras": [
        { "hebraico": "וַיִּפֹּל", "transliteral": "way-yip-pōl", "traducao_palavra": "e lançou-se/caiu" },
        { "hebraico": "עַל־צַוְּארֵי", "transliteral": "ʿal-ṣaw-wə-rê", "traducao_palavra": "sobre o pescoço de" },
        { "hebraico": "בִנְיָמִן־אָחִיו", "transliteral": "ḇin-yā-min-ʾā-ḥîw", "traducao_palavra": "Benjamim seu irmão" },
        { "hebraico": "וַיֵּבְךְּ", "transliteral": "way-yē-ḇək", "traducao_palavra": "e chorou" },
        { "hebraico": "וּבִנְיָמִן", "transliteral": "û-ḇin-yā-mîn", "traducao_palavra": "e Benjamim" },
        { "hebraico": "בָּכָה", "transliteral": "bā-ḵā", "traducao_palavra": "chorou" },
        { "hebraico": "עַל־צַוָּארָיו׃", "transliteral": "ʿal-ṣaw-wā-rāw", "traducao_palavra": "sobre o seu pescoço" }
      ]
    },
    "15": {
      "traducao_completa": "E beijou a todos os seus irmãos, e chorou sobre eles; e depois os seus irmãos falaram com ele.",
      "palavras": [
        { "hebraico": "וַיְנַשֵּׁק", "transliteral": "way-naš-šēq", "traducao_palavra": "e beijou" },
        { "hebraico": "לְכָל־אֶחָיו", "transliteral": "lə-ḵāl-ʾe-ḥāw", "traducao_palavra": "a todos seus irmãos" },
        { "hebraico": "וַיֵּבְךְּ", "transliteral": "way-yē-ḇək", "traducao_palavra": "e chorou" },
        { "hebraico": "עֲלֵיהֶם", "transliteral": "ʿă-lê-hem", "traducao_palavra": "sobre eles" },
        { "hebraico": "וְאַחֲרֵי־כֵן", "transliteral": "wə-ʾa-ḥă-rê-ḵēn", "traducao_palavra": "e depois disso" },
        { "hebraico": "דִּבְּרוּ", "transliteral": "dib-bə-rû", "traducao_palavra": "falaram" },
        { "hebraico": "אֶחָיו", "transliteral": "ʾe-ḥāw", "traducao_palavra": "seus irmãos" },
        { "hebraico": "אִתּוֹ׃", "transliteral": "ʾit-tô", "traducao_palavra": "com ele" }
      ]
    },
    "16": {
      "traducao_completa": "E a voz foi ouvida na casa de Faraó, dizendo: Vieram os irmãos de José; e foi bom aos olhos de Faraó e aos olhos de seus servos.",
      "palavras": [
        { "hebraico": "וְהַקֹּל", "transliteral": "wə-haq-qōl", "traducao_palavra": "e a voz" },
        { "hebraico": "נִשְׁמַע", "transliteral": "niš-maʿ", "traducao_palavra": "foi ouvida [em]" },
        { "hebraico": "בֵּית", "transliteral": "bêṯ", "traducao_palavra": "casa de" },
        { "hebraico": "פַּרְעֹה", "transliteral": "par-ʿōh", "traducao_palavra": "Faraó" },
        { "hebraico": "לֵאמֹר", "transliteral": "lē-mōr", "traducao_palavra": "dizendo" },
        { "hebraico": "בָּאוּ", "transliteral": "bā-ʾû", "traducao_palavra": "vieram" },
        { "hebraico": "אֲחֵי", "transliteral": "ʾă-ḥê", "traducao_palavra": "os irmãos de" },
        { "hebraico": "יוֹסֵף", "transliteral": "yô-sēp̄", "traducao_palavra": "José" },
        { "hebraico": "וַיִּיטַב", "transliteral": "way-yî-ṭaḇ", "traducao_palavra": "e foi bom" },
        { "hebraico": "בְּעֵינֵי", "transliteral": "bə-ʿê-nê", "traducao_palavra": "aos olhos de" },
        { "hebraico": "פַרְעֹה", "transliteral": "p̄ar-ʿōh", "traducao_palavra": "Faraó" },
        { "hebraico": "וּבְעֵינֵי", "transliteral": "û-ḇə-ʿê-nê", "traducao_palavra": "e aos olhos de" },
        { "hebraico": "עֲבָדָיו׃", "transliteral": "ʿă-ḇā-ḏāw", "traducao_palavra": "seus servos" }
      ]
    },
    "17": {
      "traducao_completa": "E disse Faraó a José: Dize a teus irmãos: Fazei isto: carregai os vossos animais e ide, entrai na terra de Canaã.",
      "palavras": [
        { "hebraico": "וַיֹּאמֶר", "transliteral": "way-yō-mer", "traducao_palavra": "e disse" },
        { "hebraico": "פַּרְעֹה", "transliteral": "par-ʿōh", "traducao_palavra": "Faraó" },
        { "hebraico": "אֶל־יוֹסֵף", "transliteral": "ʾel-yô-sēp̄", "traducao_palavra": "a José" },
        { "hebraico": "אֱמֹר", "transliteral": "ʾĕ-mōr", "traducao_palavra": "dize" },
        { "hebraico": "אֶל־אַחֶיךָ", "transliteral": "ʾel-ʾa-ḥe-ḵā", "traducao_palavra": "a teus irmãos" },
        { "hebraico": "זֹאת", "transliteral": "zōṯ", "traducao_palavra": "isto" },
        { "hebraico": "עֲשׂוּ", "transliteral": "ʿă-śû", "traducao_palavra": "fazei" },
        { "hebraico": "טַעֲנוּ", "transliteral": "ṭa-ʿă-nû", "traducao_palavra": "carregai" },
        { "hebraico": "אֶת־בְּעִירְכֶם", "transliteral": "ʾeṯ-bə-ʿî-rə-ḵem", "traducao_palavra": "vossos animais" },
        { "hebraico": "וּלְכוּ־בֹאוּ", "transliteral": "û-lə-ḵû-ḇō-ʾû", "traducao_palavra": "e ide, entrai" },
        { "hebraico": "אַרְצָה", "transliteral": "ʾār-ṣā", "traducao_palavra": "[na] terra de" },
        { "hebraico": "כְּנָעַן׃", "transliteral": "kə-nā-ʿan", "traducao_palavra": "Canaã" }
      ]
    },
    "18": {
      "traducao_completa": "E tomai o vosso pai e as vossas casas e vinde a mim; e eu vos darei o melhor da terra do Egito, e comereis a gordura da terra.",
      "palavras": [
        { "hebraico": "וּקְחוּ", "transliteral": "û-qə-ḥû", "traducao_palavra": "e tomai" },
        { "hebraico": "אֶת־אֲבִיכֶם", "transliteral": "ʾeṯ-ʾă-ḇî-ḵem", "traducao_palavra": "o vosso pai" },
        { "hebraico": "וְאֶת־בָּתֵּיכֶם", "transliteral": "wə-ʾeṯ-bāt-tê-ḵem", "traducao_palavra": "e as vossas casas" },
        { "hebraico": "וּבֹאוּ", "transliteral": "û-ḇō-ʾû", "traducao_palavra": "e vinde" },
        { "hebraico": "אֵלָי", "transliteral": "ʾē-lāy", "traducao_palavra": "a mim" },
        { "hebraico": "וְאֶתְּנָה", "transliteral": "wə-ʾet-tə-nā", "traducao_palavra": "e eu darei" },
        { "hebraico": "לָכֶם", "transliteral": "lā-ḵem", "traducao_palavra": "a vós" },
        { "hebraico": "אֶת־טוּב", "transliteral": "ʾeṯ-ṭûḇ", "traducao_palavra": "o melhor de" },
        { "hebraico": "אֶרֶץ", "transliteral": "ʾe-reṣ", "traducao_palavra": "terra de" },
        { "hebraico": "מִצְרַיִם", "transliteral": "miṣ-ra-yim", "traducao_palavra": "Egito" },
        { "hebraico": "וְאִכְלוּ", "transliteral": "wə-ʾiḵ-lû", "traducao_palavra": "e comereis" },
        { "hebraico": "אֶת־חֵלֶב", "transliteral": "ʾeṯ-ḥē-leḇ", "traducao_palavra": "[a] gordura de" },
        { "hebraico": "הָאָרֶץ׃", "transliteral": "hā-ʾā-reṣ", "traducao_palavra": "a terra" }
      ]
    },
    "19": {
      "traducao_completa": "E tu, foste ordenado [a dizer]: Fazei isto: tomai para vós da terra do Egito carros para os vossos pequeninos e para as vossas mulheres, e trazei o vosso pai e vinde.",
      "palavras": [
        { "hebraico": "וְאַתָּה", "transliteral": "wə-ʾat-tā", "traducao_palavra": "e tu" },
        { "hebraico": "צֻוֵּיתָה", "transliteral": "ṣuw-wê-ṯā", "traducao_palavra": "foste ordenado" },
        { "hebraico": "זֹאת", "transliteral": "zōṯ", "traducao_palavra": "isto" },
        { "hebraico": "עֲשׂוּ", "transliteral": "ʿă-śû", "traducao_palavra": "fazei" },
        { "hebraico": "קְחוּ־לָכֶם", "transliteral": "qə-ḥû-lā-ḵem", "traducao_palavra": "tomai para vós" },
        { "hebraico": "מֵאֶרֶץ", "transliteral": "mē-ʾe-reṣ", "traducao_palavra": "da terra de" },
        { "hebraico": "מִצְרַיִם", "transliteral": "miṣ-ra-yim", "traducao_palavra": "Egito" },
        { "hebraico": "עֲגָלוֹת", "transliteral": "ʿă-ḡā-lôṯ", "traducao_palavra": "carros" },
        { "hebraico": "לְטַפְּכֶם", "transliteral": "lə-ṭap-pə-ḵem", "traducao_palavra": "para vossos pequeninos" },
        { "hebraico": "וְלִנְשֵׁיכֶם", "transliteral": "wə-lin-šê-ḵem", "traducao_palavra": "e para vossas mulheres" },
        { "hebraico": "וּנְשָׂאתֶם", "transliteral": "û-nə-śā-ṯem", "traducao_palavra": "e trazei/levantai" },
        { "hebraico": "אֶת־אֲבִיכֶם", "transliteral": "ʾeṯ-ʾă-ḇî-ḵem", "traducao_palavra": "o vosso pai" },
        { "hebraico": "וּבָאתֶם׃", "transliteral": "û-ḇā-ṯem", "traducao_palavra": "e vinde" }
      ]
    },
    "20": {
      "traducao_completa": "E não olhe o vosso olho para os vossos utensílios, porque o melhor de toda a terra do Egito é vosso.",
      "palavras": [
        { "hebraico": "וְעֵינְכֶם", "transliteral": "wə-ʿên-ḵem", "traducao_palavra": "e vosso olho" },
        { "hebraico": "אַל־תָּחֹס", "transliteral": "ʾal-tā-ḥōs", "traducao_palavra": "não tenha pena/olhe" },
        { "hebraico": "עַל־כְּלֵיכֶם", "transliteral": "ʿal-kə-lê-ḵem", "traducao_palavra": "sobre vossos utensílios" },
        { "hebraico": "כִּי־טוּב", "transliteral": "kî-ṭûḇ", "traducao_palavra": "porque o melhor de" },
        { "hebraico": "כָּל־אֶרֶץ", "transliteral": "kāl-ʾe-reṣ", "traducao_palavra": "toda terra de" },
        { "hebraico": "מִצְרַיִם", "transliteral": "miṣ-ra-yim", "traducao_palavra": "Egito" },
        { "hebraico": "לָכֶם", "transliteral": "lā-ḵem", "traducao_palavra": "para vós" },
        { "hebraico": "הוּא׃", "transliteral": "hû", "traducao_palavra": "é ela/ele" }
      ]
    },
    "21": {
      "traducao_completa": "E fizeram assim os filhos de Israel; e José deu-lhes carros conforme a ordem de Faraó, e deu-lhes provisão para o caminho.",
      "palavras": [
        { "hebraico": "וַיַּעֲשׂוּ־כֵן", "transliteral": "way-ya-ʿă-śû-ḵēn", "traducao_palavra": "e fizeram assim" },
        { "hebraico": "בְּנֵי", "transliteral": "bə-nê", "traducao_palavra": "filhos de" },
        { "hebraico": "יִשְׂרָאֵל", "transliteral": "yiś-rā-ʾēl", "traducao_palavra": "Israel" },
        { "hebraico": "וַיִּתֵּן", "transliteral": "way-yit-tēn", "traducao_palavra": "e deu" },
        { "hebraico": "לָהֶם", "transliteral": "lā-hem", "traducao_palavra": "a eles" },
        { "hebraico": "יוֹסֵף", "transliteral": "yô-sēp̄", "traducao_palavra": "José" },
        { "hebraico": "עֲגָלוֹת", "transliteral": "ʿă-ḡā-lôṯ", "traducao_palavra": "carros" },
        { "hebraico": "עַל־פִּי", "transliteral": "ʿal-pî", "traducao_palavra": "conforme a boca/ordem de" },
        { "hebraico": "פַרְעֹה", "transliteral": "p̄ar-ʿōh", "traducao_palavra": "Faraó" },
        { "hebraico": "וַיִּתֵּן", "transliteral": "way-yit-tēn", "traducao_palavra": "e deu" },
        { "hebraico": "לָהֶם", "transliteral": "lā-hem", "traducao_palavra": "a eles" },
        { "hebraico": "צֵדָה", "transliteral": "ṣê-ḏā", "traducao_palavra": "provisão" },
        { "hebraico": "לַדָּרֶךְ׃", "transliteral": "lad-dā-reḵ", "traducao_palavra": "para o caminho" }
      ]
    },
    "22": {
      "traducao_completa": "A todos eles deu, a cada um, mudas de vestes; mas a Benjamim deu trezentas [peças] de prata e cinco mudas de vestes.",
      "palavras": [
        { "hebraico": "לְכֻלָּם", "transliteral": "lə-ḵul-lām", "traducao_palavra": "a todos eles" },
        { "hebraico": "נָתַן", "transliteral": "nā-ṯān", "traducao_palavra": "deu" },
        { "hebraico": "לָאִישׁ", "transliteral": "lā-ʾîš", "traducao_palavra": "a cada um [ao homem]" },
        { "hebraico": "חֲלִפוֹת", "transliteral": "ḥă-li-p̄ôṯ", "traducao_palavra": "mudas de" },
        { "hebraico": "שְׂמָלֹת", "transliteral": "śə-mā-lōṯ", "traducao_palavra": "vestes" },
        { "hebraico": "וּלְבִנְיָמִן", "transliteral": "û-lə-ḇin-yā-min", "traducao_palavra": "e a Benjamim" },
        { "hebraico": "נָתַן", "transliteral": "nā-ṯān", "traducao_palavra": "deu" },
        { "hebraico": "שְׁלֹשׁ", "transliteral": "šə-lōš", "traducao_palavra": "três de" },
        { "hebraico": "מֵאוֹת", "transliteral": "mē-ʾôṯ", "traducao_palavra": "centenas [trezentas]" },
        { "hebraico": "כֶּסֶף", "transliteral": "ke-sep̄", "traducao_palavra": "[de] prata" },
        { "hebraico": "וְחָמֵשׁ", "transliteral": "wə-ḥā-mēš", "traducao_palavra": "e cinco" },
        { "hebraico": "חֲלִפֹת", "transliteral": "ḥă-li-p̄ōṯ", "traducao_palavra": "mudas de" },
        { "hebraico": "שְׂמָלֹת׃", "transliteral": "śə-mā-lōṯ", "traducao_palavra": "vestes" }
      ]
    },
    "23": {
      "traducao_completa": "E a seu pai enviou conforme isto: dez jumentos carregados do melhor do Egito, e dez jumentas carregadas de cereal e pão e mantimento para seu pai, para o caminho.",
      "palavras": [
        { "hebraico": "וּלְאָבִיו", "transliteral": "û-lə-ʾā-ḇîw", "traducao_palavra": "e para seu pai" },
        { "hebraico": "שָׁלַח", "transliteral": "šā-laḥ", "traducao_palavra": "enviou" },
        { "hebraico": "כְּזֹאת", "transliteral": "kə-zōṯ", "traducao_palavra": "conforme isto" },
        { "hebraico": "עֲשָׂרָה", "transliteral": "ă-śā-rāh", "traducao_palavra": "dez" },
        { "hebraico": "חֲמֹרִים", "transliteral": "ḥă-mō-rîm", "traducao_palavra": "jumentos" },
        { "hebraico": "נֹשְׂאִים", "transliteral": "nō-śə-ʾîm", "traducao_palavra": "carregando" },
        { "hebraico": "מִטּוּב", "transliteral": "miṭ-ṭûḇ", "traducao_palavra": "do melhor de" },
        { "hebraico": "מִצְרָיִם", "transliteral": "miṣ-rā-yim", "traducao_palavra": "Egito" },
        { "hebraico": "וְעֶשֶׂר", "transliteral": "wə-ʿe-śer", "traducao_palavra": "e dez" },
        { "hebraico": "אֲתֹנֹת", "transliteral": "ʾă-ṯō-nōṯ", "traducao_palavra": "jumentas" },
        { "hebraico": "נֹשְׂאֹת", "transliteral": "nō-śə-ʾōṯ", "traducao_palavra": "carregando" },
        { "hebraico": "בָּר", "transliteral": "bār", "traducao_palavra": "cereal" },
        { "hebraico": "וְלֶחֶם", "transliteral": "wə-le-ḥem", "traducao_palavra": "e pão" },
        { "hebraico": "וּמָזוֹן", "transliteral": "û-mā-zôn", "traducao_palavra": "e mantimento" },
        { "hebraico": "לְאָבִיו", "transliteral": "lə-ʾā-ḇîw", "traducao_palavra": "para seu pai" },
        { "hebraico": "לַדָּרֶךְ׃", "transliteral": "lad-dā-reḵ", "traducao_palavra": "para o caminho" }
      ]
    },
    "24": {
      "traducao_completa": "E despediu os seus irmãos, e eles foram; e disse-lhes: Não vos perturbeis no caminho.",
      "palavras": [
        { "hebraico": "וַיְשַׁלַּח", "transliteral": "way-šal-laḥ", "traducao_palavra": "e despediu" },
        { "hebraico": "אֶת־אֶחָיו", "transliteral": "ʾeṯ-ʾe-ḥāw", "traducao_palavra": "[os] seus irmãos" },
        { "hebraico": "וַיֵּלֵכוּ", "transliteral": "way-yê-lê-ḵû", "traducao_palavra": "e eles foram" },
        { "hebraico": "וַיֹּאמֶר", "transliteral": "way-yō-mer", "traducao_palavra": "e disse" },
        { "hebraico": "אֲלֵהֶם", "transliteral": "ʾă-lē-hem", "traducao_palavra": "a eles" },
        { "hebraico": "אַל־תִּרְגְּזוּ", "transliteral": "ʾal-tir-gə-zû", "traducao_palavra": "não vos perturbeis/brigueis" },
        { "hebraico": "בַּדָּרֶךְ׃", "transliteral": "bad-dā-reḵ", "traducao_palavra": "no caminho" }
      ]
    },
    "25": {
      "traducao_completa": "E subiram do Egito e vieram à terra de Canaã, a Jacó, seu pai.",
      "palavras": [
        { "hebraico": "וַיַּעֲלוּ", "transliteral": "way-ya-ʿă-lû", "traducao_palavra": "e subiram" },
        { "hebraico": "מִמִּצְרָיִם", "transliteral": "mim-miṣ-rā-yim", "traducao_palavra": "do Egito" },
        { "hebraico": "וַיָּבֹאוּ", "transliteral": "way-yā-ḇō-ʾû", "traducao_palavra": "e vieram" },
        { "hebraico": "אֶרֶץ", "transliteral": "ʾe-reṣ", "traducao_palavra": "[à] terra de" },
        { "hebraico": "כְּנָעַן", "transliteral": "kə-na-ʿan", "traducao_palavra": "Canaã" },
        { "hebraico": "אֶל־יַעֲקֹב", "transliteral": "ʾel-ya-ʿă-qōḇ", "traducao_palavra": "a Jacó" },
        { "hebraico": "אֲבִיהֶם׃", "transliteral": "ă-ḇî-hem", "traducao_palavra": "pai deles" }
      ]
    },
    "26": {
      "traducao_completa": "E anunciaram-lhe, dizendo: José ainda vive, e ele é governador em toda a terra do Egito. E seu coração desmaiou, pois não acreditava neles.",
      "palavras": [
        { "hebraico": "וַיַּגִּדוּ", "transliteral": "way-yag-gi-ḏû", "traducao_palavra": "e anunciaram" },
        { "hebraico": "לוֹ", "transliteral": "lô", "traducao_palavra": "a ele" },
        { "hebraico": "לֵאמֹר", "transliteral": "lē-mōr", "traducao_palavra": "dizendo" },
        { "hebraico": "עוֹד", "transliteral": "ʿôḏ", "traducao_palavra": "ainda" },
        { "hebraico": "יוֹסֵף", "transliteral": "yô-sēp̄", "traducao_palavra": "José" },
        { "hebraico": "חַי", "transliteral": "ḥay", "traducao_palavra": "vive" },
        { "hebraico": "וְכִי־הוּא", "transliteral": "wə-ḵî-hû", "traducao_palavra": "e que ele" },
        { "hebraico": "מֹשֵׁל", "transliteral": "mō-šēl", "traducao_palavra": "[é] governador" },
        { "hebraico": "בְּכָל־אֶרֶץ", "transliteral": "bə-ḵāl-ʾe-reṣ", "traducao_palavra": "em toda terra de" },
        { "hebraico": "מִצְרָיִם", "transliteral": "miṣ-rā-yim", "traducao_palavra": "Egito" },
        { "hebraico": "וַיָּפָג", "transliteral": "way-yā-p̄āḡ", "traducao_palavra": "e desmaiou/enfraqueceu" },
        { "hebraico": "לִבּוֹ", "transliteral": "lib-bô", "traducao_palavra": "seu coração" },
        { "hebraico": "כִּי", "transliteral": "kî", "traducao_palavra": "pois" },
        { "hebraico": "לֹא־הֶאֱמִין", "transliteral": "lō-he-ʾĕ-mîn", "traducao_palavra": "não acreditava" },
        { "hebraico": "לָהֶם׃", "transliteral": "lā-hem", "traducao_palavra": "neles" }
      ]
    },
    "27": {
      "traducao_completa": "E falaram-lhe todas as palavras de José, que ele lhes falara; e viu os carros que José enviara para levá-lo, e reviveu o espírito de Jacó, pai deles.",
      "palavras": [
        { "hebraico": "וַיְדַבְּרוּ", "transliteral": "way-ḏab-bə-rû", "traducao_palavra": "e falaram" },
        { "hebraico": "אֵלָיו", "transliteral": "ʾē-lāw", "traducao_palavra": "a ele" },
        { "hebraico": "אֵת", "transliteral": "ʾēṯ", "traducao_palavra": "[objeto]" },
        { "hebraico": "כָּל־דִּבְרֵי", "transliteral": "kāl-diḇ-rê", "traducao_palavra": "todas as palavras de" },
        { "hebraico": "יוֹסֵף", "transliteral": "yô-sēp̄", "traducao_palavra": "José" },
        { "hebraico": "אֲשֶׁר", "transliteral": "ʾă-šer", "traducao_palavra": "que" },
        { "hebraico": "דִּבֶּר", "transliteral": "dib-ber", "traducao_palavra": "falara" },
        { "hebraico": "אֲלֵהֶם", "transliteral": "ʾă-lē-hem", "traducao_palavra": "a eles" },
        { "hebraico": "וַיַּרְא", "transliteral": "way-yarʾ", "traducao_palavra": "e viu" },
        { "hebraico": "אֶת־הָעֲגָלוֹת", "transliteral": "ʾeṯ-hā-ʿă-ḡā-lôṯ", "traducao_palavra": "os carros" },
        { "hebraico": "אֲשֶׁר־שָׁלַח", "transliteral": "ʾă-šer-šā-laḥ", "traducao_palavra": "que enviara" },
        { "hebraico": "יוֹסֵף", "transliteral": "yô-sēp̄", "traducao_palavra": "José" },
        { "hebraico": "לָשֵׂאת", "transliteral": "lā-śēṯ", "traducao_palavra": "para levar" },
        { "hebraico": "אֹתוֹ", "transliteral": "ʾō-ṯô", "traducao_palavra": "a ele" },
        { "hebraico": "וַתְּחִי", "transliteral": "wat-tə-ḥî", "traducao_palavra": "e reviveu" },
        { "hebraico": "רוּחַ", "transliteral": "rû-aḥ", "traducao_palavra": "[o] espírito de" },
        { "hebraico": "יַעֲקֹב", "transliteral": "ya-ʿă-qōḇ", "traducao_palavra": "Jacó" },
        { "hebraico": "אֲבִיהֶם׃", "transliteral": "ă-ḇî-hem", "traducao_palavra": "pai deles" }
      ]
    },
    "28": {
      "traducao_completa": "E disse Israel: Basta! José, meu filho, ainda vive; irei e o verei antes que eu morra.",
      "palavras": [
        { "hebraico": "וַיֹּאמֶר", "transliteral": "way-yō-mer", "traducao_palavra": "e disse" },
        { "hebraico": "יִשְׂרָאֵל", "transliteral": "yiś-rā-ʾēl", "traducao_palavra": "Israel" },
        { "hebraico": "רַב", "transliteral": "raḇ", "traducao_palavra": "muito/basta" },
        { "hebraico": "עוֹד־יוֹסֵף", "transliteral": "ʿôḏ-yô-sēp̄", "traducao_palavra": "ainda José" },
        { "hebraico": "בְּנִי", "transliteral": "bə-nî", "traducao_palavra": "meu filho" },
        { "hebraico": "חָי", "transliteral": "ḥāy", "traducao_palavra": "vive" },
        { "hebraico": "אֵלְכָה", "transliteral": "ʾê-lə-ḵā", "traducao_palavra": "irei" },
        { "hebraico": "וְאֶרְאֶנּוּ", "transliteral": "wə-ʾer-ʾen-nû", "traducao_palavra": "e o verei" },
        { "hebraico": "בְּטֶרֶם", "transliteral": "bə-ṭe-rem", "traducao_palavra": "antes" },
        { "hebraico": "אָמוּת׃", "transliteral": "ʾā-mûṯ", "traducao_palavra": "[que] eu morra" }
      ]
    }
  }
