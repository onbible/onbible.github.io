    "10": {
      "traducao_completa": "E uniu cinco cortinas uma à outra; e as outras cinco cortinas uniu uma à outra.",
      "palavras": [
        { "hebraico": "וַיְחַבֵּר", "transliteral": "way-ḥab-bēr", "traducao_palavra": "e uniu" },
