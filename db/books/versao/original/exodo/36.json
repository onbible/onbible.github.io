    "11": {
      "traducao_completa": "E fez laçadas de azul na borda da cortina única, na extremidade, na junção; assim fez na borda da cortina da extremidade, na segunda junção.",
      "palavras": [
        { "hebraico": "וַיַּעַשׂ", "transliteral": "way-ya-ʿaś", "traducao_palavra": "e fez" },
