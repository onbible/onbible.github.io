        { "hebraico": "הָאַחַת", "transliteral": "hā-ʾa-ḥaṯ", "traducao_palavra": "a uma" },
        { "hebraico": "שְׁמֹנֶה", "transliteral": "šə-mō-neh", "traducao_palavra": "oito" },
