        { "hebraico": "אֶת־כַּסְפּוֹ", "transliteral": "ʾeṯ-kas-pô", "traducao_palavra": "o seu dinheiro" },
        { "hebraico": "וְגַם", "transliteral": "wə-ḡam", "traducao_palavra": "e também" },
