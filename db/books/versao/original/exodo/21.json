{
  "livro": "Êxodo - שְׁמוֹת - Shemot",
  "capítulo": 21,
  "titulos": {},
  "versiculos": {
    "1": {
      "traducao_completa": "E estes são os juízos que porás diante deles.",
      "palavras": [
        { "hebraico": "וְאֵלֶּה", "transliteral": "wə-ʾēl-leh", "traducao_palavra": "e estes [são]" },
        { "hebraico": "הַמִּשְׁפָּטִים", "transliteral": "ham-miš-pā-ṭîm", "traducao_palavra": "os juízos/decretos" },
        { "hebraico": "אֲשֶׁר", "transliteral": "ʾă-šer", "traducao_palavra": "que" },
        { "hebraico": "תָּשִׂים", "transliteral": "tā-śîm", "traducao_palavra": "porás" },
        { "hebraico": "לִפְנֵיהֶם׃", "transliteral": "lip̄-nê-hem", "traducao_palavra": "diante deles" }
      ]
    },
    "2": {
      "traducao_completa": "Quando comprares um servo hebreu, seis anos servirá; e no sétimo sairá livre, de graça.",
      "palavras": [
        { "hebraico": "כִּי", "transliteral": "kî", "traducao_palavra": "quando" },
        { "hebraico": "תִקְנֶה", "transliteral": "ṯiq-neh", "traducao_palavra": "comprares" },
        { "hebraico": "עֶבֶד", "transliteral": "ʿe-ḇeḏ", "traducao_palavra": "um servo" },
        { "hebraico": "עִבְרִי", "transliteral": "ʿiḇ-rî", "traducao_palavra": "hebreu" },
        { "hebraico": "שֵׁשׁ", "transliteral": "šēš", "traducao_palavra": "seis" },
        { "hebraico": "שָׁנִים", "transliteral": "šā-nîm", "traducao_palavra": "anos" },
        { "hebraico": "יַעֲבֹד", "transliteral": "ya-ʿă-ḇōḏ", "traducao_palavra": "servirá" },
        { "hebraico": "וּבַשְּׁבִעִת", "transliteral": "û-ḇaš-šə-ḇi-ʿiṯ", "traducao_palavra": "e no sétimo" },
        { "hebraico": "יֵצֵא", "transliteral": "yē-ṣē", "traducao_palavra": "sairá" },
        { "hebraico": "לַחָפְשִׁי", "transliteral": "la-ḥāp̄-šî", "traducao_palavra": "para o livre" },
        { "hebraico": "חִנָּם׃", "transliteral": "ḥin-nām", "traducao_palavra": "de graça" }
      ]
    },
    "3": {
      "traducao_completa": "Se entrou só com o seu corpo, só com o seu corpo sairá; se era homem casado, sairá sua mulher com ele.",
      "palavras": [
        { "hebraico": "אִם־בְּגַפּוֹ", "transliteral": "ʾim-bə-ḡap-pô", "traducao_palavra": "se com seu corpo/sozinho" },
        { "hebraico": "יָבֹא", "transliteral": "yā-ḇō", "traducao_palavra": "entrou" },
        { "hebraico": "בְּגַפּוֹ", "transliteral": "bə-ḡap-pô", "traducao_palavra": "com seu corpo" },
        { "hebraico": "יֵצֵא", "transliteral": "yē-ṣē", "traducao_palavra": "sairá" },
        { "hebraico": "אִם־בַּעַל", "transliteral": "ʾim-ba-ʿal", "traducao_palavra": "se senhor de" },
        { "hebraico": "אִשָּׁה", "transliteral": "ʾiš-šā", "traducao_palavra": "mulher" },
        { "hebraico": "הוּא", "transliteral": "hû", "traducao_palavra": "[era] ele" },
        { "hebraico": "וְיָצְאָה", "transliteral": "wə-yā-ṣə-ʾā", "traducao_palavra": "então sairá" },
        { "hebraico": "אִשְׁתּוֹ", "transliteral": "ʾiš-tô", "traducao_palavra": "sua mulher" },
        { "hebraico": "עִמּוֹ׃", "transliteral": "ʿim-mô", "traducao_palavra": "com ele" }
      ]
    },
    "4": {
      "traducao_completa": "Se o seu senhor lhe houver dado uma mulher e ela lhe houver dado à luz filhos ou filhas, a mulher e os seus filhos serão do seu senhor, e ele sairá só com o seu corpo.",
      "palavras": [
        { "hebraico": "אִם־אֲדֹנָיו", "transliteral": "ʾim-ʾă-ḏō-nāw", "traducao_palavra": "se o seu senhor" },
        { "hebraico": "יִתֶּן־לוֹ", "transliteral": "yit-ten-lô", "traducao_palavra": "der a ele" },
        { "hebraico": "אִשָּׁה", "transliteral": "ʾiš-šā", "traducao_palavra": "uma mulher" },
        { "hebraico": "וְיָלְדָה־לּוֹ", "transliteral": "wə-yā-lə-ḏā-lô", "traducao_palavra": "e ela der à luz a ele" },
        { "hebraico": "בָנִים", "transliteral": "ḇā-nîm", "traducao_palavra": "filhos" },
        { "hebraico": "אוֹ", "transliteral": "ʾô", "traducao_palavra": "ou" },
        { "hebraico": "בָנוֹת", "transliteral": "ḇā-nôṯ", "traducao_palavra": "filhas" },
        { "hebraico": "הָאִשָּׁה", "transliteral": "hā-ʾiš-šā", "traducao_palavra": "a mulher" },
        { "hebraico": "וִילָדֶיהָ", "transliteral": "wî-lā-ḏe-hā", "traducao_palavra": "e seus filhos" },
        { "hebraico": "תִּהְיֶה", "transliteral": "tih-yeh", "traducao_palavra": "será" },
        { "hebraico": "לַאדֹנֶיהָ", "transliteral": "la-ḏō-ne-hā", "traducao_palavra": "para o seu senhor" },
        { "hebraico": "וְהוּא", "transliteral": "wə-hû", "traducao_palavra": "e ele" },
        { "hebraico": "יֵצֵא", "transliteral": "yē-ṣē", "traducao_palavra": "sairá" },
        { "hebraico": "בְגַפּוֹ׃", "transliteral": "ḇə-ḡap-pô", "traducao_palavra": "com seu corpo" }
      ]
    },
    "5": {
      "traducao_completa": "Mas se o servo expressamente disser: Amo o meu senhor, a minha mulher e os meus filhos; não quero sair livre,",
      "palavras": [
        { "hebraico": "וְאִם־אָמֹר", "transliteral": "wə-ʾim-ʾā-mōr", "traducao_palavra": "e se dizendo" },
        { "hebraico": "יֹאמַר", "transliteral": "yō-mar", "traducao_palavra": "disser" },
        { "hebraico": "הָעֶבֶד", "transliteral": "hā-ʿe-ḇeḏ", "traducao_palavra": "o servo" },
        { "hebraico": "אָהַבְתִּי", "transliteral": "ʾā-haḇ-tî", "traducao_palavra": "amo" },
        { "hebraico": "אֶת־אֲדֹנִי", "transliteral": "ʾeṯ-ʾă-ḏō-nî", "traducao_palavra": "[o] meu senhor" },
        { "hebraico": "אֶת־אִשְׁתִּי", "transliteral": "ʾeṯ-ʾiš-tî", "traducao_palavra": "[a] minha mulher" },
        { "hebraico": "וְאֶת־בָּנָי", "transliteral": "wə-ʾeṯ-bā-nāy", "traducao_palavra": "e [os] meus filhos" },
        { "hebraico": "לֹא", "transliteral": "lō", "traducao_palavra": "não" },
        { "hebraico": "אֵצֵא", "transliteral": "ʾē-ṣē", "traducao_palavra": "sairei" },
        { "hebraico": "חָפְשִׁי׃", "transliteral": "ḥāp̄-šî", "traducao_palavra": "livre" }
      ]
    },
    "6": {
      "traducao_completa": "Então o seu senhor o levará aos juízes, e o fará chegar à porta ou ao umbral, e o seu senhor lhe furará a orelha com uma sovela; e ele o servirá para sempre.",
      "palavras": [
        { "hebraico": "וְהִגִּישׁוֹ", "transliteral": "wə-hig-gî-šô", "traducao_palavra": "e fará chegar ele" },
        { "hebraico": "אֲדֹנָיו", "transliteral": "ʾă-ḏō-nāw", "traducao_palavra": "seu senhor" },
        { "hebraico": "אֶל־הָאֱלֹהִים", "transliteral": "ʾel-hā-ʾĕ-lō-hîm", "traducao_palavra": "aos juízes/Deus" },
        { "hebraico": "וְהִגִּישׁוֹ", "transliteral": "wə-hig-gî-šô", "traducao_palavra": "e fará chegar ele" },
        { "hebraico": "אֶל־הַדֶּלֶת", "transliteral": "ʾel-had-de-leṯ", "traducao_palavra": "à porta" },
        { "hebraico": "אוֹ", "transliteral": "ʾô", "traducao_palavra": "ou" },
        { "hebraico": "אֶל־הַמְּזוּזָה", "transliteral": "ʾel-ham-mə-zû-zā", "traducao_palavra": "ao umbral" },
        { "hebraico": "וְרָצַע", "transliteral": "wə-rā-ṣaʿ", "traducao_palavra": "e furará" },
        { "hebraico": "אֲדֹנָיו", "transliteral": "ʾă-ḏō-nāw", "traducao_palavra": "seu senhor" },
        { "hebraico": "אֶת־אָזְנוֹ", "transliteral": "ʾeṯ-ʾāz-nô", "traducao_palavra": "sua orelha" },
        { "hebraico": "בַּמַּרְצֵעַ", "transliteral": "bam-mar-ṣē-aʿ", "traducao_palavra": "com a sovela" },
        { "hebraico": "וַעֲבָדוֹ", "transliteral": "wa-ʿă-ḇā-ḏô", "traducao_palavra": "e servirá a ele" },
        { "hebraico": "לְעֹלָם׃", "transliteral": "lə-ʿō-lām", "traducao_palavra": "para sempre" }
      ]
    },
    "7": {
      "traducao_completa": "E se um homem vender sua filha por serva, ela não sairá como saem os servos.",
      "palavras": [
        { "hebraico": "וְכִי־יִמְכֹּר", "transliteral": "wə-ḵî-yim-kōr", "traducao_palavra": "e se vender" },
        { "hebraico": "אִישׁ", "transliteral": "ʾîš", "traducao_palavra": "um homem" },
        { "hebraico": "אֶת־בִּתּוֹ", "transliteral": "ʾeṯ-bit-tô", "traducao_palavra": "sua filha" },
        { "hebraico": "לְאָמָה", "transliteral": "lə-ʾā-mā", "traducao_palavra": "por serva" },
        { "hebraico": "לֹא", "transliteral": "lō", "traducao_palavra": "não" },
        { "hebraico": "תֵצֵא", "transliteral": "ṯē-ṣē", "traducao_palavra": "sairá ela" },
        { "hebraico": "כְּצֵאת", "transliteral": "kə-ṣēṯ", "traducao_palavra": "como a saída de" },
        { "hebraico": "הָעֲבָדִים׃", "transliteral": "hā-ʿă-ḇā-ḏîm", "traducao_palavra": "os servos" }
      ]
    },
    "8": {
      "traducao_completa": "Se ela for má aos olhos de seu senhor, que não a desposou, então ele permitirá que ela seja resgatada; a um povo estranho não terá poder de vendê-la, por ter usado de fraude para com ela.",
      "palavras": [
        { "hebraico": "אִם־רָעָה", "transliteral": "ʾim-rā-ʿā", "traducao_palavra": "se má" },
        { "hebraico": "בְּעֵינֵי", "transliteral": "bə-ʿê-nê", "traducao_palavra": "aos olhos de" },
        { "hebraico": "אֲדֹנֶיהָ", "transliteral": "ă-ḏō-ne-hā", "traducao_palavra": "seu senhor" },
        { "hebraico": "אֲשֶׁר־לוֹ", "transliteral": "ʾă-šer-lô", "traducao_palavra": "que para ele" },
        { "hebraico": "יְעָדָהּ", "transliteral": "yə-ʿā-ḏāh", "traducao_palavra": "[não] a destinou/desposou [Qere]" },
        { "hebraico": "וְהֶפְדָּהּ", "transliteral": "wə-hep̄-dāh", "traducao_palavra": "então permitirá resgate" },
        { "hebraico": "לְעַם", "transliteral": "lə-ʿam", "traducao_palavra": "a povo" },
        { "hebraico": "נָכְרִי", "transliteral": "nā-ḵərî", "traducao_palavra": "estranho" },
        { "hebraico": "לֹא־יִמְשֹׁל", "transliteral": "lō-yim-šōl", "traducao_palavra": "não terá poder" },
        { "hebraico": "לְמָכְרָהּ", "transliteral": "lə-māḵ-rāh", "traducao_palavra": "de vendê-la" },
        { "hebraico": "בְּבִגְדוֹ־בָהּ׃", "transliteral": "bə-ḇiḡ-ḏô-ḇāh", "traducao_palavra": "por agir falsamente com ela" }
      ]
    },
    "9": {
      "traducao_completa": "Mas se a desposar para seu filho, fará com ela conforme o direito das filhas.",
      "palavras": [
        { "hebraico": "וְאִם־לִבְנוֹ", "transliteral": "wə-ʾim-liḇ-nô", "traducao_palavra": "e se para seu filho" },
        { "hebraico": "יִיעָדֶנָּה", "transliteral": "yî-ʿā-ḏen-nā", "traducao_palavra": "a desposar" },
        { "hebraico": "כְּמִשְׁפַּט", "transliteral": "kə-miš-paṭ", "traducao_palavra": "conforme o direito de" },
        { "hebraico": "הַבָּנוֹת", "transliteral": "hab-bā-nôṯ", "traducao_palavra": "as filhas" },
        { "hebraico": "יַעֲשֶׂה־לָּהּ׃", "transliteral": "ya-ʿă-śeh-lāh", "traducao_palavra": "fará para ela" }
      ]
    },
    "10": {
      "traducao_completa": "Se tomar para si outra, não diminuirá o mantimento dela, nem a sua veste, nem o seu direito conjugal.",
      "palavras": [
        { "hebraico": "אִם־אַחֶרֶת", "transliteral": "ʾim-ʾa-ḥe-reṯ", "traducao_palavra": "se outra" },
        { "hebraico": "יִקַּח־לוֹ", "transliteral": "yiq-qaḥ-lô", "traducao_palavra": "tomar para si" },
        { "hebraico": "שְׁאֵרָהּ", "transliteral": "šə-ʾē-rāh", "traducao_palavra": "o mantimento dela" },
        { "hebraico": "כְּסוּתָהּ", "transliteral": "kə-śû-ṯāh", "traducao_palavra": "sua veste" },
        { "hebraico": "וְעֹנָתָהּ", "transliteral": "wə-ʿō-nā-ṯāh", "traducao_palavra": "e seu dever conjugal" },
        { "hebraico": "לֹא", "transliteral": "lō", "traducao_palavra": "não" },
        { "hebraico": "יִגְרָע׃", "transliteral": "yiḡ-rāʿ", "traducao_palavra": "diminuirá" }
      ]
    },
    "11": {
      "traducao_completa": "E se não lhe fizer estas três coisas, ela sairá de graça, sem dinheiro.",
      "palavras": [
        { "hebraico": "וְאִם־שְׁלָשׁ־אֵלֶּה", "transliteral": "wə-ʾim-šə-lāš-ʾēl-leh", "traducao_palavra": "e se estas três" },
        { "hebraico": "לֹא", "transliteral": "lō", "traducao_palavra": "não" },
        { "hebraico": "יַעֲשֶׂה", "transliteral": "ya-ʿă-śeh", "traducao_palavra": "fizer" },
        { "hebraico": "לָּהּ", "transliteral": "lāh", "traducao_palavra": "para ela" },
        { "hebraico": "וְיָצְאָה", "transliteral": "wə-yā-ṣə-ʾā", "traducao_palavra": "então sairá ela" },
        { "hebraico": "חִנָּם", "transliteral": "ḥin-nām", "traducao_palavra": "de graça" },
        { "hebraico": "אֵין", "transliteral": "ʾên", "traducao_palavra": "sem" },
        { "hebraico": "כָּסֶף׃", "transliteral": "kā-sep̄", "traducao_palavra": "dinheiro" }
      ]
    },
    "12": {
      "traducao_completa": "Aquele que ferir a um homem, de modo que morra, certamente morrerá.",
      "palavras": [
        { "hebraico": "מַכֵּה", "transliteral": "mak-kēh", "traducao_palavra": "ferindo" },
        { "hebraico": "אִישׁ", "transliteral": "ʾîš", "traducao_palavra": "um homem" },
        { "hebraico": "וָמֵת", "transliteral": "wā-mēṯ", "traducao_palavra": "e morra" },
        { "hebraico": "מוֹת", "transliteral": "môṯ", "traducao_palavra": "morrendo" },
        { "hebraico": "יוּמָת׃", "transliteral": "yû-māṯ", "traducao_palavra": "certamente morrerá" }
      ]
    },
    "13": {
      "traducao_completa": "Mas se não lhe armou cilada, mas Deus o permitiu cair na sua mão, então te designarei um lugar para onde ele fugirá.",
      "palavras": [
        { "hebraico": "וַאֲשֶׁר", "transliteral": "wa-ʾă-šer", "traducao_palavra": "mas aquele que" },
        { "hebraico": "לֹא", "transliteral": "lō", "traducao_palavra": "não" },
        { "hebraico": "צָדָה", "transliteral": "ṣā-ḏā", "traducao_palavra": "armou cilada" },
        { "hebraico": "וְהָאֱלֹהִים", "transliteral": "wə-hā-ʾĕ-lō-hîm", "traducao_palavra": "mas o Deus" },
        { "hebraico": "אִנָּה", "transliteral": "ʾin-nā", "traducao_palavra": "fez ocorrer" },
        { "hebraico": "לְיָדוֹ", "transliteral": "lə-yā-ḏô", "traducao_palavra": "para sua mão" },
        { "hebraico": "וְשַׂמְתִּי", "transliteral": "wə-śam-tî", "traducao_palavra": "então porei" },
        { "hebraico": "לְךָ", "transliteral": "lə-ḵā", "traducao_palavra": "para ti" },
        { "hebraico": "מָקוֹם", "transliteral": "mā-qôm", "traducao_palavra": "um lugar" },
        { "hebraico": "אֲשֶׁר", "transliteral": "ʾă-šer", "traducao_palavra": "para onde" },
        { "hebraico": "יָנוּס", "transliteral": "yā-nûs", "traducao_palavra": "fugirá" },
        { "hebraico": "שָׁמָּה׃", "transliteral": "šām-mā", "traducao_palavra": "ali" }
      ]
    },
    "14": {
      "traducao_completa": "Mas se um homem se exaltar contra o seu próximo, para matá-lo com astúcia, do meu altar o tirarás, para que morra.",
      "palavras": [
        { "hebraico": "וְכִי־יָזִד", "transliteral": "wə-ḵî-yā-ziḏ", "traducao_palavra": "e se exaltar/agir presunçosamente" },
        { "hebraico": "אִישׁ", "transliteral": "ʾîš", "traducao_palavra": "um homem" },
        { "hebraico": "עַל־רֵעֵהוּ", "transliteral": "ʿal-rē-ʿē-hû", "traducao_palavra": "contra seu próximo" },
        { "hebraico": "לְהָרְגוֹ", "transliteral": "lə-hā-rə-ḡô", "traducao_palavra": "para matá-lo" },
