        { "hebraico": "כֶּסֶף", "transliteral": "ke-sep̄", "traducao_palavra": "dinheiro" },
        { "hebraico": "יָשִׁיב", "transliteral": "yā-šîḇ", "traducao_palavra": "devolverá" },
        { "hebraico": "לִבְעָלָיו", "transliteral": "liḇ-ʿā-lāw", "traducao_palavra": "ao dono dele" },
