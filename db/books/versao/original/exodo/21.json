        { "hebraico": "מֵעִם", "transliteral": "mē-ʿim", "traducao_palavra": "de com" },
        { "hebraico": "מִזְבְּחִי", "transliteral": "miz-bə-ḥî", "traducao_palavra": "meu altar" },
