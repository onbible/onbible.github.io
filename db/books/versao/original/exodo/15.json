        { "hebraico": "יִשְׂרָאֵל", "transliteral": "yiś-rā-ʾēl", "traducao_palavra": "Israel" },
        { "hebraico": "אֶת־הַשִּׁירָה", "transliteral": "ʾeṯ-haš-šî-rā", "traducao_palavra": "este cântico" },
        { "hebraico": "הַזֹּאת", "transliteral": "haz-zōṯ", "traducao_palavra": "este" },
        { "hebraico": "לַיהוָה", "transliteral": "la-YHWH", "traducao_palavra": "a YHWH" },
