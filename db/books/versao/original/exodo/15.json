        { "hebraico": "נֵהַלְתָּ", "transliteral": "nē-hal-tā", "traducao_palavra": "conduziste" },
        { "hebraico": "בְעָזְּךָ", "transliteral": "ḇə-ʿāz-zə-ḵā", "traducao_palavra": "com tua força" },
        { "hebraico": "אֶל־נְוֵה", "transliteral": "ʾel-nə-wē", "traducao_palavra": "à habitação de" },
