        { "hebraico": "נֶאְדָּרִי", "transliteral": "ne-ʾə-dā-rî", "traducao_palavra": "gloriosa" },
        { "hebraico": "בַּכֹּחַ", "transliteral": "bak-kō-aḥ", "traducao_palavra": "em poder" },
        { "hebraico": "יְמִינְךָ", "transliteral": "yə-mî-nə-ḵā", "traducao_palavra": "tua destra" },
        { "hebraico": "יְהוָה", "transliteral": "YHWH", "traducao_palavra": "YHWH" },
        { "hebraico": "תִּרְעַץ", "transliteral": "tir-ʿaṣ", "traducao_palavra": "despedaçou" },
        { "hebraico": "אוֹיֵב׃", "transliteral": "ʾô-yēḇ", "traducao_palavra": "inimigo" }
      ]
    },
    "7": {
      "traducao_completa": "E na grandeza da tua excelência derrubaste os que se levantaram contra ti; enviaste o teu furor, que os consumiu como restolho.",
      "palavras": [
        { "hebraico": "וּבְרֹב", "transliteral": "û-ḇə-rōḇ", "traducao_palavra": "e na multidão/grandeza de" },
        { "hebraico": "גְּאוֹנְךָ", "transliteral": "gə-ʾô-nə-ḵā", "traducao_palavra": "tua excelência" },
