        { "hebraico": "וַיֹּאמֶר", "transliteral": "way-yō-mer", "traducao_palavra": "e disse" },
        { "hebraico": "אִם־שָׁמוֹעַ", "transliteral": "ʾim-šā-mô-aʿ", "traducao_palavra": "se ouvindo" },
