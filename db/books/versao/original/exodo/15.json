        { "hebraico": "תְהֹמֹת", "transliteral": "ṯə-hō-mōṯ", "traducao_palavra": "abismos" },
        { "hebraico": "בְּלֶב־יָם׃", "transliteral": "bə-leḇ-yām", "traducao_palavra": "no coração do mar" }
