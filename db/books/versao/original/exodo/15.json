        { "hebraico": "שְׁמוֹ׃", "transliteral": "šə-mô", "traducao_palavra": "[é] seu nome" }
      ]
    },
    "4": {
      "traducao_completa": "Os carros de Faraó e o seu exército lançou no mar; e os escolhidos dos seus capitães foram afogados no Mar de Juncos.",
      "palavras": [
