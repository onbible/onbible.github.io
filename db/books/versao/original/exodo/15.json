        { "hebraico": "פַּרְעֹה", "transliteral": "par-ʿōh", "traducao_palavra": "Faraó" },
        { "hebraico": "וְחֵילוֹ", "transliteral": "wə-ḥê-lô", "traducao_palavra": "e seu exército" },
        { "hebraico": "יָרָה", "transliteral": "yā-rā", "traducao_palavra": "lançou" },
        { "hebraico": "בַיָּם", "transliteral": "ḇay-yām", "traducao_palavra": "no mar" },
