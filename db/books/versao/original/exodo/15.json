        { "hebraico": "תְּשַׁלַּח", "transliteral": "tə-šal-laḥ", "traducao_palavra": "enviaste" },
        { "hebraico": "חֲרֹנְךָ", "transliteral": "ḥă-rō-nə-ḵā", "traducao_palavra": "teu furor" },
        { "hebraico": "יֹאכְלֵמוֹ", "transliteral": "yō-ḵə-lê-mô", "traducao_palavra": "consumiu-os" },
        { "hebraico": "כַּקַּשׁ׃", "transliteral": "kaq-qaš", "traducao_palavra": "como restolho" }
      ]
    },
    "8": {
      "traducao_completa": "E com o sopro das tuas narinas amontoaram-se as águas; as correntes pararam como um montão; os abismos coalharam-se no coração do mar.",
