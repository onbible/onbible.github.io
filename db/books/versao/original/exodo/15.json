        { "hebraico": "יָרְדוּ", "transliteral": "yā-rə-ḏû", "traducao_palavra": "desceram" },
        { "hebraico": "בִמְצוֹלֹת", "transliteral": "ḇim-ṣô-lōṯ", "traducao_palavra": "nas profundezas" },
