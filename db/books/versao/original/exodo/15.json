    "9": {
      "traducao_completa": "Disse o inimigo: Perseguirei, alcançarei, repartirei o despojo; fartar-se-á deles a minha alma; arrancarei a minha espada, a minha mão os destruirá.",
      "palavras": [
        { "hebraico": "אָמַר", "transliteral": "ʾā-mar", "traducao_palavra": "disse" },
        { "hebraico": "אוֹיֵב", "transliteral": "ʾô-yēḇ", "traducao_palavra": "[o] inimigo" },
        { "hebraico": "אֶרְדֹּף", "transliteral": "ʾer-dōp̄", "traducao_palavra": "perseguirei" },
        { "hebraico": "אַשִּׂיג", "transliteral": "ʾaś-śîḡ", "traducao_palavra": "alcançarei" },
