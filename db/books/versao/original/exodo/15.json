    "11": {
      "traducao_completa": "Quem como tu entre os deuses, ó YHWH? Quem como tu, majestoso em santidade, terrível em louvores, fazendo maravilhas?",
      "palavras": [
        { "hebraico": "מִי־כָמֹכָה", "transliteral": "mî-ḵā-mō-ḵā", "traducao_palavra": "quem [é] como tu" },
        { "hebraico": "בָּאֵלִם", "transliteral": "bā-ʾē-lim", "traducao_palavra": "entre os deuses" },
        { "hebraico": "יְהוָה", "transliteral": "YHWH", "traducao_palavra": "YHWH" },
        { "hebraico": "מִי", "transliteral": "mî", "traducao_palavra": "quem" },
        { "hebraico": "כָּמֹכָה", "transliteral": "kā-mō-ḵā", "traducao_palavra": "como tu" },
