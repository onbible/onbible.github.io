    },
    "6": {
      "traducao_completa": "A tua destra, ó YHWH, gloriosa em poder; a tua destra, ó YHWH, despedaçou o inimigo.",
      "palavras": [
        { "hebraico": "יְמִינְךָ", "transliteral": "yə-mî-nə-ḵā", "traducao_palavra": "tua destra" },
