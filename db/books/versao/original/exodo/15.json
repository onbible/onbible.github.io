        { "hebraico": "וּבְרוּחַ", "transliteral": "û-ḇə-rû-aḥ", "traducao_palavra": "e com o espírito/vento de" },
        { "hebraico": "אַפֶּיךָ", "transliteral": "ʾap-pe-ḵā", "traducao_palavra": "tuas narinas" },
        { "hebraico": "נֶעֶרְמוּ", "transliteral": "ne-ʿer-mû", "traducao_palavra": "amontoaram-se" },
