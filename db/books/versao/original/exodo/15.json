        { "hebraico": "נָחִיתָ", "transliteral": "nā-ḥî-ṯā", "traducao_palavra": "guiaste" },
        { "hebraico": "בְחַסְדְּךָ", "transliteral": "ḇə-ḥas-də-ḵā", "traducao_palavra": "na tua benignidade" },
