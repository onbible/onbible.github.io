        { "hebraico": "פֶלֶא׃", "transliteral": "p̄e-leʾ", "traducao_palavra": "maravilha" }
      ]
    },
    "12": {
      "traducao_completa": "Estendeste a tua destra, a terra os engoliu.",
      "palavras": [
        { "hebraico": "נָטִיתָ", "transliteral": "nā-ṭî-ṯā", "traducao_palavra": "estendeste" },
