    "2": {
      "traducao_completa": "Minha força e meu cântico é Yah, e Ele foi para mim por salvação; este é o meu Deus, e eu lhe farei uma habitação; o Deus de meu pai, e eu o exaltarei.",
      "palavras": [
        { "hebraico": "עָזִּי", "transliteral": "ʿāz-zî", "traducao_palavra": "minha força" },
        { "hebraico": "וְזִמְרָת", "transliteral": "wə-zim-rāṯ", "traducao_palavra": "e meu cântico" },
        { "hebraico": "יָהּ", "transliteral": "yāh", "traducao_palavra": "Yah" },
        { "hebraico": "וַיְהִי־לִי", "transliteral": "way-hî-lî", "traducao_palavra": "e foi para mim" },
