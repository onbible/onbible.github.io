        { "hebraico": "חַרְבִּי", "transliteral": "ḥar-bî", "traducao_palavra": "minha espada" },
        { "hebraico": "תּוֹרִישֵׁמוֹ", "transliteral": "ṯô-rî-šē-mô", "traducao_palavra": "desapossará/destruirá a eles" },
        { "hebraico": "יָדִי׃", "transliteral": "yā-ḏî", "traducao_palavra": "minha mão" }
