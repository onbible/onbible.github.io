        { "hebraico": "זֶה", "transliteral": "zeh", "traducao_palavra": "este" },
        { "hebraico": "אֵלִי", "transliteral": "ʾē-lî", "traducao_palavra": "[é] meu Deus" },
        { "hebraico": "וְאַנְוֵהוּ", "transliteral": "wə-ʾan-wē-hû", "traducao_palavra": "e farei-lhe habitação" },
