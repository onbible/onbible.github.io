      ]
    },
    "15": {
      "traducao_completa": "E fizeram para o peitoral correntes de obra trançada, obra de cordão, de ouro puro.",
      "palavras": [
        { "hebraico": "וַיַּעֲשׂוּ", "transliteral": "way-ya-ʿă-śû", "traducao_palavra": "e fizeram" },
        { "hebraico": "עַל־הַחֹשֶׁן", "transliteral": "ʿal-ha-ḥō-šen", "traducao_palavra": "sobre o peitoral" }
      ]
    },
    "16": {
      "traducao_completa": "E fizeram dois engastes de ouro e duas argolas de ouro; e puseram as duas argolas nas duas extremidades do peitoral.",
      "palavras": [
        { "hebraico": "וַיַּעֲשׂוּ", "transliteral": "way-ya-ʿă-śû", "traducao_palavra": "e fizeram" },
        { "hebraico": "שְׁתֵּי", "transliteral": "šə-tê", "traducao_palavra": "duas de" },
        { "hebraico": "מִשְׁבְּצֹת", "transliteral": "miš-bə-ṣōṯ", "traducao_palavra": "engastes" }
      ]
    },
    "17": {
      "traducao_completa": "E puseram as duas tranças de ouro nas duas argolas, nas extremidades do peitoral.",
      "palavras": [
        { "hebraico": "וַיִּתְּנוּ", "transliteral": "way-yit-tə-nû", "traducao_palavra": "e puseram" }
      ]
    },
    "18": {
      "traducao_completa": "E as duas pontas das duas tranças puseram nos dois engastes; e as puseram sobre as ombreiras do efode, na sua parte dianteira.",
      "palavras": [
        { "hebraico": "וְאֵת", "transliteral": "wə-ʾēṯ", "traducao_palavra": "e" }
      ]
    },
    "19": {
      "traducao_completa": "E fizeram duas argolas de ouro e as puseram nas duas extremidades do peitoral, na sua borda, que estava junto ao efode, por dentro.",
      "palavras": [
        { "hebraico": "וַיַּעֲשׂוּ", "transliteral": "way-ya-ʿă-śû", "traducao_palavra": "e fizeram" }
      ]
    },
    "20": {
      "traducao_completa": "Fizeram mais duas argolas de ouro e as puseram nas duas ombreiras do efode, por baixo, na sua parte dianteira, junto à sua junção, sobre o cinto de obra esmerada do efode.",
      "palavras": [
        { "hebraico": "וַיַּעֲשׂוּ", "transliteral": "way-ya-ʿă-śû", "traducao_palavra": "e fizeram" }
      ]
    },
    "21": {
      "traducao_completa": "E ligaram o peitoral pelas suas argolas às argolas do efode com um cordão de azul, para que estivesse sobre o cinto de obra esmerada do efode, e não se apartasse o peitoral do efode, como YHWH ordenara a Moisés.",
      "palavras": [
        { "hebraico": "וַיִּרְכְּסוּ", "transliteral": "way-yir-kə-śû", "traducao_palavra": "e ligaram" },
        { "hebraico": "אֶת־הַחֹשֶׁן", "transliteral": "ʾeṯ-ha-ḥō-šen", "traducao_palavra": "o peitoral" }
      ]
    },
    "22": {
      "traducao_completa": "E fez o manto do efode de obra de tecelão, todo de azul.",
      "palavras": [
        { "hebraico": "וַיַּעַשׂ", "transliteral": "way-ya-ʿaś", "traducao_palavra": "e fez" },
        { "hebraico": "אֶת־מְעִיל", "transliteral": "ʾeṯ-mə-ʿîl", "traducao_palavra": "[o] manto de" },
        { "hebraico": "הָאֵפֹד", "transliteral": "hā-ʾê-p̄ōḏ", "traducao_palavra": "o efode" },
        { "hebraico": "מַעֲשֵׂה", "transliteral": "ma-ʿă-śēh", "traducao_palavra": "obra de" },
        { "hebraico": "אֹרֵג", "transliteral": "ʾō-rēḡ", "traducao_palavra": "tecelão" },
        { "hebraico": "כְּלִיל", "transliteral": "kə-lîl", "traducao_palavra": "todo de" },
        { "hebraico": "תְּכֵלֶת׃", "transliteral": "tə-ḵē-leṯ", "traducao_palavra": "azul" }
      ]
    },
    "23": {
      "traducao_completa": "E a abertura do manto no meio dele, como a abertura de uma cota de malha; uma orla para a sua abertura ao redor, para que não se rompesse.",
      "palavras": [
        { "hebraico": "וּפִי־הַמְּעִיל", "transliteral": "û-p̄î-ham-mə-ʿîl", "traducao_palavra": "e a abertura do manto" },
        { "hebraico": "בְּתוֹכוֹ", "transliteral": "bə-ṯô-ḵô", "traducao_palavra": "no meio dele" },
        { "hebraico": "כְּפִי", "transliteral": "kə-p̄î", "traducao_palavra": "como a abertura de" },
        { "hebraico": "תַחְרָא", "transliteral": "taḥ-rā", "traducao_palavra": "cota de malha" },
        { "hebraico": "שָׂפָה", "transliteral": "śā-p̄ā", "traducao_palavra": "uma orla" },
        { "hebraico": "לְפִיו", "transliteral": "lə-p̄îw", "traducao_palavra": "para sua abertura" },
        { "hebraico": "סָבִיב", "transliteral": "śā-ḇîḇ", "traducao_palavra": "ao redor" },
        { "hebraico": "לֹא", "transliteral": "lō", "traducao_palavra": "[para que] não" },
        { "hebraico": "יִקָּרֵעַ׃", "transliteral": "yiq-qā-rē-aʿ", "traducao_palavra": "se rompesse" }
      ]
    },
    "24": {
      "traducao_completa": "E fizeram nas abas do manto romãs de azul, e de púrpura, e de carmesim retorcido.",
      "palavras": [
        { "hebraico": "וַיַּעֲשׂוּ", "transliteral": "way-ya-ʿă-śû", "traducao_palavra": "e fizeram" },
        { "hebraico": "עַל־שׁוּלֵי", "transliteral": "ʿal-šû-lê", "traducao_palavra": "nas abas de" },
        { "hebraico": "הַמְּעִיל", "transliteral": "ham-mə-ʿîl", "traducao_palavra": "o manto" },
        { "hebraico": "רִמּוֹנֵי", "transliteral": "rim-mô-nê", "traducao_palavra": "romãs de" },
        { "hebraico": "תְּכֵלֶת", "transliteral": "tə-ḵē-leṯ", "traducao_palavra": "azul" }
      ]
    },
    "25": {
      "traducao_completa": "Fizeram também campainhas de ouro puro, e puseram as campainhas no meio das romãs, nas abas do manto ao redor, entre as romãs.",
      "palavras": [
        { "hebraico": "וַיַּעֲשׂוּ", "transliteral": "way-ya-ʿă-śû", "traducao_palavra": "e fizeram" },
        { "hebraico": "פַעֲמֹנֵי", "transliteral": "p̄a-ʿă-mō-nê", "traducao_palavra": "campainhas de" },
        { "hebraico": "זָהָב", "transliteral": "zā-hāḇ", "traducao_palavra": "ouro" },
        { "hebraico": "טָהוֹר", "transliteral": "ṭā-hôr", "traducao_palavra": "puro" }
      ]
    },
    "26": {
      "traducao_completa": "Uma campainha e uma romã, uma campainha e uma romã, nas abas do manto ao redor, para ministrar, como YHWH ordenara a Moisés.",
      "palavras": [
        { "hebraico": "פַּעֲמֹן", "transliteral": "pa-ʿă-mōn", "traducao_palavra": "uma campainha" },
        { "hebraico": "וְרִמּוֹן", "transliteral": "wə-rim-môn", "traducao_palavra": "e uma romã" }
      ]
    },
    "27": {
      "traducao_completa": "E fizeram as túnicas de linho fino, obra de tecelão, para Arão e para seus filhos.",
      "palavras": [
        { "hebraico": "וַיַּעֲשׂוּ", "transliteral": "way-ya-ʿă-śû", "traducao_palavra": "e fizeram" },
        { "hebraico": "אֶת־הַכֻּתֳּנֹת", "transliteral": "ʾeṯ-hak-kut-to-nōṯ", "traducao_palavra": "as túnicas" },
