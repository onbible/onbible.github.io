      ]
    },
    "2": {
      "traducao_completa": "E fez o efode de ouro, azul, púrpura, carmesim e linho fino retorcido.",
      "palavras": [
        { "hebraico": "וַיַּעַשׂ", "transliteral": "way-ya-ʿaś", "traducao_palavra": "e fez" },
        { "hebraico": "אֶת־הָאֵפֹד", "transliteral": "ʾeṯ-hā-ʾê-p̄ōḏ", "traducao_palavra": "o efode" },
        { "hebraico": "זָהָב", "transliteral": "zā-hāḇ", "traducao_palavra": "ouro" },
