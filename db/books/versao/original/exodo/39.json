      ]
    },
    "13": {
      "traducao_completa": "E a quarta fileira: berilo, ônix e jaspe; engastadas em engastes de ouro nos seus engastes.",
      "palavras": [
        { "hebraico": "וְהַטּוּר", "transliteral": "wə-ha-ṭûr", "traducao_palavra": "e a fileira" },
        { "hebraico": "הָרְבִיעִי", "transliteral": "hā-rə-ḇî-ʿî", "traducao_palavra": "a quarta" }
      ]
    },
    "14": {
      "traducao_completa": "E as pedras eram conforme os nomes dos filhos de Israel, doze segundo os seus nomes; gravuras de selo, cada uma com o seu nome, para as doze tribos.",
      "palavras": [
        { "hebraico": "וְהָאֲבָנִים", "transliteral": "wə-hā-ʾă-ḇā-nîm", "traducao_palavra": "e as pedras" },
