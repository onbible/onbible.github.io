        { "hebraico": "אֶת־בִּגְדֵי", "transliteral": "ʾeṯ-biḡ-ḏê", "traducao_palavra": "as vestes de" },
        { "hebraico": "הַקֹּדֶשׁ", "transliteral": "ha-qō-ḏeš", "traducao_palavra": "santidade" },
        { "hebraico": "אֲשֶׁר", "transliteral": "ʾă-šer", "traducao_palavra": "que [eram]" },
        { "hebraico": "לְאַהֲרֹן", "transliteral": "lə-ʾa-hă-rōn", "traducao_palavra": "para Arão" },
