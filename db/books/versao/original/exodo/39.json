    "3": {
      "traducao_completa": "E bateram as lâminas de ouro, e as cortou em fios, para tecê-las no meio do azul, e no meio da púrpura, e no meio do carmesim, e no meio do linho fino, obra de artífice.",
      "palavras": [
        { "hebraico": "וַיְרַקְּעוּ", "transliteral": "way-raq-qə-ʿû", "traducao_palavra": "e bateram/estenderam" },
        { "hebraico": "אֶת־פַּחֵי", "transliteral": "ʾeṯ-pa-ḥê", "traducao_palavra": "[as] lâminas de" },
        { "hebraico": "הַזָּהָב", "transliteral": "haz-zā-hāḇ", "traducao_palavra": "o ouro" },
        { "hebraico": "וְקִצֵּץ", "transliteral": "wə-qiṣ-ṣēṣ", "traducao_palavra": "e cortou" },
        { "hebraico": "פְּתִילִם", "transliteral": "pə-ṯî-lim", "traducao_palavra": "fios" },
        { "hebraico": "לַעֲשׂוֹת", "transliteral": "la-ʿă-śôṯ", "traducao_palavra": "para fazer/trabalhar" },
        { "hebraico": "בְּתוֹךְ", "transliteral": "bə-ṯôḵ", "traducao_palavra": "no meio de" }
      ]
    },
    "4": {
      "traducao_completa": "Fizeram-lhe ombreiras que se uniam; nas suas duas extremidades se unia.",
      "palavras": [
        { "hebraico": "כְּתֵפֹת", "transliteral": "ḵə-ṯē-p̄ōṯ", "traducao_palavra": "ombreiras" },
        { "hebraico": "עָשׂוּ־לוֹ", "transliteral": "ʿā-śû-lô", "traducao_palavra": "fizeram para ele" },
        { "hebraico": "חֹבְרֹת", "transliteral": "ḥō-ḇə-rōṯ", "traducao_palavra": "unidas" }
      ]
    },
    "5": {
      "traducao_completa": "E o cinto de obra esmerada que estava sobre ele era da mesma obra, de uma só peça com ele; de ouro, azul, púrpura, carmesim e linho fino retorcido, como YHWH ordenara a Moisés.",
      "palavras": [
        { "hebraico": "וְחֵשֶׁב", "transliteral": "wə-ḥē-šeḇ", "traducao_palavra": "e o cinto de" },
        { "hebraico": "אֲפֻדָּתוֹ", "transliteral": "ʾă-p̄ud-dā-ṯô", "traducao_palavra": "seu efode" },
        { "hebraico": "אֲשֶׁר", "transliteral": "ʾă-šer", "traducao_palavra": "que [estava]" },
        { "hebraico": "עָלָיו", "transliteral": "ʿā-lāyw", "traducao_palavra": "sobre ele" }
      ]
    },
    "6": {
      "traducao_completa": "E prepararam as pedras de ônix, engastadas em engastes de ouro, gravadas com gravuras de selo, com os nomes dos filhos de Israel.",
      "palavras": [
        { "hebraico": "וַיַּעֲשׂוּ", "transliteral": "way-ya-ʿă-śû", "traducao_palavra": "e fizeram/prepararam" },
        { "hebraico": "אֶת־אַבְנֵי", "transliteral": "ʾeṯ-ʾaḇ-nê", "traducao_palavra": "as pedras de" },
        { "hebraico": "הַשֹּׁהַם", "transliteral": "ha-šō-ham", "traducao_palavra": "o ônix" }
      ]
    },
    "7": {
      "traducao_completa": "E as pôs sobre as ombreiras do efode, por pedras de memorial para os filhos de Israel, como YHWH ordenara a Moisés.",
      "palavras": [
        { "hebraico": "וַיָּשֶׂם", "transliteral": "way-yā-śem", "traducao_palavra": "e as pôs" },
        { "hebraico": "אֹתָם", "transliteral": "ʾō-ṯām", "traducao_palavra": "elas" },
        { "hebraico": "עַל", "transliteral": "ʿal", "traducao_palavra": "sobre" },
        { "hebraico": "כִּתְפֹת", "transliteral": "kiṯ-p̄ōṯ", "traducao_palavra": "ombreiras de" },
        { "hebraico": "הָאֵפֹד", "transliteral": "hā-ʾê-p̄ōḏ", "traducao_palavra": "o efode" }
      ]
    },
    "8": {
      "traducao_completa": "E fez o peitoral de obra de artífice, como a obra do efode: de ouro, azul, púrpura, carmesim e linho fino retorcido.",
      "palavras": [
        { "hebraico": "וַיַּעַשׂ", "transliteral": "way-ya-ʿaś", "traducao_palavra": "e fez" },
        { "hebraico": "אֶת־הַחֹשֶׁן", "transliteral": "ʾeṯ-ha-ḥō-šen", "traducao_palavra": "o peitoral" },
        { "hebraico": "מַעֲשֵׂה", "transliteral": "ma-ʿă-śēh", "traducao_palavra": "obra de" },
        { "hebraico": "חֹשֵׁב", "transliteral": "ḥō-šēḇ", "traducao_palavra": "artífice" }
      ]
    },
    "9": {
      "traducao_completa": "Quadrado era; dobrado fizeram o peitoral; um palmo era o seu comprimento, e um palmo a sua largura, sendo dobrado.",
      "palavras": [
        { "hebraico": "רָבוּעַ", "transliteral": "rā-ḇû-aʿ", "traducao_palavra": "quadrado" },
        { "hebraico": "הָיָה", "transliteral": "hā-yā", "traducao_palavra": "era" },
        { "hebraico": "כָּפוּל", "transliteral": "kā-p̄ûl", "traducao_palavra": "dobrado" }
      ]
    },
    "10": {
      "traducao_completa": "E encheram nele quatro fileiras de pedras: a primeira fileira de sárdio, topázio e carbúnculo; esta era a primeira fileira.",
      "palavras": [
        { "hebraico": "וַיְמַלְאוּ־בוֹ", "transliteral": "way-mal-ʾû-ḇô", "traducao_palavra": "e encheram nele" },
        { "hebraico": "אַרְבָּעָה", "transliteral": "ʾar-bā-ʿā", "traducao_palavra": "quatro" },
        { "hebraico": "טוּרֵי", "transliteral": "ṭû-rê", "traducao_palavra": "fileiras de" },
        { "hebraico": "אָבֶן", "transliteral": "ʾā-ḇen", "traducao_palavra": "pedra" }
      ]
    },
    "11": {
      "traducao_completa": "E a segunda fileira: esmeralda, safira e diamante.",
      "palavras": [
        { "hebraico": "וְהַטוּר", "transliteral": "wə-ha-ṭûr", "traducao_palavra": "e a fileira" },
        { "hebraico": "הַשֵּׁנִי", "transliteral": "haš-šê-nî", "traducao_palavra": "a segunda" }
      ]
    },
    "12": {
      "traducao_completa": "E a terceira fileira: jacinto, ágata e ametista.",
      "palavras": [
        { "hebraico": "וְהַטּוּר", "transliteral": "wə-ha-ṭûr", "traducao_palavra": "e a fileira" },
