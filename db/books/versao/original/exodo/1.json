{
  "livro": "Êxodo - שְׁמוֹת - Shemot",
  "capítulo": 1,
  "titulos": {},
  "versiculos": {
    "1": {
      "traducao_completa": "E estes são os nomes dos filhos de Israel que vieram para o Egito; com Jacó vieram, cada um com sua casa.",
      "palavras": [
        { "hebraico": "וְאֵלֶּה", "transliteral": "wə-ʾēl-leh", "traducao_palavra": "e estes [são]" },
        { "hebraico": "שְׁמוֹת", "transliteral": "šə-môṯ", "traducao_palavra": "[os] nomes de" },
        { "hebraico": "בְּנֵי", "transliteral": "bə-nê", "traducao_palavra": "filhos de" },
        { "hebraico": "יִשְׂרָאֵל", "transliteral": "yiś-rā-ʾēl", "traducao_palavra": "Israel" },
        { "hebraico": "הַבָּאִים", "transliteral": "hab-bā-ʾîm", "traducao_palavra": "os que vieram" },
        { "hebraico": "מִצְרַיְמָה", "transliteral": "miṣ-ray-māh", "traducao_palavra": "[ao] Egito" },
        { "hebraico": "אֵת", "transliteral": "ʾēṯ", "traducao_palavra": "[com]" },
        { "hebraico": "יַעֲקֹב", "transliteral": "ya-ʿă-qōḇ", "traducao_palavra": "Jacó" },
        { "hebraico": "אִישׁ", "transliteral": "ʾîš", "traducao_palavra": "cada um" },
        { "hebraico": "וּבֵיתוֹ", "transliteral": "û-ḇê-ṯô", "traducao_palavra": "e sua casa" }
      ]
    },
    "2": {
