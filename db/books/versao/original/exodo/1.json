      ]
    },
    "11": {
      "traducao_completa": "E puseram sobre eles feitores de tributos, para os afligirem com suas cargas; e edificaram a Faraó cidades-celeiros, Pitom e Ramessés.",
      "palavras": [
        { "hebraico": "וַיָּשִׂימוּ", "transliteral": "way-yā-śî-mû", "traducao_palavra": "e puseram" },
        { "hebraico": "עֲלֵיהֶם", "transliteral": "ʿă-lê-hem", "traducao_palavra": "sobre eles" },
        { "hebraico": "שָׂרֵי", "transliteral": "śā-rê", "traducao_palavra": "chefes de" },
        { "hebraico": "מִסִּים", "transliteral": "mis-sîm", "traducao_palavra": "tributos" },
        { "hebraico": "לְמַעַן", "transliteral": "lə-ma-ʿan", "traducao_palavra": "para afligi-los" },
        { "hebraico": "עַנֹּת", "transliteral": "ʿan-nōṯ", "traducao_palavra": "com suas cargas" },
        { "hebraico": "וַיִּבֶן", "transliteral": "way-yi-ḇen", "traducao_palavra": "e edificaram" },
        { "hebraico": "עָרֵי", "transliteral": "ʿā-rê", "traducao_palavra": "cidades de" },
        { "hebraico": "מִסְכְּנוֹת", "transliteral": "mis-kə-nōṯ", "traducao_palavra": "armazéns" },
        { "hebraico": "לְפַרְעֹה", "transliteral": "lə-p̄ar-ʿōh", "traducao_palavra": "para Faraó" },
        { "hebraico": "אֶת־פִּתֹם", "transliteral": "ʾeṯ-piṯ-ōm", "traducao_palavra": "Pitom" },
        { "hebraico": "וְאֶת־רַעַמְסֵס׃", "transliteral": "wə-ʾeṯ-ra-ʿam-sēs", "traducao_palavra": "e Ramessés" }
      ]
    },
    "12": {
      "traducao_completa": "Mas quanto mais os afligiam, tanto mais se multiplicavam e tanto mais se espalhavam; e sentiram horror diante dos filhos de Israel.",
      "palavras": [
        { "hebraico": "וְכַאֲשֶׁר", "transliteral": "wə-ḵa-ʾă-šer", "traducao_palavra": "e conforme/quanto mais" },
        { "hebraico": "יְעַנּוּ", "transliteral": "yə-ʿan-nû", "traducao_palavra": "afligiam" },
        { "hebraico": "אֹתוֹ", "transliteral": "ʾō-ṯô", "traducao_palavra": "a ele [o povo]" },
        { "hebraico": "כֵּן", "transliteral": "kēn", "traducao_palavra": "assim/tanto mais" },
        { "hebraico": "יִרְבֶּה", "transliteral": "yir-beh", "traducao_palavra": "se multiplicava" },
        { "hebraico": "וְכֵן", "transliteral": "wə-ḵēn", "traducao_palavra": "e assim" },
        { "hebraico": "יִפְרֹץ", "transliteral": "yip̄-rōṣ", "traducao_palavra": "rompia/espalhava" },
        { "hebraico": "וַיָּקֻצוּ", "transliteral": "way-yā-qu-ṣû", "traducao_palavra": "e sentiram horror/enfado" },
        { "hebraico": "מִפְּנֵי", "transliteral": "mip-pə-nê", "traducao_palavra": "diante de/por causa de" },
        { "hebraico": "בְּנֵי", "transliteral": "bə-nê", "traducao_palavra": "filhos de" },
        { "hebraico": "יִשְׂרָאֵל׃", "transliteral": "yiś-rā-ʾēl", "traducao_palavra": "Israel" }
      ]
    },
    "13": {
      "traducao_completa": "E os egípcios fizeram os filhos de Israel servir com rigor.",
      "palavras": [
        { "hebraico": "וַיַּעֲבִדוּ", "transliteral": "way-ya-ʿă-ḇi-ḏû", "traducao_palavra": "e fizeram servir" },
        { "hebraico": "מִצְרַיִם", "transliteral": "miṣ-ra-yim", "traducao_palavra": "egípcios" },
        { "hebraico": "אֶת־בְּנֵי", "transliteral": "ʾeṯ-bə-nê", "traducao_palavra": "[os] filhos de" },
        { "hebraico": "יִשְׂרָאֵל", "transliteral": "yiś-rā-ʾēl", "traducao_palavra": "Israel" },
