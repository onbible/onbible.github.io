        { "hebraico": "וַיְהִי", "transliteral": "way-hî", "traducao_palavra": "e foi" },
        { "hebraico": "כָּל־נֶפֶשׁ", "transliteral": "kāl-ne-p̄eš", "traducao_palavra": "toda alma de" },
        { "hebraico": "יֹצְאֵי", "transliteral": "yō-ṣə-ʾê", "traducao_palavra": "os que saíram de" },
        { "hebraico": "יֶרֶךְ־יַעֲקֹב", "transliteral": "ye-reḵ ya-ʿă-qōḇ", "traducao_palavra": "coxa de Jacó" },
        { "hebraico": "שִׁבְעִים", "transliteral": "šib-ʿîm", "traducao_palavra": "setenta" },
        { "hebraico": "נָפֶשׁ", "transliteral": "nā-p̄eš", "traducao_palavra": "almas" },
        { "hebraico": "וְיוֹסֵף", "transliteral": "wə-yô-sēp̄", "traducao_palavra": "e José" },
        { "hebraico": "הָיָה", "transliteral": "hā-yāh", "traducao_palavra": "[estava]" },
        { "hebraico": "בְּמִצְרָיִם׃", "transliteral": "bə-miṣ-rā-yim", "traducao_palavra": "no Egito" }
      ]
    },
    "6": {
      "traducao_completa": "E morreu José, e todos os seus irmãos, e toda aquela geração.",
      "palavras": [
        { "hebraico": "וַיָּמָת", "transliteral": "way-yā-māṯ", "traducao_palavra": "e morreu" },
        { "hebraico": "יוֹסֵף", "transliteral": "yô-sēp̄", "traducao_palavra": "José" },
        { "hebraico": "וְכָל־אֶחָיו", "transliteral": "wə-ḵāl-ʾe-ḥāw", "traducao_palavra": "e todos seus irmãos" },
        { "hebraico": "וְכֹל", "transliteral": "wə-ḵōl", "traducao_palavra": "e toda" },
        { "hebraico": "הַדּוֹר", "transliteral": "had-dō-wr", "traducao_palavra": "aquela geração" }
      ]
    },
    "7": {
      "traducao_completa": "E os filhos de Israel frutificaram, e se multiplicaram, e se tornaram fortes, e encheram a terra.",
      "palavras": [
        { "hebraico": "וּבְנֵי", "transliteral": "û-ḇə-nê", "traducao_palavra": "e os filhos de" },
        { "hebraico": "יִשְׂרָאֵל", "transliteral": "yiś-rā-ʾēl", "traducao_palavra": "Israel" },
        { "hebraico": "פָּרוּ", "transliteral": "p̄ā-rû", "traducao_palavra": "frutificaram" },
        { "hebraico": "וַיִּשְׁרְצוּ", "transliteral": "way-yiš-rə-ṣû", "traducao_palavra": "e proliferaram" },
        { "hebraico": "וַיִּרְבּוּ", "transliteral": "way-yir-bû", "traducao_palavra": "e multiplicaram-se" },
        { "hebraico": "וַיַּעַצְמוּ", "transliteral": "way-ya-ʿaṣ-mû", "traducao_palavra": "e tornaram-se fortes" },
        { "hebraico": "מְאֹד", "transliteral": "mə-ʾōḏ", "traducao_palavra": "muito" },
        { "hebraico": "וַתִּמָּלֵא", "transliteral": "wat-tim-mā-lê", "traducao_palavra": "e encheram" },
        { "hebraico": "הָאָרֶץ", "transliteral": "hā-ʾā-reṣ", "traducao_palavra": "a terra" }
      ]
    },
    "8": {
      "traducao_completa": "E levantou-se um novo rei sobre o Egito, que não conhecia a José.",
      "palavras": [
        { "hebraico": "וַיָּקָם", "transliteral": "way-yā-qām", "traducao_palavra": "e levantou-se" },
        { "hebraico": "מֶלֶךְ־חָדָשׁ", "transliteral": "me-leḵ-ḥā-ḏāš", "traducao_palavra": "rei novo" },
        { "hebraico": "עַל־מִצְרָיִם", "transliteral": "ʿal-miṣ-rā-yim", "traducao_palavra": "sobre Egito" },
        { "hebraico": "אֲשֶׁר", "transliteral": "ʾă-šer", "traducao_palavra": "que" },
        { "hebraico": "לֹא־יָדַע", "transliteral": "lō-yā-ḏaʿ", "traducao_palavra": "não conhecia" },
        { "hebraico": "אֶת־יוֹסֵף׃", "transliteral": "ʾeṯ-yô-sēp̄", "traducao_palavra": "a José" }
      ]
    },
    "9": {
      "traducao_completa": "E disse ao seu povo: Eis que o povo dos filhos de Israel é maior e mais forte do que nós.",
      "palavras": [
        { "hebraico": "וַיֹּאמֶר", "transliteral": "way-yō-mer", "traducao_palavra": "e disse" },
        { "hebraico": "אֶל־עַמּוֹ", "transliteral": "ʾel-ʿam-mô", "traducao_palavra": "a seu povo" },
        { "hebraico": "הִנֵּה", "transliteral": "hin-nēh", "traducao_palavra": "eis que" },
        { "hebraico": "עַם", "transliteral": "ʿam", "traducao_palavra": "o povo de" },
        { "hebraico": "בְּנֵי", "transliteral": "bə-nê", "traducao_palavra": "filhos de" },
        { "hebraico": "יִשְׂרָאֵל", "transliteral": "yiś-rā-ʾēl", "traducao_palavra": "Israel" },
        { "hebraico": "רַב", "transliteral": "raḇ", "traducao_palavra": "[é] numeroso" },
        { "hebraico": "וְעָצוּם", "transliteral": "wə-ʿā-ṣûm", "traducao_palavra": "e forte" },
        { "hebraico": "מִמֶּנּוּ׃", "transliteral": "mim-men-nû", "traducao_palavra": "do que nós" }
      ]
    },
    "10": {
      "traducao_completa": "Vinde, usemos de astúcia para com eles, para que não se multipliquem, e aconteça que, em havendo guerra, se juntem também aos nossos inimigos, e pelejem contra nós, e subam da terra.",
      "palavras": [
        { "hebraico": "הָבָה", "transliteral": "hā-ḇāh", "traducao_palavra": "Vinde/Vamos" },
        { "hebraico": "נִּתְחַכְּמָה", "transliteral": "niṯ-ḥaḵ-māh", "traducao_palavra": "usemos de sabedoria" },
        { "hebraico": "לּוֹ", "transliteral": "lō", "traducao_palavra": "para eles" },
        { "hebraico": "פֶּן־יִרְבֶּה", "transliteral": "pen-yir-beh", "traducao_palavra": "para que não se multipliquem" },
        { "hebraico": "וְהָיָה", "transliteral": "wə-hā-yāh", "traducao_palavra": "e seja" },
        { "hebraico": "כִּי־תִקְרֶאנָה", "transliteral": "kî-ṯiq-rē-nāh", "traducao_palavra": "que aconteça" },
        { "hebraico": "מִלְחָמָה", "transliteral": "mil-ḥā-māh", "traducao_palavra": "guerra" },
        { "hebraico": "וְנוֹסַף", "transliteral": "wə-nō-sap̄", "traducao_palavra": "e se juntem" },
        { "hebraico": "גַּם־הֵם", "transliteral": "gam-hēm", "traducao_palavra": "também eles" },
        { "hebraico": "עַל־שֹׂנְאֵינוּ", "transliteral": "ʿal-śō-nə-ʾê-nû", "traducao_palavra": "aos nossos inimigos" },
        { "hebraico": "וְנִלְחֲמוּ", "transliteral": "wə-nil-ḥă-mû", "traducao_palavra": "e lutem" },
        { "hebraico": "בָּנוּ", "transliteral": "bā-nû", "traducao_palavra": "contra nós" },
        { "hebraico": "וְעָלוּ", "transliteral": "wə-ʿā-lû", "traducao_palavra": "e subam" },
