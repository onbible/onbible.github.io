      ]
    },
    "14": {
      "traducao_completa": "E amarguraram as suas vidas com servidão dura, em argila e em tijolos, e em todo serviço no campo; com todo o seu serviço, no qual os faziam servir com rigor.",
      "palavras": [
        { "hebraico": "וַיְמָרְרוּ", "transliteral": "way-mā-ră-rû", "traducao_palavra": "e amarguraram" },
        { "hebraico": "אֶת־חַיֵּיהֶם", "transliteral": "ʾeṯ-ḥay-yê-hem", "traducao_palavra": "as suas vidas" },
        { "hebraico": "בַּעֲבֹדָה", "transliteral": "ba-ʿă-ḇō-ḏā", "traducao_palavra": "com serviço/servidão" },
        { "hebraico": "קָשָׁה", "transliteral": "qā-šā", "traducao_palavra": "dura" },
        { "hebraico": "בְּחֹמֶר", "transliteral": "bə-ḥō-mer", "traducao_palavra": "em argila/betume" },
        { "hebraico": "וּבִלְבֵנִים", "transliteral": "û-ḇil-ḇê-nîm", "traducao_palavra": "e em tijolos" },
        { "hebraico": "וּבְכָל־עֲבֹדָה", "transliteral": "û-ḇə-ḵāl-ʿă-ḇō-ḏā", "traducao_palavra": "e em todo serviço" },
