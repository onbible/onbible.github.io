        { "hebraico": "אֵת", "transliteral": "ʾēṯ", "traducao_palavra": "[objeto]" },
        { "hebraico": "כָּל־עֲבֹדָתָם", "transliteral": "kāl-ʿă-ḇō-ḏā-ṯām", "traducao_palavra": "todo o serviço deles" },
        { "hebraico": "אֲשֶׁר־עָבְדוּ", "transliteral": "ʾă-šer-ʿā-ḇə-ḏû", "traducao_palavra": "que serviram/fizeram" },
        { "hebraico": "בָהֶם", "transliteral": "ḇā-hem", "traducao_palavra": "neles" },
        { "hebraico": "בְּפָרֶךְ׃", "transliteral": "bə-p̄ā-reḵ", "traducao_palavra": "com rigor" }
      ]
    },
    "15": {
      "traducao_completa": "E falou o rei do Egito às parteiras hebreias, das quais o nome de uma era Sifrá, e o nome da segunda, Puá.",
      "palavras": [
        { "hebraico": "וַיֹּאמֶר", "transliteral": "way-yō-mer", "traducao_palavra": "e falou" },
        { "hebraico": "מֶלֶךְ", "transliteral": "me-leḵ", "traducao_palavra": "[o] rei de" },
        { "hebraico": "מִצְרַיִם", "transliteral": "miṣ-ra-yim", "traducao_palavra": "Egito" },
        { "hebraico": "לַמְיַלְּדֹת", "transliteral": "lam-yal-lə-ḏōṯ", "traducao_palavra": "às parteiras" },
        { "hebraico": "הָעִבְרִיֹּת", "transliteral": "hā-ʿiḇ-ri-yōṯ", "traducao_palavra": "as hebreias" },
        { "hebraico": "אֲשֶׁר", "transliteral": "ʾă-šer", "traducao_palavra": "que" },
        { "hebraico": "שֵׁם", "transliteral": "šēm", "traducao_palavra": "[o] nome de" },
        { "hebraico": "הָאַחַת", "transliteral": "hā-ʾa-ḥaṯ", "traducao_palavra": "a uma" },
        { "hebraico": "שִׁפְרָה", "transliteral": "šip̄-rā", "traducao_palavra": "Sifrá" },
        { "hebraico": "וְשֵׁם", "transliteral": "wə-šēm", "traducao_palavra": "e o nome de" },
        { "hebraico": "הַשֵּׁנִית", "transliteral": "haš-šê-nîṯ", "traducao_palavra": "a segunda" },
        { "hebraico": "פּוּעָה׃", "transliteral": "pû-ʿā", "traducao_palavra": "Puá" }
      ]
    },
    "16": {
      "traducao_completa": "E disse: Quando partejardes as hebreias, e virdes sobre o assento de parto, se for filho, matá-lo-eis; mas se for filha, viverá.",
      "palavras": [
        { "hebraico": "וַיֹּאמֶר", "transliteral": "way-yō-mer", "traducao_palavra": "e disse" },
        { "hebraico": "בְּיַלֶּדְכֶן", "transliteral": "bə-yal-leḏ-ḵen", "traducao_palavra": "ao partejardes vós" },
        { "hebraico": "אֶת־הָעִבְרִיּוֹת", "transliteral": "ʾeṯ-hā-ʿiḇ-ri-yôṯ", "traducao_palavra": "[as] hebreias" },
        { "hebraico": "וּרְאִיתֶן", "transliteral": "ûr-ʾî-ṯen", "traducao_palavra": "e virdes" },
        { "hebraico": "עַל־הָאָבְנָיִם", "transliteral": "ʿal-hā-ʾāḇ-nā-yim", "traducao_palavra": "sobre o assento de parto" },
        { "hebraico": "אִם־בֵּן", "transliteral": "ʾim-bēn", "traducao_palavra": "se filho" },
        { "hebraico": "הוּא", "transliteral": "hû", "traducao_palavra": "[for] ele" },
        { "hebraico": "וַהֲמִתֶּן", "transliteral": "wa-hă-miṯ-ten", "traducao_palavra": "então matareis" },
        { "hebraico": "אֹתוֹ", "transliteral": "ʾō-ṯô", "traducao_palavra": "a ele" },
        { "hebraico": "וְאִם־בַּת", "transliteral": "wə-ʾim-baṯ", "traducao_palavra": "e se filha" },
        { "hebraico": "הִיא", "transliteral": "hî", "traducao_palavra": "[for] ela" },
        { "hebraico": "וָחָיָה׃", "transliteral": "wā-ḥā-yā", "traducao_palavra": "então viverá" }
      ]
    },
    "17": {
      "traducao_completa": "Mas as parteiras temeram a Deus, e não fizeram como lhes falara o rei do Egito; e preservaram a vida dos meninos.",
      "palavras": [
        { "hebraico": "וַתִּירֶאןָ", "transliteral": "wat-tî-re-nā", "traducao_palavra": "e temeram" },
        { "hebraico": "הַמְיַלְּדֹת", "transliteral": "ham-yal-lə-ḏōṯ", "traducao_palavra": "as parteiras" },
        { "hebraico": "אֶת־הָאֱלֹהִים", "transliteral": "ʾeṯ-hā-ʾĕ-lō-hîm", "traducao_palavra": "a Deus" },
        { "hebraico": "וְלֹא", "transliteral": "wə-lō", "traducao_palavra": "e não" },
        { "hebraico": "עָשׂוּ", "transliteral": "ʿā-śû", "traducao_palavra": "fizeram" },
        { "hebraico": "כַּאֲשֶׁר", "transliteral": "ka-ʾă-šer", "traducao_palavra": "conforme" },
        { "hebraico": "דִּבֶּר", "transliteral": "dib-ber", "traducao_palavra": "falara" },
        { "hebraico": "אֲלֵיהֶן", "transliteral": "ʾă-lê-hen", "traducao_palavra": "a elas" },
        { "hebraico": "מֶלֶךְ", "transliteral": "me-leḵ", "traducao_palavra": "rei de" },
        { "hebraico": "מִצְרָיִם", "transliteral": "miṣ-rā-yim", "traducao_palavra": "Egito" },
        { "hebraico": "וַתְּחַיֶּיןָ", "transliteral": "wat-tə-ḥay-ye-nā", "traducao_palavra": "e preservaram a vida de" },
        { "hebraico": "אֶת־הַיְלָדִים׃", "transliteral": "ʾeṯ-hay-lā-ḏîm", "traducao_palavra": "[os] meninos" }
      ]
    },
    "18": {
      "traducao_completa": "Então o rei do Egito chamou as parteiras e disse-lhes: Por que fizestes esta coisa, que preservastes a vida dos meninos?",
      "palavras": [
        { "hebraico": "וַיִּקְרָא", "transliteral": "way-yiq-rā", "traducao_palavra": "e chamou" },
        { "hebraico": "מֶלֶךְ־מִצְרַיִם", "transliteral": "me-leḵ-miṣ-ra-yim", "traducao_palavra": "o rei do Egito" },
        { "hebraico": "לַמְיַלְּדֹת", "transliteral": "lam-yal-lə-ḏōṯ", "traducao_palavra": "às parteiras" },
        { "hebraico": "וַיֹּאמֶר", "transliteral": "way-yō-mer", "traducao_palavra": "e disse" },
        { "hebraico": "לָהֶן", "transliteral": "lā-hen", "traducao_palavra": "a elas" },
        { "hebraico": "מַדּוּעַ", "transliteral": "mad-dû-aʿ", "traducao_palavra": "por que" },
        { "hebraico": "עֲשִׂיתֶן", "transliteral": "ă-śî-ṯen", "traducao_palavra": "fizestes vós" },
        { "hebraico": "הַדָּבָר", "transliteral": "had-dā-ḇār", "traducao_palavra": "a coisa" },
        { "hebraico": "הַזֶּה", "transliteral": "haz-zeh", "traducao_palavra": "esta" },
        { "hebraico": "וַתְּחַיֶּיןָ", "transliteral": "wat-tə-ḥay-ye-nā", "traducao_palavra": "e preservastes a vida de" },
        { "hebraico": "אֶת־הַיְלָדִים׃", "transliteral": "ʾeṯ-hay-lā-ḏîm", "traducao_palavra": "[os] meninos" }
      ]
    },
    "19": {
      "traducao_completa": "E disseram as parteiras a Faraó: É que as hebreias não são como as mulheres egípcias; porque elas são vigorosas, e antes que a parteira venha a elas, já deram à luz.",
      "palavras": [
        { "hebraico": "וַתֹּאמַרְןָ", "transliteral": "wat-tō-mar-nā", "traducao_palavra": "e disseram" },
        { "hebraico": "הַמְיַלְּדֹת", "transliteral": "ham-yal-lə-ḏōṯ", "traducao_palavra": "as parteiras" },
        { "hebraico": "אֶל־פַּרְעֹה", "transliteral": "ʾel-par-ʿōh", "traducao_palavra": "a Faraó" },
        { "hebraico": "כִּי", "transliteral": "kî", "traducao_palavra": "porque" },
        { "hebraico": "לֹא", "transliteral": "lō", "traducao_palavra": "não" },
        { "hebraico": "כַנָּשִׁים", "transliteral": "ḵan-nā-šîm", "traducao_palavra": "como as mulheres" },
        { "hebraico": "הַמִּצְרִיֹּת", "transliteral": "ham-miṣ-ri-yōṯ", "traducao_palavra": "egípcias" },
        { "hebraico": "הָעִבְרִיֹּת", "transliteral": "hā-ʿiḇ-ri-yōṯ", "traducao_palavra": "[são] as hebreias" },
        { "hebraico": "כִּי־חָיוֹת", "transliteral": "kî-ḥā-yôṯ", "traducao_palavra": "porque vigorosas/vivas" },
        { "hebraico": "הֵנָּה", "transliteral": "hēn-nā", "traducao_palavra": "[são] elas" },
        { "hebraico": "בְּטֶרֶם", "transliteral": "bə-ṭe-rem", "traducao_palavra": "antes de" },
        { "hebraico": "תָּבוֹא", "transliteral": "tā-ḇô", "traducao_palavra": "vir" },
        { "hebraico": "אֲלֵהֶן", "transliteral": "ʾă-lê-hen", "traducao_palavra": "a elas" },
        { "hebraico": "הַמְיַלֶּדֶת", "transliteral": "ham-yal-le-ḏeṯ", "traducao_palavra": "a parteira" },
        { "hebraico": "וְיָלָדוּ׃", "transliteral": "wə-yā-lā-ḏû", "traducao_palavra": "e já deram à luz" }
      ]
    },
    "20": {
      "traducao_completa": "E Deus fez bem às parteiras; e o povo se multiplicou e se tornou muito forte.",
      "palavras": [
        { "hebraico": "וַיֵּיטֶב", "transliteral": "way-yê-ṭeḇ", "traducao_palavra": "e fez bem/foi bom" },
        { "hebraico": "אֱלֹהִים", "transliteral": "ʾĕ-lō-hîm", "traducao_palavra": "Deus" },
        { "hebraico": "לַמְיַלְּדֹת", "transliteral": "lam-yal-lə-ḏōṯ", "traducao_palavra": "às parteiras" },
        { "hebraico": "וַיִּרֶב", "transliteral": "way-yi-reḇ", "traducao_palavra": "e multiplicou-se" },
        { "hebraico": "הָעָם", "transliteral": "hā-ʿām", "traducao_palavra": "o povo" },
        { "hebraico": "וַיַּעַצְמוּ", "transliteral": "way-ya-ʿaṣ-mû", "traducao_palavra": "e tornaram-se fortes" },
        { "hebraico": "מְאֹד׃", "transliteral": "mə-ʾōḏ", "traducao_palavra": "muito" }
      ]
    },
    "21": {
      "traducao_completa": "E aconteceu que, porque as parteiras temeram a Deus, Ele lhes estabeleceu casas.",
      "palavras": [
        { "hebraico": "וַיְהִי", "transliteral": "way-hî", "traducao_palavra": "e aconteceu" },
        { "hebraico": "כִּי־יָרְאוּ", "transliteral": "kî-yā-rə-ʾû", "traducao_palavra": "que temeram" },
        { "hebraico": "הַמְיַלְּדֹת", "transliteral": "ham-yal-lə-ḏōṯ", "traducao_palavra": "as parteiras" },
        { "hebraico": "אֶת־הָאֱלֹהִים", "transliteral": "ʾeṯ-hā-ʾĕ-lō-hîm", "traducao_palavra": "a Deus" },
        { "hebraico": "וַיַּעַשׂ", "transliteral": "way-ya-ʿaś", "traducao_palavra": "e fez" },
        { "hebraico": "לָהֶם", "transliteral": "lā-hem", "traducao_palavra": "para elas" },
        { "hebraico": "בָּתִּים׃", "transliteral": "bāt-tîm", "traducao_palavra": "casas/famílias" }
      ]
    },
    "22": {
      "traducao_completa": "E ordenou Faraó a todo o seu povo, dizendo: Todo filho que nascer, lançá-lo-eis no Rio, mas toda filha preservareis a vida.",
      "palavras": [
        { "hebraico": "וַיְצַו", "transliteral": "way-ṣaw", "traducao_palavra": "e ordenou" },
        { "hebraico": "פַּרְעֹה", "transliteral": "par-ʿōh", "traducao_palavra": "Faraó" },
        { "hebraico": "לְכָל־עַמּוֹ", "transliteral": "lə-ḵāl-ʿam-mô", "traducao_palavra": "a todo seu povo" },
        { "hebraico": "לֵאמֹר", "transliteral": "lē-mōr", "traducao_palavra": "dizendo" },
        { "hebraico": "כָּל־הַבֵּן", "transliteral": "kāl-hab-bēn", "traducao_palavra": "todo o filho" },
        { "hebraico": "הַיִּלּוֹד", "transliteral": "hay-yil-lôḏ", "traducao_palavra": "o nascido" },
        { "hebraico": "הַיְאֹרָה", "transliteral": "hay-yə-ʾō-rā", "traducao_palavra": "ao Rio [Nilo]" },
        { "hebraico": "תַּשְׁלִיכֻהוּ", "transliteral": "taš-lî-ḵu-hû", "traducao_palavra": "lançá-lo-eis" },
        { "hebraico": "וְכָל־הַבַּת", "transliteral": "wə-ḵāl-hab-baṯ", "traducao_palavra": "e toda filha" },
        { "hebraico": "תְּחַיּוּן׃", "transliteral": "tə-ḥay-yûn", "traducao_palavra": "preservareis a vida" }
      ]
