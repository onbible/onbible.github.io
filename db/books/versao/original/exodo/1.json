        { "hebraico": "רְאוּבֵן", "transliteral": "rə-ʾû-ḇēn", "traducao_palavra": "Rúben" },
        { "hebraico": "שִׁמְעוֹן", "transliteral": "šim-ʿôn", "traducao_palavra": "Simeão" },
        { "hebraico": "לֵוִי", "transliteral": "lê-wî", "traducao_palavra": "Levi" },
        { "hebraico": "וִיהוּדָה׃", "transliteral": "wî-hû-ḏāh", "traducao_palavra": "e Judá" }
      ]
    },
    "3": {
      "traducao_completa": "Issacar, Zebulom e Benjamim,",
      "palavras": [
        { "hebraico": "יִשָּׂשכָר", "transliteral": "yiś-śā-ḵār", "traducao_palavra": "Issacar" },
        { "hebraico": "זְבוּלֻן", "transliteral": "zə-ḇû-lun", "traducao_palavra": "Zebulom" },
        { "hebraico": "וּבִנְיָמִן׃", "transliteral": "û-bin-yā-min", "traducao_palavra": "e Benjamim" }
      ]
    },
    "4": {
      "traducao_completa": "Dã e Naftali, Gade e Aser.",
      "palavras": [
        { "hebraico": "דָּן", "transliteral": "ḏān", "traducao_palavra": "Dã" },
        { "hebraico": "וְנַפְתָּלִי", "transliteral": "wə-nap̄-tā-lî", "traducao_palavra": "e Naftali" },
        { "hebraico": "גָּד", "transliteral": "ḡāḏ", "traducao_palavra": "Gade" },
        { "hebraico": "וְאָשֵׁר׃", "transliteral": "wə-ʾā-šēr", "traducao_palavra": "e Aser" }
      ]
    },
    "5": {
      "traducao_completa": "E todas as almas que saíram da coxa de Jacó eram setenta almas; e José estava no Egito.",
