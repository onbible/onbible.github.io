        { "hebraico": "וְאַדְנֵיהֶם", "transliteral": "wə-ʾaḏ-nê-hem", "traducao_palavra": "e suas bases" },
        { "hebraico": "עֶשְׂרִים", "transliteral": "ʿeś-rîm", "traducao_palavra": "vinte" },
        { "hebraico": "נְחֹשֶׁת", "transliteral": "nə-ḥō-šeṯ", "traducao_palavra": "bronze" }
      ]
    },
    "11": {
      "traducao_completa": "E para o lado do norte, cortinas de cem côvados; as suas vinte colunas e as suas vinte bases de bronze; os ganchos das colunas e as suas faixas de prata.",
      "palavras": [
        { "hebraico": "וְלִפְאַת", "transliteral": "wə-lip̄-ʾaṯ", "traducao_palavra": "e para o lado de" },
        { "hebraico": "צָפוֹן", "transliteral": "ṣā-p̄ôn", "traducao_palavra": "norte" }
      ]
    },
    "12": {
      "traducao_completa": "E para o lado do ocidente, cortinas de cinquenta côvados; as suas dez colunas e as suas dez bases; os ganchos das colunas e as suas faixas de prata.",
      "palavras": [
        { "hebraico": "וְלִפְאַת־יָם", "transliteral": "wə-lip̄-ʾaṯ-yām", "traducao_palavra": "e para o lado do mar [oeste]" }
      ]
    },
    "13": {
      "traducao_completa": "E para o lado do oriente, ao nascer do sol, cinquenta côvados.",
      "palavras": [
        { "hebraico": "וְלִפְאַת", "transliteral": "wə-lip̄-ʾaṯ", "traducao_palavra": "e para o lado" },
