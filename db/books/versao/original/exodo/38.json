        { "hebraico": "אֵלֶּה", "transliteral": "ʾēl-leh", "traducao_palavra": "estes [são]" },
        { "hebraico": "פְקוּדֵי", "transliteral": "p̄ə-qû-ḏê", "traducao_palavra": "os registros/contas de" },
        { "hebraico": "הַמִּשְׁכָּן", "transliteral": "ham-miš-kān", "traducao_palavra": "o Tabernáculo" },
        { "hebraico": "מִשְׁכַּן", "transliteral": "miš-kan", "traducao_palavra": "Tabernáculo de" },
