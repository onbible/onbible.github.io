      ]
    },
    "7": {
      "traducao_completa": "E introduziu os varais nas argolas aos lados do altar, para com eles o carregar; oco, de tábuas, o fez.",
      "palavras": [
        { "hebraico": "וַיָּבֵא", "transliteral": "way-yā-ḇē", "traducao_palavra": "e introduziu" },
