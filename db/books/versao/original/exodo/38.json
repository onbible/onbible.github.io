        { "hebraico": "לַגֻּלְגֹּלֶת", "transliteral": "lag-gul-gō-leṯ", "traducao_palavra": "por cabeça" },
        { "hebraico": "מַחֲצִית", "transliteral": "ma-ḥă-ṣîṯ", "traducao_palavra": "metade de" },
        { "hebraico": "הַשֶּׁקֶל", "transliteral": "ha-še-qel", "traducao_palavra": "o siclo" },
        { "hebraico": "בְּשֶׁקֶל", "transliteral": "bə-še-qel", "traducao_palavra": "no siclo de" },
        { "hebraico": "הַקֹּדֶשׁ", "transliteral": "ha-qō-ḏeš", "traducao_palavra": "o santuário" }
      ]
    },
    "27": {
      "traducao_completa": "E houve cem talentos de prata para fundir as bases do santuário e as bases do véu; cem bases de cem talentos, um talento por base.",
