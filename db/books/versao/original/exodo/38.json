        { "hebraico": "בַּטַּבָּעֹת", "transliteral": "ba-ṭab-bā-ʿōṯ", "traducao_palavra": "nas argolas" }
      ]
    },
    "8": {
      "traducao_completa": "E fez a bacia de bronze e a sua base de bronze, dos espelhos das mulheres que serviam, as quais serviam à porta da tenda da congregação.",
      "palavras": [
        { "hebraico": "וַיַּעַשׂ", "transliteral": "way-ya-ʿaś", "traducao_palavra": "e fez" },
