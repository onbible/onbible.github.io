      ]
    },
    "9": {
      "traducao_completa": "Fez também o pátio; para o lado do sul, ao meio-dia, as cortinas do pátio eram de linho fino retorcido, de cem côvados.",
      "palavras": [
        { "hebraico": "וַיַּעַשׂ", "transliteral": "way-ya-ʿaś", "traducao_palavra": "e fez" },
        { "hebraico": "אֶת־הֶחָצֵר", "transliteral": "ʾeṯ-he-ḥā-ṣēr", "traducao_palavra": "o pátio" }
      ]
    },
    "10": {
      "traducao_completa": "As suas vinte colunas e as suas vinte bases eram de bronze; os ganchos das colunas e as suas faixas eram de prata.",
      "palavras": [
        { "hebraico": "עַמּוּדֵיהֶם", "transliteral": "ʿam-mû-ḏê-hem", "traducao_palavra": "suas colunas" },
