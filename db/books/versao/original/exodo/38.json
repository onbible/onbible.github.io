    "3": {
      "traducao_completa": "E fez todos os utensílios do altar: os cinzeiros, as pás, as bacias, os garfos e os braseiros; todos os seus utensílios fez de bronze.",
      "palavras": [
        { "hebraico": "וַיַּעַשׂ", "transliteral": "way-ya-ʿaś", "traducao_palavra": "e fez" },
        { "hebraico": "אֶת־כָּל־כְּלֵי", "transliteral": "ʾeṯ-kāl-kə-lê", "traducao_palavra": "todos os vasos de" },
