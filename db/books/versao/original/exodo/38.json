        { "hebraico": "אֲשֶׁר", "transliteral": "ʾă-šer", "traducao_palavra": "que" },
        { "hebraico": "פֻּקַּד", "transliteral": "puq-qaḏ", "traducao_palavra": "foi contado" },
        { "hebraico": "עַל־פִּי", "transliteral": "ʿal-pî", "traducao_palavra": "conforme a boca de" },
        { "hebraico": "מֹשֶׁה", "transliteral": "mō-šeh", "traducao_palavra": "Moisés" },
        { "hebraico": "עֲבֹדַת", "transliteral": "ʿă-ḇō-ḏaṯ", "traducao_palavra": "[para] o serviço de" },
        { "hebraico": "הַלְוִיִּם", "transliteral": "hal-wî-yim", "traducao_palavra": "os levitas" },
        { "hebraico": "בְּיַד", "transliteral": "bə-yaḏ", "traducao_palavra": "pela mão de" },
        { "hebraico": "אִיתָמָר", "transliteral": "ʾî-ṯā-mār", "traducao_palavra": "Itamar" },
