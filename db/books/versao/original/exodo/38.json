        { "hebraico": "וְרֹקֵם", "transliteral": "wə-rō-qēm", "traducao_palavra": "e bordador" }
      ]
    },
    "24": {
      "traducao_completa": "Todo o ouro empregado na obra, em toda a obra do santuário, a saber, o ouro da oferta de movimento, foi vinte e nove talentos e setecentos e trinta siclos, segundo o siclo do santuário.",
      "palavras": [
        { "hebraico": "כָּל־הַזָּהָב", "transliteral": "kāl-haz-zā-hāḇ", "traducao_palavra": "todo o ouro" },
        { "hebraico": "הֶעָשׂוּי", "transliteral": "he-ʿā-śûy", "traducao_palavra": "o feito/usado" },
        { "hebraico": "לַמְּלָּאכָה", "transliteral": "lam-məlā-ḵā", "traducao_palavra": "na obra" },
        { "hebraico": "בְּכֹל", "transliteral": "bə-ḵōl", "traducao_palavra": "em toda" },
        { "hebraico": "מְלֶאכֶת", "transliteral": "mle-ḵeṯ", "traducao_palavra": "obra de" },
        { "hebraico": "הַקֹּדֶשׁ", "transliteral": "ha-qō-ḏeš", "traducao_palavra": "o santuário" },
        { "hebraico": "וַיְהִי", "transliteral": "way-hî", "traducao_palavra": "e foi" },
        { "hebraico": "זְהַב", "transliteral": "zə-haḇ", "traducao_palavra": "[o] ouro de" },
        { "hebraico": "הַתְּנוּפָה", "transliteral": "hat-tə-nû-p̄ā", "traducao_palavra": "o movimento" },
        { "hebraico": "תֵּשַׁע", "transliteral": "tē-šaʿ", "traducao_palavra": "nove" },
        { "hebraico": "וְעֶשְׂרִים", "transliteral": "wə-ʿeś-rîm", "traducao_palavra": "e vinte" },
        { "hebraico": "כִּכָּר", "transliteral": "kik-kār", "traducao_palavra": "talento" },
        { "hebraico": "וּשְׁבַע", "transliteral": "û-šə-ḇaʿ", "traducao_palavra": "e sete de" },
        { "hebraico": "מֵאוֹת", "transliteral": "mê-ʾôṯ", "traducao_palavra": "centenas" },
        { "hebraico": "וּשְׁלֹשִׁים", "transliteral": "û-šə-lō-šîm", "traducao_palavra": "e trinta" },
        { "hebraico": "שֶׁקֶל", "transliteral": "še-qel", "traducao_palavra": "siclo" },
        { "hebraico": "בְּשֶׁקֶל", "transliteral": "bə-še-qel", "traducao_palavra": "no siclo de" },
