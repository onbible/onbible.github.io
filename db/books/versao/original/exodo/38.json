        { "hebraico": "טַבָּעֹת", "transliteral": "ṭab-bā-ʿōṯ", "traducao_palavra": "argolas" }
      ]
    },
    "6": {
      "traducao_completa": "E fez os varais de madeira de acácia, e os cobriu de bronze.",
      "palavras": [
        { "hebraico": "וַיַּעַשׂ", "transliteral": "way-ya-ʿaś", "traducao_palavra": "e fez" },
