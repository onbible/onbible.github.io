        { "hebraico": "עַל", "transliteral": "ʿal", "traducao_palavra": "sobre" },
        { "hebraico": "אַרְבַּע", "transliteral": "ʾar-baʿ", "traducao_palavra": "quatro de" },
        { "hebraico": "פִּנֹּתָיו", "transliteral": "pin-nō-ṯāyw", "traducao_palavra": "seus cantos" },
        { "hebraico": "מִמֶּנּוּ", "transliteral": "mim-men-nû", "traducao_palavra": "dele mesmo" },
        { "hebraico": "הָיוּ", "transliteral": "hā-yû", "traducao_palavra": "eram" },
