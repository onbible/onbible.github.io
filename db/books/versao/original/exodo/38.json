      ]
    },
    "29": {
      "traducao_completa": "E o bronze da oferta de movimento foi setenta talentos e dois mil e quatrocentos siclos.",
      "palavras": [
        { "hebraico": "וּנְחֹשֶׁת", "transliteral": "û-nə-ḥō-šeṯ", "traducao_palavra": "e o bronze de" },
        { "hebraico": "הַתְּנוּפָה", "transliteral": "hat-tə-nû-p̄ā", "traducao_palavra": "o movimento" },
        { "hebraico": "שִׁבְעִים", "transliteral": "šiḇ-ʿîm", "traducao_palavra": "setenta" },
        { "hebraico": "כִּכָּר", "transliteral": "kik-kār", "traducao_palavra": "talento" },
        { "hebraico": "וְאַלְפַּיִם", "transliteral": "wə-ʾal-pa-yim", "traducao_palavra": "e dois mil" },
        { "hebraico": "וְאַרְבַּע", "transliteral": "wə-ʾar-baʿ", "traducao_palavra": "e quatro" },
