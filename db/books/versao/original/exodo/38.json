      ]
    },
    "14": {
      "traducao_completa": "Quinze côvados de cortinas a um lado; as suas três colunas e as suas três bases.",
      "palavras": [
        { "hebraico": "קְלָעִים", "transliteral": "qə-lā-ʿîm", "traducao_palavra": "cortinas" },
        { "hebraico": "חֲמֵשׁ־עֶשְׂרֵה", "transliteral": "ḥă-mēš-ʿeś-rēh", "traducao_palavra": "quinze" },
        { "hebraico": "אַמָּה", "transliteral": "ʾam-mā", "traducao_palavra": "côvado" }
      ]
    },
    "15": {
      "traducao_completa": "E para o outro lado, deste e daquele lado da porta do pátio, quinze côvados de cortinas; as suas três colunas e as suas três bases.",
      "palavras": [
        { "hebraico": "וְלַכָּתֵף", "transliteral": "wə-lak-kā-ṯēp̄", "traducao_palavra": "e para a ala/ombro" },
        { "hebraico": "הַשֵּׁנִית", "transliteral": "haš-šê-nîṯ", "traducao_palavra": "a segunda" }
      ]
    },
    "16": {
      "traducao_completa": "Todas as cortinas do pátio ao redor eram de linho fino retorcido.",
      "palavras": [
        { "hebraico": "כָּל־קִלְעֵי", "transliteral": "kāl-qil-ʿê", "traducao_palavra": "todas as cortinas de" },
        { "hebraico": "הֶחָצֵר", "transliteral": "he-ḥā-ṣēr", "traducao_palavra": "o pátio" }
      ]
    },
    "17": {
      "traducao_completa": "E as bases das colunas eram de bronze; os ganchos das colunas e as suas faixas eram de prata; e a cobertura das suas cabeças era de prata; e todas as colunas do pátio eram cingidas de faixas de prata.",
      "palavras": [
        { "hebraico": "וְהָאֲדָנִים", "transliteral": "wə-hā-ʾă-ḏā-nîm", "traducao_palavra": "e as bases" },
        { "hebraico": "לָעַמֻּדִים", "transliteral": "lā-ʿam-mu-ḏîm", "traducao_palavra": "para as colunas" },
        { "hebraico": "נְחֹשֶׁת", "transliteral": "nə-ḥō-šeṯ", "traducao_palavra": "bronze" }
      ]
    },
    "18": {
      "traducao_completa": "E o anteparo da porta do pátio era obra de bordador, de azul, de púrpura, de carmesim e de linho fino retorcido; e de vinte côvados era o comprimento, e a altura na largura era de cinco côvados, correspondendo às cortinas do pátio.",
      "palavras": [
        { "hebraico": "וּמָסָךְ", "transliteral": "û-mā-śāḵ", "traducao_palavra": "e o anteparo de" },
        { "hebraico": "שַׁעַר", "transliteral": "ša-ʿar", "traducao_palavra": "portal de" },
        { "hebraico": "הֶחָצֵר", "transliteral": "he-ḥā-ṣēr", "traducao_palavra": "o pátio" }
      ]
    },
    "19": {
      "traducao_completa": "E as suas colunas eram quatro, e as suas bases quatro, de bronze; os seus ganchos de prata, e a cobertura das suas cabeças e as suas faixas de prata.",
      "palavras": [
        { "hebraico": "וְעַמֻּדֵיהֶם", "transliteral": "wə-ʿam-mu-ḏê-hem", "traducao_palavra": "e as suas colunas" },
        { "hebraico": "אַרְבָּעָה", "transliteral": "ʾar-bā-ʿā", "traducao_palavra": "quatro" }
      ]
    },
    "20": {
      "traducao_completa": "E todos os pregos do Tabernáculo e do pátio ao redor eram de bronze.",
      "palavras": [
        { "hebraico": "וְכָל־הַיְתֵדֹת", "transliteral": "wə-ḵāl-hay-ṯē-ḏōṯ", "traducao_palavra": "e todos os pregos" },
        { "hebraico": "לַמִּשְׁכָּן", "transliteral": "lam-miš-kān", "traducao_palavra": "para o Tabernáculo" },
        { "hebraico": "וְלֶחָצֵר", "transliteral": "wə-le-ḥā-ṣēr", "traducao_palavra": "e para o pátio" },
        { "hebraico": "סָבִיב", "transliteral": "śā-ḇîḇ", "traducao_palavra": "ao redor" },
        { "hebraico": "נְחֹשֶׁת׃", "transliteral": "nə-ḥō-šeṯ", "traducao_palavra": "bronze" }
      ]
    },
    "21": {
      "traducao_completa": "Estes são os registros do Tabernáculo, o Tabernáculo do Testemunho, que foram contados conforme a ordem de Moisés, para o serviço dos levitas, por mão de Itamar, filho de Arão, o sacerdote.",
