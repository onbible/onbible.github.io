        { "hebraico": "אָהֳלִיאָב", "transliteral": "ʾo-ho-lî-ʾāḇ", "traducao_palavra": "Oholiabe" },
        { "hebraico": "בֶּן־אֲחִיסָמָךְ", "transliteral": "ben-ʾă-ḥî-śā-māḵ", "traducao_palavra": "filho de Aisamaque" },
        { "hebraico": "לְמַטֵּה־דָן", "transliteral": "lə-maṭ-ṭēh-ḏān", "traducao_palavra": "da tribo de Dã" },
        { "hebraico": "חָרָשׁ", "transliteral": "ḥā-rāš", "traducao_palavra": "artífice" },
