        { "hebraico": "מִכְבָּר", "transliteral": "miḵ-bār", "traducao_palavra": "uma grelha" },
        { "hebraico": "מַעֲשֵׂה", "transliteral": "ma-ʿă-śēh", "traducao_palavra": "obra de" },
        { "hebraico": "רֶשֶׁת", "transliteral": "re-šeṯ", "traducao_palavra": "rede" },
        { "hebraico": "נְחֹשֶׁת", "transliteral": "nə-ḥō-šeṯ", "traducao_palavra": "bronze" }
      ]
    },
    "5": {
      "traducao_completa": "E fundiu quatro argolas para as quatro extremidades da grelha de bronze, para lugares dos varais.",
      "palavras": [
        { "hebraico": "וַיִּצֹק", "transliteral": "way-yi-ṣōq", "traducao_palavra": "e fundiu" },
