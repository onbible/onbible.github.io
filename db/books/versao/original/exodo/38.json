        { "hebraico": "בָּהּ", "transliteral": "bāh", "traducao_palavra": "com ele [bronze]" },
        { "hebraico": "אֶת־אַדְנֵי", "transliteral": "ʾeṯ-ʾaḏ-nê", "traducao_palavra": "[as] bases de" },
        { "hebraico": "פֶּתַח", "transliteral": "pe-ṯaḥ", "traducao_palavra": "entrada de" },
        { "hebraico": "אֹהֶל", "transliteral": "ʾō-hel", "traducao_palavra": "tenda de" },
        { "hebraico": "מוֹעֵד", "transliteral": "mô-ʿēḏ", "traducao_palavra": "congregação" }
      ]
    },
