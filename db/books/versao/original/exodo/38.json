      ]
    },
    "28": {
      "traducao_completa": "E dos mil setecentos e setenta e cinco [siclos] fez os ganchos para as colunas, e cobriu as suas cabeças, e as cingiu de faixas.",
      "palavras": [
        { "hebraico": "וְאֶת־הָאֶלֶף", "transliteral": "wə-ʾeṯ-hā-ʾe-lep̄", "traducao_palavra": "e dos mil" },
        { "hebraico": "וּשְׁבַע", "transliteral": "û-šə-ḇaʿ", "traducao_palavra": "e sete de" },
        { "hebraico": "הַמֵּאוֹת", "transliteral": "ham-mê-ʾôṯ", "traducao_palavra": "as centenas" },
        { "hebraico": "וַחֲמִשָּׁה", "transliteral": "wa-ḥă-miš-šā", "traducao_palavra": "e cinco" },
        { "hebraico": "וְשִׁבְעִים", "transliteral": "wə-šiḇ-ʿîm", "traducao_palavra": "e setenta" },
        { "hebraico": "עָשָׂה", "transliteral": "ʿā-śā", "traducao_palavra": "fez" },
        { "hebraico": "וָוִים", "transliteral": "wā-wîm", "traducao_palavra": "ganchos" },
