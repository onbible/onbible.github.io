      ]
    },
    "4": {
      "traducao_completa": "E fez para o altar uma grelha de obra de rede de bronze, debaixo da sua cercadura, desde baixo até ao meio dele.",
      "palavras": [
        { "hebraico": "וַיַּעַשׂ", "transliteral": "way-ya-ʿaś", "traducao_palavra": "e fez" },
