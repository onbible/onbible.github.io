        { "hebraico": "וַיְהִי", "transliteral": "way-hî", "traducao_palavra": "e foi" },
        { "hebraico": "מְאַת", "transliteral": "mə-ʾaṯ", "traducao_palavra": "cem" },
        { "hebraico": "כִּכַּר", "transliteral": "kik-kar", "traducao_palavra": "talento de" },
        { "hebraico": "הַכֶּסֶף", "transliteral": "hak-ke-sep̄", "traducao_palavra": "a prata" },
        { "hebraico": "לָצֶקֶת", "transliteral": "lā-ṣe-qeṯ", "traducao_palavra": "para fundir" },
        { "hebraico": "אֵת", "transliteral": "ʾēṯ", "traducao_palavra": "[objeto]" },
