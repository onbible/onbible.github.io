        { "hebraico": "פְּקוּדֵי", "transliteral": "pə-qû-ḏê", "traducao_palavra": "os contados de" },
        { "hebraico": "הָעֵדָה", "transliteral": "hā-ʿē-ḏā", "traducao_palavra": "a congregação" },
        { "hebraico": "מְאַת", "transliteral": "mə-ʾaṯ", "traducao_palavra": "cem" },
        { "hebraico": "כִּכָּר", "transliteral": "kik-kār", "traducao_palavra": "talento" }
      ]
    },
    "26": {
      "traducao_completa": "Um beca por cabeça, isto é, meio siclo, segundo o siclo do santuário, de todo aquele que passava ao recenseamento, de vinte anos para cima, para seiscentas e três mil e quinhentas e cinquenta [pessoas].",
