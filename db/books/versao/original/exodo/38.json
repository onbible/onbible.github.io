        { "hebraico": "רָבוּעַ", "transliteral": "rā-ḇû-aʿ", "traducao_palavra": "quadrado" },
        { "hebraico": "וְשָׁלֹשׁ", "transliteral": "wə-šā-lōš", "traducao_palavra": "e três" },
