    "13": {
      "traducao_completa": "E se um homem pedir emprestado do seu próximo e este ficar aleijado ou morrer, não estando o seu dono com ele, certamente pagará.",
      "palavras": [
        { "hebraico": "וְכִי־יִשְׁאַל", "transliteral": "wə-ḵî-yiš-ʾal", "traducao_palavra": "e se pedir" },
        { "hebraico": "אִישׁ", "transliteral": "ʾîš", "traducao_palavra": "um homem" },
        { "hebraico": "מֵעִם", "transliteral": "mē-ʿim", "traducao_palavra": "de com" },
        { "hebraico": "רֵעֵהוּ", "transliteral": "rē-ʿē-hû", "traducao_palavra": "seu próximo" },
        { "hebraico": "וְנִשְׁבַּר", "transliteral": "wə-niš-bar", "traducao_palavra": "e for quebrado" },
        { "hebraico": "אוֹ־מֵת", "transliteral": "ʾô-mēṯ", "traducao_palavra": "ou morrer" },
        { "hebraico": "בְּעָלָיו", "transliteral": "bə-ʿā-lāw", "traducao_palavra": "seu dono" },
        { "hebraico": "אֵין־עִמּוֹ", "transliteral": "ʾên-ʿim-mô", "traducao_palavra": "não [estando] com ele" },
        { "hebraico": "שַׁלֵּם", "transliteral": "šal-lēm", "traducao_palavra": "pagando" },
        { "hebraico": "יְשַׁלֵּם׃", "transliteral": "yə-šal-lēm", "traducao_palavra": "certamente pagará" }
      ]
    },
    "14": {
      "traducao_completa": "Se o seu dono estiver com ele, não pagará; se for alugado, virá pelo seu aluguel.",
      "palavras": [
        { "hebraico": "אִם־בְּעָלָיו", "transliteral": "ʾim-bə-ʿā-lāw", "traducao_palavra": "se o seu dono" },
        { "hebraico": "עִמּוֹ", "transliteral": "ʿim-mô", "traducao_palavra": "[estiver] com ele" },
        { "hebraico": "לֹא", "transliteral": "lō", "traducao_palavra": "não" },
        { "hebraico": "יְשַׁלֵּם", "transliteral": "yə-šal-lēm", "traducao_palavra": "pagará" },
        { "hebraico": "אִם־שָׂכִיר", "transliteral": "ʾim-śā-ḵîr", "traducao_palavra": "se alugado" },
        { "hebraico": "הוּא", "transliteral": "hû", "traducao_palavra": "[for] ele" },
        { "hebraico": "בָּא", "transliteral": "bā", "traducao_palavra": "virá" },
        { "hebraico": "בִּשְׂכָרוֹ׃", "transliteral": "biś-ḵā-rô", "traducao_palavra": "pelo seu salário/aluguel" }
      ]
    },
    "15": {
      "traducao_completa": "E se um homem seduzir uma virgem que não for desposada, e se deitar com ela, certamente pagará o dote para que seja sua mulher.",
      "palavras": [
        { "hebraico": "וְכִי־יְפַתֶּה", "transliteral": "wə-ḵî-yə-p̄at-teh", "traducao_palavra": "e se seduzir" },
        { "hebraico": "אִישׁ", "transliteral": "ʾîš", "traducao_palavra": "um homem" },
        { "hebraico": "בְּתוּלָה", "transliteral": "bə-ṯû-lā", "traducao_palavra": "[a] uma virgem" },
        { "hebraico": "אֲשֶׁר", "transliteral": "ʾă-šer", "traducao_palavra": "que" },
        { "hebraico": "לֹא־אֹרָשָׂה", "transliteral": "lō-ʾō-rā-śā", "traducao_palavra": "não for desposada" },
        { "hebraico": "וְשָׁכַב", "transliteral": "wə-šā-ḵaḇ", "traducao_palavra": "e se deitar" },
        { "hebraico": "עִמָּהּ", "transliteral": "ʿim-mā", "traducao_palavra": "com ela" },
        { "hebraico": "מָהֹר", "transliteral": "mā-hōr", "traducao_palavra": "dotando [pagando dote]" },
        { "hebraico": "יִמְהָרֶנָּה", "transliteral": "yim-hā-ren-nā", "traducao_palavra": "certamente a dotará" },
        { "hebraico": "לּוֹ", "transliteral": "lô", "traducao_palavra": "para si" },
        { "hebraico": "לְאִשָּׁה׃", "transliteral": "lə-ʾiš-šā", "traducao_palavra": "por mulher" }
      ]
    },
    "16": {
      "traducao_completa": "Se seu pai recusar expressamente dar-lha, pagará em dinheiro conforme o dote das virgens.",
      "palavras": [
        { "hebraico": "אִם־מָאֵן", "transliteral": "ʾim-mā-ʾēn", "traducao_palavra": "se recusando" },
        { "hebraico": "יְמָאֵן", "transliteral": "yə-mā-ʾēn", "traducao_palavra": "recusar" },
        { "hebraico": "אָבִיהָ", "transliteral": "ʾā-ḇî-hā", "traducao_palavra": "o pai dela" },
        { "hebraico": "לְתִתָּהּ", "transliteral": "lə-ṯit-tāh", "traducao_palavra": "de dar a ela" },
        { "hebraico": "לוֹ", "transliteral": "lô", "traducao_palavra": "a ele" },
        { "hebraico": "כֶּסֶף", "transliteral": "ke-sep̄", "traducao_palavra": "dinheiro" },
        { "hebraico": "יִשְׁקֹל", "transliteral": "yiš-qōl", "traducao_palavra": "pesará/pagará" },
        { "hebraico": "כְּמֹהַר", "transliteral": "kə-mō-har", "traducao_palavra": "conforme o dote de" },
        { "hebraico": "הַבְּתוּלֹת׃", "transliteral": "hab-bə-ṯû-lōṯ", "traducao_palavra": "as virgens" }
      ]
    },
    "17": {
      "traducao_completa": "À feiticeira não deixarás viver.",
