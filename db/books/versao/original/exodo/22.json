        { "hebraico": "עָלָיו", "transliteral": "ʿā-lāw", "traducao_palavra": "sobre ele" },
        { "hebraico": "דָּמִים", "transliteral": "dā-mîm", "traducao_palavra": "sangues [culpa]" },
