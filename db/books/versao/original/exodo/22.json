        { "hebraico": "לָאֱלֹהִים", "transliteral": "lā-ʾĕ-lō-hîm", "traducao_palavra": "aos deuses" },
        { "hebraico": "יָחֳרָם", "transliteral": "yā-ḥo-rām", "traducao_palavra": "será anematizado/destruído" },
        { "hebraico": "בִּלְתִּי", "transliteral": "bil-tî", "traducao_palavra": "exceto" },
        { "hebraico": "לַיהוָה", "transliteral": "la-YHWH", "traducao_palavra": "a YHWH" },
        { "hebraico": "לְבַדּוֹ׃", "transliteral": "lə-ḇad-dô", "traducao_palavra": "a Ele somente" }
      ]
    },
    "20": {
      "traducao_completa": "E ao estrangeiro não afligirás, nem o oprimirás; pois estrangeiros fostes na terra do Egito.",
      "palavras": [
        { "hebraico": "וְגֵר", "transliteral": "wə-ḡēr", "traducao_palavra": "e estrangeiro" },
        { "hebraico": "לֹא־תוֹנֶה", "transliteral": "lō-ṯô-neh", "traducao_palavra": "não afligirás/maltratarás" },
        { "hebraico": "וְלֹא", "transliteral": "wə-lō", "traducao_palavra": "nem" },
        { "hebraico": "תִלְחָצֶנּוּ", "transliteral": "ṯil-ḥā-ṣen-nû", "traducao_palavra": "oprimirás a ele" },
        { "hebraico": "כִּי־גֵרִים", "transliteral": "kî-ḡê-rîm", "traducao_palavra": "pois estrangeiros" },
        { "hebraico": "הֱיִיתֶם", "transliteral": "hĕ-yî-ṯem", "traducao_palavra": "fostes vós" },
        { "hebraico": "בְּאֶרֶץ", "transliteral": "bə-ʾe-reṣ", "traducao_palavra": "na terra de" },
        { "hebraico": "מִצְרָיִם׃", "transliteral": "miṣ-rā-yim", "traducao_palavra": "Egito" }
      ]
    },
    "21": {
      "traducao_completa": "A nenhuma viúva nem órfão afligireis.",
      "palavras": [
        { "hebraico": "כָּל־אַלְמָנָה", "transliteral": "kāl-ʾal-mā-nā", "traducao_palavra": "toda viúva" },
        { "hebraico": "וְיָתוֹם", "transliteral": "wə-yā-ṯôm", "traducao_palavra": "e órfão" },
        { "hebraico": "לֹא", "transliteral": "lō", "traducao_palavra": "não" },
        { "hebraico": "תְעַנּוּן׃", "transliteral": "ṯə-ʿan-nûn", "traducao_palavra": "afligireis" }
      ]
    },
    "22": {
      "traducao_completa": "Se de algum modo o afligires, e ele clamando clamar a mim, certamente ouvirei o seu clamor.",
      "palavras": [
