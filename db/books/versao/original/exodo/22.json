        { "hebraico": "הַגַּנָּב", "transliteral": "hag-gan-nāḇ", "traducao_palavra": "o ladrão" },
        { "hebraico": "וְהֻכָּה", "transliteral": "wə-huk-kā", "traducao_palavra": "e for ferido" },
