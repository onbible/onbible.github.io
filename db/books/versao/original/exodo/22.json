        { "hebraico": "אוֹ־נִשְׁבָּה", "transliteral": "ʾô-niš-bā", "traducao_palavra": "ou for cativo/levado" },
        { "hebraico": "אֵין", "transliteral": "ʾên", "traducao_palavra": "sem [que]" },
        { "hebraico": "רֹאֶה׃", "transliteral": "rō-ʾeh", "traducao_palavra": "ninguém veja" }
