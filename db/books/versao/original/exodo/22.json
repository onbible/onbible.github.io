        { "hebraico": "תְעַנֶּה", "transliteral": "ṯə-ʿan-neh", "traducao_palavra": "afligires" },
        { "hebraico": "אֹתוֹ", "transliteral": "ʾō-ṯô", "traducao_palavra": "a ele" },
        { "hebraico": "כִּי", "transliteral": "kî", "traducao_palavra": "certamente/que" },
        { "hebraico": "אִם־צָעֹק", "transliteral": "ʾim-ṣā-ʿōq", "traducao_palavra": "se clamando" },
        { "hebraico": "יִצְעַק", "transliteral": "yiṣ-ʿaq", "traducao_palavra": "clame" },
        { "hebraico": "אֵלַי", "transliteral": "ʾē-lay", "traducao_palavra": "a mim" },
        { "hebraico": "שָׁמֹעַ", "transliteral": "šā-mō-aʿ", "traducao_palavra": "ouvindo" },
        { "hebraico": "אֶשְׁמַע", "transliteral": "ʾeš-maʿ", "traducao_palavra": "ouvirei" },
        { "hebraico": "צַעֲקָתוֹ׃", "transliteral": "ṣa-ʿă-qā-ṯô", "traducao_palavra": "seu clamor" }
      ]
    },
    "23": {
      "traducao_completa": "E a minha ira se acenderá, e vos matarei à espada; e vossas mulheres ficarão viúvas, e vossos filhos, órfãos.",
      "palavras": [
        { "hebraico": "וְחָרָה", "transliteral": "wə-ḥā-rā", "traducao_palavra": "e se acenderá" },
        { "hebraico": "אַפִּי", "transliteral": "ʾap-pî", "traducao_palavra": "minha ira [nariz]" },
        { "hebraico": "וְהָרַגְתִּי", "transliteral": "wə-hā-raḡ-tî", "traducao_palavra": "e matarei" },
        { "hebraico": "אֶתְכֶם", "transliteral": "ʾeṯ-kem", "traducao_palavra": "a vós" },
        { "hebraico": "בֶּחָרֶב", "transliteral": "be-ḥā-reḇ", "traducao_palavra": "pela espada" },
        { "hebraico": "וְהָיוּ", "transliteral": "wə-hā-yû", "traducao_palavra": "e serão" },
        { "hebraico": "נְשֵׁיכֶם", "transliteral": "nə-šê-ḵem", "traducao_palavra": "vossas mulheres" },
        { "hebraico": "אַלְמָנוֹת", "transliteral": "ʾal-mā-nôṯ", "traducao_palavra": "viúvas" },
        { "hebraico": "וּבְנֵיכֶם", "transliteral": "û-ḇə-nê-ḵem", "traducao_palavra": "e vossos filhos" },
        { "hebraico": "יְתֹמִים׃", "transliteral": "yə-ṯō-mîm", "traducao_palavra": "órfãos" }
      ]
    },
    "24": {
      "traducao_completa": "Se emprestares dinheiro ao meu povo, ao pobre que está contigo, não te portarás com ele como um credor; não lhe imporás usura.",
      "palavras": [
        { "hebraico": "אִם־כֶּסֶף", "transliteral": "ʾim-ke-sep̄", "traducao_palavra": "se dinheiro" },
        { "hebraico": "תַּלְוֶה", "transliteral": "tal-weh", "traducao_palavra": "emprestares" },
        { "hebraico": "אֶת־עַמִּי", "transliteral": "ʾeṯ-ʿam-mî", "traducao_palavra": "ao meu povo" },
        { "hebraico": "אֶת־הֶעָנִי", "transliteral": "ʾeṯ-he-ʿā-nî", "traducao_palavra": "ao pobre" },
        { "hebraico": "עִמָּךְ", "transliteral": "ʿim-māḵ", "traducao_palavra": "[que está] contigo" },
        { "hebraico": "לֹא־תִהְיֶה", "transliteral": "lō-ṯih-yeh", "traducao_palavra": "não serás/portarás" },
        { "hebraico": "לוֹ", "transliteral": "lô", "traducao_palavra": "para ele" },
        { "hebraico": "כְּנֹשֶׁה", "transliteral": "kə-nō-šeh", "traducao_palavra": "como um credor" },
        { "hebraico": "לֹא־תְשִׂימוּן", "transliteral": "lō-ṯə-śî-mûn", "traducao_palavra": "não poreis" },
        { "hebraico": "עָלָיו", "transliteral": "ʿā-lāw", "traducao_palavra": "sobre ele" },
        { "hebraico": "נֶשֶׁךְ׃", "transliteral": "ne-šeḵ", "traducao_palavra": "usura/juro" }
      ]
    },
    "25": {
      "traducao_completa": "Se de fato tomares em penhor a capa do teu próximo, até ao pôr do sol lha restituirás;",
      "palavras": [
        { "hebraico": "אִם־חָבֹל", "transliteral": "ʾim-ḥā-ḇōl", "traducao_palavra": "se empenhando" },
        { "hebraico": "תַּחְבֹּל", "transliteral": "taḥ-bōl", "traducao_palavra": "tomares em penhor" },
        { "hebraico": "שַׂלְמַת", "transliteral": "śal-maṯ", "traducao_palavra": "a capa de" },
        { "hebraico": "רֵעֶךָ", "transliteral": "rē-ʿe-ḵā", "traducao_palavra": "teu próximo" },
        { "hebraico": "עַד־בֹּא", "transliteral": "ʿaḏ-bō", "traducao_palavra": "até a vinda de/pôr de" },
        { "hebraico": "הַשֶּׁמֶשׁ", "transliteral": "haš-še-meš", "traducao_palavra": "o sol" },
        { "hebraico": "תְּשִׁיבֶנּוּ", "transliteral": "tə-šî-ḇen-nû", "traducao_palavra": "restituirás a ela [capa]" },
        { "hebraico": "לּוֹ׃", "transliteral": "lô", "traducao_palavra": "a ele" }
      ]
    },
    "26": {
      "traducao_completa": "porque aquela é a sua única cobertura, é a veste da sua pele; em que se deitaria? E será que, quando clamar a mim, eu ouvirei, porque sou misericordioso.",
      "palavras": [
        { "hebraico": "כִּי", "transliteral": "kî", "traducao_palavra": "porque" },
        { "hebraico": "הִוא", "transliteral": "hî", "traducao_palavra": "ela [é]" },
        { "hebraico": "כְסוּתֹה", "transliteral": "ḵə-śû-ṯō", "traducao_palavra": "sua cobertura" },
        { "hebraico": "לְבַדָּהּ", "transliteral": "lə-ḇad-dāh", "traducao_palavra": "única" },
        { "hebraico": "הִוא", "transliteral": "hî", "traducao_palavra": "ela [é]" },
        { "hebraico": "שִׂמְלָתוֹ", "transliteral": "śim-lā-ṯô", "traducao_palavra": "sua veste" },
        { "hebraico": "לְעֹרוֹ", "transliteral": "lə-ʿō-rô", "traducao_palavra": "para sua pele" },
        { "hebraico": "בַּמֶּה", "transliteral": "bam-meh", "traducao_palavra": "em que" },
        { "hebraico": "יִשְׁכָּב", "transliteral": "yiš-kāḇ", "traducao_palavra": "se deitará?" },
        { "hebraico": "וְהָיָה", "transliteral": "wə-hā-yā", "traducao_palavra": "e será" },
        { "hebraico": "כִּי־יִצְעַק", "transliteral": "kî-yiṣ-ʿaq", "traducao_palavra": "quando clamar" },
        { "hebraico": "אֵלַי", "transliteral": "ʾē-lay", "traducao_palavra": "a mim" },
        { "hebraico": "וְשָׁמַעְתִּי", "transliteral": "wə-šā-maʿ-tî", "traducao_palavra": "e ouvirei" },
        { "hebraico": "כִּי־חַנּוּן", "transliteral": "kî-ḥan-nûn", "traducao_palavra": "porque misericordioso" },
        { "hebraico": "אָנִי׃", "transliteral": "ʾā-nî", "traducao_palavra": "[sou] eu" }
      ]
    },
    "27": {
      "traducao_completa": "A Deus não amaldiçoarás, nem ao príncipe do teu povo amaldiçoarás.",
      "palavras": [
        { "hebraico": "אֱלֹהִים", "transliteral": "ʾĕ-lō-hîm", "traducao_palavra": "Deus/Juízes" },
        { "hebraico": "לֹא", "transliteral": "lō", "traducao_palavra": "não" },
        { "hebraico": "תְקַלֵּל", "transliteral": "ṯə-qal-lēl", "traducao_palavra": "amaldiçoarás" },
        { "hebraico": "וְנָשִׂיא", "transliteral": "wə-nā-śî", "traducao_palavra": "e príncipe/líder" },
        { "hebraico": "בְעַמְּךָ", "transliteral": "ḇə-ʿam-mə-ḵā", "traducao_palavra": "no teu povo" },
        { "hebraico": "לֹא", "transliteral": "lō", "traducao_palavra": "não" },
        { "hebraico": "תָאֹר׃", "transliteral": "ṯā-ʾōr", "traducao_palavra": "amaldiçoarás/execrarás" }
      ]
    },
    "28": {
      "traducao_completa": "A tua plenitude e a tua lágrima não tardarás; o primogênito de teus filhos darás a mim.",
      "palavras": [
        { "hebraico": "מְלֵאָתְךָ", "transliteral": "mə-lē-ʾā-ṯə-ḵā", "traducao_palavra": "tua plenitude [colheita]" },
        { "hebraico": "וְדִמְעֲךָ", "transliteral": "wə-ḏim-ʿă-ḵā", "traducao_palavra": "e tua lágrima [vinho/azeite]" },
        { "hebraico": "לֹא", "transliteral": "lō", "traducao_palavra": "não" },
        { "hebraico": "תְאַחֵר", "transliteral": "ṯə-ʾa-ḥēr", "traducao_palavra": "tardarás" },
        { "hebraico": "בְּכוֹר", "transliteral": "bə-ḵôr", "traducao_palavra": "primogênito de" },
        { "hebraico": "בָּנֶיךָ", "transliteral": "bā-ne-ḵā", "traducao_palavra": "teus filhos" },
        { "hebraico": "תִּתֶּן־לִּי׃", "transliteral": "tit-ten-lî", "traducao_palavra": "darás a mim" }
      ]
    },
    "29": {
      "traducao_completa": "Assim farás com os teus bois e com as tuas ovelhas: sete dias estarão com a sua mãe, e ao oitavo dia mo darás.",
      "palavras": [
        { "hebraico": "כֵּן־תַּעֲשֶׂה", "transliteral": "kēn-ta-ʿă-śeh", "traducao_palavra": "assim farás" },
        { "hebraico": "לְשֹׁרְךָ", "transliteral": "lə-šō-rə-ḵā", "traducao_palavra": "com teu boi" },
        { "hebraico": "לְצֹאנֶךָ", "transliteral": "lə-ṣō-ne-ḵā", "traducao_palavra": "com tua ovelha" },
        { "hebraico": "שִׁבְעַת", "transliteral": "šiḇ-ʿaṯ", "traducao_palavra": "sete de" },
        { "hebraico": "יָמִים", "transliteral": "yā-mîm", "traducao_palavra": "dias" },
        { "hebraico": "יִהְיֶה", "transliteral": "yih-yeh", "traducao_palavra": "estará" },
        { "hebraico": "עִם־אִמּוֹ", "transliteral": "ʿim-ʾim-mô", "traducao_palavra": "com sua mãe" },
        { "hebraico": "בַּיּוֹם", "transliteral": "bay-yôm", "traducao_palavra": "no dia" },
        { "hebraico": "הַשְּׁמִינִי", "transliteral": "haš-šə-mî-nî", "traducao_palavra": "o oitavo" },
        { "hebraico": "תִּתְּנוֹ־לִי׃", "transliteral": "tit-tə-nô-lî", "traducao_palavra": "darás a ele [animal] para mim" }
      ]
    },
    "30": {
      "traducao_completa": "E homens santos sereis para mim; e carne dilacerada no campo não comereis; aos cães a lançareis.",
      "palavras": [
        { "hebraico": "וְאַנְשֵׁי־קֹדֶשׁ", "transliteral": "wə-ʾan-šê-qō-ḏeš", "traducao_palavra": "e homens de santidade" },
        { "hebraico": "תִּהְיוּן", "transliteral": "tih-yûn", "traducao_palavra": "sereis vós" },
        { "hebraico": "לִי", "transliteral": "lî", "traducao_palavra": "para mim" },
        { "hebraico": "וּבָשָׂר", "transliteral": "û-ḇā-śār", "traducao_palavra": "e carne" },
        { "hebraico": "בַּשָּׂדֶה", "transliteral": "baś-śā-ḏeh", "traducao_palavra": "no campo" },
