        { "hebraico": "יְשַׁלֵּם", "transliteral": "yə-šal-lēm", "traducao_palavra": "pagará" },
        { "hebraico": "לִבְעָלָיו׃", "transliteral": "liḇ-ʿā-lāw", "traducao_palavra": "ao seu dono" }
      ]
