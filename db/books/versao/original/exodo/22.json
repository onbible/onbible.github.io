        { "hebraico": "מְכַשֵּׁפָה", "transliteral": "mə-ḵaš-šē-p̄ā", "traducao_palavra": "feiticeira" },
        { "hebraico": "לֹא", "transliteral": "lō", "traducao_palavra": "não" },
        { "hebraico": "תְחַיֶּה׃", "transliteral": "ṯə-ḥay-yeh", "traducao_palavra": "deixarás viver" }
      ]
    },
    "18": {
      "traducao_completa": "Todo aquele que se deitar com animal, certamente morrerá.",
      "palavras": [
        { "hebraico": "כָּל־שֹׁכֵב", "transliteral": "kāl-šō-ḵēḇ", "traducao_palavra": "todo o que se deitar" },
        { "hebraico": "עִם־בְּהֵמָה", "transliteral": "ʿim-bə-hē-mā", "traducao_palavra": "com animal" },
        { "hebraico": "מוֹת", "transliteral": "môṯ", "traducao_palavra": "morrendo" },
        { "hebraico": "יוּמָת׃", "transliteral": "yû-māṯ", "traducao_palavra": "certamente morrerá" }
      ]
    },
    "19": {
      "traducao_completa": "O que sacrificar aos deuses, exceto somente a YHWH, será totalmente destruído.",
