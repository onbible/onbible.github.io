        { "hebraico": "יְשַׁלֵּם", "transliteral": "yə-šal-lēm", "traducao_palavra": "pagará" },
        { "hebraico": "שְׁנָיִם׃", "transliteral": "šə-nā-yim", "traducao_palavra": "o dobro" }
