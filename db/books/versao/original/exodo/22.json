    "12": {
      "traducao_completa": "Se for dilacerado, trá-lo-á em testemunho; não pagará o dilacerado.",
      "palavras": [
        { "hebraico": "אִם־טָרֹף", "transliteral": "ʾim-ṭā-rōp̄", "traducao_palavra": "se despedaçando" },
        { "hebraico": "יִטָּרֵף", "transliteral": "yiṭ-ṭā-rēp̄", "traducao_palavra": "for despedaçado" },
        { "hebraico": "יְבִאֵהוּ", "transliteral": "yə-ḇi-ʾē-hû", "traducao_palavra": "trá-lo-á" },
        { "hebraico": "עֵד", "transliteral": "ʿēḏ", "traducao_palavra": "[como] testemunho" },
        { "hebraico": "הַטְּרֵפָה", "transliteral": "haṭ-ṭə-rē-p̄ā", "traducao_palavra": "o despedaçado" },
        { "hebraico": "לֹא", "transliteral": "lō", "traducao_palavra": "não" },
        { "hebraico": "יְשַׁלֵּם׃", "transliteral": "yə-šal-lēm", "traducao_palavra": "pagará" }
