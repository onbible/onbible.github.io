    "28": {
      "traducao_completa": "E o varal do meio passará pelo meio das tábuas, de uma extremidade até à outra.",
      "palavras": [
        { "hebraico": "וְהַבְּרִיחַ", "transliteral": "wə-hab-bə-rî-aḥ", "traducao_palavra": "e o varal" },
