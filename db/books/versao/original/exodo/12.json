        { "hebraico": "לָכֶם", "transliteral": "lā-ḵem", "traducao_palavra": "para vós" },
        { "hebraico": "רֹאשׁ", "transliteral": "rōš", "traducao_palavra": "cabeça/princípio de" },
        { "hebraico": "חֳדָשִׁים", "transliteral": "ḥo-ḏā-šîm", "traducao_palavra": "meses" },
        { "hebraico": "רִאשׁוֹן", "transliteral": "ri-šôn", "traducao_palavra": "primeiro" },
