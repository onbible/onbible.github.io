        { "hebraico": "תֹּאכְלוּ", "transliteral": "tō-ḵəlû", "traducao_palavra": "comereis" },
        { "hebraico": "אֹתוֹ", "transliteral": "ʾō-ṯô", "traducao_palavra": "a ele" },
