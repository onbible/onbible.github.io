        { "hebraico": "אַל־תֹּאכְלוּ", "transliteral": "ʾal-tō-ḵəlû", "traducao_palavra": "não comereis" },
        { "hebraico": "מִמֶּנּוּ", "transliteral": "mim-men-nû", "traducao_palavra": "dele" },
        { "hebraico": "נָא", "transliteral": "nā", "traducao_palavra": "cru" },
        { "hebraico": "וּבָשֵׁל", "transliteral": "û-ḇā-šēl", "traducao_palavra": "ou cozido" },
