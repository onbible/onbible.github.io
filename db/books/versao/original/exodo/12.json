        { "hebraico": "בֶּן־שָׁנָה", "transliteral": "ben-šā-nā", "traducao_palavra": "filho de um ano" },
        { "hebraico": "יִהְיֶה", "transliteral": "yih-yeh", "traducao_palavra": "será" },
