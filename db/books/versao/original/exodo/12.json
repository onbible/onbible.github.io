        { "hebraico": "וְעַל־קִרְבּוֹ׃", "transliteral": "wə-ʿal-qir-bô", "traducao_palavra": "e sobre seu interior" }
      ]
    },
    "10": {
      "traducao_completa": "E nada deixareis dele até pela manhã; e o que dele ficar até pela manhã, queimareis no fogo.",
      "palavras": [
        { "hebraico": "וְלֹא־תוֹתִירוּ", "transliteral": "wə-lō-ṯô-ṯî-rû", "traducao_palavra": "e não deixareis" },
        { "hebraico": "מִמֶּנּוּ", "transliteral": "mim-men-nû", "traducao_palavra": "dele" },
        { "hebraico": "עַד־בֹּקֶר", "transliteral": "ʿaḏ-bō-qer", "traducao_palavra": "até a manhã" },
        { "hebraico": "וְהַנֹּתָר", "transliteral": "wə-han-nō-ṯār", "traducao_palavra": "e o que sobrar" },
