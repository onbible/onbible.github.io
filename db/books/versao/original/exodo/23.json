        { "hebraico": "בְּאֶרֶץ", "transliteral": "bə-ʾe-reṣ", "traducao_palavra": "na terra de" },
        { "hebraico": "מִצְרָיִם׃", "transliteral": "miṣ-rā-yim", "traducao_palavra": "Egito" }
      ]
    },
    "10": {
      "traducao_completa": "E seis anos semearás a tua terra e recolherás o seu produto.",
      "palavras": [
        { "hebraico": "וְשֵׁשׁ", "transliteral": "wə-šēš", "traducao_palavra": "e seis de" },
        { "hebraico": "שָׁנִים", "transliteral": "šā-nîm", "traducao_palavra": "anos" },
        { "hebraico": "תִּזְרַע", "transliteral": "tiz-raʿ", "traducao_palavra": "semearás" },
        { "hebraico": "אֶת־אַרְצֶךָ", "transliteral": "ʾeṯ-ʾar-ṣe-ḵā", "traducao_palavra": "tua terra" },
        { "hebraico": "וְאָסַפְתָּ", "transliteral": "wə-ʾā-sap̄-tā", "traducao_palavra": "e recolherás" },
        { "hebraico": "אֶת־תְּבוּאָתָהּ׃", "transliteral": "ʾeṯ-tə-ḇû-ʾā-ṯāh", "traducao_palavra": "o seu produto" }
      ]
    },
    "11": {
      "traducao_completa": "Mas no sétimo ano a deixarás descansar e ficar sem cultivo, para que comam os pobres do teu povo, e o que eles deixarem comam os animais do campo. Assim farás com a tua vinha e com o teu olival.",
      "palavras": [
        { "hebraico": "וְהַשְּׁבִיעִת", "transliteral": "wə-haš-šə-ḇî-ʿiṯ", "traducao_palavra": "e no sétimo" },
        { "hebraico": "תִּשְׁמְטֶנָּה", "transliteral": "tiš-mə-ṭen-nā", "traducao_palavra": "a deixarás descansar/soltarás" },
        { "hebraico": "וּנְטַשְׁתָּהּ", "transliteral": "û-nə-ṭaš-tāh", "traducao_palavra": "e a abandonarás" },
        { "hebraico": "וְאָכְלוּ", "transliteral": "wə-ʾā-ḵəlû", "traducao_palavra": "para que comam" },
        { "hebraico": "אֶבְיֹנֵי", "transliteral": "ʾeḇ-yō-nê", "traducao_palavra": "[os] necessitados de" },
        { "hebraico": "עַמֶּךָ", "transliteral": "ʿam-me-ḵā", "traducao_palavra": "teu povo" },
        { "hebraico": "וְיִתְרָם", "transliteral": "wə-yiṯ-rām", "traducao_palavra": "e o resto deles" },
        { "hebraico": "תֹּאכַל", "transliteral": "tō-ḵal", "traducao_palavra": "comerá" },
        { "hebraico": "חַיַּת", "transliteral": "ḥay-yaṯ", "traducao_palavra": "[o] animal de" },
        { "hebraico": "הַשָּׂדֶה", "transliteral": "haś-śā-ḏeh", "traducao_palavra": "o campo" },
        { "hebraico": "כֵּן־תַּעֲשֶׂה", "transliteral": "kēn-ta-ʿă-śeh", "traducao_palavra": "assim farás" },
        { "hebraico": "לְכַרְמְךָ", "transliteral": "lə-ḵar-mə-ḵā", "traducao_palavra": "com tua vinha" },
        { "hebraico": "לְזֵיתֶךָ׃", "transliteral": "lə-zê-ṯe-ḵā", "traducao_palavra": "[e] com teu olival" }
      ]
    },
    "12": {
      "traducao_completa": "Seis dias farás as tuas obras, mas no sétimo dia descansarás; para que descanse o teu boi e o teu jumento, e para que tome alento o filho da tua serva e o estrangeiro.",
      "palavras": [
        { "hebraico": "שֵׁשֶׁת", "transliteral": "šē-šeṯ", "traducao_palavra": "seis de" },
        { "hebraico": "יָמִים", "transliteral": "yā-mîm", "traducao_palavra": "dias" },
        { "hebraico": "תַּעֲשֶׂה", "transliteral": "ta-ʿă-śeh", "traducao_palavra": "farás" },
        { "hebraico": "מַעֲשֶׂיךָ", "transliteral": "ma-ʿă-śe-ḵā", "traducao_palavra": "tuas obras" },
        { "hebraico": "וּבַיּוֹם", "transliteral": "û-ḇay-yôm", "traducao_palavra": "e no dia" },
        { "hebraico": "הַשְּׁבִיעִי", "transliteral": "haš-šə-ḇî-ʿî", "traducao_palavra": "o sétimo" },
        { "hebraico": "תִּשְׁבֹּת", "transliteral": "tiš-bōṯ", "traducao_palavra": "descansarás" },
        { "hebraico": "לְמַעַן", "transliteral": "lə-ma-ʿan", "traducao_palavra": "para que" },
        { "hebraico": "יָנוּחַ", "transliteral": "yā-nû-aḥ", "traducao_palavra": "descanse" },
        { "hebraico": "שׁוֹרְךָ", "transliteral": "šôr-ḵā", "traducao_palavra": "teu boi" },
        { "hebraico": "וַחֲמֹרֶךָ", "transliteral": "wa-ḥă-mō-re-ḵā", "traducao_palavra": "e teu jumento" },
        { "hebraico": "וְיִנָּפֵשׁ", "transliteral": "wə-yin-nā-p̄ēš", "traducao_palavra": "e tome alento/respire" },
        { "hebraico": "בֶּן־אֲמָתְךָ", "transliteral": "ben-ʾămā-ṯə-ḵā", "traducao_palavra": "filho de tua serva" },
        { "hebraico": "וְהַגֵּר׃", "transliteral": "wə-hag-gēr", "traducao_palavra": "e o estrangeiro" }
      ]
    },
    "13": {
      "traducao_completa": "E em tudo o que vos tenho dito, guardai-vos; e do nome de outros deuses não fareis memória, nem se ouça da tua boca.",
      "palavras": [
        { "hebraico": "וּבְכֹל", "transliteral": "û-ḇə-ḵōl", "traducao_palavra": "e em tudo" },
        { "hebraico": "אֲשֶׁר־אָמַרְתִּי", "transliteral": "ʾă-šer-ʾā-mar-tî", "traducao_palavra": "que eu disse" },
        { "hebraico": "אֲלֵיכֶם", "transliteral": "ă-lê-ḵem", "traducao_palavra": "a vós" },
        { "hebraico": "תִּשָּׁמֵרוּ", "transliteral": "tiš-šā-mê-rû", "traducao_palavra": "guardai-vos" },
        { "hebraico": "וְשֵׁם", "transliteral": "wə-šēm", "traducao_palavra": "e [do] nome de" },
        { "hebraico": "אֱלֹהִים", "transliteral": "ʾĕ-lō-hîm", "traducao_palavra": "deuses" },
        { "hebraico": "אֲחֵרִים", "transliteral": "ʾă-ḥē-rîm", "traducao_palavra": "outros" },
        { "hebraico": "לֹא", "transliteral": "lō", "traducao_palavra": "não" },
        { "hebraico": "תַזְכִּירוּ", "transliteral": "ṯaz-kî-rû", "traducao_palavra": "fareis menção" },
        { "hebraico": "לֹא", "transliteral": "lō", "traducao_palavra": "não" },
        { "hebraico": "יִשָּׁמַע", "transliteral": "yiš-šā-maʿ", "traducao_palavra": "seja ouvido" },
        { "hebraico": "עַל־פִּיךָ׃", "transliteral": "ʿal-pî-ḵā", "traducao_palavra": "sobre tua boca" }
      ]
    },
    "14": {
      "traducao_completa": "Três vezes no ano me celebrareis festa.",
      "palavras": [
        { "hebraico": "שָׁלֹשׁ", "transliteral": "šā-lōš", "traducao_palavra": "três de" },
