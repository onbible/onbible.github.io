        { "hebraico": "וֶהֱבִיאֲךָ", "transliteral": "wə-he-ḇî-ʾă-ḵā", "traducao_palavra": "e te introduzirá" },
        { "hebraico": "אֶל־הָאֱמֹרִי", "transliteral": "ʾel-hā-ʾĕ-mō-rî", "traducao_palavra": "ao amorreu" },
