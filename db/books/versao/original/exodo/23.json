        { "hebraico": "הַחִוִּי", "transliteral": "ha-ḥiw-wî", "traducao_palavra": "o heveu" },
        { "hebraico": "וְהַיְבוּסִי", "transliteral": "wə-hay-ḇû-śî", "traducao_palavra": "e ao jebuseu" },
        { "hebraico": "וְהִכְחַדְתִּיו׃", "transliteral": "wə-hiḵ-ḥaḏ-tîw", "traducao_palavra": "e exterminarei a ele [coletivo]" }
