{
  "livro": "Êxodo - שְׁמוֹת - Shemot",
  "capítulo": 23,
  "titulos": {},
  "versiculos": {
    "1": {
      "traducao_completa": "Não levantarás falso rumor; não ponhas a tua mão com o ímpio, para seres testemunha de violência.",
      "palavras": [
        { "hebraico": "לֹא", "transliteral": "lō", "traducao_palavra": "não" },
        { "hebraico": "תִשָּׂא", "transliteral": "ṯiś-śā", "traducao_palavra": "levantarás/tomarás" },
        { "hebraico": "שֵׁמַע", "transliteral": "šē-maʿ", "traducao_palavra": "rumor/notícia" },
        { "hebraico": "שָׁוְא", "transliteral": "šā-wə", "traducao_palavra": "falso/vão" },
        { "hebraico": "אַל־תָּשֶׁת", "transliteral": "ʾal-tā-šeṯ", "traducao_palavra": "não ponhas" },
        { "hebraico": "יָדְךָ", "transliteral": "yā-ḏə-ḵā", "traducao_palavra": "tua mão" },
        { "hebraico": "עִם־רָשָׁע", "transliteral": "ʿim-rā-šāʿ", "traducao_palavra": "com [o] ímpio" },
        { "hebraico": "לִהְיֹת", "transliteral": "li-hyōṯ", "traducao_palavra": "para ser" },
        { "hebraico": "עֵד", "transliteral": "ʿēḏ", "traducao_palavra": "testemunha de" },
        { "hebraico": "חָמָס׃", "transliteral": "ḥā-mās", "traducao_palavra": "violência" }
      ]
    },
    "2": {
      "traducao_completa": "Não seguirás a multidão para fazer o mal; nem responderás em juízo desviando-te após a multidão para perverter o direito.",
      "palavras": [
        { "hebraico": "לֹא־תִהְיֶה", "transliteral": "lō-ṯih-yeh", "traducao_palavra": "não serás/seguirás" },
        { "hebraico": "אַחֲרֵי־רַבִּים", "transliteral": "ʾa-ḥă-rê-rab-bîm", "traducao_palavra": "atrás de muitos/multidão" },
        { "hebraico": "לְרָעֹת", "transliteral": "lə-rā-ʿōṯ", "traducao_palavra": "para maldades" },
        { "hebraico": "וְלֹא־תַעֲנֶה", "transliteral": "wə-lō-ṯa-ʿă-neh", "traducao_palavra": "e não responderás" },
        { "hebraico": "עַל־רִב", "transliteral": "ʿal-riḇ", "traducao_palavra": "sobre contenda/juízo" },
        { "hebraico": "לִנְטֹת", "transliteral": "lin-ṭōṯ", "traducao_palavra": "para desviar-te" },
        { "hebraico": "אַחֲרֵי", "transliteral": "ʾa-ḥă-rê", "traducao_palavra": "atrás de" },
        { "hebraico": "רַבִּים", "transliteral": "rab-bîm", "traducao_palavra": "muitos" },
        { "hebraico": "לְהַטֹּת׃", "transliteral": "lə-haṭ-ṭōṯ", "traducao_palavra": "para perverter/desviar" }
      ]
    },
    "3": {
      "traducao_completa": "Nem ao pobre favorecerás no seu pleito.",
      "palavras": [
        { "hebraico": "וְדָל", "transliteral": "wə-ḏāl", "traducao_palavra": "e ao pobre" },
        { "hebraico": "לֹא", "transliteral": "lō", "traducao_palavra": "não" },
        { "hebraico": "תֶהְדַּר", "transliteral": "ṯeh-dar", "traducao_palavra": "favorecerás/honrarás" },
        { "hebraico": "בְּרִיבוֹ׃", "transliteral": "bə-rî-ḇô", "traducao_palavra": "na sua contenda/pleito" }
      ]
    },
    "4": {
      "traducao_completa": "Se encontrares o boi do teu inimigo, ou o seu jumento, desgarrado, certamente lho reconduzirás.",
      "palavras": [
        { "hebraico": "כִּי", "transliteral": "kî", "traducao_palavra": "se" },
        { "hebraico": "תִפְגַּע", "transliteral": "ṯip̄-gaʿ", "traducao_palavra": "encontrares" },
        { "hebraico": "שׁוֹר", "transliteral": "šôr", "traducao_palavra": "[o] boi de" },
        { "hebraico": "אֹיִבְךָ", "transliteral": "ʾō-yiḇ-ḵā", "traducao_palavra": "teu inimigo" },
        { "hebraico": "אוֹ", "transliteral": "ʾô", "traducao_palavra": "ou" },
        { "hebraico": "חֲמֹרוֹ", "transliteral": "ḥă-mō-rô", "traducao_palavra": "seu jumento" },
        { "hebraico": "תֹּעֶה", "transliteral": "tō-ʿeh", "traducao_palavra": "errante/desgarrado" },
        { "hebraico": "הָשֵׁב", "transliteral": "hā-šēḇ", "traducao_palavra": "fazendo voltar" },
