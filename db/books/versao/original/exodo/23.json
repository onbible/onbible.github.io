        { "hebraico": "אֱלֹהֵיכֶם", "transliteral": "ʾĕ-lō-hê-ḵem", "traducao_palavra": "vosso Deus" },
        { "hebraico": "וּבֵרַךְ", "transliteral": "û-ḇē-raḵ", "traducao_palavra": "e ele abençoará" },
        { "hebraico": "אֶת־לַחְמְךָ", "transliteral": "ʾeṯ-laḥ-mə-ḵā", "traducao_palavra": "[o] teu pão" },
        { "hebraico": "וְאֶת־מֵימֶיךָ", "transliteral": "wə-ʾeṯ-mê-me-ḵā", "traducao_palavra": "e as tuas águas" },
        { "hebraico": "וַהֲסִרֹתִי", "transliteral": "wa-hă-śi-rō-ṯî", "traducao_palavra": "e eu tirarei" },
        { "hebraico": "מַחֲלָה", "transliteral": "ma-ḥă-lā", "traducao_palavra": "enfermidade" },
        { "hebraico": "מִקִּרְבֶּךָ׃", "transliteral": "miq-qir-be-ḵā", "traducao_palavra": "do meio de ti" }
      ]
    },
    "26": {
      "traducao_completa": "Não haverá mulher que aborte, nem estéril na tua terra; o número dos teus dias completarei.",
      "palavras": [
        { "hebraico": "לֹא", "transliteral": "lō", "traducao_palavra": "não" },
        { "hebraico": "תִהְיֶה", "transliteral": "tih-yeh", "traducao_palavra": "haverá" },
        { "hebraico": "מְשַׁכֵּלָה", "transliteral": "mə-šak-kē-lā", "traducao_palavra": "abortante/que perde filhos" },
        { "hebraico": "וַעֲקָרָה", "transliteral": "wa-ʿă-qā-rā", "traducao_palavra": "e estéril" },
        { "hebraico": "בְּאַרְצֶךָ", "transliteral": "bə-ʾar-ṣe-ḵā", "traducao_palavra": "na tua terra" },
        { "hebraico": "אֶת־מִסְפַּר", "transliteral": "ʾeṯ-mis-par", "traducao_palavra": "[o] número de" },
        { "hebraico": "יָמֶיךָ", "transliteral": "yā-me-ḵā", "traducao_palavra": "teus dias" },
        { "hebraico": "אֲמַלֵּא׃", "transliteral": "ʾă-mal-lē", "traducao_palavra": "eu encherei/completarei" }
      ]
    },
    "27": {
      "traducao_completa": "O meu terror enviarei diante de ti, e perturbarei a todo o povo onde entrares, e farei que todos os teus inimigos te voltem as costas.",
      "palavras": [
        { "hebraico": "אֶת־אֵימָתִי", "transliteral": "ʾeṯ-ʾê-mā-ṯî", "traducao_palavra": "o meu terror" },
        { "hebraico": "אֲשַׁלַּח", "transliteral": "ʾă-šal-laḥ", "traducao_palavra": "enviarei" },
        { "hebraico": "לְפָנֶיךָ", "transliteral": "lə-p̄ā-ne-ḵā", "traducao_palavra": "diante de ti" },
        { "hebraico": "וְהַמֹּתִי", "transliteral": "wə-ham-mō-ṯî", "traducao_palavra": "e perturbarei/confundirei" },
        { "hebraico": "אֶת־כָּל־הָעָם", "transliteral": "ʾeṯ-kāl-hā-ʿām", "traducao_palavra": "todo o povo" },
        { "hebraico": "אֲשֶׁר", "transliteral": "ʾă-šer", "traducao_palavra": "ao qual" },
        { "hebraico": "תָּבֹא", "transliteral": "tā-ḇō", "traducao_palavra": "entrares" },
        { "hebraico": "בָּהֶם", "transliteral": "bā-hem", "traducao_palavra": "neles" },
        { "hebraico": "וְנָתַתִּי", "transliteral": "wə-nā-ṯat-tî", "traducao_palavra": "e farei/darei" },
        { "hebraico": "אֶת־כָּל־אֹיְבֶיךָ", "transliteral": "ʾeṯ-kāl-ʾō-yə-ḇe-ḵā", "traducao_palavra": "todos teus inimigos" },
        { "hebraico": "אֵלֶיךָ", "transliteral": "ʾē-le-ḵā", "traducao_palavra": "a ti" },
        { "hebraico": "עֹרֶף׃", "transliteral": "ʿō-rep̄", "traducao_palavra": "nuca/costas" }
      ]
    },
    "28": {
      "traducao_completa": "E enviarei o vespão diante de ti, para que expulse o heveu, o cananeu e o hitita de diante de ti.",
      "palavras": [
        { "hebraico": "וְשָׁלַחְתִּי", "transliteral": "wə-šā-laḥ-tî", "traducao_palavra": "e enviarei" },
        { "hebraico": "אֶת־הַצִּרְעָה", "transliteral": "ʾeṯ-haṣ-ṣir-ʿā", "traducao_palavra": "o vespão/terror" },
        { "hebraico": "לְפָנֶיךָ", "transliteral": "lə-p̄ā-ne-ḵā", "traducao_palavra": "diante de ti" },
        { "hebraico": "וְגֵרְשָׁה", "transliteral": "wə-ḡē-rə-šā", "traducao_palavra": "e expulsará" },
        { "hebraico": "אֶת־הַחִוִּי", "transliteral": "ʾeṯ-ha-ḥiw-wî", "traducao_palavra": "o heveu" },
        { "hebraico": "אֶת־הַכְּנַעֲנִי", "transliteral": "ʾeṯ-hak-kə-na-ʿă-nî", "traducao_palavra": "o cananeu" },
        { "hebraico": "וְאֶת־הַחִתִּי", "transliteral": "wə-ʾeṯ-ha-ḥit-tî", "traducao_palavra": "e o hitita" },
        { "hebraico": "מִלְּפָנֶיךָ׃", "transliteral": "mil-lə-p̄ā-ne-ḵā", "traducao_palavra": "de diante de ti" }
      ]
    },
    "29": {
      "traducao_completa": "Não os expulsarei de diante de ti num só ano, para que a terra não se torne desolada e os animais do campo se multipliquem contra ti.",
      "palavras": [
        { "hebraico": "לֹא", "transliteral": "lō", "traducao_palavra": "não" },
        { "hebraico": "אֲגָרְשֶׁנּוּ", "transliteral": "ʾă-ḡā-rə-šen-nû", "traducao_palavra": "os expulsarei" },
        { "hebraico": "מִפָּנֶיךָ", "transliteral": "mip-pā-ne-ḵā", "traducao_palavra": "de diante de ti" },
        { "hebraico": "בְּשָׁנָה", "transliteral": "bə-šā-nā", "traducao_palavra": "em ano" },
        { "hebraico": "אֶחָת", "transliteral": "ʾe-ḥāṯ", "traducao_palavra": "único" },
        { "hebraico": "פֶּן־תִּהְיֶה", "transliteral": "pen-tih-yeh", "traducao_palavra": "para que não se torne" },
        { "hebraico": "הָאָרֶץ", "transliteral": "hā-ʾā-reṣ", "traducao_palavra": "a terra" },
        { "hebraico": "שְׁמָמָה", "transliteral": "šə-mā-mā", "traducao_palavra": "desolada" },
        { "hebraico": "וְרָבָה", "transliteral": "wə-rā-ḇā", "traducao_palavra": "e se multiplique" },
        { "hebraico": "עָלֶיךָ", "transliteral": "ʿā-le-ḵā", "traducao_palavra": "contra ti" },
        { "hebraico": "חַיַּת", "transliteral": "ḥay-yaṯ", "traducao_palavra": "[o] animal de" },
        { "hebraico": "הַשָּׂדֶה׃", "transliteral": "haś-śā-ḏeh", "traducao_palavra": "o campo" }
      ]
    },
    "30": {
      "traducao_completa": "Pouco a pouco os expulsarei de diante de ti, até que te multipliques e herdes a terra.",
      "palavras": [
        { "hebraico": "מְעַט", "transliteral": "mə-ʿaṭ", "traducao_palavra": "pouco" },
        { "hebraico": "מְעַט", "transliteral": "mə-ʿaṭ", "traducao_palavra": "a pouco" },
        { "hebraico": "אֲגָרְשֶׁנּוּ", "transliteral": "ʾă-ḡā-rə-šen-nû", "traducao_palavra": "os expulsarei" },
        { "hebraico": "מִפָּנֶיךָ", "transliteral": "mip-pā-ne-ḵā", "traducao_palavra": "de diante de ti" },
        { "hebraico": "עַד", "transliteral": "ʿaḏ", "traducao_palavra": "até" },
        { "hebraico": "אֲשֶׁר", "transliteral": "ʾă-šer", "traducao_palavra": "que" },
        { "hebraico": "תִּפְרֶה", "transliteral": "tip̄-reh", "traducao_palavra": "te multipliques/frutifiques" },
        { "hebraico": "וְנָחַלְתָּ", "transliteral": "wə-nā-ḥal-tā", "traducao_palavra": "e herdes/possuas" },
        { "hebraico": "אֶת־הָאָרֶץ׃", "transliteral": "ʾeṯ-hā-ʾā-reṣ", "traducao_palavra": "a terra" }
      ]
    },
    "31": {
      "traducao_completa": "E porei o teu termo desde o Mar Vermelho até ao mar dos filisteus, e desde o deserto até ao Rio; porque entregarei nas vossas mãos os moradores da terra, e tu os expulsarás de diante de ti.",
      "palavras": [
        { "hebraico": "וְשַׁתִּי", "transliteral": "wə-šat-tî", "traducao_palavra": "e porei" },
        { "hebraico": "אֶת־גְּבֻלְךָ", "transliteral": "ʾeṯ-ḡə-ḇul-ḵā", "traducao_palavra": "o teu termo/limite" },
        { "hebraico": "מִיַּם־סוּף", "transliteral": "miy-yam-sûp̄", "traducao_palavra": "desde o Mar de Juncos" },
        { "hebraico": "וְעַד־יָם", "transliteral": "wə-ʿaḏ-yām", "traducao_palavra": "e até o mar de" },
        { "hebraico": "פְּלִשְׁתִּים", "transliteral": "pə-liš-tîm", "traducao_palavra": "filisteus" },
        { "hebraico": "וּמִמִּדְבָּר", "transliteral": "û-mim-miḏ-bār", "traducao_palavra": "e do deserto" },
        { "hebraico": "עַד־הַנָּהָר", "transliteral": "ʿaḏ-han-nā-hār", "traducao_palavra": "até o Rio [Eufrates]" },
        { "hebraico": "כִּי", "transliteral": "kî", "traducao_palavra": "porque" },
        { "hebraico": "אֶתֵּן", "transliteral": "ʾet-tēn", "traducao_palavra": "entregarei" },
        { "hebraico": "בְּיֶדְכֶם", "transliteral": "bə-yeḏ-ḵem", "traducao_palavra": "na vossa mão" },
        { "hebraico": "אֵת", "transliteral": "ʾēṯ", "traducao_palavra": "[objeto]" },
        { "hebraico": "יֹשְׁבֵי", "transliteral": "yō-šə-ḇê", "traducao_palavra": "os moradores de" },
        { "hebraico": "הָאָרֶץ", "transliteral": "hā-ʾā-reṣ", "traducao_palavra": "a terra" },
        { "hebraico": "וְגֵרַשְׁתָּמוֹ", "transliteral": "wə-ḡē-raš-tā-mô", "traducao_palavra": "e expulsarás a eles" },
        { "hebraico": "מִפָּנֶיךָ׃", "transliteral": "mip-pā-ne-ḵā", "traducao_palavra": "de diante de ti" }
      ]
    },
    "32": {
      "traducao_completa": "Não farás aliança com eles nem com os seus deuses.",
      "palavras": [
        { "hebraico": "לֹא־תִכְרֹת", "transliteral": "lō-ṯiḵ-rōṯ", "traducao_palavra": "não cortarás/farás" },
        { "hebraico": "לָהֶם", "transliteral": "lā-hem", "traducao_palavra": "para eles" },
        { "hebraico": "וְלֵאלֹהֵיהֶם", "transliteral": "wə-lê-lō-hê-hem", "traducao_palavra": "e para os deuses deles" },
        { "hebraico": "בְּרִית׃", "transliteral": "bə-rîṯ", "traducao_palavra": "aliança" }
      ]
    },
    "33": {
      "traducao_completa": "Não habitarão na tua terra, para que não te façam pecar contra mim; se servires aos seus deuses, certamente isso te será por laço.",
      "palavras": [
        { "hebraico": "לֹא", "transliteral": "lō", "traducao_palavra": "não" },
        { "hebraico": "יֵשְׁבוּ", "transliteral": "yē-šə-ḇû", "traducao_palavra": "habitarão" },
        { "hebraico": "בְּאַרְצְךָ", "transliteral": "bə-ʾar-ṣə-ḵā", "traducao_palavra": "na tua terra" },
        { "hebraico": "פֶּן־יַחֲטִיאוּ", "transliteral": "pen-ya-ḥă-ṭî-ʾû", "traducao_palavra": "para que não façam pecar" },
        { "hebraico": "אֹתְךָ", "transliteral": "ʾō-ṯə-ḵā", "traducao_palavra": "a ti" },
        { "hebraico": "לִי", "transliteral": "lî", "traducao_palavra": "contra mim" },
        { "hebraico": "כִּי", "transliteral": "kî", "traducao_palavra": "porque [se]" },
        { "hebraico": "תַעֲבֹד", "transliteral": "ṯa-ʿă-ḇōḏ", "traducao_palavra": "servires" },
        { "hebraico": "אֶת־אֱלֹהֵיהֶם", "transliteral": "ʾeṯ-ʾĕ-lō-hê-hem", "traducao_palavra": "[a]os deuses deles" },
        { "hebraico": "כִּי־יִהְיֶה", "transliteral": "kî-yih-yeh", "traducao_palavra": "pois será" },
        { "hebraico": "לְךָ", "transliteral": "lə-ḵā", "traducao_palavra": "para ti" },
        { "hebraico": "לְמוֹקֵשׁ׃", "transliteral": "lə-mō-qēš", "traducao_palavra": "por laço/armadilha" }
      ]
    }
  }
