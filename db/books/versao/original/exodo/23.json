        { "hebraico": "כְּמַעֲשֵׂיהֶם", "transliteral": "kə-ma-ʿă-śê-hem", "traducao_palavra": "conforme as obras deles" },
        { "hebraico": "כִּי", "transliteral": "kî", "traducao_palavra": "mas" },
        { "hebraico": "הָרֵס", "transliteral": "hā-rēs", "traducao_palavra": "destruindo" },
        { "hebraico": "תְּהָרְסֵם", "transliteral": "tə-hā-rə-śēm", "traducao_palavra": "os destruirás" },
