        { "hebraico": "לוֹ׃", "transliteral": "lô", "traducao_palavra": "a ele" }
      ]
    },
    "5": {
      "traducao_completa": "Se vires o jumento daquele que te odeia caído debaixo da sua carga, deixarás de ajudá-lo? Certamente o ajudarás juntamente com ele.",
      "palavras": [
        { "hebraico": "כִּי־תִרְאֶה", "transliteral": "kî-ṯir-ʾeh", "traducao_palavra": "se vires" },
        { "hebraico": "חֲמוֹר", "transliteral": "ḥă-môr", "traducao_palavra": "[o] jumento de" },
        { "hebraico": "שֹׂנַאֲךָ", "transliteral": "śō-na-ʾă-ḵā", "traducao_palavra": "[o] que te odeia" },
        { "hebraico": "רֹבֵץ", "transliteral": "rō-ḇēṣ", "traducao_palavra": "caído/deitado" },
        { "hebraico": "תַּחַת", "transliteral": "ta-ḥaṯ", "traducao_palavra": "debaixo de" },
        { "hebraico": "מַשָּׂאוֹ", "transliteral": "maś-śā-ʾô", "traducao_palavra": "sua carga" },
        { "hebraico": "וְחָדַלְתָּ", "transliteral": "wə-ḥā-ḏal-tā", "traducao_palavra": "e deixarias" },
        { "hebraico": "מֵעֲזֹב", "transliteral": "mē-ʿă-zōḇ", "traducao_palavra": "de ajudar" },
        { "hebraico": "לוֹ", "transliteral": "lô", "traducao_palavra": "a ele" },
        { "hebraico": "עָזֹב", "transliteral": "ʿā-zōḇ", "traducao_palavra": "ajudando" },
        { "hebraico": "תַּעֲזֹב", "transliteral": "ta-ʿă-zōḇ", "traducao_palavra": "ajudarás" },
        { "hebraico": "עִמּוֹ׃", "transliteral": "ʿim-mô", "traducao_palavra": "com ele" }
      ]
    },
    "6": {
      "traducao_completa": "Não perverterás o direito do teu pobre no seu pleito.",
      "palavras": [
        { "hebraico": "לֹא", "transliteral": "lō", "traducao_palavra": "não" },
        { "hebraico": "תַטֶּה", "transliteral": "ṯaṭ-ṭeh", "traducao_palavra": "perverterás/desviarás" },
        { "hebraico": "מִשְׁפַּט", "transliteral": "miš-paṭ", "traducao_palavra": "[o] direito de" },
        { "hebraico": "אֶבְיֹנְךָ", "transliteral": "ʾeḇ-yō-nə-ḵā", "traducao_palavra": "teu necessitado" },
        { "hebraico": "בְּרִיבוֹ׃", "transliteral": "bə-rî-ḇô", "traducao_palavra": "na sua contenda" }
      ]
    },
    "7": {
      "traducao_completa": "De palavra de mentira te afastarás; e ao inocente e ao justo não matarás; porque não justificarei o ímpio.",
      "palavras": [
        { "hebraico": "מִדְּבַר־שֶׁקֶר", "transliteral": "mid-də-ḇar-še-qer", "traducao_palavra": "de palavra de mentira" },
        { "hebraico": "תִּרְחָק", "transliteral": "tir-ḥāq", "traducao_palavra": "te afastarás" },
        { "hebraico": "וְנָקִי", "transliteral": "wə-nā-qî", "traducao_palavra": "e [ao] inocente" },
        { "hebraico": "וְצַדִּיק", "transliteral": "wə-ṣad-dîq", "traducao_palavra": "e [ao] justo" },
        { "hebraico": "אַל־תַּהֲרֹג", "transliteral": "ʾal-ta-hă-rōḡ", "traducao_palavra": "não matarás" },
        { "hebraico": "כִּי", "transliteral": "kî", "traducao_palavra": "porque" },
        { "hebraico": "לֹא־אַצְדִּיק", "transliteral": "lō-ʾaṣ-dîq", "traducao_palavra": "não justificarei" },
        { "hebraico": "רָשָׁע׃", "transliteral": "rā-šāʿ", "traducao_palavra": "[o] ímpio" }
      ]
    },
    "8": {
      "traducao_completa": "E suborno não aceitarás; porque o suborno cega os que têm vista e perverte as palavras dos justos.",
      "palavras": [
        { "hebraico": "וְשֹׁחַד", "transliteral": "wə-šō-ḥaḏ", "traducao_palavra": "e suborno" },
        { "hebraico": "לֹא", "transliteral": "lō", "traducao_palavra": "não" },
        { "hebraico": "תִקָּח", "transliteral": "ṯiq-qāḥ", "traducao_palavra": "tomarás/aceitarás" },
        { "hebraico": "כִּי", "transliteral": "kî", "traducao_palavra": "porque" },
        { "hebraico": "הַשֹּׁחַד", "transliteral": "haš-šō-ḥaḏ", "traducao_palavra": "o suborno" },
        { "hebraico": "יְעַוֵּר", "transliteral": "yə-ʿaw-wēr", "traducao_palavra": "cega" },
        { "hebraico": "פִּקְחִים", "transliteral": "piq-ḥîm", "traducao_palavra": "[os que têm] vista/abertos" },
        { "hebraico": "וִיסַלֵּף", "transliteral": "wî-sal-lēp̄", "traducao_palavra": "e perverte" },
        { "hebraico": "דִּבְרֵי", "transliteral": "diḇ-rê", "traducao_palavra": "palavras de" },
        { "hebraico": "צַדִּיקִים׃", "transliteral": "ṣad-dî-qîm", "traducao_palavra": "justos" }
      ]
    },
    "9": {
      "traducao_completa": "E ao estrangeiro não oprimirás; pois vós sabeis a alma do estrangeiro, porquanto fostes estrangeiros na terra do Egito.",
      "palavras": [
        { "hebraico": "וְגֵר", "transliteral": "wə-ḡēr", "traducao_palavra": "e [ao] estrangeiro" },
        { "hebraico": "לֹא", "transliteral": "lō", "traducao_palavra": "não" },
        { "hebraico": "תִלְחָץ", "transliteral": "ṯil-ḥāṣ", "traducao_palavra": "oprimirás" },
        { "hebraico": "וְאַתֶּם", "transliteral": "wə-ʾat-tem", "traducao_palavra": "e vós" },
        { "hebraico": "יְדַעְתֶּם", "transliteral": "yə-ḏaʿ-tem", "traducao_palavra": "sabeis/conheceis" },
