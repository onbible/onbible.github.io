        { "hebraico": "וְהוֹדַעְתָּ", "transliteral": "wə-hô-ḏaʿ-tā", "traducao_palavra": "e farás saber" },
        { "hebraico": "לָהֶם", "transliteral": "lā-hem", "traducao_palavra": "a eles" },
