        { "hebraico": "וּמִבָּתֶּיךָ", "transliteral": "û-mib-bāt-te-ḵā", "traducao_palavra": "e de tuas casas" },
        { "hebraico": "וּמֵעֲבָדֶיךָ", "transliteral": "û-mē-ʿă-ḇā-ḏe-ḵā", "traducao_palavra": "e de teus servos" },
        { "hebraico": "וּמֵעַמֶּךָ", "transliteral": "û-mē-ʿam-me-ḵā", "traducao_palavra": "e de teu povo" },
