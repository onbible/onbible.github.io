        { "hebraico": "אַתָּה", "transliteral": "ʾat-tā", "traducao_palavra": "[és] tu" },
        { "hebraico": "פֶּן־אֲכֶלְךָ", "transliteral": "pen-ʾă-ḵel-ḵā", "traducao_palavra": "para que não te consuma" },
