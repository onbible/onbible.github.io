        { "hebraico": "חָלָב", "transliteral": "ḥā-lāḇ", "traducao_palavra": "leite" },
        { "hebraico": "וּדְבָשׁ", "transliteral": "û-ḏə-ḇāš", "traducao_palavra": "e mel" },
