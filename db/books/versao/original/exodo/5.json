    "9": {
      "traducao_completa": "Agrave-se o serviço sobre esses homens, para que trabalhem nele e não atentem a palavras de mentira.",
      "palavras": [
        { "hebraico": "תִּכְבַּד", "transliteral": "tiḵ-baḏ", "traducao_palavra": "agreve-se" },
