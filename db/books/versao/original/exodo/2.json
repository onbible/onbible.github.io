        { "hebraico": "לֵכִי", "transliteral": "lê-ḵî", "traducao_palavra": "vai" },
        { "hebraico": "וַתֵּלֶךְ", "transliteral": "wat-tē-leḵ", "traducao_palavra": "e foi" },
        { "hebraico": "הָעַלְמָה", "transliteral": "hā-ʿal-mā", "traducao_palavra": "a moça" },
