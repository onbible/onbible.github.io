        { "hebraico": "הָהֵם", "transliteral": "hā-hēm", "traducao_palavra": "aqueles" },
        { "hebraico": "וַיִּגְדַּל", "transliteral": "way-yiḡ-dal", "traducao_palavra": "e tornou-se grande" },
