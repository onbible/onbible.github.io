        { "hebraico": "הֹלְכֹת", "transliteral": "hō-lə-ḵōṯ", "traducao_palavra": "andavam/passeavam" },
        { "hebraico": "עַל־יַד", "transliteral": "ʿal-yaḏ", "traducao_palavra": "pela mão/lado de" },
        { "hebraico": "הַיְאֹר", "transliteral": "hay-yə-ʾōr", "traducao_palavra": "o Rio" },
