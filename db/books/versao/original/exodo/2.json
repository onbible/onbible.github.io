        { "hebraico": "מַכֶּה", "transliteral": "mak-keh", "traducao_palavra": "ferindo" },
        { "hebraico": "אִישׁ־עִבְרִי", "transliteral": "ʾîš-ʿiḇ-rî", "traducao_palavra": "um homem hebreu" },
