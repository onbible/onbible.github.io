      ]
    },
    "21": {
      "traducao_completa": "E Moisés consentiu em habitar com o homem; e ele deu a Moisés a Zípora, sua filha.",
      "palavras": [
        { "hebraico": "וַיּוֹאֶל", "transliteral": "way-yô-ʾel", "traducao_palavra": "e consentiu/quis" },
