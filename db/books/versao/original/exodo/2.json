        { "hebraico": "זֶה׃", "transliteral": "zeh", "traducao_palavra": "[é] este" }
      ]
    },
    "7": {
      "traducao_completa": "Então disse sua irmã à filha de Faraó: Irei eu e chamarei para ti uma mulher ama das hebreias, para que ela te crie o menino?",
