        { "hebraico": "אֶת־הַמִּצְרִי", "transliteral": "ʾeṯ-ham-miṣ-rî", "traducao_palavra": "o egípcio" },
        { "hebraico": "וַיִּירָא", "transliteral": "way-yî-rā", "traducao_palavra": "e temeu" },
