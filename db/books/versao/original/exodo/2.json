        { "hebraico": "רֵעֶךָ׃", "transliteral": "rē-ʿe-ḵā", "traducao_palavra": "teu próximo/companheiro" }
      ]
    },
    "14": {
      "traducao_completa": "E ele disse: Quem te pôs por homem príncipe e juiz sobre nós? Acaso pensas tu em matar-me como mataste o egípcio? E temeu Moisés e disse: Certamente a coisa é conhecida.",
      "palavras": [
