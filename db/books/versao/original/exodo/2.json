        { "hebraico": "אֶל־בַּת־פַּרְעֹה", "transliteral": "ʾel-baṯ-par-ʿōh", "traducao_palavra": "à filha de Faraó" },
        { "hebraico": "הַאֵלֵךְ", "transliteral": "ha-ʾē-lēḵ", "traducao_palavra": "irei eu?" },
