        { "hebraico": "תַעֲבֹ֑ר", "transliteral": "ṯa-ʿă-ḇōr", "traducao_palavra": "passarás" },
        { "hebraico": "וַיֵּצֵ֤א", "transliteral": "way-yê-ṣê", "traducao_palavra": "e saiu" },
