        { "hebraico": "וּבְכֶ֔רֶם", "transliteral": "ū-ḇə-ḵe-rem", "traducao_palavra": "e em vinha" },
        { "hebraico": "לֹ֥א", "transliteral": "lō", "traducao_palavra": "não" },
        { "hebraico": "נִשְׁתֶּ֖ה", "transliteral": "niš-teh", "traducao_palavra": "beberemos" },
        { "hebraico": "מֵ֣י", "transliteral": "mê", "traducao_palavra": "águas de" },
        { "hebraico": "בְאֵ֑ר", "transliteral": "ḇə-ʾēr", "traducao_palavra": "poço" },
        { "hebraico": "בְּדֶ֤רֶךְ", "transliteral": "bə-ḏe-reḵ", "traducao_palavra": "pelo caminho de" },
        { "hebraico": "הַמֶּ֨לֶךְ֙", "transliteral": "ham-me-leḵ", "traducao_palavra": "o rei [real]" },
        { "hebraico": "נֵלֵ֔ךְ", "transliteral": "nê-lêḵ", "traducao_palavra": "iremos" },
