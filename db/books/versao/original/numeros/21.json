        { "hebraico": "אֲשֶֽׁר־נַעֲבֹ֖ר", "transliteral": "ʾă-šer-na-ʿă-ḇōr", "traducao_palavra": "que passemos" },
        { "hebraico": "גְּבֻלֶֽךָ׃", "transliteral": "gə-ḇu-le-ḵā", "traducao_palavra": "teu termo/limite" }
      ]
    },
    "23": {
      "traducao_completa": "Porém Seom não deixou passar a Israel pelos seus termos; antes Seom ajuntou todo o seu povo, e saiu ao encontro de Israel ao deserto, e veio a Jaza, e pelejou contra Israel.",
