    },
    "5": {
      "traducao_completa": "Quando tocades alarme, então partirão os arraiais que estão acampados ao oriente.",
      "palavras": [
        { "hebraico": "וּתְקַעְתֶּ֖ם", "transliteral": "ū-ṯə-qaʿ-tem", "traducao_palavra": "e quando tocades" },
        { "hebraico": "תְּרוּעָ֑ה", "transliteral": "tə-rû-ʿā", "traducao_palavra": "alarme/toque quebrado" },
        { "hebraico": "וְנָסְעוּ֙", "transliteral": "wə-nā-śə-ʿû", "traducao_palavra": "então partirão" },
        { "hebraico": "הַֽמַּחֲנֹ֔ות", "transliteral": "ham-ma-ḥă-nôṯ", "traducao_palavra": "os arraiais" },
        { "hebraico": "הַחֹנִ֖ים", "transliteral": "ha-ḥō-nîm", "traducao_palavra": "os que acampam" },
