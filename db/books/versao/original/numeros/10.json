{
  "livro": "Números - בְּמִדְבַּר - Bemidbar",
  "capítulo": 10,
  "titulos": {},
  "versiculos": {
    "1": {
      "traducao_completa": "E falou YHWH a Moisés, dizendo:",
      "palavras": [
        { "hebraico": "וַיְדַבֵּ֥ר", "transliteral": "way-yə-ḏab-bēr", "traducao_palavra": "e falou" },
        { "hebraico": "יְהוָ֖ה", "transliteral": "YHWH", "traducao_palavra": "YHWH" },
        { "hebraico": "אֶל־מֹשֶׁ֥ה", "transliteral": "ʾel-mō-šeh", "traducao_palavra": "a Moisés" },
        { "hebraico": "לֵּאמֹֽר׃", "transliteral": "lē-mōr", "traducao_palavra": "dizendo" }
      ]
    },
    "2": {
      "traducao_completa": "Faze para ti duas trombetas de prata; de obra batida as farás, e elas te servirão para a convocação da congregação, e para a partida dos arraiais.",
      "palavras": [
        { "hebraico": "עֲשֵׂ֣ה", "transliteral": "ʿă-śēh", "traducao_palavra": "faze" },
        { "hebraico": "לְךָ֗", "transliteral": "lə-ḵā", "traducao_palavra": "para ti" },
        { "hebraico": "שְׁתֵּי֙", "transliteral": "šə-tê", "traducao_palavra": "duas" },
        { "hebraico": "חֲצֹוצְרֹ֣ת", "transliteral": "ḥă-ṣô-ṣə-rōṯ", "traducao_palavra": "trombetas de" },
        { "hebraico": "כֶּ֔סֶף", "transliteral": "ke-sep̄", "traducao_palavra": "prata" },
        { "hebraico": "מִקְשָׁה", "transliteral": "miq-šā", "traducao_palavra": "obra batida" },
        { "hebraico": "תַּעֲשֶׂ֣ה", "transliteral": "ṯa-ʿă-śeh", "traducao_palavra": "farás" },
        { "hebraico": "אֹתָ֑ם", "transliteral": "ʾō-ṯām", "traducao_palavra": "elas" },
        { "hebraico": "וְהָי֤וּ", "transliteral": "wə-hā-yû", "traducao_palavra": "e serão" },
        { "hebraico": "לְךָ֙", "transliteral": "lə-ḵā", "traducao_palavra": "para ti" },
        { "hebraico": "לְמִקְרָ֣א", "transliteral": "lə-miq-rā", "traducao_palavra": "para a convocação de" },
        { "hebraico": "הָעֵדָ֔ה", "transliteral": "hā-ʿē-ḏā", "traducao_palavra": "a congregação" },
        { "hebraico": "וּלְמַסַּ֖ע", "transliteral": "ū-lə-mas-saʿ", "traducao_palavra": "e para a partida de" },
        { "hebraico": "אֶת־הַֽמַּחֲנֹֽות׃", "transliteral": "ʾeṯ-ham-ma-ḥă-nôṯ", "traducao_palavra": "os arraiais" }
      ]
    },
    "3": {
      "traducao_completa": "E, quando as tocaram, toda a congregação se ajuntará a ti à porta da tenda da congregação.",
      "palavras": [
        { "hebraico": "וְתָקְע֖וּ", "transliteral": "wə-ṯā-qə-ʿû", "traducao_palavra": "e quando as tocaram" },
        { "hebraico": "בָּהֵ֑ן", "transliteral": "bā-hên", "traducao_palavra": "nelas" },
        { "hebraico": "וְנֹועֲד֤וּ", "transliteral": "wə-nô-ʿă-ḏû", "traducao_palavra": "e se reunirão" },
        { "hebraico": "אֵלֶ֨יךָ֙", "transliteral": "ʾê-le-ḵā", "traducao_palavra": "a ti" },
        { "hebraico": "כָּל־הָעֵדָ֔ה", "transliteral": "kāl-hā-ʿē-ḏā", "traducao_palavra": "toda a congregação" },
        { "hebraico": "אֶל־פֶּ֖תַח", "transliteral": "ʾel-pe-ṯaḥ", "traducao_palavra": "à porta de" },
        { "hebraico": "אֹ֥הֶל", "transliteral": "ʾō-hel", "traducao_palavra": "tenda de" },
        { "hebraico": "מוֹעֵֽד׃", "transliteral": "mô-ʿēḏ", "traducao_palavra": "reunião" }
      ]
    },
    "4": {
      "traducao_completa": "Mas, quando tocaram uma só, então os príncipes, os cabeças dos milhares de Israel, se ajuntarão a ti.",
      "palavras": [
        { "hebraico": "וְאִם־בְּאַחַ֖ת", "transliteral": "wə-ʾim-bə-ʾe-ḥaṯ", "traducao_palavra": "e se em uma só" },
        { "hebraico": "יִתְקָ֑עוּ", "transliteral": "yiṯ-qā-ʿû", "traducao_palavra": "tocarem" },
        { "hebraico": "וְנֹועֲד֤וּ", "transliteral": "wə-nô-ʿă-ḏû", "traducao_palavra": "então se ajuntarão" },
        { "hebraico": "אֵלֶ֨יךָ֙", "transliteral": "ʾê-le-ḵā", "traducao_palavra": "a ti" },
        { "hebraico": "הַנְּשִׂיאִ֔ים", "transliteral": "han-nə-śî-ʾîm", "traducao_palavra": "os príncipes" },
        { "hebraico": "רָאשֵׁ֖י", "transliteral": "rā-šê", "traducao_palavra": "cabeças de" },
        { "hebraico": "אַלְפֵ֥י", "transliteral": "ʾal-p̄ê", "traducao_palavra": "milhares de" },
        { "hebraico": "יִשְׂרָאֵֽל׃", "transliteral": "yiś-rā-ʾēl", "traducao_palavra": "Israel" }
