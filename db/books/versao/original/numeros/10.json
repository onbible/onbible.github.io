        { "hebraico": "וַיְהִ֞י", "transliteral": "way-hî", "traducao_palavra": "e aconteceu" },
        { "hebraico": "בַּשָּׁנָ֧ה", "transliteral": "ba-šā-nā", "traducao_palavra": "no ano" },
