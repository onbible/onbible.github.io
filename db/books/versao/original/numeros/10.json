      ]
    },
    "8": {
      "traducao_completa": "E os filhos de Arão, os sacerdotes, tocarão as trombetas; e isto vos será por estatuto perpétuo pelas vossas gerações.",
      "palavras": [
        { "hebraico": "וּבְנֵ֤י", "transliteral": "ū-ḇə-nê", "traducao_palavra": "e os filhos de" },
        { "hebraico": "אַהֲרֹן֙", "transliteral": "ʾa-hă-rōn", "traducao_palavra": "Arão" },
        { "hebraico": "הַכֹּ֣הֲנִ֔ים", "transliteral": "hak-kō-hă-nîm", "traducao_palavra": "os sacerdotes" },
        { "hebraico": "יִתְקְע֖וּ", "transliteral": "yiṯ-qə-ʿû", "traducao_palavra": "tocarão" },
        { "hebraico": "בַּחֲצֹוצְרֹ֑ות", "transliteral": "ba-ḥă-ṣô-ṣə-rôṯ", "traducao_palavra": "as trombetas" },
        { "hebraico": "וְהָי֨וּ", "transliteral": "wə-hā-yû", "traducao_palavra": "e será" },
        { "hebraico": "לָכֶ֧ם", "transliteral": "lā-ḵem", "traducao_palavra": "para vós" },
        { "hebraico": "לְחֻקַּ֥ת", "transliteral": "lə-ḥuq-qaṯ", "traducao_palavra": "por estatuto de" },
        { "hebraico": "עוֹלָ֖ם", "transliteral": "ʿô-lām", "traducao_palavra": "eternidade" },
        { "hebraico": "לְדֹרֹתֵיכֶֽם׃", "transliteral": "lə-ḏō-rō-ṯê-ḵem", "traducao_palavra": "pelas vossas gerações" }
      ]
    },
    "9": {
      "traducao_completa": "E quando, na vossa terra, sairdes à guerra contra o inimigo que vos oprime, também tocareis alarme com as trombetas, e perante YHWH vosso Deus sereis lembrados, e sereis salvos de vossos inimigos.",
      "palavras": [
        { "hebraico": "וְכִֽי־תָבֹ֨אוּ", "transliteral": "wə-kî-ṯā-ḇō-ʾû", "traducao_palavra": "e quando sirdes" },
        { "hebraico": "מִלְחָמָה֙", "transliteral": "mil-ḥā-mā", "traducao_palavra": "[à] guerra" },
        { "hebraico": "בְּאַרְצְכֶ֔ם", "transliteral": "bə-ʾar-ṣə-ḵem", "traducao_palavra": "na vossa terra" },
        { "hebraico": "עַל־הַצַּ֖ר", "transliteral": "ʿal-haṣ-ṣar", "traducao_palavra": "contra o inimigo" },
        { "hebraico": "הַצֹּרֵ֣ר", "transliteral": "haṣ-ṣō-rēr", "traducao_palavra": "que oprime" },
