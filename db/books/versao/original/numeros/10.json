    },
    "6": {
      "traducao_completa": "Quando tocades alarme segunda vez, então partirão os arraiais que estão acampados ao sul; para as suas partidas tocarão alarme.",
      "palavras": [
        { "hebraico": "וּתְקַעְתֶּ֤ם", "transliteral": "ū-ṯə-qaʿ-tem", "traducao_palavra": "e quando tocades" },
        { "hebraico": "תְּרוּעָה֙", "transliteral": "tə-rû-ʿā", "traducao_palavra": "alarme" },
        { "hebraico": "שֵׁנִ֔ית", "transliteral": "šē-nîṯ", "traducao_palavra": "segunda vez" },
        { "hebraico": "וְנָסְעוּ֙", "transliteral": "wə-nā-śə-ʿû", "traducao_palavra": "então partirão" },
