    },
    "12": {
      "traducao_completa": "E os filhos de Israel partiram, segundo a ordem das suas marchas, do deserto de Sinai; e a nuvem parou no deserto de Parã.",
      "palavras": [
        { "hebraico": "וַיִּסְע֧וּ", "transliteral": "way-yis-ʿû", "traducao_palavra": "e partiram" },
        { "hebraico": "בְנֵֽי־יִשְׂרָאֵ֛ל", "transliteral": "ḇə-nê yiś-rā-ʾēl", "traducao_palavra": "os filhos de Israel" },
