        { "hebraico": "עֹולֹ֣תֵיכֶ֔ם", "transliteral": "ʿô-lō-ṯê-ḵem", "traducao_palavra": "vossos holocaustos" },
        { "hebraico": "וְעַ֖ל", "transliteral": "wə-ʿal", "traducao_palavra": "e sobre" },
        { "hebraico": "זִבְחֵ֣י", "transliteral": "ziḇ-ḥê", "traducao_palavra": "sacrifícios de" },
        { "hebraico": "שַׁלְמֵיכֶ֑ם", "transliteral": "šal-mê-ḵem", "traducao_palavra": "vossa paz" },
        { "hebraico": "וְהָי֨וּ", "transliteral": "wə-hā-yû", "traducao_palavra": "e serão" },
        { "hebraico": "לָכֶ֤ם", "transliteral": "lā-ḵem", "traducao_palavra": "para vós" },
        { "hebraico": "לְזִכָּרֹון֙", "transliteral": "lə-zik-kā-rôn", "traducao_palavra": "por memorial" },
        { "hebraico": "לִפְנֵ֣י", "transliteral": "lip̄-nê", "traducao_palavra": "perante" },
        { "hebraico": "אֱלֹהֵיכֶ֔ם", "transliteral": "ʾĕ-lō-hê-ḵem", "traducao_palavra": "vosso Deus" },
        { "hebraico": "אֲנִ֖י", "transliteral": "ʾă-nî", "traducao_palavra": "Eu [sou]" },
        { "hebraico": "יְהוָ֥ה", "transliteral": "YHWH", "traducao_palavra": "YHWH" },
        { "hebraico": "אֱלֹהֵיכֶֽם׃", "transliteral": "ʾĕ-lō-hê-ḵem", "traducao_palavra": "vosso Deus" }
      ]
    },
    "11": {
      "traducao_completa": "E aconteceu que, no ano segundo, no mês segundo, aos vinte do mês, a nuvem se levantou de sobre o tabernáculo do testemunho.",
