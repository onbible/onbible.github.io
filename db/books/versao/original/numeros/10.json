        { "hebraico": "הַחֹנִ֣ים", "transliteral": "ha-ḥō-nîm", "traducao_palavra": "os que acampam" },
        { "hebraico": "תֵּימָ֑נָה", "transliteral": "ṯê-mā-nā", "traducao_palavra": "ao sul" },
        { "hebraico": "תְּרוּעָ֥ה", "transliteral": "tə-rû-ʿā", "traducao_palavra": "alarme" },
        { "hebraico": "יִתְקְע֖וּ", "transliteral": "yiṯ-qə-ʿû", "traducao_palavra": "tocarão" },
        { "hebraico": "לְמַסְּעֵיהֶֽם׃", "transliteral": "lə-mas-śə-ʿê-hem", "traducao_palavra": "para as partidas deles" }
      ]
    },
    "7": {
      "traducao_completa": "Mas, ajuntando a congregação, tocarão, porém não tocarão alarme.",
      "palavras": [
        { "hebraico": "וּבְהַקְהִ֖יל", "transliteral": "ū-ḇə-haq-hîl", "traducao_palavra": "e ao ajuntar" },
        { "hebraico": "אֶת־הַקָּהָ֑ל", "transliteral": "ʾeṯ-haq-qā-hāl", "traducao_palavra": "a congregação" },
