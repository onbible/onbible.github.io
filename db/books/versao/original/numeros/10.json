        { "hebraico": "וְנִזְכַּרְתֶּם֙", "transliteral": "wə-niz-kar-tem", "traducao_palavra": "e sereis lembrados" },
        { "hebraico": "לִפְנֵי֙", "transliteral": "lip̄-nê", "traducao_palavra": "perante" },
        { "hebraico": "יְהוָ֣ה", "transliteral": "YHWH", "traducao_palavra": "YHWH" },
