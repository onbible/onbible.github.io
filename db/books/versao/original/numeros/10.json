        { "hebraico": "מֵאֹיְבֵיכֶֽם׃", "transliteral": "mē-ʾō-yə-ḇê-ḵem", "traducao_palavra": "de vossos inimigos" }
      ]
    },
    "10": {
      "traducao_completa": "Semelhantemente, no dia da vossa alegria, e nas vossas solenidades, e nos princípios dos vossos meses, tocareis as trombetas sobre os vossos holocaustos, e sobre os vossos sacrifícios pacíficos, e vos serão por memorial perante vosso Deus. Eu sou YHWH vosso Deus.",
      "palavras": [
        { "hebraico": "וּבְי֨וֹם", "transliteral": "ū-ḇə-yôm", "traducao_palavra": "e no dia de" },
        { "hebraico": "שִׂמְḥַתְכֶ֥ם", "transliteral": "śim-ḥaṯ-ḵem", "traducao_palavra": "vossa alegria" },
