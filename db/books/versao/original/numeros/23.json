        { "hebraico": "וְדַם־חֲלָלִ֖ים", "transliteral": "wə-ḏam-ḥă-lā-lîm", "traducao_palavra": "e o sangue dos mortos" },
        { "hebraico": "יִשְׁתֶּֽה׃", "transliteral": "yiš-teh", "traducao_palavra": "beba" }
