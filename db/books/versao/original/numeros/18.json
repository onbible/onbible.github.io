    "11": {
      "traducao_completa": "Também isto será teu: a oferta alçada das suas dádivas com todas as ofertas movidas dos filhos de Israel; a ti, a teus filhos e a tuas filhas contigo as tenho dado por estatuto perpétuo; todo o que estiver limpo na tua casa as comerá.",
      "palavras": [
        { "hebraico": "וְזֶה־לְּךָ֗", "transliteral": "wə-zeh-lə-ḵā", "traducao_palavra": "e isto [será] para ti" },
