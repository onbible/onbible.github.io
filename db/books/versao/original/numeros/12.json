        { "hebraico": "בְּמֹשֶׁ֔ה", "transliteral": "bə-mō-šeh", "traducao_palavra": "contra Moisés" },
        { "hebraico": "עַל־אֹדֹ֛ות", "transliteral": "ʿal-ʾō-ḏôṯ", "traducao_palavra": "por causa de" },
