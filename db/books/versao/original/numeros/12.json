        { "hebraico": "לָקָ֑ח", "transliteral": "lā-qāḥ", "traducao_palavra": "ele tomara" },
        { "hebraico": "כִּֽי־אִשָּׁ֥ה", "transliteral": "kî-ʾiš-šā", "traducao_palavra": "pois mulher" },
        { "hebraico": "כֻשִׁ֖ית", "transliteral": "ḵu-šîṯ", "traducao_palavra": "cusita" },
        { "hebraico": "לָקָֽח׃", "transliteral": "lā-qāḥ", "traducao_palavra": "ele tomara" }
