        { "hebraico": "וְהַיְבוּסִ֥י", "transliteral": "wə-hay-ḇû-śî", "traducao_palavra": "e o jebuseu" },
        { "hebraico": "וְהָֽאֱמֹרִ֖י", "transliteral": "wə-hā-ʾĕ-mō-rî", "traducao_palavra": "e o amorreu" },
        { "hebraico": "יֹושֵׁ֣ב", "transliteral": "yô-šêḇ", "traducao_palavra": "habitam" },
