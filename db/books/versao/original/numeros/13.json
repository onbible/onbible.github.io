        { "hebraico": "וְהַֽכְּנַעֲנִ֞י", "transliteral": "wə-hak-kə-na-ʿă-nî", "traducao_palavra": "e o cananeu" },
        { "hebraico": "יֹושֵׁ֤ב", "transliteral": "yô-šêḇ", "traducao_palavra": "habita" },
        { "hebraico": "עַל־הַיָּ֔ם", "transliteral": "ʿal-hay-yām", "traducao_palavra": "junto ao mar" },
