        { "hebraico": "אֲשֶׁר֩", "transliteral": "ʾă-šer", "traducao_palavra": "que" },
        { "hebraico": "עָבַ֨רְנוּ", "transliteral": "ʿā-ḇar-nû", "traducao_palavra": "passamos" },
