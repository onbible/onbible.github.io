        { "hebraico": "הִ֔וא", "transliteral": "hî", "traducao_palavra": "ela" },
        { "hebraico": "וְכָל־הָעָ֛ם", "transliteral": "wə-ḵāl-hā-ʿām", "traducao_palavra": "e todo o povo" },
        { "hebraico": "אֲשֶׁר־רָאִ֥ינוּ", "transliteral": "ʾă-šer-rā-ʾî-nû", "traducao_palavra": "que vimos" },
