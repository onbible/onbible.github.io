        { "hebraico": "אֹתָ֔הּ", "transliteral": "ʾō-ṯāh", "traducao_palavra": "ela" },
        { "hebraico": "אֶל־בְּנֵ֥י", "transliteral": "ʾel-bə-nê", "traducao_palavra": "aos filhos de" },
