        { "hebraico": "כָּלֵ֛ב", "transliteral": "kā-lēḇ", "traducao_palavra": "Calebe" },
        { "hebraico": "אֶת־הָעָ֖ם", "transliteral": "ʾeṯ-hā-ʿām", "traducao_palavra": "o povo" },
        { "hebraico": "אֶל־מֹשֶׁ֑ה", "transliteral": "ʾel-mō-šeh", "traducao_palavra": "perante Moisés" },
        { "hebraico": "וַיֹּ֗אמֶר", "transliteral": "way-yō-mer", "traducao_palavra": "e disse" },
        { "hebraico": "עָלֹ֤ה", "transliteral": "ʿā-lō", "traducao_palavra": "subindo" },
        { "hebraico": "נַעֲלֶה֙", "transliteral": "na-ʿă-leh", "traducao_palavra": "subamos" },
        { "hebraico": "וְיָרַ֣שְׁנוּ", "transliteral": "wə-yā-raš-nû", "traducao_palavra": "e herdemos" },
        { "hebraico": "אֹתָ֔הּ", "transliteral": "ʾō-ṯāh", "traducao_palavra": "ela" },
        { "hebraico": "כִּֽי־יָכֹ֥ול", "transliteral": "kî-yā-ḵôl", "traducao_palavra": "pois podendo" },
        { "hebraico": "נוּכַ֖ל", "transliteral": "nû-ḵal", "traducao_palavra": "poderemos" },
        { "hebraico": "לָֽהּ׃", "transliteral": "lāh", "traducao_palavra": "[prevalecer] contra ela" }
      ]
    },
    "31": {
      "traducao_completa": "Porém os homens que com ele subiram disseram: Não poderemos subir contra aquele povo, porque é mais forte do que nós.",
      "palavras": [
        { "hebraico": "וְהָ֨אֲנָשִׁ֜ים", "transliteral": "wə-hā-ʾă-nā-šîm", "traducao_palavra": "mas os homens" },
        { "hebraico": "אֲשֶׁר־עָל֨וּ", "transliteral": "ʾă-šer-ʿā-lû", "traducao_palavra": "que subiram" },
        { "hebraico": "עִמֹּו֙", "transliteral": "ʿim-mô", "traducao_palavra": "com ele" },
        { "hebraico": "אָמְר֔וּ", "transliteral": "ʾā-mə-rû", "traducao_palavra": "disseram" },
        { "hebraico": "לֹ֥א", "transliteral": "lō", "traducao_palavra": "não" },
        { "hebraico": "נוּכַ֖ל", "transliteral": "nû-ḵal", "traducao_palavra": "poderemos" },
        { "hebraico": "לַעֲלֹ֣ות", "transliteral": "la-ʿă-lôṯ", "traducao_palavra": "subir" },
        { "hebraico": "אֶל־הָעָ֑ם", "transliteral": "ʾel-hā-ʿām", "traducao_palavra": "contra o povo" },
        { "hebraico": "כִּֽי־חָזָ֥ק", "transliteral": "kî-ḥā-zāq", "traducao_palavra": "porque forte" },
