        { "hebraico": "לִפְנֵ֥י", "transliteral": "lip̄-nê", "traducao_palavra": "perante" },
        { "hebraico": "הָעֵדָ֖ה", "transliteral": "hā-ʿê-ḏā", "traducao_palavra": "a congregação" },
        { "hebraico": "לַמִּשְׁפָּֽט׃", "transliteral": "lam-miš-pāṭ", "traducao_palavra": "para o juízo" }
      ]
    },
    "13": {
      "traducao_completa": "E das cidades que derdes, haverá seis cidades de refúgio para vós.",
      "palavras": [
        { "hebraico": "וְהֶעָרִ֖ים", "transliteral": "wə-he-ʿā-rîm", "traducao_palavra": "e as cidades" },
        { "hebraico": "אֲשֶׁ֣ר", "transliteral": "ʾă-šer", "traducao_palavra": "que" },
        { "hebraico": "תִּתֵּ֑נוּ", "transliteral": "tit-tê-nû", "traducao_palavra": "derdes" },
        { "hebraico": "שֵׁשׁ־עָרֵ֥י", "transliteral": "šêš-ʿā-rê", "traducao_palavra": "seis cidades de" },
        { "hebraico": "מִקְלָ֖ט", "transliteral": "miq-lāṭ", "traducao_palavra": "refúgio" },
        { "hebraico": "תִּהְיֶ֥ינָה", "transliteral": "tih-ye-nā", "traducao_palavra": "serão" },
        { "hebraico": "לָכֶֽם׃", "transliteral": "lā-ḵem", "traducao_palavra": "para vós" }
      ]
    },
    "14": {
      "traducao_completa": "Três destas cidades dareis deste lado do Jordão, e três destas cidades dareis na terra de Canaã; cidades de refúgio serão.",
      "palavras": [
        { "hebraico": "אֵ֣ת", "transliteral": "ʾêṯ", "traducao_palavra": "[objeto]" },
        { "hebraico": "שְׁלֹ֣שׁ", "transliteral": "šə-lōš", "traducao_palavra": "três de" },
        { "hebraico": "הֶעָרִ֗ים", "transliteral": "he-ʿā-rîm", "traducao_palavra": "as cidades" },
        { "hebraico": "תִּתְּנוּ֙", "transliteral": "tit-tə-nû", "traducao_palavra": "dareis" },
        { "hebraico": "מֵעֵ֣בֶר", "transliteral": "mê-ʿê-ḇer", "traducao_palavra": "além de" },
        { "hebraico": "לַיַּרְדֵּ֔ן", "transliteral": "lay-yar-dên", "traducao_palavra": "o Jordão" },
        { "hebraico": "וְאֵ֨ת", "transliteral": "wə-ʾêṯ", "traducao_palavra": "e" },
        { "hebraico": "שְׁלֹ֣שׁ", "transliteral": "šə-lōš", "traducao_palavra": "três de" },
        { "hebraico": "הֶעָרִ֔ים", "transliteral": "he-ʿā-rîm", "traducao_palavra": "as cidades" },
        { "hebraico": "תִּתְּנ֖וּ", "transliteral": "tit-tə-nû", "traducao_palavra": "dareis" },
        { "hebraico": "בְּאֶ֣רֶץ", "transliteral": "bə-ʾe-reṣ", "traducao_palavra": "na terra de" },
        { "hebraico": "כְּנָ֑עַן", "transliteral": "kə-nā-ʿan", "traducao_palavra": "Canaã" },
        { "hebraico": "עָרֵ֥י", "transliteral": "ʿā-rê", "traducao_palavra": "cidades de" },
        { "hebraico": "מִקְלָ֖ט", "transliteral": "miq-lāṭ", "traducao_palavra": "refúgio" },
        { "hebraico": "תִּהְיֶֽינָה׃", "transliteral": "tih-ye-nā", "traducao_palavra": "serão" }
      ]
    },
    "15": {
      "traducao_completa": "Para os filhos de Israel, e para o estrangeiro, e para o que peregrina no meio deles, serão estas seis cidades por refúgio, para que ali fuja aquele que ferir a alguma pessoa por erro.",
      "palavras": [
        { "hebraico": "לִבְנֵ֣י", "transliteral": "liḇ-nê", "traducao_palavra": "para filhos de" },
        { "hebraico": "יִשְׂרָאֵ֡ל", "transliteral": "yiś-rā-ʾēl", "traducao_palavra": "Israel" },
        { "hebraico": "וְלַגֵּר֩", "transliteral": "wə-lag-gêr", "traducao_palavra": "e para o estrangeiro" },
        { "hebraico": "וְלַתֹּושָׁ֨ב", "transliteral": "wə-lat-tô-šāḇ", "traducao_palavra": "e para o residente" },
        { "hebraico": "בְּתֹוכָ֑ם", "transliteral": "bə-ṯô-ḵām", "traducao_palavra": "no meio deles" }
      ]
    },
    "16": {
      "traducao_completa": "Porém, se o ferir com instrumento de ferro, e morrer, homicida é; certamente o homicida morrerá.",
      "palavras": [
        { "hebraico": "וְאִם־בִּכְלִ֨י", "transliteral": "wə-ʾim-biḵ-lî", "traducao_palavra": "e se com instrumento de" },
        { "hebraico": "בַרְזֶ֧ל", "transliteral": "ḇar-zel", "traducao_palavra": "ferro" },
        { "hebraico": "הִכָּ֛הוּ", "transliteral": "hik-kā-hû", "traducao_palavra": "o feriu" },
        { "hebraico": "וַיָּמֹ֖ת", "transliteral": "way-yā-mōṯ", "traducao_palavra": "e morreu" },
        { "hebraico": "רֹצֵ֣חַֽ", "transliteral": "rō-ṣê-aḥ", "traducao_palavra": "homicida [é]" },
        { "hebraico": "ה֑וּא", "transliteral": "hû", "traducao_palavra": "ele" },
        { "hebraico": "מֹ֥ות", "transliteral": "môṯ", "traducao_palavra": "morte [certamente]" },
        { "hebraico": "יוּמַ֖ת", "transliteral": "yû-maṯ", "traducao_palavra": "será morto" },
        { "hebraico": "הָרֹצֵֽחַ׃", "transliteral": "hā-rō-ṣê-aḥ", "traducao_palavra": "o homicida" }
      ]
    },
    "17": {
      "traducao_completa": "Ou se o ferir com uma pedra na mão, com que possa morrer, e morrer, homicida é; certamente o homicida morrerá.",
      "palavras": [
        { "hebraico": "וְאִ֣ם", "transliteral": "wə-ʾim", "traducao_palavra": "ou se" },
        { "hebraico": "בְּאֶ֣בֶן", "transliteral": "bə-ʾe-ḇen", "traducao_palavra": "com pedra de" },
        { "hebraico": "יָ֗ד", "transliteral": "yāḏ", "traducao_palavra": "mão" },
        { "hebraico": "אֲשֶׁר־יָמ֥וּת", "transliteral": "ʾă-šer-yā-mûṯ", "traducao_palavra": "que pode morrer" },
        { "hebraico": "בָּ֛הּ", "transliteral": "bāh", "traducao_palavra": "por ela" },
        { "hebraico": "הִכָּ֖הוּ", "transliteral": "hik-kā-hû", "traducao_palavra": "o feriu" },
        { "hebraico": "וַיָּמֹ֑ת", "transliteral": "way-yā-mōṯ", "traducao_palavra": "e morreu" }
      ]
    },
    "18": {
      "traducao_completa": "Ou se o ferir com instrumento de madeira na mão, com que possa morrer, e morrer, homicida é; certamente o homicida morrerá.",
      "palavras": [
        { "hebraico": "אֹ֡ו", "transliteral": "ʾô", "traducao_palavra": "ou" },
        { "hebraico": "בִּכְלִ֣י", "transliteral": "biḵ-lî", "traducao_palavra": "com instrumento de" },
        { "hebraico": "עֵֽץ־יָד֩", "transliteral": "ʿêṣ-yāḏ", "traducao_palavra": "madeira de mão" }
      ]
    },
    "19": {
      "traducao_completa": "O vingador do sangue matará o homicida; ao encontrá-lo, o matará.",
      "palavras": [
        { "hebraico": "גֹּאֵ֣ל", "transliteral": "gō-ʾēl", "traducao_palavra": "o vingador de" },
        { "hebraico": "הַדָּ֔ם", "transliteral": "had-dām", "traducao_palavra": "o sangue" },
        { "hebraico": "ה֥וּא", "transliteral": "hû", "traducao_palavra": "ele" },
        { "hebraico": "יָמִ֖ית", "transliteral": "yā-mîṯ", "traducao_palavra": "matará" },
        { "hebraico": "אֶת־הָרֹצֵ֑חַ", "transliteral": "ʾeṯ-hā-rō-ṣê-aḥ", "traducao_palavra": "o homicida" },
        { "hebraico": "בְּפִגְעֹו־בֹ֖ו", "transliteral": "bə-p̄iḡ-ʿô-ḇô", "traducao_palavra": "ao encontrá-lo" },
        { "hebraico": "יְמִיתֶֽנּוּ׃", "transliteral": "yə-mî-ṯen-nû", "traducao_palavra": "o matará" }
      ]
    },
    "20": {
      "traducao_completa": "E se o empurrar com ódio, ou lançar contra ele alguma coisa em emboscada, e ele morrer;",
      "palavras": [
        { "hebraico": "וְאִם־בְּשִׂנְאָ֖ה", "transliteral": "wə-ʾim-bə-śin-ʾā", "traducao_palavra": "e se com ódio" },
        { "hebraico": "יֶהְדָּפֶ֑נּוּ", "transliteral": "yeh-dā-p̄en-nû", "traducao_palavra": "o empurrar" },
        { "hebraico": "אֹו־הִשְׁלִ֨יךְ", "transliteral": "ʾô-hiš-lîḵ", "traducao_palavra": "ou lançar" },
        { "hebraico": "עָלָ֧יו", "transliteral": "ʿā-lāyw", "traducao_palavra": "sobre ele" },
        { "hebraico": "בִּצְדִיָּ֖ה", "transliteral": "biṣ-ḏiy-yā", "traducao_palavra": "em emboscada" },
        { "hebraico": "וַיָּמֹֽת׃", "transliteral": "way-yā-mōṯ", "traducao_palavra": "e morreu" }
      ]
    },
    "21": {
      "traducao_completa": "Ou por inimizade o ferir com a sua mão, e ele morrer, certamente morrerá o que o feriu; homicida é; o vingador do sangue matará o homicida ao encontrá-lo.",
      "palavras": [
        { "hebraico": "אֹ֣ו", "transliteral": "ʾô", "traducao_palavra": "ou" },
        { "hebraico": "בְאֵיבָ֞ה", "transliteral": "ḇə-ʾê-ḇā", "traducao_palavra": "por inimizade" }
      ]
    },
    "22": {
      "traducao_completa": "Porém, se o empurrar subitamente, sem inimizade, ou contra ele lançar qualquer instrumento sem emboscada,",
      "palavras": [
        { "hebraico": "וְאִם־בְּפֶ֜תַע", "transliteral": "wə-ʾim-bə-p̄e-ṯaʿ", "traducao_palavra": "e se subitamente" },
        { "hebraico": "בְּלֹא־אֵיבָ֗ה", "transliteral": "bə-lō-ʾê-ḇā", "traducao_palavra": "sem inimizade" },
        { "hebraico": "הֲדָפֹוֹ֙", "transliteral": "hă-ḏā-p̄ô", "traducao_palavra": "o empurrou" }
      ]
    },
    "23": {
      "traducao_completa": "Ou sobre ele lançar qualquer pedra com que possa morrer, sem o ver, e ele morrer, não sendo seu inimigo nem procurando o seu mal,",
      "palavras": [
        { "hebraico": "אֹ֣ו", "transliteral": "ʾô", "traducao_palavra": "ou" },
        { "hebraico": "בְכָל־אֶ֤בֶן", "transliteral": "ḇə-ḵāl-ʾe-ḇen", "traducao_palavra": "com toda pedra" }
      ]
    },
    "24": {
      "traducao_completa": "Então a congregação julgará entre o que feriu e o vingador do sangue, segundo estes juízos.",
      "palavras": [
        { "hebraico": "וְשָׁ֨פְט֥וּ", "transliteral": "wə-šā-p̄ə-ṭû", "traducao_palavra": "e julgarão" },
        { "hebraico": "הָעֵדָ֔ה", "transliteral": "hā-ʿê-ḏā", "traducao_palavra": "a congregação" }
      ]
    },
    "25": {
      "traducao_completa": "E a congregação livrará o homicida da mão do vingador do sangue, e a congregação o fará voltar à cidade do seu refúgio, onde se acolhera; e ali ficará até à morte do sumo sacerdote, que foi ungido com o óleo santo.",
      "palavras": [
        { "hebraico": "וְהִצִּ֨יל", "transliteral": "wə-hiṣ-ṣîl", "traducao_palavra": "e livrará" },
        { "hebraico": "הָעֵדָ֜ה", "transliteral": "hā-ʿê-ḏā", "traducao_palavra": "a congregação" },
        { "hebraico": "אֶת־הָרֹצֵ֗חַ", "transliteral": "ʾeṯ-hā-rō-ṣê-aḥ", "traducao_palavra": "o homicida" },
        { "hebraico": "מִיַּד֮", "transliteral": "miy-yaḏ", "traducao_palavra": "da mão de" },
        { "hebraico": "גֹּאֵ֣ל", "transliteral": "gō-ʾēl", "traducao_palavra": "vingador de" },
        { "hebraico": "הַדָּם֒", "transliteral": "had-dām", "traducao_palavra": "o sangue" },
        { "hebraico": "וְהֵשִׁ֨יבוּ", "transliteral": "wə-hê-šî-ḇû", "traducao_palavra": "e farão voltar" },
        { "hebraico": "אֹתֹ֤ו", "transliteral": "ʾō-ṯô", "traducao_palavra": "ele" },
        { "hebraico": "עַד־מֹות֙", "transliteral": "ʿaḏ-môṯ", "traducao_palavra": "até a morte de" },
        { "hebraico": "הַכֹּהֵ֣ן", "transliteral": "hak-kō-hên", "traducao_palavra": "o sacerdote" },
        { "hebraico": "הַגָּדֹ֔ל", "transliteral": "hag-gā-ḏōl", "traducao_palavra": "grande/sumo" }
      ]
    },
    "26": {
      "traducao_completa": "Mas, se o homicida de alguma maneira sair dos limites da cidade do seu refúgio, onde se acolhera,",
      "palavras": [
        { "hebraico": "וְאִם־יָצֹ֥א", "transliteral": "wə-ʾim-yā-ṣō", "traducao_palavra": "e se saindo" },
        { "hebraico": "יֵצֵ֖א", "transliteral": "yê-ṣê", "traducao_palavra": "sair" },
        { "hebraico": "הָרֹצֵ֑חַ", "transliteral": "hā-rō-ṣê-aḥ", "traducao_palavra": "o homicida" },
        { "hebraico": "אֶת־גְּב֥וּל", "transliteral": "ʾeṯ-gə-ḇûl", "traducao_palavra": "o limite de" }
      ]
    },
    "27": {
      "traducao_completa": "E o vingador do sangue o achar fora dos limites da cidade do seu refúgio, e o vingador do sangue matar o homicida, não será culpado de sangue.",
      "palavras": [
        { "hebraico": "וּמָצָ֣א", "transliteral": "ū-mā-ṣā", "traducao_palavra": "e achar" },
        { "hebraico": "אֹתֹ֗ו", "transliteral": "ʾō-ṯô", "traducao_palavra": "ele" }
      ]
    },
    "28": {
      "traducao_completa": "Pois o homicida deve ficar na cidade do seu refúgio até à morte do sumo sacerdote; mas, depois da morte do sumo sacerdote, o homicida voltará à terra da sua possessão.",
      "palavras": [
        { "hebraico": "כִּ֣י", "transliteral": "kî", "traducao_palavra": "porque" },
        { "hebraico": "בְּעִיר־מִקְלָטֹ֥ו", "transliteral": "bə-ʿîr-miq-lā-ṭô", "traducao_palavra": "na cidade de seu refúgio" },
        { "hebraico": "יֵשֵׁ֕ב", "transliteral": "yê-šêḇ", "traducao_palavra": "habitará" }
      ]
    },
    "29": {
      "traducao_completa": "E estas coisas vos serão por estatuto de juízo em vossas gerações, em todas as vossas habitações.",
      "palavras": [
        { "hebraico": "וְהָי֨וּ", "transliteral": "wə-hā-yû", "traducao_palavra": "e serão" },
        { "hebraico": "אֵ֧לֶּה", "transliteral": "ʾēl-leh", "traducao_palavra": "estas [coisas]" },
        { "hebraico": "לָכֶ֛ם", "transliteral": "lā-ḵem", "traducao_palavra": "para vós" },
        { "hebraico": "לְחֻקַּ֥ת", "transliteral": "lə-ḥuq-qaṯ", "traducao_palavra": "por estatuto de" },
        { "hebraico": "מִשְׁפָּ֖ט", "transliteral": "miš-pāṭ", "traducao_palavra": "juízo" }
      ]
    },
    "30": {
      "traducao_completa": "Todo aquele que matar uma pessoa, o homicida será morto pela boca de testemunhas; mas uma só testemunha não testemunhará contra alguém para morrer.",
      "palavras": [
        { "hebraico": "כָּל־מַכֵּה־נֶ֔פֶשׁ", "transliteral": "kāl-mak-kê-ne-p̄eš", "traducao_palavra": "todo o que fere alma" },
        { "hebraico": "לְפִ֥י", "transliteral": "lə-p̄î", "traducao_palavra": "pela boca de" },
        { "hebraico": "עֵדִ֖ים", "transliteral": "ʿê-ḏîm", "traducao_palavra": "testemunhas" },
        { "hebraico": "יִרְצַ֣ח", "transliteral": "yir-ṣaḥ", "traducao_palavra": "matará/executará" },
        { "hebraico": "אֶת־הָרֹצֵ֑חַ", "transliteral": "ʾeṯ-hā-rō-ṣê-aḥ", "traducao_palavra": "o homicida" },
        { "hebraico": "וְעֵ֣ד", "transliteral": "wə-ʿêḏ", "traducao_palavra": "e testemunha" },
        { "hebraico": "אֶחָ֔ד", "transliteral": "ʾe-ḥāḏ", "traducao_palavra": "única" },
        { "hebraico": "לֹא־יַעֲנֶ֥ה", "transliteral": "lō-ya-ʿă-neh", "traducao_palavra": "não responderá/deporá" }
      ]
    },
    "31": {
      "traducao_completa": "E não tomareis resgate pela vida do homicida que é culpado de morte; pois certamente morrerá.",
      "palavras": [
        { "hebraico": "וְלֹא־תִקְח֣וּ", "transliteral": "wə-lō-ṯiq-ḥû", "traducao_palavra": "e não tomareis" },
        { "hebraico": "כֹ֔פֶר", "transliteral": "ḵō-p̄er", "traducao_palavra": "resgate" }
      ]
    },
    "32": {
      "traducao_completa": "Nem tomareis resgate por aquele que se acolher à cidade do seu refúgio, para tornar a habitar na terra, antes da morte do sacerdote.",
      "palavras": [
        { "hebraico": "וְלֹא־תִקְח֣וּ", "transliteral": "wə-lō-ṯiq-ḥû", "traducao_palavra": "e não tomareis" },
        { "hebraico": "כֹ֔פֶר", "transliteral": "ḵō-p̄er", "traducao_palavra": "resgate" }
      ]
    },
    "33": {
      "traducao_completa": "Assim não profanareis a terra em que estais; porque o sangue profana a terra; e nenhuma expiação se fará pela terra por causa do sangue que nela for derramado, senão com o sangue daquele que o derramou.",
      "palavras": [
        { "hebraico": "וְלֹֽא־תַחֲנִ֣יפוּ", "transliteral": "wə-lō-ṯa-ḥă-nî-p̄û", "traducao_palavra": "e não profanareis" },
        { "hebraico": "אֶת־הָאָ֗רֶץ", "transliteral": "ʾeṯ-hā-ʾā-reṣ", "traducao_palavra": "a terra" }
      ]
