    "12": {
      "traducao_completa": "Casaram-se nas famílias dos filhos de Manassés, filho de José; e a sua herança ficou na tribo da família de seu pai.",
      "palavras": [
        { "hebraico": "מִֽמִּשְׁפְּחֹ֧ת", "transliteral": "mim-miš-pə-ḥōṯ", "traducao_palavra": "nas famílias de" },
