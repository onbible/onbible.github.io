{
  "livro": "Números - בְּמִדְבַּר - Bemidbar",
  "capítulo": 36,
  "titulos": {},
  "versiculos": {
    "1": {
      "traducao_completa": "E aproximaram-se os cabeças das casas paternas da família dos filhos de Gileade, filho de Maquir, filho de Manassés, das famílias dos filhos de José; e falaram diante de Moisés e diante dos príncipes, cabeças das casas paternas dos filhos de Israel,",
      "palavras": [
        { "hebraico": "וַֽיִּקְרְב֞וּ", "transliteral": "way-yiq-rə-ḇû", "traducao_palavra": "e aproximaram-se" },
        { "hebraico": "רָאשֵׁ֣י", "transliteral": "rā-šê", "traducao_palavra": "os cabeças de" },
        { "hebraico": "הָאָבֹ֗ות", "transliteral": "hā-ʾā-ḇôṯ", "traducao_palavra": "os pais/casas paternas" },
        { "hebraico": "לְמִשְׁפַּחַ֧ת", "transliteral": "lə-miš-pa-ḥaṯ", "traducao_palavra": "da família de" },
        { "hebraico": "בְּנֵי־גִלְעָ֛ד", "transliteral": "bə-nê-ḡil-ʿāḏ", "traducao_palavra": "filhos de Gileade" },
        { "hebraico": "בֶּן־מָכִ֥יר", "transliteral": "ben-mā-ḵîr", "traducao_palavra": "filho de Maquir" },
        { "hebraico": "בֶּן־מְנַשֶּׁ֖ה", "transliteral": "ben-mə-naš-šeh", "traducao_palavra": "filho de Manassés" },
        { "hebraico": "מִמִּשְׁפְּחֹ֥ת", "transliteral": "mim-miš-pə-ḥōṯ", "traducao_palavra": "das famílias de" },
        { "hebraico": "בְּנֵי־יֹוסֵ֑ף", "transliteral": "bə-nê-yô-sêp̄", "traducao_palavra": "filhos de José" },
        { "hebraico": "וַֽיְדַבְּר֞וּ", "transliteral": "way-ḏab-bə-rû", "traducao_palavra": "e falaram" },
        { "hebraico": "לִפְנֵ֤י", "transliteral": "lip̄-nê", "traducao_palavra": "diante de" },
        { "hebraico": "מֹשֶׁה֙", "transliteral": "mō-šeh", "traducao_palavra": "Moisés" }
      ]
    },
    "2": {
      "traducao_completa": "E disseram: A meu senhor ordenou YHWH que desse a terra em herança por sorte aos filhos de Israel; e a meu senhor foi ordenado por YHWH que a herança de Zelofeade, nosso irmão, se desse a suas filhas.",
      "palavras": [
        { "hebraico": "וַיֹּאמְר֗וּ", "transliteral": "way-yō-mə-rû", "traducao_palavra": "e disseram" },
        { "hebraico": "אֶת־אֲדֹנִי֙", "transliteral": "ʾeṯ-ʾă-ḏō-nî", "traducao_palavra": "a meu senhor" },
        { "hebraico": "צִוָּ֣ה", "transliteral": "ṣiw-wā", "traducao_palavra": "ordenou" },
        { "hebraico": "יְהוָ֔ה", "transliteral": "YHWH", "traducao_palavra": "YHWH" },
        { "hebraico": "לָתֵ֨ת", "transliteral": "lā-ṯêṯ", "traducao_palavra": "para dar" },
        { "hebraico": "אֶת־הָאָ֧רֶץ", "transliteral": "ʾeṯ-hā-ʾā-reṣ", "traducao_palavra": "a terra" },
        { "hebraico": "בְּנַחֲלָ֛ה", "transliteral": "bə-na-ḥă-lā", "traducao_palavra": "em herança" },
        { "hebraico": "בְּגֹורָ֖ל", "transliteral": "bə-ḡô-rāl", "traducao_palavra": "por sorte" }
      ]
    },
    "3": {
      "traducao_completa": "E se elas se casarem com algum dos filhos das outras tribos dos filhos de Israel, então a sua herança será diminuída da herança de nossos pais, e acrescentada à herança da tribo a que vierem a pertencer; assim se diminuirá da sorte da nossa herança.",
      "palavras": [
        { "hebraico": "וְהָי֞וּ", "transliteral": "wə-hā-yû", "traducao_palavra": " e se elas forem" },
        { "hebraico": "לְאֶחָ֨ד", "transliteral": "lə-ʾe-ḥāḏ", "traducao_palavra": "para um de" },
        { "hebraico": "מִבְּנֵ֧י", "transliteral": "mib-bə-nê", "traducao_palavra": "os filhos de" },
        { "hebraico": "שִׁבְטֵי־יִשְׂרָאֵ֛ל", "transliteral": "šiḇ-ṭê-yiś-rā-ʾēl", "traducao_palavra": "tribos de Israel" },
        { "hebraico": "לְנָשִׁ֖ים", "transliteral": "lə-nā-šîm", "traducao_palavra": "por mulheres" },
        { "hebraico": "וְנִגְרְעָ֤ה", "transliteral": "wə-niḡ-rə-ʿā", "traducao_palavra": "e seria tirada/diminuída" },
        { "hebraico": "נַחֲלָתָן֙", "transliteral": "na-ḥă-lā-ṯān", "traducao_palavra": "a herança delas" }
      ]
    },
    "4": {
      "traducao_completa": "E vindo também o jubileu dos filhos de Israel, a sua herança se acrescentará à herança da tribo a que pertencerem; assim a sua herança será diminuída da herança da tribo de nossos pais.",
      "palavras": [
        { "hebraico": "וְאִם־יִהְיֶ֣ה", "transliteral": "wə-ʾim-yih-yeh", "traducao_palavra": "e quando houver" },
        { "hebraico": "הַיֹּבֵל֮", "transliteral": "hay-yō-ḇêl", "traducao_palavra": "o jubileu" },
        { "hebraico": "לִבְנֵ֣י", "transliteral": "liḇ-nê", "traducao_palavra": "para filhos de" },
        { "hebraico": "יִשְׂרָאֵל֒", "transliteral": "yiś-rā-ʾēl", "traducao_palavra": "Israel" }
      ]
    },
    "5": {
      "traducao_completa": "Então Moisés deu ordem aos filhos de Israel, conforme o mandado de YHWH, dizendo: A tribo dos filhos de José fala retamente.",
      "palavras": [
        { "hebraico": "וַיְצַ֤ו", "transliteral": "way-ṣaw", "traducao_palavra": "e ordenou" },
        { "hebraico": "מֹשֶׁה֙", "transliteral": "mō-šeh", "traducao_palavra": "Moisés" },
        { "hebraico": "עַל־פִּ֥י", "transliteral": "ʿal-pî", "traducao_palavra": "pela boca de" },
        { "hebraico": "יְהוָ֖ה", "transliteral": "YHWH", "traducao_palavra": "YHWH" },
        { "hebraico": "לֵאמֹ֑ר", "transliteral": "lê-mōr", "traducao_palavra": "dizendo" },
        { "hebraico": "כֵּ֛ן", "transliteral": "kên", "traducao_palavra": "retamente/assim" },
        { "hebraico": "מַטֵּ֥ה", "transliteral": "maṭ-ṭê", "traducao_palavra": "a tribo de" },
        { "hebraico": "בְנֵֽי־יֹוסֵ֖ף", "transliteral": "ḇə-nê-yô-sêp̄", "traducao_palavra": "filhos de José" },
        { "hebraico": "דֹּבְרִֽים׃", "transliteral": "dō-ḇə-rîm", "traducao_palavra": "estão falando" }
      ]
    },
    "6": {
      "traducao_completa": "Esta é a palavra que YHWH ordenou acerca das filhas de Zelofeade, dizendo: Casem-se com quem bem lhes parecer, contanto que se casem na família da tribo de seu pai.",
      "palavras": [
        { "hebraico": "זֶ֣ה", "transliteral": "zeh", "traducao_palavra": "esta [é]" },
        { "hebraico": "הַדָּבָ֞ר", "transliteral": "had-dā-ḇār", "traducao_palavra": "a palavra" },
        { "hebraico": "אֲשֶׁר־צִוָּ֣ה", "transliteral": "ʾă-šer-ṣiw-wā", "traducao_palavra": "que ordenou" },
        { "hebraico": "יְהוָ֗ה", "transliteral": "YHWH", "traducao_palavra": "YHWH" },
