        { "hebraico": "כֵּ֥ן", "transliteral": "kên", "traducao_palavra": "assim" },
        { "hebraico": "עָשׂ֖וּ", "transliteral": "ʿā-śû", "traducao_palavra": "fizeram" },
        { "hebraico": "בְּנֹ֥ות", "transliteral": "bə-nôṯ", "traducao_palavra": "as filhas de" },
        { "hebraico": "צְלָפְחָֽד׃", "transliteral": "ṣə-lā-p̄ə-ḥāḏ", "traducao_palavra": "Zelofeade" }
      ]
    },
    "11": {
      "traducao_completa": "Pois Maalá, Tirza, Hogla, Milca e Noa, filhas de Zelofeade, casaram-se com os filhos de seus tios paternos.",
      "palavras": [
        { "hebraico": "וַתִּהְיֶ֜ינָה", "transliteral": "wat-tih-ye-nā", "traducao_palavra": "e foram" },
        { "hebraico": "מַחְלָ֣ה", "transliteral": "maḥ-lā", "traducao_palavra": "Maalá" },
        { "hebraico": "תִרְצָ֗ה", "transliteral": "ṯir-ṣā", "traducao_palavra": "Tirza" },
        { "hebraico": "וְחָגְלָ֧ה", "transliteral": "wə-ḥāḡ-lā", "traducao_palavra": "e Hogla" },
        { "hebraico": "וּמִלְכָּ֛ה", "transliteral": "ū-mil-kā", "traducao_palavra": "e Milca" },
        { "hebraico": "וְנֹעָ֖ה", "transliteral": "wə-nō-ʿā", "traducao_palavra": "e Noa" }
      ]
