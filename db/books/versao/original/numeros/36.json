        { "hebraico": "צְלָפְחָד֙", "transliteral": "ṣə-lā-p̄ə-ḥāḏ", "traducao_palavra": "Zelofeade" },
        { "hebraico": "לַטֹּ֥וב", "transliteral": "laṭ-ṭôḇ", "traducao_palavra": "ao que for bom" },
        { "hebraico": "בְּעֵינֵיהֶ֖ם", "transliteral": "bə-ʿê-nê-hem", "traducao_palavra": "em seus olhos" },
        { "hebraico": "תִּהְיֶ֣eנָה", "transliteral": "tih-ye-nā", "traducao_palavra": "elas serão" },
        { "hebraico": "לְנָשִׁ֑ים", "transliteral": "lə-nā-šîm", "traducao_palavra": "por mulheres" }
      ]
    },
    "7": {
      "traducao_completa": "Assim a herança dos filhos de Israel não passará de tribo em tribo; pois os filhos de Israel se chegarão cada um à herança da tribo de seus pais.",
      "palavras": [
        { "hebraico": "וְלֹֽא־תִסֹּ֤ב", "transliteral": "wə-lō-ṯis-sōḇ", "traducao_palavra": "e não rodeará/passará" },
        { "hebraico": "נַחֲלָה֙", "transliteral": "na-ḥă-lā", "traducao_palavra": "herança" },
        { "hebraico": "לִבְנֵ֣י", "transliteral": "liḇ-nê", "traducao_palavra": "para os filhos de" },
        { "hebraico": "יִשְׂרָאֵ֔ל", "transliteral": "yiś-rā-ʾēl", "traducao_palavra": "Israel" },
        { "hebraico": "מִמַּטֶּ֖ה", "transliteral": "mim-maṭ-ṭeh", "traducao_palavra": "de tribo" },
        { "hebraico": "אֶל־מַטֶּ֑ה", "transliteral": "ʾel-maṭ-ṭeh", "traducao_palavra": "para tribo" }
      ]
    },
    "8": {
      "traducao_completa": "E qualquer filha que herdar uma herança nas tribos dos filhos de Israel se casará com algum da família da tribo de seu pai, para que os filhos de Israel possuam cada um a herança de seus pais.",
      "palavras": [
        { "hebraico": "וְכָל־בַּ֗ת", "transliteral": "wə-ḵāl-baṯ", "traducao_palavra": "e toda filha" },
        { "hebraico": "יֹרֶשֶׁת", "transliteral": "yō-re-šeṯ", "traducao_palavra": "que herdar" },
        { "hebraico": "נַחֲלָה֙", "transliteral": "na-ḥă-lā", "traducao_palavra": "herança" }
      ]
    },
    "9": {
      "traducao_completa": "Assim a herança não passará de uma tribo a outra; pois as tribos dos filhos de Israel se chegarão cada uma à sua herança.",
      "palavras": [
        { "hebraico": "וְלֹֽא־תִסֹּ֤ב", "transliteral": "wə-lō-ṯis-sōḇ", "traducao_palavra": "e não passará" },
        { "hebraico": "נַחֲלָה֙", "transliteral": "na-ḥă-lā", "traducao_palavra": "herança" },
        { "hebraico": "מִמַּטֶּ֖ה", "transliteral": "mim-maṭ-ṭeh", "traducao_palavra": "de tribo" },
        { "hebraico": "לְמַטֶּ֣ה", "transliteral": "lə-maṭ-ṭeh", "traducao_palavra": "para tribo" },
        { "hebraico": "אַחֵ֑ר", "transliteral": "ʾa-ḥêr", "traducao_palavra": "outra" }
      ]
    },
    "10": {
      "traducao_completa": "Como YHWH ordenara a Moisés, assim fizeram as filhas de Zelofeade.",
      "palavras": [
        { "hebraico": "כַּאֲשֶׁ֛ר", "transliteral": "ka-ʾă-šer", "traducao_palavra": "conforme" },
        { "hebraico": "צִוָּ֥ה", "transliteral": "ṣiw-wā", "traducao_palavra": "ordenara" },
