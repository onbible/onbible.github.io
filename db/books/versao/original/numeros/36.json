        { "hebraico": "לְנָשִׁ֑ים", "transliteral": "lə-nā-šîm", "traducao_palavra": "por mulheres" }
      ]
    },
    "13": {
      "traducao_completa": "Estes são os mandamentos e os juízos que YHWH ordenou pela mão de Moisés aos filhos de Israel, nas campinas de Moabe, junto ao Jordão de Jericó.",
      "palavras": [
        { "hebraico": "אֵ֣לֶּה", "transliteral": "ʾēl-leh", "traducao_palavra": "estes [são]" },
