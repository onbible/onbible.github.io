        { "hebraico": "עַתָּ֕ה", "transliteral": "ʿat-tā", "traducao_palavra": "agora" },
        { "hebraico": "הֲיָכֹ֥ול", "transliteral": "hă-yā-ḵôl", "traducao_palavra": "porventura podendo" },
