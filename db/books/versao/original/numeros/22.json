{
  "livro": "Números - בְּמִדְבַּר - Bemidbar",
  "capítulo": 22,
  "titulos": {},
  "versiculos": {
    "1": {
      "traducao_completa": "E partiram os filhos de Israel, e acamparam nas campinas de Moabe, além do Jordão, na altura de Jericó.",
      "palavras": [
        { "hebraico": "וַיִּסְע֖וּ", "transliteral": "way-yis-ʿû", "traducao_palavra": "e partiram" },
        { "hebraico": "בְּנֵ֣י", "transliteral": "bə-nê", "traducao_palavra": "os filhos de" },
        { "hebraico": "יִשְׂרָאֵ֑ל", "transliteral": "yiś-rā-ʾēl", "traducao_palavra": "Israel" },
        { "hebraico": "וַֽיַּחֲנ֞וּ", "transliteral": "way-ya-ḥă-nû", "traducao_palavra": "e acamparam" },
        { "hebraico": "בְּעַֽרְבֹ֣ות", "transliteral": "bə-ʿar-ḇôṯ", "traducao_palavra": "nas campinas/planícies de" },
