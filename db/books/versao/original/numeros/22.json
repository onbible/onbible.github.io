        { "hebraico": "מֵעֵ֖בֶר", "transliteral": "mê-ʿê-ḇer", "traducao_palavra": "além de" },
        { "hebraico": "לְיַרְדֵּ֥ן", "transliteral": "lə-yar-dên", "traducao_palavra": "[o] Jordão [de]" },
        { "hebraico": "יְרֵחֹֽו׃", "transliteral": "yə-rê-ḥô", "traducao_palavra": "Jericó" }
      ]
    },
    "2": {
      "traducao_completa": "Viu, pois, Balaque, filho de Zipor, tudo o que Israel tinha feito aos amorreus.",
      "palavras": [
        { "hebraico": "וַיַּ֥רְא", "transliteral": "way-yar", "traducao_palavra": "e viu" },
        { "hebraico": "בָּלָ֖ק", "transliteral": "bā-lāq", "traducao_palavra": "Balaque" },
        { "hebraico": "בֶּן־צִפֹּ֑ור", "transliteral": "ben-ṣip-pôr", "traducao_palavra": "filho de Zipor" },
        { "hebraico": "אֵ֥ת", "transliteral": "ʾeṯ", "traducao_palavra": "[objeto]" },
        { "hebraico": "כָּל־אֲשֶׁר־עָשָׂ֥ה", "transliteral": "kāl-ʾă-šer-ʿā-śā", "traducao_palavra": "tudo o que fizera" },
        { "hebraico": "יִשְׂרָאֵ֖ל", "transliteral": "yiś-rā-ʾēl", "traducao_palavra": "Israel" },
        { "hebraico": "לָֽאֱמֹרִֽי׃", "transliteral": "lā-ʾĕ-mō-rî", "traducao_palavra": "ao amorreu" }
      ]
    },
    "3": {
      "traducao_completa": "E Moabe temeu muito o povo, porque era numeroso; e Moabe angustiou-se por causa dos filhos de Israel.",
      "palavras": [
        { "hebraico": "וַיָּ֨גָר", "transliteral": "way-yā-ḡār", "traducao_palavra": "e temeu/assustou-se" },
        { "hebraico": "מוֹאָ֥ב", "transliteral": "mô-ʾāḇ", "traducao_palavra": "Moabe" },
        { "hebraico": "מִפְּנֵי", "transliteral": "mip-pə-nê", "traducao_palavra": "diante da face de" },
        { "hebraico": "הָעָ֛ם", "transliteral": "hā-ʿām", "traducao_palavra": "o povo" },
        { "hebraico": "מְאֹ֖ד", "transliteral": "mə-ʾōḏ", "traducao_palavra": "muito" },
        { "hebraico": "כִּ֥י", "transliteral": "kî", "traducao_palavra": "porque" },
        { "hebraico": "רַב־ה֑וּא", "transliteral": "rab-hû", "traducao_palavra": "numeroso ele [era]" },
        { "hebraico": "וַיָּ֣קָץ", "transliteral": "way-yā-qāṣ", "traducao_palavra": "e angustiou-se/teve nojo" },
        { "hebraico": "מוֹאָ֔ב", "transliteral": "mô-ʾāḇ", "traducao_palavra": "Moabe" },
        { "hebraico": "מִפְּנֵ֖י", "transliteral": "mip-pə-nê", "traducao_palavra": "diante da face de" },
        { "hebraico": "בְּנֵ֥י", "transliteral": "bə-nê", "traducao_palavra": "filhos de" },
        { "hebraico": "יִשְׂרָאֵֽל׃", "transliteral": "yiś-rā-ʾēl", "traducao_palavra": "Israel" }
      ]
    },
    "4": {
      "traducao_completa": "Pelo que Moabe disse aos anciãos de Midiã: Agora lamberá esta multidão tudo quanto houver ao redor de nós, como o boi lambe a erva do campo. Balaque, filho de Zipor, era nesse tempo rei de Moabe.",
      "palavras": [
        { "hebraico": "וַיֹּ֨אמֶר", "transliteral": "way-yō-mer", "traducao_palavra": "e disse" },
        { "hebraico": "מוֹאָ֜ב", "transliteral": "mô-ʾāḇ", "traducao_palavra": "Moabe" },
        { "hebraico": "אֶל־זִקְנֵ֣י", "transliteral": "ʾel-ziq-nê", "traducao_palavra": "aos anciãos de" },
        { "hebraico": "מִדְיָ֗ן", "transliteral": "miḏ-yān", "traducao_palavra": "Midiã" }
      ]
    },
    "5": {
      "traducao_completa": "Enviou ele mensageiros a Balaão, filho de Beor, a Petor, que está junto ao rio, na terra dos filhos do seu povo, a chamá-lo, dizendo: Eis que um povo saiu do Egito; eis que cobre a face da terra, e está parado defronte de mim.",
      "palavras": [
        { "hebraico": "וַיִּשְׁלַ֨ח", "transliteral": "way-yiš-laḥ", "traducao_palavra": "e enviou" },
        { "hebraico": "מַלְאָכִ֜ים", "transliteral": "mal-ʾā-ḵîm", "traducao_palavra": "mensageiros" },
        { "hebraico": "אֶל־בִּלְעָ֣ם", "transliteral": "ʾel-bil-ʿām", "traducao_palavra": "a Balaão" },
        { "hebraico": "בֶּן־בְּעֹ֗ר", "transliteral": "ben-bə-ʿôr", "traducao_palavra": "filho de Beor" }
      ]
    },
    "6": {
      "traducao_completa": "Vem, pois, agora, rogo-te, amaldiçoa-me este povo, pois mais poderoso é do que eu; para ver se prevalecerei, e o feriremos e o expulsarei da terra; porque eu sei que a quem tu abençoares será abençoado, e a quem tu amaldiçoares será amaldiçoado.",
      "palavras": [
        { "hebraico": "וְעַתָּה֩", "transliteral": "wə-ʿat-tā", "traducao_palavra": "e agora" },
        { "hebraico": "לְכָה־נָּ֨א", "transliteral": "lə-ḵā-nā", "traducao_palavra": "vem, rogo-te" },
        { "hebraico": "אָֽרָה־לִּ֜י", "transliteral": "ʾā-rā-lî", "traducao_palavra": "amaldiçoa para mim" },
        { "hebraico": "אֶת־הָעָ֣ם", "transliteral": "ʾeṯ-hā-ʿām", "traducao_palavra": "[objeto] o povo" },
        { "hebraico": "הַזֶּ֗ה", "transliteral": "haz-zeh", "traducao_palavra": "este" }
      ]
    },
    "7": {
      "traducao_completa": "Então foram-se os anciãos de Moabe e os anciãos de Midiã, com o preço dos encantamentos nas suas mãos; e chegaram a Balaão, e lhe disseram as palavras de Balaque.",
      "palavras": [
        { "hebraico": "וַיֵּלְכ֞וּ", "transliteral": "way-yê-lə-ḵû", "traducao_palavra": "e foram" },
        { "hebraico": "זִקְנֵ֥י", "transliteral": "ziq-nê", "traducao_palavra": "anciãos de" },
        { "hebraico": "מֹואָ֖ב", "transliteral": "mô-ʾāḇ", "traducao_palavra": "Moabe" }
      ]
    },
    "8": {
      "traducao_completa": "E ele lhes disse: Passai aqui esta noite, e vos trarei a resposta, como YHWH me falar; então os príncipes de Moabe ficaram com Balaão.",
      "palavras": [
        { "hebraico": "וַיֹּ֣אמֶר", "transliteral": "way-yō-mer", "traducao_palavra": "e disse" },
        { "hebraico": "אֲלֵיהֶ֗ם", "transliteral": "ʾă-lê-hem", "traducao_palavra": "a eles" },
        { "hebraico": "לִ֤ינוּ", "transliteral": "lî-nû", "traducao_palavra": "pernoitai" },
        { "hebraico": "פֹה֙", "transliteral": "p̄ōh", "traducao_palavra": "aqui" },
        { "hebraico": "הַלַּ֔יְלָה", "transliteral": "hal-lay-lā", "traducao_palavra": "esta noite" }
      ]
    },
    "9": {
      "traducao_completa": "E veio Deus a Balaão, e disse: Quem são estes homens que estão contigo?",
      "palavras": [
        { "hebraico": "וַיָּבֹ֥א", "transliteral": "way-yā-ḇō", "traducao_palavra": "e veio" },
        { "hebraico": "אֱלֹהִ֖ים", "transliteral": "ʾĕ-lō-hîm", "traducao_palavra": "Deus" },
        { "hebraico": "אֶל־בִּלְעָ֑ם", "transliteral": "ʾel-bil-ʿām", "traducao_palavra": "a Balaão" },
        { "hebraico": "וַיֹּ֕אמֶר", "transliteral": "way-yō-mer", "traducao_palavra": "e disse" },
        { "hebraico": "מִ֛י", "transliteral": "mî", "traducao_palavra": "quem" },
        { "hebraico": "הָאֲנָשִׁ֥ים", "transliteral": "hā-ʾă-nā-šîm", "traducao_palavra": "os homens" },
        { "hebraico": "הָאֵ֖לֶּה", "transliteral": "hā-ʾēl-leh", "traducao_palavra": "estes" },
        { "hebraico": "עִמָּֽךְ׃", "transliteral": "ʿim-māḵ", "traducao_palavra": "contigo" }
      ]
    },
    "10": {
      "traducao_completa": "E Balaão disse a Deus: Balaque, filho de Zipor, rei de Moabe, os enviou a mim, dizendo:",
      "palavras": [
        { "hebraico": "וַיֹּ֥אמֶר", "transliteral": "way-yō-mer", "traducao_palavra": "e disse" },
        { "hebraico": "בִּלְעָ֖ם", "transliteral": "bil-ʿām", "traducao_palavra": "Balaão" },
        { "hebraico": "אֶל־הָאֱלֹהִ֑ים", "transliteral": "ʾel-hā-ʾĕ-lō-hîm", "traducao_palavra": "a Deus" }
      ]
    },
    "11": {
      "traducao_completa": "Eis que o povo que saiu do Egito cobre a face da terra; vem agora, amaldiçoa-mo; porventura poderei pelejar contra ele e expulsá-lo.",
      "palavras": [
        { "hebraico": "הִנֵּ֤ה", "transliteral": "hin-nê", "traducao_palavra": "eis" },
        { "hebraico": "הָעָם֙", "transliteral": "hā-ʿām", "traducao_palavra": "o povo" }
      ]
    },
    "12": {
      "traducao_completa": "Então disse Deus a Balaão: Não irás com eles, nem amaldiçoarás a este povo, porquanto é bendito.",
      "palavras": [
        { "hebraico": "וַיֹּ֤אמֶר", "transliteral": "way-yō-mer", "traducao_palavra": "e disse" },
        { "hebraico": "אֱלֹהִים֙", "transliteral": "ʾĕ-lō-hîm", "traducao_palavra": "Deus" },
        { "hebraico": "אֶל־בִּלְעָ֔ם", "transliteral": "ʾel-bil-ʿām", "traducao_palavra": "a Balaão" },
        { "hebraico": "לֹ֥א", "transliteral": "lō", "traducao_palavra": "não" },
        { "hebraico": "תֵלֵ֖ךְ", "transliteral": "ṯê-lêḵ", "traducao_palavra": "irás" },
        { "hebraico": "עִמָּהֶ֑ם", "transliteral": "ʿim-mā-hem", "traducao_palavra": "com eles" },
        { "hebraico": "לֹא", "transliteral": "lō", "traducao_palavra": "não" },
        { "hebraico": "תָאָֹר֙", "transliteral": "ṯā-ʾōr", "traducao_palavra": "amaldiçoarás" },
        { "hebraico": "אֶת־הָעָ֔ם", "transliteral": "ʾeṯ-hā-ʿām", "traducao_palavra": "[objeto] o povo" },
        { "hebraico": "כִּ֥י", "transliteral": "kî", "traducao_palavra": "porque" },
        { "hebraico": "בָר֖וּךְ", "transliteral": "ḇā-rûḵ", "traducao_palavra": "bendito" },
        { "hebraico": "הֽוּא׃", "transliteral": "hû", "traducao_palavra": "ele [é]" }
      ]
    },
    "13": {
      "traducao_completa": "Então Balaão levantou-se pela manhã, e disse aos príncipes de Balaque: Ide à vossa terra, porque YHWH recusa deixar-me ir convosco.",
      "palavras": [
        { "hebraico": "וַיָּ֤קָם", "transliteral": "way-yā-qām", "traducao_palavra": "então levantou-se" },
        { "hebraico": "בִּלְעָם֙", "transliteral": "bil-ʿām", "traducao_palavra": "Balaão" },
        { "hebraico": "בַּבֹּ֔קֶר", "transliteral": "bab-bō-qer", "traducao_palavra": "pela manhã" }
      ]
    },
    "14": {
      "traducao_completa": "E levantaram-se os príncipes de Moabe, e vieram a Balaque, e disseram: Balaão recusou vir conosco.",
      "palavras": [
        { "hebraico": "וַיָּק֥וּמוּ", "transliteral": "way-yā-qû-mû", "traducao_palavra": "e levantaram-se" },
        { "hebraico": "שָׂרֵ֣י", "transliteral": "śā-rê", "traducao_palavra": "príncipes de" },
        { "hebraico": "מֹואָ֑ב", "transliteral": "mô-ʾāḇ", "traducao_palavra": "Moabe" }
      ]
    },
    "15": {
      "traducao_completa": "Porém Balaque tornou ainda a enviar príncipes, em maior número e mais honrados do que aqueles.",
      "palavras": [
        { "hebraico": "וַיֹּ֥סֶף", "transliteral": "way-yō-sep̄", "traducao_palavra": "e tornou/prosseguiu" },
        { "hebraico": "עֹ֖וד", "transliteral": "ʿôḏ", "traducao_palavra": "ainda" },
        { "hebraico": "בָּלָ֑ק", "transliteral": "bā-lāq", "traducao_palavra": "Balaque" },
        { "hebraico": "שְׁלֹ֣חַ", "transliteral": "šə-lō-aḥ", "traducao_palavra": "enviar" },
        { "hebraico": "שָׂרִ֔ים", "transliteral": "śā-rîm", "traducao_palavra": "príncipes" },
        { "hebraico": "רַבִּ֥ים", "transliteral": "rab-bîm", "traducao_palavra": "muitos/mais" },
        { "hebraico": "וְנִכְבָּדִ֖ים", "transliteral": "wə-niḵ-bā-ḏîm", "traducao_palavra": "e honrados" },
        { "hebraico": "מֵאֵֽלֶּה׃", "transliteral": "mê-ʾēl-leh", "traducao_palavra": "do que aqueles" }
      ]
    },
    "16": {
      "traducao_completa": "Os quais vieram a Balaão, e lhe disseram: Assim diz Balaque, filho de Zipor: Rogo-te que não te demores em vir a mim.",
      "palavras": [
        { "hebraico": "וַיָּבֹ֖אוּ", "transliteral": "way-yā-ḇō-ʾû", "traducao_palavra": "e vieram" },
        { "hebraico": "אֶל־בִּלְעָ֑ם", "transliteral": "ʾel-bil-ʿām", "traducao_palavra": "a Balaão" }
      ]
    },
    "17": {
      "traducao_completa": "Porque grandemente te honrarei, e farei tudo o que me disseres; vem, pois, rogo-te, amaldiçoa-me este povo.",
      "palavras": [
        { "hebraico": "כִּֽי־כַבֵּ֤ד", "transliteral": "kî-ḵab-bêḏ", "traducao_palavra": "porque honrando" },
        { "hebraico": "אֲכַבֶּדְךָ֙", "transliteral": "ʾă-ḵab-beḏ-ḵā", "traducao_palavra": "te honrarei" },
        { "hebraico": "מְאֹ֔ד", "transliteral": "mə-ʾōḏ", "traducao_palavra": "grandemente" }
      ]
    },
    "18": {
      "traducao_completa": "Respondeu, porém, Balaão, e disse aos servos de Balaque: Ainda que Balaque me desse a sua casa cheia de prata e de ouro, eu não poderia transgredir a palavra de YHWH meu Deus, para fazer coisa pequena ou grande.",
      "palavras": [
        { "hebraico": "וַיַּ֣עַן", "transliteral": "way-ya-ʿan", "traducao_palavra": "e respondeu" },
        { "hebraico": "בִּלְעָ֗ם", "transliteral": "bil-ʿām", "traducao_palavra": "Balaão" },
        { "hebraico": "וַיֹּ֨אמֶר֮", "transliteral": "way-yō-mer", "traducao_palavra": "e disse" },
        { "hebraico": "אֶל־עַבְדֵ֣י", "transliteral": "ʾel-ʿaḇ-ḏê", "traducao_palavra": "aos servos de" },
        { "hebraico": "בָלָק֒", "transliteral": "ḇā-lāq", "traducao_palavra": "Balaque" },
        { "hebraico": "אִם־יִתֶּן־לִ֨י", "transliteral": "ʾim-yit-ten-lî", "traducao_palavra": "se desse para mim" },
        { "hebraico": "בָלָ֜ק", "transliteral": "ḇā-lāq", "traducao_palavra": "Balaque" },
        { "hebraico": "מְלֹ֥א", "transliteral": "məlō", "traducao_palavra": "cheio de" },
        { "hebraico": "בֵיתֹו֙", "transliteral": "ḇê-ṯô", "traducao_palavra": "sua casa" },
        { "hebraico": "כֶּ֣סֶף", "transliteral": "ke-sep̄", "traducao_palavra": "prata" },
        { "hebraico": "וְזָהָ֔ב", "transliteral": "wə-zā-hāḇ", "traducao_palavra": "e ouro" },
        { "hebraico": "לֹ֣א", "transliteral": "lō", "traducao_palavra": "não" },
        { "hebraico": "אוּכַ֗ל", "transliteral": "ʾû-ḵal", "traducao_palavra": "poderia" },
        { "hebraico": "לַעֲבֹר֙", "transliteral": "la-ʿă-ḇōr", "traducao_palavra": "transgredir/passar" },
        { "hebraico": "אֶת־פִּי֙", "transliteral": "ʾeṯ-pî", "traducao_palavra": "[a] boca de" },
        { "hebraico": "יְהוָ֣ה", "transliteral": "YHWH", "traducao_palavra": "YHWH" },
        { "hebraico": "אֱלֹהָ֔י", "transliteral": "ʾĕ-lō-hāy", "traducao_palavra": "meu Deus" },
        { "hebraico": "לַעֲשֹׂ֥ות", "transliteral": "la-ʿă-śôṯ", "traducao_palavra": "para fazer" },
        { "hebraico": "קְטַנָּ֖ה", "transliteral": "qə-ṭan-nā", "traducao_palavra": "[coisa] pequena" },
        { "hebraico": "אֹ֥ו", "transliteral": "ʾô", "traducao_palavra": "ou" },
        { "hebraico": "גְדוֹלָֽה׃", "transliteral": "ḡə-ḏô-lā", "traducao_palavra": "grande" }
      ]
    },
    "19": {
      "traducao_completa": "Agora, pois, rogo-vos que também aqui fiqueis esta noite, para que eu saiba o que mais YHWH me dirá.",
      "palavras": [
        { "hebraico": "וְעַתָּ֗ה", "transliteral": "wə-ʿat-tā", "traducao_palavra": "e agora" },
        { "hebraico": "שְׁב֨וּ", "transliteral": "šə-ḇû", "traducao_palavra": "ficai" },
