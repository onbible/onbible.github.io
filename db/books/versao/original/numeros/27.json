        { "hebraico": "מֵ֣ת", "transliteral": "mêṯ", "traducao_palavra": "morreu" },
        { "hebraico": "בַּמִּדְבָּר֒", "transliteral": "bam-miḏ-bār", "traducao_palavra": "no deserto" },
        { "hebraico": "וְה֨וּא", "transliteral": "wə-hû", "traducao_palavra": "e ele" },
        { "hebraico": "לֹא־הָיָ֜ה", "transliteral": "lō-hā-yā", "traducao_palavra": "não estava" },
