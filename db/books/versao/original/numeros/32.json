        { "hebraico": "קִרְיָתָֽיִם׃", "transliteral": "qir-yā-ṯā-yim", "traducao_palavra": "Quiriataim" }
      ]
    },
    "38": {
      "traducao_completa": "E Nebo, e Baal-Meom (mudando-se-lhes os nomes), e Sibma; e deram outros nomes às cidades que edificaram.",
