        { "hebraico": "מָכִ֧יר", "transliteral": "mā-ḵîr", "traducao_palavra": "Maquir" },
        { "hebraico": "גִּלְעָ֖דָה", "transliteral": "gil-ʿā-ḏā", "traducao_palavra": "a Gileade" },
