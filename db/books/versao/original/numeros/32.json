        { "hebraico": "אֲשֶׁר־בָּֽהּ׃", "transliteral": "ʾă-šer-bāh", "traducao_palavra": "que [estava] nela" }
      ]
    },
    "40": {
      "traducao_completa": "Assim deu Moisés Gileade a Maquir, filho de Manassés, o qual habitou nela.",
      "palavras": [
        { "hebraico": "וַיִּתֵּ֤ן", "transliteral": "way-yit-tên", "traducao_palavra": "e deu" },
        { "hebraico": "מֹשֶׁה֙", "transliteral": "mō-šeh", "traducao_palavra": "Moisés" },
        { "hebraico": "אֶת־הַגִּלְעָ֔ד", "transliteral": "ʾeṯ-hag-gil-ʿāḏ", "traducao_palavra": "Gileade" },
