    },
    "16": {
      "traducao_completa": "Então se chegaram a ele, e disseram: Edificaremos aqui currais para o nosso gado, e cidades para as nossas crianças;",
      "palavras": [
        { "hebraico": "וַיִּגְּשׁ֨וּ", "transliteral": "way-yig-gə-šû", "traducao_palavra": "e chegaram-se" },
        { "hebraico": "גִּדְרֹ֧ת", "transliteral": "giḏ-rōṯ", "traducao_palavra": "currais de" },
        { "hebraico": "צֹ֛אן", "transliteral": "ṣōn", "traducao_palavra": "ovelhas" },
        { "hebraico": "נִבְנֶ֥ה", "transliteral": "niḇ-neh", "traducao_palavra": "edificaremos" }
