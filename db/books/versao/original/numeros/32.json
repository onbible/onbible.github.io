    "13": {
      "traducao_completa": "Assim se acendeu a ira de YHWH contra Israel, e fê-los andar errantes pelo deserto quarenta anos, até que toda aquela geração que fizera mal aos olhos de YHWH se consumisse.",
      "palavras": [
        { "hebraico": "וַיִּֽחַר־אַ֤ף", "transliteral": "way-yi-ḥar-ʾap̄", "traducao_palavra": "e acendeu-se a ira de" },
        { "hebraico": "יְהוָה֙", "transliteral": "YHWH", "traducao_palavra": "YHWH" },
        { "hebraico": "וַיְנִעֵ֣ם", "transliteral": "way-ni-ʿêm", "traducao_palavra": "e fê-los errar/vagar" },
        { "hebraico": "בַּמִּדְבָּ֔ר", "transliteral": "bam-miḏ-bār", "traducao_palavra": "no deserto" },
