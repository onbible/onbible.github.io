        { "hebraico": "וַיִּקְרָ֥א", "transliteral": "way-yiq-rā", "traducao_palavra": "e chamou" },
        { "hebraico": "אֶתְהֶ֖ן", "transliteral": "ʾeṯ-hen", "traducao_palavra": "a elas" },
        { "hebraico": "חַוֹּ֥ת", "transliteral": "ḥaw-wōṯ", "traducao_palavra": "aldeias de" },
        { "hebraico": "יָאִֽיר׃", "transliteral": "yā-ʾîr", "traducao_palavra": "Jair" }
      ]
    },
    "42": {
      "traducao_completa": "E foi Nobá, e tomou a Quenate com as suas aldeias; e chamou-lhe Nobá, segundo o seu nome.",
      "palavras": [
        { "hebraico": "וְנֹ֣בַח", "transliteral": "wə-nō-ḇaḥ", "traducao_palavra": "e Nobá" },
