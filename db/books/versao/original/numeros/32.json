        { "hebraico": "סִיחֹ֣ן", "transliteral": "sî-ḥōn", "traducao_palavra": "Seom" },
        { "hebraico": "וְאֶת־מַמְלֶ֔כֶת", "transliteral": "wə-ʾeṯ-mam-le-ḵeṯ", "traducao_palavra": "e o reino de" },
        { "hebraico": "עֹ֖וג", "transliteral": "ʿôḡ", "traducao_palavra": "Ogue" },
