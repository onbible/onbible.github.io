        { "hebraico": "בָּנ֣וּ", "transliteral": "bā-nû", "traducao_palavra": "edificaram" },
        { "hebraico": "אֶת־חֶשְׁבֹּון֙", "transliteral": "ʾeṯ-ḥeš-bôn", "traducao_palavra": "Hesbom" },
