        { "hebraico": "הַבָּשָׁ֑ן", "transliteral": "hab-bā-šān", "traducao_palavra": "o Basã" }
      ]
    },
    "34": {
      "traducao_completa": "E os filhos de Gade edificaram a Dibom, e Atarote, e Aroer;",
      "palavras": [
