        { "hebraico": "שֹׁופָ֖ן", "transliteral": "šô-p̄ān", "traducao_palavra": "Sofã" },
        { "hebraico": "וְאֶת־יַעְזֵ֥ר", "transliteral": "wə-ʾeṯ-yaʿ-zêr", "traducao_palavra": "e Jazer" },
        { "hebraico": "וְיָגְבְּהָֽה׃", "transliteral": "wə-yāḡ-bə-hā", "traducao_palavra": "e Jogbeá" }
      ]
    },
    "36": {
      "traducao_completa": "E Bete-Ninra, e Bete-Harã, cidades fortificadas; e currais de ovelhas.",
      "palavras": [
        { "hebraico": "וְאֶת־בֵּ֥ית", "transliteral": "wə-ʾeṯ-bêṯ", "traducao_palavra": "e Bete-" },
        { "hebraico": "נִמְרָ֖ה", "transliteral": "nim-rā", "traducao_palavra": "Ninra" },
        { "hebraico": "וְאֶת־בֵּ֣ית", "transliteral": "wə-ʾeṯ-bêṯ", "traducao_palavra": "e Bete-" },
        { "hebraico": "הָרָ֑ן", "transliteral": "hā-rān", "traducao_palavra": "Harã" },
        { "hebraico": "עָרֵ֥י", "transliteral": "ʿā-rê", "traducao_palavra": "cidades de" },
        { "hebraico": "מִבְצָ֖ר", "transliteral": "miḇ-ṣār", "traducao_palavra": "fortaleza" },
        { "hebraico": "וְגִדְרֹ֥ת", "transliteral": "wə-ḡiḏ-rōṯ", "traducao_palavra": "e currais de" },
