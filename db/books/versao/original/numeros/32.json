    },
    "37": {
      "traducao_completa": "E os filhos de Rúben edificaram a Hesbom, e Eleale, e Quiriataim;",
      "palavras": [
        { "hebraico": "וּבְנֵ֥י", "transliteral": "ū-ḇə-nê", "traducao_palavra": "e filhos de" },
