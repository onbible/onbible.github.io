        { "hebraico": "תַּ֣חַת", "transliteral": "ta-ḥaṯ", "traducao_palavra": "em lugar de" },
        { "hebraico": "אֲבֹתֵיכֶ֑ם", "transliteral": "ʾă-ḇō-ṯê-ḵem", "traducao_palavra": "vossos pais" },
        { "hebraico": "תַּרְבּ֖וּת", "transliteral": "tar-bûṯ", "traducao_palavra": "uma raça/prole" },
        { "hebraico": "חַטָּאִ֑ים", "transliteral": "ḥaṭ-ṭā-ʾîm", "traducao_palavra": "pecadores" }
      ]
    },
    "15": {
      "traducao_completa": "Se vós vos desviardes de segui-lo, ele ainda os deixará mais no deserto, e destruireis a todo este povo.",
