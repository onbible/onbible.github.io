        { "hebraico": "הָלַ֔ךְ", "transliteral": "hā-laḵ", "traducao_palavra": "foi" },
        { "hebraico": "וַיִּלְכֹּ֖ד", "transliteral": "way-yil-kōḏ", "traducao_palavra": "e tomou" },
