        { "hebraico": "הַמֹּואֲבִיָּ֜ה", "transliteral": "ham-mô-ʾă-ḇî-yā", "traducao_palavra": "a moabita" },
        { "hebraico": "אֶל־נָעֳמִ֗י", "transliteral": "ʾel-nā-ʿo-mî", "traducao_palavra": "a Noemi" },
        { "hebraico": "אֵֽלְכָה־", "transliteral": "ʾê-lə-ḵā-", "traducao_palavra": "deixa-me ir" },
        { "hebraico": "נָּ֨א", "transliteral": "nā", "traducao_palavra": "peço-te" },
        { "hebraico": "הַשָּׂדֶ֜ה", "transliteral": "haś-śā-ḏeh", "traducao_palavra": "ao campo" },
        { "hebraico": "וַאֲלַקֳּטָ֤ה", "transliteral": "wa-ʾă-laq-qo-ṭā", "traducao_palavra": "e colherei" },
        { "hebraico": "בַשִּׁבֳּלִים֙", "transliteral": "ḇaš-šib-bo-lîm", "traducao_palavra": "entre as espigas" },
        { "hebraico": "אַחֲרֵ֕ר", "transliteral": "ʾa-ḥă-rê", "traducao_palavra": "atrás de" },
        { "hebraico": "אֲשֶׁ֥ר", "transliteral": "ʾă-šer", "traducao_palavra": "[daquele] que" },
        { "hebraico": "אֶמְצָא־", "transliteral": "ʾem-ṣā-", "traducao_palavra": "eu achar" },
        { "hebraico": "חֵ֖ן", "transliteral": "ḥên", "traducao_palavra": "graça" },
