        { "hebraico": "אֶמְצָא־", "transliteral": "ʾem-ṣā-", "traducao_palavra": "ache" },
        { "hebraico": "חֵ֨ן", "transliteral": "ḥên", "traducao_palavra": "graça" },
        { "hebraico": "בְּעֵינֶ֤יךָ", "transliteral": "bə-ʿê-ne-yḵā", "traducao_palavra": "em teus olhos" },
