        { "hebraico": "לָ֔הּ", "transliteral": "lāh", "traducao_palavra": "para ela" },
        { "hebraico": "מִן־", "transliteral": "min-", "traducao_palavra": "das" },
        { "hebraico": "הַצְּבָתִ֑ים", "transliteral": "haṣ-ṣə-ḇā-ṯîm", "traducao_palavra": "braçadas/feixes" },
