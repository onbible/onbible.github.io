        { "hebraico": "מָצָ֨אתִי", "transliteral": "mā-ṣā-ṯî", "traducao_palavra": "achei" },
        { "hebraico": "חֵ֤ן", "transliteral": "ḥên", "traducao_palavra": "graça" },
        { "hebraico": "בְּעֵינֶ֙יךָ֙", "transliteral": "bə-ʿê-ne-yḵā", "traducao_palavra": "em teus olhos" },
        { "hebraico": "לְהַכִּירֵ֔נִי", "transliteral": "lə-hak-kî-rê-nî", "traducao_palavra": "para me reconhecer/notar" },
        { "hebraico": "וְאָנֹכִ֖י", "transliteral": "wə-ʾā-nō-ḵî", "traducao_palavra": "sendo eu" },
