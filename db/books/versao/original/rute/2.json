        { "hebraico": "הַלֶּ֔חֶם", "transliteral": "hal-le-ḥem", "traducao_palavra": "pão" },
        { "hebraico": "וְטָבַ֥לְתְּ", "transliteral": "wə-ṭā-ḇalt", "traducao_palavra": "e molha" },
        { "hebraico": "פִּתֵּ֖ךְ", "transliteral": "pit-têḵ", "traducao_palavra": "teu bocado" },
        { "hebraico": "בַּחֹ֑מֶץ", "transliteral": "ba-ḥō-meṣ", "traducao_palavra": "no vinagre" },
        { "hebraico": "וַתֵּ֙שֶׁב֙", "transliteral": "wat-tê-šeḇ", "traducao_palavra": "e assentou-se" },
