        { "hebraico": "וַתִּשְׁתַּ֖חוּ", "transliteral": "wat-tiš-tā-ḥû", "traducao_palavra": "e inclinou-se" },
        { "hebraico": "אָ֑רְצָה", "transliteral": "ʾā-rə-ṣā", "traducao_palavra": "à terra" },
        { "hebraico": "וַתֹּ֣אמֶר", "transliteral": "wat-tō-mer", "traducao_palavra": "e disse" },
        { "hebraico": "אֵלָ֗יו", "transliteral": "ʾê-lāw", "traducao_palavra": "lhe" },
