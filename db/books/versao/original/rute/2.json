        { "hebraico": "בָֽהּ׃", "transliteral": "ḇāh", "traducao_palavra": "a ela" }
      ]
    },
    "17": {
      "traducao_completa": "E colheu naquele campo até à tarde; e debulhou o que colhera, e foi quase um efa de cevada.",
