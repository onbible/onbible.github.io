        { "hebraico": "שִׁפְחָתֶ֑ךָ", "transliteral": "šip̄-ḥā-ṯe-ḵā", "traducao_palavra": "tua serva" },
        { "hebraico": "וְאָנֹכִי֙", "transliteral": "wə-ʾā-nō-ḵî", "traducao_palavra": "embora eu" },
