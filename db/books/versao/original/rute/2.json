        { "hebraico": "בֵּ֧ין", "transliteral": "bên", "traducao_palavra": "entre" },
        { "hebraico": "הָעֳמָרִ֛ים", "transliteral": "hā-ʿo-mā-rîm", "traducao_palavra": "as gavelas" },
        { "hebraico": "תְּלַקֵּ֖ט", "transliteral": "tə-laq-qēṭ", "traducao_palavra": "colha ela" },
