        { "hebraico": "לְאִישָׁ֗הּ", "transliteral": "lə-ʾî-šāh", "traducao_palavra": "de seu marido" },
        { "hebraico": "אִ֚ישׁ", "transliteral": "ʾîš", "traducao_palavra": "um homem" },
        { "hebraico": "גִּבֹּ֣ור", "transliteral": "gib-bôr", "traducao_palavra": "valente/poderoso" },
