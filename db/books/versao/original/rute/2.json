        { "hebraico": "בִתִּֽי׃", "transliteral": "ḇit-tî", "traducao_palavra": "minha filha" }
      ]
    },
    "3": {
      "traducao_completa": "Foi, pois, e chegou, e colhia no campo após os segadores; e aconteceu-lhe de entrar na parte do campo que pertencia a Boaz, que era da família de Elimeleque.",
