        { "hebraico": "מִמִּשְׁפַּ֖חַת", "transliteral": "mim-miš-pa-ḥaṯ", "traducao_palavra": "da família de" },
        { "hebraico": "אֱלִימֶ֑לֶךְ", "transliteral": "ʾĕ-lî-me-leḵ", "traducao_palavra": "Elimeleque" },
        { "hebraico": "וּשְׁמֹ֖ו", "transliteral": "ū-šə-mô", "traducao_palavra": "e seu nome [era]" },
        { "hebraico": "בֹּֽעַז׃", "transliteral": "bō-ʿaz", "traducao_palavra": "Boaz" }
      ]
    },
    "2": {
      "traducao_completa": "E Rute, a moabita, disse a Noemi: Deixa-me ir ao campo, e colherei espigas atrás daquele a cujos olhos eu achar graça. E ela lhe disse: Vai, minha filha.",
