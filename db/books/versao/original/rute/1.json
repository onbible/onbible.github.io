      ]
    },
    "19": {
      "traducao_completa": "Assim, pois, caminharam ambas, até que chegaram a Belém. E sucedeu que, entrando elas em Belém, toda a cidade se comoveu por causa delas, e diziam: Não é esta Noemi?",
      "palavras": [
        { "hebraico": "וַתֵּלַ֣כְנָה", "transliteral": "wat-tê-laḵ-nā", "traducao_palavra": "e caminharam" },
        { "hebraico": "שְׁתֵּיהֶ֔ם", "transliteral": "šə-tê-hem", "traducao_palavra": "ambas elas" },
