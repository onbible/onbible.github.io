        { "hebraico": "כְּבֹאָ֣נָה", "transliteral": "kə-ḇō-ʾā-nā", "traducao_palavra": "ao chegarem" },
        { "hebraico": "בֵּ֣ית", "transliteral": "bêṯ", "traducao_palavra": "Belém" },
        { "hebraico": "לֶ֔חֶם", "transliteral": "le-ḥem", "traducao_palavra": "[Pão]" },
