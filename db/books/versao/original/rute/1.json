        { "hebraico": "תֵּלְכִ֜י", "transliteral": "tê-lə-ḵî", "traducao_palavra": "fores" },
        { "hebraico": "אֵלֵ֗ךְ", "transliteral": "ʾê-lēḵ", "traducao_palavra": "irei" },
        { "hebraico": "וּבַאֲשֶׁ֥ר", "transliteral": "ū-ḇa-ʾă-šer", "traducao_palavra": "e onde" },
