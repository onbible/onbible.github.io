        { "hebraico": "כִּ֥י", "transliteral": "kî", "traducao_palavra": "porque" },
        { "hebraico": "גֹאֵ֖ל", "transliteral": "ḡō-ʾēl", "traducao_palavra": "remidor/resgatador" },
        { "hebraico": "אָֽתָּה׃", "transliteral": "ʾāt-tā", "traducao_palavra": "[és] tu" }
      ]
    },
    "10": {
      "traducao_completa": "E disse ele: Bendita sejas tu de YHWH, minha filha; melhor fizeste esta tua última benevolência do que a primeira, pois não foste após os jovens, quer pobres quer ricos.",
      "palavras": [
        { "hebraico": "וַיֹּ֗אמֶר", "transliteral": "way-yō-mer", "traducao_palavra": "e disse ele" },
