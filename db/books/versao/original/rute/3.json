    "9": {
      "traducao_completa": "E disse ele: Quem és tu? E ela disse: Sou Rute, tua serva; estende, pois, a tua aba sobre a tua serva, porque tu és o remidor.",
      "palavras": [
        { "hebraico": "וַיֹּ֖אמֶר", "transliteral": "way-yō-mer", "traducao_palavra": "e disse ele" },
