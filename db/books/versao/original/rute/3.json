        { "hebraico": "חַסְדֵּ֥ךְ", "transliteral": "ḥas-dêḵ", "traducao_palavra": "tua bondade" },
        { "hebraico": "הָאַחֲרֹ֖ון", "transliteral": "hā-ʾa-ḥă-rôn", "traducao_palavra": "a última" },
