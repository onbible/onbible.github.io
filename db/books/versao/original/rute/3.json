        { "hebraico": "וַיָּ֤מָד", "transliteral": "way-yā-māḏ", "traducao_palavra": "e mediu" },
        { "hebraico": "שֵׁשׁ־", "transliteral": "šēš-", "traducao_palavra": "seis" },
        { "hebraico": "שְׂעֹרִים֙", "transliteral": "śə-ʿō-rîm", "traducao_palavra": "cevadas [medidas]" },
