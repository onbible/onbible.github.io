        { "hebraico": "אַ֣תְּ", "transliteral": "ʾat", "traducao_palavra": "[sejas] tu" },
        { "hebraico": "לַיהוָה֮", "transliteral": "la-YHWH", "traducao_palavra": "por YHWH" },
        { "hebraico": "בִּתִּי֒", "transliteral": "bit-tî", "traducao_palavra": "minha filha" },
