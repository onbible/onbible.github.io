      ]
    },
    "11": {
      "traducao_completa": "Agora, pois, minha filha, não temas; tudo quanto disseste te farei, pois toda a cidade do meu povo sabe que és mulher virtuosa.",
      "palavras": [
        { "hebraico": "וְעַתָּ֗ה", "transliteral": "wə-ʿat-tā", "traducao_palavra": "e agora" },
        { "hebraico": "בִּתִּי֙", "transliteral": "bit-tî", "traducao_palavra": "minha filha" },
