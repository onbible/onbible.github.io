        { "hebraico": "מָנֹ֖וחַ", "transliteral": "mā-nô-aḥ", "traducao_palavra": "descanso" },
        { "hebraico": "אֲשֶׁ֥ר", "transliteral": "ʾă-šer", "traducao_palavra": "para que" },
        { "hebraico": "יִֽיטַב־", "transliteral": "yî-ṭaḇ-", "traducao_palavra": "te vá bem" },
        { "hebraico": "לָֽךְ׃", "transliteral": "lāḵ", "traducao_palavra": "a ti" }
      ]
    },
    "2": {
