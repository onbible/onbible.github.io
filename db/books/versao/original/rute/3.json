        { "hebraico": "אָנֹכִי֙", "transliteral": "ʾā-nō-ḵî", "traducao_palavra": "sou eu" },
        { "hebraico": "ר֣וּת", "transliteral": "rûṯ", "traducao_palavra": "Rute" },
        { "hebraico": "אֲמָתֶ֔ךָ", "transliteral": "ʾă-mā-ṯe-ḵā", "traducao_palavra": "tua serva" },
        { "hebraico": "וּפָרַשְׂתָּ֤", "transliteral": "ū-p̄ā-raś-tā", "traducao_palavra": "estende" },
        { "hebraico": "כְנָפֶ֙ךָ֙", "transliteral": "ḵə-nā-p̄e-ḵā", "traducao_palavra": "tua aba/asa" },
        { "hebraico": "עַל־", "transliteral": "ʿal-", "traducao_palavra": "sobre" },
