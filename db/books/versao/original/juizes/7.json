        { "hebraico": "וַיָּ֣נָס", "transliteral": "way-yā-nās", "traducao_palavra": "e fugiu" },
        { "hebraico": "הַֽמַּחֲנֶ֗ה", "transliteral": "ham-ma-ḥă-neh", "traducao_palavra": "o acampamento" },
