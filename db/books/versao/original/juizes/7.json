    "25": {
      "traducao_completa": "E prenderam a dois príncipes dos midianitas, a Orebe e a Zeebe, e mataram a Orebe na penha de Orebe, e a Zeebe mataram no lagar de Zeebe, e perseguiram aos midianitas; e trouxeram as cabeças de Orebe e de Zeebe a Gideão, além do Jordão.",
      "palavras": [
        { "hebraico": "וַֽיִּלְכְּד֡וּ", "transliteral": "way-yil-kə-ḏū", "traducao_palavra": "e prenderam" },
        { "hebraico": "שְׁנֵֽי־שָׂרֵ֨י", "transliteral": "šə-nê-śā-rê", "traducao_palavra": "dois príncipes de" },
        { "hebraico": "מִדְיָ֜ן", "transliteral": "miḏ-yān", "traducao_palavra": "Midiã" },
