        { "hebraico": "הֵבִ֙יאוּ֙", "transliteral": "hê-ḇî-ʾū", "traducao_palavra": "trouxeram" },
        { "hebraico": "אֶל־גִּדְעֹ֔ון", "transliteral": "ʾel-giḏ-ʿôn", "traducao_palavra": "a Gideão" },
