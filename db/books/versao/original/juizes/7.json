        { "hebraico": "וְאֶת־זְאֵ֗ב", "transliteral": "wə-ʾeṯ-zə-ʾēḇ", "traducao_palavra": "e a Zeebe" },
        { "hebraico": "וַיַּהַרְג֨וּ", "transliteral": "way-ya-har-gū", "traducao_palavra": "e mataram" },
        { "hebraico": "אֶת־עֹרֵ֤ב", "transliteral": "ʾeṯ-ʿō-rêḇ", "traducao_palavra": "a Orebe" },
        { "hebraico": "בְּצוּר־עֹורֵב֙", "transliteral": "bə-ṣūr-ʿô-rēḇ", "traducao_palavra": "na penha de Orebe" },
        { "hebraico": "וְאֶת־זְאֵב֙", "transliteral": "wə-ʾeṯ-zə-ʾēḇ", "traducao_palavra": "e a Zeebe" },
        { "hebraico": "הָרְג֣וּ", "transliteral": "hā-rə-gū", "traducao_palavra": "mataram" },
        { "hebraico": "בְיֶֽקֶב־זְאֵ֔ב", "transliteral": "ḇə-ye-qeḇ-zə-ʾēḇ", "traducao_palavra": "no lagar de Zeebe" },
        { "hebraico": "וַֽיִּרְדְּפ֖וּ", "transliteral": "way-yir-də-p̄ū", "traducao_palavra": "e perseguiram" },
