        { "hebraico": "וַיִּצָּעֵ֞ק", "transliteral": "way-yiṣ-ṣā-ʿēq", "traducao_palavra": "e convocou-se" },
        { "hebraico": "כָּל־אִ֤ישׁ", "transliteral": "kāl-ʾîš", "traducao_palavra": "todos os homens de" },
        { "hebraico": "אֶפְרַ֙יִם֙", "transliteral": "ʾep̄-ra-yim", "traducao_palavra": "Efraim" },
        { "hebraico": "וַיִּלְכְּד֣וּ", "transliteral": "way-yil-kə-ḏū", "traducao_palavra": "e tomaram" },
        { "hebraico": "אֶת־הַמַּ֔יִם", "transliteral": "ʾeṯ-ham-ma-yim", "traducao_palavra": "as águas" },
        { "hebraico": "עַ֛ד", "transliteral": "ʿaḏ", "traducao_palavra": "até" },
        { "hebraico": "בֵּ֥ית", "transliteral": "bêṯ", "traducao_palavra": "Bete-Bara" },
