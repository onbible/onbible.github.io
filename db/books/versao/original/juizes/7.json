    "24": {
      "traducao_completa": "E Gideão enviou mensageiros a todas as montanhas de Efraim, dizendo: Descei ao encontro dos midianitas, e tomai-lhes as águas até Bete-Bara, a saber, o Jordão. Convocou-se, pois, a todos os homens de Efraim, e tomaram as águas até Bete-Bara, e o Jordão.",
      "palavras": [
        { "hebraico": "וּמַלְאָכִ֡ים", "transliteral": "ū-mal-ʾā-ḵîm", "traducao_palavra": "e mensageiros" },
        { "hebraico": "שָׁלַ֣ח", "transliteral": "šā-laḥ", "traducao_palavra": "enviou" },
        { "hebraico": "גִּדְעֹון֩", "transliteral": "giḏ-ʿôn", "traducao_palavra": "Gideão" },
        { "hebraico": "בְּכָל־הַר־אֶפְרַ֨יִם", "transliteral": "bə-ḵāl-har-ʾep̄-ra-yim", "traducao_palavra": "por toda a montanha de Efraim" },
        { "hebraico": "לֵאמֹ֜ר", "transliteral": "lē-mōr", "traducao_palavra": "dizendo" },
        { "hebraico": "רְד֣וּ", "transliteral": "rə-ḏū", "traducao_palavra": "descei" },
        { "hebraico": "לִקְרַ֤את", "transliteral": "liq-raṯ", "traducao_palavra": "ao encontro de" },
        { "hebraico": "מִדְיָן֙", "transliteral": "miḏ-yān", "traducao_palavra": "Midiã" },
        { "hebraico": "וְלִכְד֤וּ", "transliteral": "wə-liḵ-ḏū", "traducao_palavra": "e tomai" },
        { "hebraico": "לָהֶם֙", "transliteral": "lā-hem", "traducao_palavra": "deles" },
        { "hebraico": "אֶת־הַמַּ֔יִם", "transliteral": "ʾeṯ-ham-ma-yim", "traducao_palavra": "as águas" },
        { "hebraico": "עַ֛ד", "transliteral": "ʿaḏ", "traducao_palavra": "até" },
        { "hebraico": "בֵּ֥ית", "transliteral": "bêṯ", "traducao_palavra": "Bete-Bara" },
        { "hebraico": "בָּרָ֖ה", "transliteral": "bā-rā", "traducao_palavra": " " },
