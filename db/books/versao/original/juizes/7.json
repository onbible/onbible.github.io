      ]
    },
    "19": {
      "traducao_completa": "Chegou, pois, Gideão, e os cem homens que com ele iam, ao extremo do arraial, ao princípio da vigília da meia-noite, havendo sido de pouco trocadas as guardas; então tocaram as buzinas, e quebraram os cântaros, que tinham nas mãos.",
      "palavras": [
