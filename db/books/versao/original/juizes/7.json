        { "hebraico": "בַּלַּפִּדִ֔ים", "transliteral": "bal-lap-pi-ḏîm", "traducao_palavra": "nas tochas" },
        { "hebraico": "וּבְיַד־יְמִינָ֖ם", "transliteral": "ū-ḇə-yaḏ-yə-mî-nām", "traducao_palavra": "e em sua direita mão" },
