      ]
    },
    "23": {
      "traducao_completa": "Então os homens de Israel, de Naftali e de Aser, e de todo o Manassés, foram convocados, e perseguiram aos midianitas.",
      "palavras": [
        { "hebraico": "וַיִּצָּעֵ֧ק", "transliteral": "way-yiṣ-ṣā-ʿēq", "traducao_palavra": "e foram convocados" },
        { "hebraico": "אִישׁ־יִשְׂרָאֵ֛ל", "transliteral": "ʾîš-yiś-rā-ʾēl", "traducao_palavra": "homens de Israel" },
