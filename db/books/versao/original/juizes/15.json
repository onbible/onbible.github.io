        { "hebraico": "וַיֹּאמֶר֩", "transliteral": "way-yō-mer", "traducao_palavra": "e disse" },
        { "hebraico": "לָהֶ֨ם", "transliteral": "lā-hem", "traducao_palavra": "lhes" },
        { "hebraico": "שִׁמְשֹׁ֔ון", "transliteral": "šim-šôn", "traducao_palavra": "Sansão" },
        { "hebraico": "נִקֵּ֥יתִי", "transliteral": "niq-qê-ṯî", "traducao_palavra": "sou inocente/limpo" },
        { "hebraico": "הַפַּ֖עַם", "transliteral": "hap-pa-ʿam", "traducao_palavra": "esta vez" },
        { "hebraico": "מִפְּלִשְׁתִּ֑ים", "transliteral": "mip-pə-liš-tîm", "traducao_palavra": "dos filisteus" },
