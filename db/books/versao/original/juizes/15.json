        { "hebraico": "כֶּ֥רֶם", "transliteral": "ke-rem", "traducao_palavra": "vinha" },
        { "hebraico": "זָֽיִת׃", "transliteral": "zā-yiṯ", "traducao_palavra": "oliveira" }
