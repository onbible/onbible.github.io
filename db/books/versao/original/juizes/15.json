        { "hebraico": "בִּגְדִ֣י", "transliteral": "biḡ-ḏî", "traducao_palavra": "com um cabrito de" },
        { "hebraico": "עִזִּ֔ים", "transliteral": "ʿiz-zîm", "traducao_palavra": "cabras" },
        { "hebraico": "וַיֹּ֕אמֶר", "transliteral": "way-yō-mer", "traducao_palavra": "e disse" },
