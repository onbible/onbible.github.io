        { "hebraico": "בִּימֵי֙", "transliteral": "bî-mê", "traducao_palavra": "nos dias de" },
        { "hebraico": "קְצִיר־", "transliteral": "qə-ṣîr-", "traducao_palavra": "ceifa de" },
