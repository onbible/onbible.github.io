        { "hebraico": "שִׁמְשֹׁ֔ון", "transliteral": "šim-šôn", "traducao_palavra": "Sansão" },
        { "hebraico": "אִם־", "transliteral": "ʾim-", "traducao_palavra": "se" },
        { "hebraico": "תַּעֲשֹׂ֖וּן", "transliteral": "ta-ʿă-śûn", "traducao_palavra": "fazeis" },
