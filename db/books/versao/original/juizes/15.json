    "9": {
      "traducao_completa": "Então os filisteus subiram, e acamparam-se em Judá, e estenderam-se por Leí.",
      "palavras": [
        { "hebraico": "וַיַּעֲל֣וּ", "transliteral": "way-ya-ʿă-lû", "traducao_palavra": "e subiram" },
