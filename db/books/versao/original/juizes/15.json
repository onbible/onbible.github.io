        { "hebraico": "שְׁלֹשׁ־", "transliteral": "šə-lōš-", "traducao_palavra": "três" },
        { "hebraico": "מֵאֹ֣ות", "transliteral": "mê-ʾôṯ", "traducao_palavra": "centenas [trezentas]" },
        { "hebraico": "שׁוּעָלִ֑ים", "transliteral": "šû-ʿā-lîm", "traducao_palavra": "raposas" },
