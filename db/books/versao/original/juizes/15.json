        { "hebraico": "אֶת־", "transliteral": "ʾeṯ-", "traducao_palavra": "a" },
        { "hebraico": "אִשְׁתֹּ֔ו", "transliteral": "ʾiš-tô", "traducao_palavra": "sua mulher" },
