        { "hebraico": "אֵשׁ֙", "transliteral": "ʾêš", "traducao_palavra": "fogo" },
        { "hebraico": "בַּלַפִּידִ֔ים", "transliteral": "bal-lap-pi-ḏîm", "traducao_palavra": "nas tochas" },
        { "hebraico": "וַיְשַׁלַּ֖ח", "transliteral": "way-šal-laḥ", "traducao_palavra": "e as soltou" },
