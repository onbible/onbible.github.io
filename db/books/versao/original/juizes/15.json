        { "hebraico": "אֲנִ֛י", "transliteral": "ʾă-nî", "traducao_palavra": "eu" },
        { "hebraico": "עִמָּהֶ֖ם", "transliteral": "ʿim-mā-hem", "traducao_palavra": "com eles" },
        { "hebraico": "רָעָֽה׃", "transliteral": "rā-ʿā", "traducao_palavra": "mal" }
      ]
    },
    "4": {
      "traducao_completa": "E foi Sansão, e tomou trezentas raposas; e, tomando fachos, as uniu cauda com cauda, e pôs um facho no meio entre as duas caudas.",
      "palavras": [
        { "hebraico": "וַיֵּ֣לֶךְ", "transliteral": "way-yê-leḵ", "traducao_palavra": "e foi" },
