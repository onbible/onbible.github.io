        { "hebraico": "אִשְׁתִּ֖י", "transliteral": "ʾiš-tî", "traducao_palavra": "minha mulher" },
        { "hebraico": "הֶחָ֑דְרָה", "transliteral": "he-ḥā-ḏə-rā", "traducao_palavra": "no quarto/câmara" },
        { "hebraico": "וְלֹא־", "transliteral": "wə-lō-", "traducao_palavra": "e não" },
        { "hebraico": "נְתָנֹ֥ו", "transliteral": "nə-ṯā-nô", "traducao_palavra": "deixou-o" },
        { "hebraico": "אָבִ֖יהָ", "transliteral": "ʾā-ḇî-hā", "traducao_palavra": "o pai dela" },
