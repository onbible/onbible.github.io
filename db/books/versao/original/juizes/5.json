        { "hebraico": "סֹפֵֽר׃", "transliteral": "sō-p̄ēr", "traducao_palavra": "comandante [escriba]" }
      ]
    },
    "15": {
      "traducao_completa": "E os príncipes de Issacar foram com Débora; e como Issacar, assim também Baraque foi enviado a pé para o vale. Nas correntes de Rúben foram grandes as resoluções do coração.",
      "palavras": [
