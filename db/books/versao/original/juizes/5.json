        { "hebraico": "שָׂרִ֔יד", "transliteral": "śā-rîḏ", "traducao_palavra": "um remanescente" },
        { "hebraico": "לְאַדִּירִ֖ים", "transliteral": "lə-ʾad-dî-rîm", "traducao_palavra": "para os nobres de [entre os nobres de]" },
        { "hebraico": "עָ֑ם", "transliteral": "ʿām", "traducao_palavra": "um povo" },
        { "hebraico": "יְהוָ֕ה", "transliteral": "YHWH", "traducao_palavra": "YHWH" },
        { "hebraico": "יְרַד־לִ֖י", "transliteral": "yə-raḏ-lî", "traducao_palavra": "desceu a mim" },
