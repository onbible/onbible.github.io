      ]
    },
    "19": {
      "traducao_completa": "Vieram reis, pelejaram; então pelejaram os reis de Canaã em Taanaque, junto às águas de Megido; não tomaram despojo de prata.",
      "palavras": [
        { "hebraico": "בָּ֤אוּ", "transliteral": "bā-ʾū", "traducao_palavra": "vieram" },
        { "hebraico": "מְלָכִים֙", "transliteral": "mə-lā-ḵîm", "traducao_palavra": "reis" },
        { "hebraico": "נִלְחָ֔מוּ", "transliteral": "nil-ḥā-mū", "traducao_palavra": "pelejaram" },
        { "hebraico": "אָ֤ז", "transliteral": "ʾāz", "traducao_palavra": "então" },
        { "hebraico": "נִלְחֲמוּ֙", "transliteral": "nil-ḥă-mū", "traducao_palavra": "pelejaram" },
        { "hebraico": "מַלְכֵ֣י", "transliteral": "mal-ḵê", "traducao_palavra": "reis de" },
        { "hebraico": "כְנַ֔עַן", "transliteral": "ḵə-na-ʿan", "traducao_palavra": "Canaã" },
        { "hebraico": "בְּתַעְנַ֖ךְ", "transliteral": "bə-ṯaʿ-naḵ", "traducao_palavra": "em Taanaque" },
        { "hebraico": "עַל־מֵ֣י", "transliteral": "ʿal-mê", "traducao_palavra": "junto a águas de" },
        { "hebraico": "מְגִדֹּ֑ו", "transliteral": "mə-ḡid-dô", "traducao_palavra": "Megido" },
