        { "hebraico": "מָחֲקָ֣ה", "transliteral": "mā-ḥă-qā", "traducao_palavra": "rachou" },
        { "hebraico": "רֹאשֹׁ֔ו", "transliteral": "rō-šô", "traducao_palavra": "sua cabeça" },
        { "hebraico": "וּמָחֲצָ֥ה", "transliteral": "ū-mā-ḥă-ṣā", "traducao_palavra": "e furou" },
