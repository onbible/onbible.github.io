        { "hebraico": "עֹֽז׃", "transliteral": "ʿōz", "traducao_palavra": "na força" }
      ]
    },
    "22": {
      "traducao_completa": "Então as unhas dos cavalos se despedaçaram pelo galopar, o galopar dos seus valentes.",
      "palavras": [
        { "hebraico": "אָ֥ז", "transliteral": "ʾāz", "traducao_palavra": "então" },
        { "hebraico": "הָלְמ֖וּ", "transliteral": "hā-lə-mū", "traducao_palavra": "bateram" },
        { "hebraico": "עִקְּבֵי־ס֑וּס", "transliteral": "ʿiq-qə-ḇê-sūs", "traducao_palavra": "os calcanhares [cascos] do cavalo" },
        { "hebraico": "מִֽדַּהֲרֹ֖ות", "transliteral": "mid-da-hă-rôṯ", "traducao_palavra": "pelo galopar" },
        { "hebraico": "דַּהֲרֹ֥ות", "transliteral": "da-hă-rôṯ", "traducao_palavra": "o galope" },
