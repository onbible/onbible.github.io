        { "hebraico": "לְעֶזְרַ֣ת", "transliteral": "lə-ʿez-raṯ", "traducao_palavra": "em socorro de" },
        { "hebraico": "יְהוָ֔ה", "transliteral": "YHWH", "traducao_palavra": "YHWH" },
        { "hebraico": "לְעֶזְרַ֥ת", "transliteral": "lə-ʿez-raṯ", "traducao_palavra": "em socorro de" },
        { "hebraico": "יְהוָ֖ה", "transliteral": "YHWH", "traducao_palavra": "YHWH" },
        { "hebraico": "בַּגִּבֹּורִֽים׃", "transliteral": "bag-gib-bô-rîm", "traducao_palavra": "com [entre] os valorosos" }
      ]
    },
    "24": {
      "traducao_completa": "Bendita seja entre as mulheres Jael, mulher de Héber, o queneu; bendita seja entre as mulheres nas tendas.",
      "palavras": [
        { "hebraico": "תְּבֹרַךְ֙", "transliteral": "tə-ḇō-raḵ", "traducao_palavra": "seja abençoada" },
        { "hebraico": "מִנָּשִׁ֔ים", "transliteral": "min-nā-šîm", "traducao_palavra": "entre [mais que as] mulheres" },
        { "hebraico": "יָעֵ֕ל", "transliteral": "yā-ʿēl", "traducao_palavra": "Jael" },
        { "hebraico": "אֵ֖שֶׁת", "transliteral": "ʾē-šeṯ", "traducao_palavra": "mulher de" },
