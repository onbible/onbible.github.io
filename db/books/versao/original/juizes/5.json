    "20": {
      "traducao_completa": "Desde os céus pelejaram; as estrelas, desde os seus cursos, pelejaram contra Sísera.",
      "palavras": [
        { "hebraico": "מִן־שָׁמַ֖יִם", "transliteral": "min-šā-ma-yim", "traducao_palavra": "desde [os] céus" },
