        { "hebraico": "בְּרַגְלָ֑יו", "transliteral": "bə-raḡ-lāw", "traducao_palavra": "a seus pés" },
        { "hebraico": "בִּפְלַגֹּ֣ות", "transliteral": "bip̄-lag-gôṯ", "traducao_palavra": "entre as facções [divisões] de" },
        { "hebraico": "רְאוּבֵ֔ן", "transliteral": "rə-ʾū-ḇēn", "traducao_palavra": "Rúben" },
        { "hebraico": "גְּדֹלִ֖ים", "transliteral": "gə-ḏō-lîm", "traducao_palavra": "grandes" },
        { "hebraico": "חִקְקֵי־לֵֽב׃", "transliteral": "ḥiq-qê-lēḇ", "traducao_palavra": "resoluções [esquadrinhamentos] de coração" }
      ]
    },
    "16": {
      "traducao_completa": "Por que ficaste tu entre as ovelhas, a ouvir as flautas dos rebanhos? Nas divisões de Rúben tiveram grandes as esquadrinhações do coração.",
      "palavras": [
        { "hebraico": "לָ֣מָּה", "transliteral": "lām-mā", "traducao_palavra": "por que" },
        { "hebraico": "יָשַׁ֗בְתָּ", "transliteral": "yā-šaḇ-tā", "traducao_palavra": "tu habitaste [ficaste firme]" },
        { "hebraico": "בֵּ֚ין", "transliteral": "bên", "traducao_palavra": "entre" },
        { "hebraico": "הַֽמִּשְׁפְּתַ֔יִם", "transliteral": "ham-miš-pə-ṯa-yim", "traducao_palavra": "os apriscos de ovelhas" },
        { "hebraico": "לִשְׁמֹ֖עַ", "transliteral": "liš-mō-aʿ", "traducao_palavra": "para ouvir" },
        { "hebraico": "שְׁרִקֹ֣ות", "transliteral": "šə-ri-qôṯ", "traducao_palavra": "os sibilos [flautas] de" },
        { "hebraico": "עֲדָרִ֑ים", "transliteral": "ʿă-ḏā-rîm", "traducao_palavra": "rebanhos" },
        { "hebraico": "לִפְלַגֹּ֣ות", "transliteral": "lip̄-lag-gôṯ", "traducao_palavra": "nas divisões de" },
        { "hebraico": "רְאוּבֵ֔ן", "transliteral": "rə-ʾū-ḇēn", "traducao_palavra": "Rúben" },
        { "hebraico": "גְּדֹולִ֖ים", "transliteral": "gə-ḏô-lîm", "traducao_palavra": "grandes" },
        { "hebraico": "חִקְרֵי־לֵֽב׃", "transliteral": "ḥiq-rê-lēḇ", "traducao_palavra": "buscas [esquadrinhações] de coração" }
      ]
    },
    "17": {
      "traducao_completa": "Gileade ficou além do Jordão; e Dã, por que se deteve nos navios? Aser se assentou no porto do mar, e ficou nas suas enseadas.",
      "palavras": [
        { "hebraico": "גִּלְעָ֗ד", "transliteral": "gil-ʿāḏ", "traducao_palavra": "Gileade" },
        { "hebraico": "בְּעֵ֤בֶר", "transliteral": "bə-ʿē-ḇer", "traducao_palavra": "além de [no lado de]" },
        { "hebraico": "הַיַּרְדֵּן֙", "transliteral": "hay-yar-dēn", "traducao_palavra": "o Jordão" },
        { "hebraico": "שָׁכֵ֔ן", "transliteral": "šā-ḵēn", "traducao_palavra": "ficou" },
        { "hebraico": "וְדָ֕ן", "transliteral": "wə-ḏān", "traducao_palavra": "e Dã" },
        { "hebraico": "לָ֥מָּה", "transliteral": "lām-mā", "traducao_palavra": "por que" },
        { "hebraico": "יָג֖וּר", "transliteral": "yā-ḡūr", "traducao_palavra": "se demorou [deter-se]" },
        { "hebraico": "אֳנִיֹּ֑ות", "transliteral": "ʾo-nî-yôṯ", "traducao_palavra": "nos navios" },
        { "hebraico": "אָשֵׁ֗ר", "transliteral": "ʾā-šēr", "traducao_palavra": "Aser" },
        { "hebraico": "יָשַׁב֙", "transliteral": "yā-šaḇ", "traducao_palavra": "assentou-se" },
        { "hebraico": "לְחֹ֣וף", "transliteral": "lə-ḥôp̄", "traducao_palavra": "ao porto de [praia]" },
        { "hebraico": "יַמִּ֔ים", "transliteral": "yam-mîm", "traducao_palavra": "mares" },
        { "hebraico": "וְעַ֥ל", "transliteral": "wə-ʿal", "traducao_palavra": "e em" },
        { "hebraico": "מִפְרָצָ֖יו", "transliteral": "mip̄-rā-ṣāw", "traducao_palavra": "suas enseadas" },
        { "hebraico": "יִשְׁכֹּֽון׃", "transliteral": "yiš-kôn", "traducao_palavra": "permaneceu" }
      ]
    },
    "18": {
      "traducao_completa": "O povo de Zebulom expôs a sua vida à morte, como também Naftali, nas alturas do campo.",
