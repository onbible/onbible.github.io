        { "hebraico": "חֵרֵ֥ף", "transliteral": "ḥê-rēp̄", "traducao_palavra": "que arriscou" },
        { "hebraico": "נַפְשֹׁ֛ו", "transliteral": "nap̄-šô", "traducao_palavra": "sua vida [alma]" },
        { "hebraico": "לָמ֖וּת", "transliteral": "lā-mūṯ", "traducao_palavra": "para a morte" },
