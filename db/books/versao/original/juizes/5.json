      ]
    },
    "14": {
      "traducao_completa": "De Efraim saiu a sua raiz contra Amaleque; e após ti vinha Benjamim dentre o teu povo; de Maquir desceram legisladores, e de Zebulom os que levam a pena do escrivão.",
      "palavras": [
