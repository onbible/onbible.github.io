        { "hebraico": "יֹשְׁבֶ֑יהָ", "transliteral": "yō-šə-ḇe-hā", "traducao_palavra": "seus moradores" },
        { "hebraico": "כִּ֤י", "transliteral": "kî", "traducao_palavra": "porque" },
