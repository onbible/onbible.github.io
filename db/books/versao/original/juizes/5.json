        { "hebraico": "עַ֖ל", "transliteral": "ʿal", "traducao_palavra": "sobre" },
        { "hebraico": "מְרֹומֵ֥י", "transliteral": "mə-rô-mê", "traducao_palavra": "as alturas de" },
