        { "hebraico": "בַּֽעֲמָמֶ֑יךָ", "transliteral": "ba-ʿă-mā-me-ḵā", "traducao_palavra": "entre teus povos" },
        { "hebraico": "מִנִּ֣י", "transliteral": "min-nî", "traducao_palavra": "de" },
        { "hebraico": "מָכִ֗יר", "transliteral": "mā-ḵîr", "traducao_palavra": "Maquir" },
        { "hebraico": "יָֽרְדוּ֙", "transliteral": "yā-rə-ḏū", "traducao_palavra": "desceram" },
        { "hebraico": "מְחֹ֣קְקִ֔ים", "transliteral": "mə-ḥō-qə-qîm", "traducao_palavra": "comandantes [legisladores]" },
