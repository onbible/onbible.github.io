        { "hebraico": "כֶּ֖סֶף", "transliteral": "ke-sep̄", "traducao_palavra": "prata" },
        { "hebraico": "לֹ֥א", "transliteral": "lō", "traducao_palavra": "não" },
        { "hebraico": "לָקָֽחוּ׃", "transliteral": "lā-qā-ḥū", "traducao_palavra": "tomaram" }
