        { "hebraico": "קִישֹׁון֙", "transliteral": "qî-šôn", "traducao_palavra": "Quisom" },
        { "hebraico": "גְּרָפָ֔ם", "transliteral": "gə-rā-p̄ām", "traducao_palavra": "os arrastou" },
        { "hebraico": "נַ֥חַל", "transliteral": "na-ḥal", "traducao_palavra": "o ribeiro de" },
        { "hebraico": "קְדוּמִ֖ים", "transliteral": "qə-ḏū-mîm", "traducao_palavra": "tempos antigos" },
