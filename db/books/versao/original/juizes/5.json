        { "hebraico": "שָׁרְשָׁם֙", "transliteral": "šā-rə-šām", "traducao_palavra": "sua raiz [os que tinham sua raiz]" },
        { "hebraico": "בַּעֲמָלֵ֔ק", "transliteral": "ba-ʿă-mā-lēq", "traducao_palavra": "em Amaleque" },
