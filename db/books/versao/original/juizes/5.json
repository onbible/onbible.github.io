        { "hebraico": "הַכֹּֽוכָבִים֙", "transliteral": "hak-kô-ḵā-ḇîm", "traducao_palavra": "as estrelas" },
        { "hebraico": "מִמְּסִלֹּותָ֔ם", "transliteral": "mim-mə-sil-lô-ṯām", "traducao_palavra": "desde as suas órbitas [cursos]" },
        { "hebraico": "נִלְחֲמ֖וּ", "transliteral": "nil-ḥă-mū", "traducao_palavra": "pelejaram" },
        { "hebraico": "עִם־סִיסְרָֽא׃", "transliteral": "ʿim-sî-sə-rā", "traducao_palavra": "com [contra] Sísera" }
      ]
    },
    "21": {
      "traducao_completa": "O ribeiro de Quisom os arrastou, aquele antigo ribeiro, o ribeiro de Quisom. Pisaste, ó minha alma, a força.",
      "palavras": [
