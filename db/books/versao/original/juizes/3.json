        { "hebraico": "הַשְּׂעִירָֽתָה׃", "transliteral": "haś-śə-ʿî-rā-ṯā", "traducao_palavra": "para Seirá" }
      ]
    },
    "27": {
      "traducao_completa": "E sucedeu que, vindo ele, tocou a trombeta no monte de Efraim; e os filhos de Israel desceram com ele do monte, e ele adiante deles.",
      "palavras": [
        { "hebraico": "וַיְהִ֣י", "transliteral": "way-hî", "traducao_palavra": "e foi" },
        { "hebraico": "בְּבֹואֹ֔ו", "transliteral": "bə-ḇô-ʾô", "traducao_palavra": "em sua vinda" },
        { "hebraico": "וַיִּתְקַ֥ע", "transliteral": "way-yit-qaʿ", "traducao_palavra": "e tocou" },
        { "hebraico": "בַּשֹּׁופָ֖ר", "transliteral": "baš-šô-p̄ār", "traducao_palavra": "a trombeta" },
