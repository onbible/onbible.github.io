        { "hebraico": "אֶפְרָ֑יִם", "transliteral": "ʾep̄-rā-yim", "traducao_palavra": "Efraim" },
        { "hebraico": "וַיֵּרְד֨וּ", "transliteral": "way-yē-rə-ḏū", "traducao_palavra": "e desceram" },
        { "hebraico": "עִמֹּ֧ו", "transliteral": "ʿim-mô", "traducao_palavra": "com ele" },
        { "hebraico": "בְנֵי־יִשְׂרָאֵ֛ל", "transliteral": "ḇə-nê-yiś-rā-ʾēl", "traducao_palavra": "filhos de Israel" },
        { "hebraico": "מִן־הָהָ֖ר", "transliteral": "min-hā-hār", "traducao_palavra": "do monte" },
        { "hebraico": "וְה֥וּא", "transliteral": "wə-hū", "traducao_palavra": "e ele" },
        { "hebraico": "לִפְנֵיהֶֽם׃", "transliteral": "lip̄-nê-hem", "traducao_palavra": "diante deles" }
