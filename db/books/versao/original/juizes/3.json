        { "hebraico": "וַיֹּ֕אמֶר", "transliteral": "way-yō-mer", "traducao_palavra": "e disse" },
        { "hebraico": "דְּבַר־סֵ֥תֶר", "transliteral": "də-ḇar-śē-ṯer", "traducao_palavra": "uma palavra secreta" },
        { "hebraico": "לִ֥י", "transliteral": "lî", "traducao_palavra": "para mim [eu tenho]" },
        { "hebraico": "אֵלֶ֖יךָ", "transliteral": "ʾē-le-ḵā", "traducao_palavra": "a ti" },
        { "hebraico": "הַמֶּ֑לֶךְ", "transliteral": "ham-me-leḵ", "traducao_palavra": "ó rei" },
        { "hebraico": "וַיֹּ֣אמֶר", "transliteral": "way-yō-mer", "traducao_palavra": "e disse" },
        { "hebraico": "הָ֔ס", "transliteral": "hās", "traducao_palavra": "silêncio [cala-te]" },
        { "hebraico": "וַיֵּצְאּוּ֙", "transliteral": "way-yē-ṣə-ʾū", "traducao_palavra": "e saíram" },
