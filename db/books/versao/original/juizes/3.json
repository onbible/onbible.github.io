        { "hebraico": "וַיִּפְתָּ֔חוּ", "transliteral": "way-yip̄-tā-ḥū", "traducao_palavra": "e abriram" },
        { "hebraico": "וְהִנֵּה֙", "transliteral": "wə-hin-nē", "traducao_palavra": "e eis" },
        { "hebraico": "אֲדֹנֵיהֶ֔ם", "transliteral": "ʾă-ḏō-nê-hem", "traducao_palavra": "seu senhor" },
