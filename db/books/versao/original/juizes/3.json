    "26": {
      "traducao_completa": "E Eúde escapou, enquanto eles esperavam; porque ele passou pelas imagens de escultura, e escapou para Seirá.",
      "palavras": [
        { "hebraico": "וְאֵה֥וּד", "transliteral": "wə-ʾē-hūḏ", "traducao_palavra": "e Eúde" },
        { "hebraico": "נִמְלַ֖ט", "transliteral": "nim-laṭ", "traducao_palavra": "escapou" },
        { "hebraico": "עַ֣ד", "transliteral": "ʿaḏ", "traducao_palavra": "até" },
        { "hebraico": "הִֽתְמַהְמְהָ֑ם", "transliteral": "hiṯ-mah-mə-hām", "traducao_palavra": "se deterem eles" },
