    "19": {
      "traducao_completa": "Porém ele voltou das imagens de escultura que estavam ao pé de Gilgal, e disse: Tenho uma palavra secreta para ti, ó rei. Este disse: Cala-te. E todos os que lhe assistiam saíram de diante dele.",
      "palavras": [
        { "hebraico": "וְה֣וּא", "transliteral": "wə-hū", "traducao_palavra": "e ele" },
        { "hebraico": "שָׁ֗ב", "transliteral": "šāḇ", "traducao_palavra": "voltou" },
        { "hebraico": "מִן־הַפְּסִילִים֙", "transliteral": "min-hap-pə-śî-lîm", "traducao_palavra": "desde as imagens de escultura" },
        { "hebraico": "אֲשֶׁ֣ר", "transliteral": "ʾă-šer", "traducao_palavra": "que" },
