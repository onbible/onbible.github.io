        { "hebraico": "נְעוּלֹ֑ות", "transliteral": "nə-ʿū-lôṯ", "traducao_palavra": "trancadas" },
        { "hebraico": "וַיֹּ֣אמְר֔וּ", "transliteral": "way-yō-mə-rū", "traducao_palavra": "e disseram" },
