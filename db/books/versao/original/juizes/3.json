        { "hebraico": "אֱלֹהֵיהֶ֔ם", "transliteral": "ʾĕ-lō-hê-hem", "traducao_palavra": "seu Deus" },
        { "hebraico": "וַיַּעַבְד֥וּ", "transliteral": "way-ya-ʿaḇ-ḏū", "traducao_palavra": "e serviram" },
        { "hebraico": "אֶת־הַבְּעָלִ֖ים", "transliteral": "ʾeṯ-hab-bə-ʿā-lîm", "traducao_palavra": "os baalins" },
        { "hebraico": "וְאֶת־הָאֲשֵׁרֹֽות׃", "transliteral": "wə-ʾeṯ-hā-ʾă-šē-rôṯ", "traducao_palavra": "e as astarotes [postes sagrados]" }
