      ]
    },
    "3": {
      "traducao_completa": "Cinco príncipes dos filisteus, e todos os cananeus, e os sidônios, e os heveus que habitavam no monte Líbano, desde o monte Baal-Hermom até à entrada de Hamate.",
      "palavras": [
