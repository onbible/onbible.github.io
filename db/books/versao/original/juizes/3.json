        { "hebraico": "וְהַצִּידֹנִ֖י", "transliteral": "wə-haṣ-ṣî-ḏō-nî", "traducao_palavra": "e o sidônio" },
        { "hebraico": "וְהַֽחִוִּ֑י", "transliteral": "wə-ha-ḥiw-wî", "traducao_palavra": "e o heveu" },
