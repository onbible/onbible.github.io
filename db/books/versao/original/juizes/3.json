        { "hebraico": "גַֽם־הַנִּצָּ֥ב", "transliteral": "ḡam-han-niṣ-ṣāḇ", "traducao_palavra": "também o cabo" },
        { "hebraico": "אַחַ֣ר", "transliteral": "ʾa-ḥar", "traducao_palavra": "após" },
        { "hebraico": "הַלַּ֗הַב", "transliteral": "hal-la-haḇ", "traducao_palavra": "a lâmina" },
        { "hebraico": "וַיִּסְגֹּ֤ר", "transliteral": "way-yis-gōr", "traducao_palavra": "e encerrou" },
        { "hebraico": "הַחֵ֨לֶב֙", "transliteral": "ha-ḥē-leḇ", "traducao_palavra": "a gordura" },
        { "hebraico": "בְּעַ֣ד", "transliteral": "bə-ʿaḏ", "traducao_palavra": "sobre" },
        { "hebraico": "הַלַּ֔הַב", "transliteral": "hal-la-haḇ", "traducao_palavra": "a lâmina" },
        { "hebraico": "כִּ֣י", "transliteral": "kî", "traducao_palavra": "porque" },
        { "hebraico": "לֹ֥א", "transliteral": "lō", "traducao_palavra": "não" },
        { "hebraico": "שָׁלַ֥ף", "transliteral": "šā-lap̄", "traducao_palavra": "tirou" },
        { "hebraico": "הַחֶ֖רֶב", "transliteral": "ha-ḥe-reḇ", "traducao_palavra": "a espada" },
        { "hebraico": "מִבִּטְנֹ֑ו", "transliteral": "mib-biṭ-nô", "traducao_palavra": "do seu ventre" },
