        { "hebraico": "וַיֵּרְד֣וּ", "transliteral": "way-yē-rə-ḏū", "traducao_palavra": "e desceram" },
        { "hebraico": "אַחֲרָ֗יו", "transliteral": "ʾa-ḥă-rāw", "traducao_palavra": "após ele" },
        { "hebraico": "וַֽיִּלְכְּד֞וּ", "transliteral": "way-yil-kə-ḏū", "traducao_palavra": "e tomaram" },
