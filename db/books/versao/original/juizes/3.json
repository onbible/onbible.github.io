        { "hebraico": "בְּיַד־מֹשֶֽׁה׃", "transliteral": "bə-yaḏ-mō-šeh", "traducao_palavra": "pela mão de Moisés" }
      ]
    },
    "5": {
      "traducao_completa": "Habitando, pois, os filhos de Israel no meio dos cananeus, dos heteus, e dos amorreus, e dos ferezeus, e dos heveus, e dos jebuseus,",
