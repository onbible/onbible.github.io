        { "hebraico": "אֶת־יַ֣ד", "transliteral": "ʾeṯ-yaḏ", "traducao_palavra": "sua mão" },
        { "hebraico": "שְׂמֹאלֹ֔ו", "transliteral": "śə-mō-lô", "traducao_palavra": "sua esquerda" },
