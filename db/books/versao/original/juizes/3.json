  "versiculos": {
    "1": {
      "traducao_completa": "Estas são as nações que o YHWH deixou para por elas provar a Israel, a todos os que não haviam conhecido todas as guerras de Canaã;",
      "palavras": [
        { "hebraico": "וְאֵ֤לֶּה", "transliteral": "wə-ʾēl-leh", "traducao_palavra": "e estas" },
        { "hebraico": "הַגֹּויִם֙", "transliteral": "hag-gō-yîm", "traducao_palavra": "as nações" },
        { "hebraico": "אֲשֶׁ֣ר", "transliteral": "ʾă-šer", "traducao_palavra": "que" },
        { "hebraico": "הִנִּ֣יחַ", "transliteral": "hin-nî-aḥ", "traducao_palavra": "deixou" },
        { "hebraico": "יְהוָ֔ה", "transliteral": "YHWH", "traducao_palavra": "YHWH" },
        { "hebraico": "לְנַסֹּ֥ות", "transliteral": "lə-nas-śôṯ", "traducao_palavra": "para provar" },
        { "hebraico": "בָּ֖ם", "transliteral": "bām", "traducao_palavra": "nelas" },
        { "hebraico": "אֶת־יִשְׂרָאֵ֑ל", "transliteral": "ʾeṯ-yiś-rā-ʾēl", "traducao_palavra": "a Israel" },
        { "hebraico": "אֵ֚ת", "transliteral": "ʾēṯ", "traducao_palavra": "a [sinal de objeto direto]" },
        { "hebraico": "כָּל־אֲשֶׁ֣ר", "transliteral": "kāl-ʾă-šer", "traducao_palavra": "todos que" },
        { "hebraico": "לֹא־יָדְע֔וּ", "transliteral": "lō-yā-ḏə-ʿū", "traducao_palavra": "não haviam conhecido" },
        { "hebraico": "אֵ֖ת", "transliteral": "ʾēṯ", "traducao_palavra": "[sinal de objeto direto]" },
        { "hebraico": "כָּל־מִלְחֲמֹ֥ות", "transliteral": "kāl-mil-ḥă-môṯ", "traducao_palavra": "todas as guerras de" },
