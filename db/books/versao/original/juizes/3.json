    },
    "10": {
      "traducao_completa": "E veio sobre ele o Espírito do YHWH, e julgou a Israel, e saiu à peleja; e o YHWH entregou na sua mão a Cusã-Risataim, rei da Mesopotâmia; e a sua mão prevaleceu contra Cusã-Risataim.",
      "palavras": [
        { "hebraico": "וַתְּהִ֨י", "transliteral": "wat-tə-hî", "traducao_palavra": "e veio a estar" },
        { "hebraico": "עָלָ֜יו", "transliteral": "ʿā-lāw", "traducao_palavra": "sobre ele" },
        { "hebraico": "ר֣וּחַ", "transliteral": "rū-aḥ", "traducao_palavra": "Espírito de" },
