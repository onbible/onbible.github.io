        { "hebraico": "יִשְׂרָאֵ֔ל", "transliteral": "yiś-rā-ʾēl", "traducao_palavra": "Israel" },
        { "hebraico": "יָשְׁב֖וּ", "transliteral": "yā-šə-ḇū", "traducao_palavra": "habitaram" },
        { "hebraico": "בְּקֶ֣רֶ", "transliteral": "bə-qe-reḇ", "traducao_palavra": "no meio de" },
