    "2": {
      "traducao_completa": "Tão-somente para que as gerações dos filhos de Israel as conhecessem, para lhes ensinar a guerra; ao menos os que dantes a não sabiam:",
      "palavras": [
        { "hebraico": "רַ֗ק", "transliteral": "raq", "traducao_palavra": "tão-somente" },
        { "hebraico": "לְמַ֙עַן֙", "transliteral": "lə-ma-ʿan", "traducao_palavra": "para que" },
        { "hebraico": "דַּ֚עַת", "transliteral": "da-ʿaṯ", "traducao_palavra": "conhecesse" },
        { "hebraico": "דֹּרֹות֙", "transliteral": "dō-rôṯ", "traducao_palavra": "gerações" },
        { "hebraico": "בְּנֵי־יִשְׂרָאֵ֔ל", "transliteral": "bə-nê-yiś-rā-ʾēl", "traducao_palavra": "filhos de Israel" },
        { "hebraico": "לְלַמְּדָ֖ם", "transliteral": "lə-lam-mə-ḏām", "traducao_palavra": "para ensiná-los" },
        { "hebraico": "מִלְחָמָ֑ה", "transliteral": "mil-ḥā-mā", "traducao_palavra": "guerra" },
        { "hebraico": "רַ֥ק", "transliteral": "raq", "traducao_palavra": "tão-somente" },
        { "hebraico": "אֲשֶׁר־לְפָנִ֖ים", "transliteral": "ʾă-šer-lə-p̄ā-nîm", "traducao_palavra": "que antes" },
        { "hebraico": "לֹ֥א", "transliteral": "lō", "traducao_palavra": "não" },
