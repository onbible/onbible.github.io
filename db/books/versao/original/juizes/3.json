        { "hebraico": "וְהִנֵּ֛ה", "transliteral": "wə-hin-nē", "traducao_palavra": "e eis" },
        { "hebraico": "דַּלְתֹ֥ות", "transliteral": "dal-ṯôṯ", "traducao_palavra": "portas de" },
