        { "hebraico": "וַיַּעַבְד֧וּ", "transliteral": "way-ya-ʿaḇ-ḏū", "traducao_palavra": "e serviram" },
        { "hebraico": "בְנֵי־יִשְׂרָאֵ֛ל", "transliteral": "ḇə-nê-yiś-rā-ʾēl", "traducao_palavra": "filhos de Israel" },
