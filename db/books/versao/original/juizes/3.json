        { "hebraico": "לִבְנֵיהֶ֑ם", "transliteral": "liḇ-nê-hem", "traducao_palavra": "aos filhos deles" },
        { "hebraico": "וַיַּעַבְד֖וּ", "transliteral": "way-ya-ʿaḇ-ḏū", "traducao_palavra": "e serviram" },
        { "hebraico": "אֶת־אֱלֹהֵיהֶֽם׃", "transliteral": "ʾeṯ-ʾĕ-lō-hê-hem", "traducao_palavra": "seus deuses" }
      ]
    },
    "7": {
      "traducao_completa": "E os filhos de Israel fizeram o que era mau aos olhos do YHWH, e se esqueceram do YHWH seu Deus; e serviram aos baalins e a Astarote.",
      "palavras": [
