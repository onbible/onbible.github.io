    "25": {
      "traducao_completa": "E esperaram até se envergonharem, porque ele não abria as portas do quarto; então tomaram a chave, e abriram, e eis seu senhor estendido morto em terra.",
      "palavras": [
        { "hebraico": "וַיָּחִ֥ילוּ", "transliteral": "way-yā-ḥî-lū", "traducao_palavra": "e esperaram" },
        { "hebraico": "עַד־בֹּ֑ושׁ", "transliteral": "ʿaḏ-bôš", "traducao_palavra": "até se envergonharem" },
        { "hebraico": "וְהִנֵּ֨ה", "transliteral": "wə-hin-nē", "traducao_palavra": "e eis" },
        { "hebraico": "אֵינֶנּ֥וּ", "transliteral": "ʾê-nen-nū", "traducao_palavra": "não [estava]" },
