        { "hebraico": "רִדְפ֣וּ", "transliteral": "riḏ-p̄ū", "traducao_palavra": "segui" },
        { "hebraico": "אַחֲרַ֔י", "transliteral": "ʾa-ḥă-ray", "traducao_palavra": "após mim" },
