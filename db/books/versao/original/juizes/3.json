      ]
    },
    "29": {
      "traducao_completa": "E naquele tempo feriram dos moabitas uns dez mil homens, todos robustos e todos homens de valor; e não escapou nenhum.",
      "palavras": [
        { "hebraico": "וַיַּכּ֨וּ", "transliteral": "way-yak-kū", "traducao_palavra": "e feriram" },
        { "hebraico": "אֶת־מֹואָ֜ב", "transliteral": "ʾeṯ-mô-ʾāḇ", "traducao_palavra": "a Moabe" },
        { "hebraico": "בָּעֵ֣ת", "transliteral": "bā-ʿēṯ", "traducao_palavra": "no tempo" },
        { "hebraico": "הַהִ֗יא", "transliteral": "ha-hî", "traducao_palavra": "aquele" },
        { "hebraico": "כַּעֲשֶׂ֨רֶת", "transliteral": "ka-ʿă-śe-reṯ", "traducao_palavra": "como dez" },
