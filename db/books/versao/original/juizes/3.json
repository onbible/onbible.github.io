        { "hebraico": "יְמִינֹ֑ו", "transliteral": "yə-mî-nô", "traducao_palavra": "sua direita" },
        { "hebraico": "וַיִּתְקָעֶ֖הָ", "transliteral": "way-yit-qā-ʿe-hā", "traducao_palavra": "e cravou [meteu] ela" },
        { "hebraico": "בְּבִטְנֹֽו׃", "transliteral": "bə-ḇiṭ-nô", "traducao_palavra": "no seu ventre" }
