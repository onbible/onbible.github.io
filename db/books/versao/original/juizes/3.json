        { "hebraico": "לָהֶ֖ם", "transliteral": "lā-hem", "traducao_palavra": "para eles" },
        { "hebraico": "לְנָשִׁ֑ים", "transliteral": "lə-nā-šîm", "traducao_palavra": "por mulheres" },
