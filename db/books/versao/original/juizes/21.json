        { "hebraico": "וְהִנֵּ֨ה", "transliteral": "wə-hin-nēh", "traducao_palavra": "e eis que" },
        { "hebraico": "אִם־יֵצְא֨וּ", "transliteral": "ʾim-yê-ṣə-ʾû", "traducao_palavra": "se saírem" },
        { "hebraico": "בְנֹות־שִׁילֹ֜ו", "transliteral": "ḇə-nôṯ-šî-lô", "traducao_palavra": "as filhas de Siló" },
        { "hebraico": "לָח֣וּל", "transliteral": "lā-ḥûl", "traducao_palavra": "para dançar" },
        { "hebraico": "בַּמְּחֹלֹ֗ות", "transliteral": "bam-mə-ḥō-lôṯ", "traducao_palavra": "em danças/rodas" },
        { "hebraico": "וִיצָאתֶם֮", "transliteral": "wî-ṣā-ṯem", "traducao_palavra": "então saireis" },
        { "hebraico": "מִן־הַכְּרָמִים֒", "transliteral": "min-hak-kə-rā-mîm", "traducao_palavra": "das vinhas" },
        { "hebraico": "וַחֲטַפְתֶּ֥ם", "transliteral": "wa-ḥă-ṭap̄-tem", "traducao_palavra": "e arrebatareis" },
        { "hebraico": "לָכֶ֛ם", "transliteral": "lā-ḵem", "traducao_palavra": "para vós" },
        { "hebraico": "אִ֥ישׁ", "transliteral": "ʾîš", "traducao_palavra": "cada um" },
