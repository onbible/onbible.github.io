        { "hebraico": "קֹולָ֔ם", "transliteral": "qô-lām", "traducao_palavra": "a voz deles" },
        { "hebraico": "וַיִּבְכּ֖וּ", "transliteral": "way-yiḇ-kû", "traducao_palavra": "e choraram" },
