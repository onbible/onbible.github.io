        { "hebraico": "אֲחֵיהֶם֮", "transliteral": "ʾă-ḥê-hem", "traducao_palavra": "seus irmãos" },
        { "hebraico": "לָרִ֣יב", "transliteral": "lā-rîḇ", "traducao_palavra": "para queixar-se" },
        { "hebraico": "אֵלֵינוּ֒", "transliteral": "ʾê-lê-nû", "traducao_palavra": "a nós" },
        { "hebraico": "וְאָמַ֤רְנוּ", "transliteral": "wə-ʾā-mar-nû", "traducao_palavra": "e diremos" },
        { "hebraico": "חָנּ֣וּנוּ", "transliteral": "ḥān-nû-nû", "traducao_palavra": "tende compaixão por nós" },
        { "hebraico": "אֹותָ֔ם", "transliteral": "ʾô-ṯām", "traducao_palavra": "deles" },
        { "hebraico": "כִּ֣י", "transliteral": "kî", "traducao_palavra": "porque" },
        { "hebraico": "לֹ֥א", "transliteral": "lō", "traducao_palavra": "não" },
        { "hebraico": "לָקַ֛חְנוּ", "transliteral": "lā-qaḥ-nû", "traducao_palavra": "tomamos" },
        { "hebraico": "אִ֥ישׁ", "transliteral": "ʾîš", "traducao_palavra": "[para] cada um" },
