    },
    "21": {
      "traducao_completa": "E olhai, e eis que, saindo as filhas de Siló a dançar em rodas, saí vós das vinhas, e arrebatai cada um sua mulher das filhas de Siló, e ide-vos para a terra de Benjamim.",
      "palavras": [
