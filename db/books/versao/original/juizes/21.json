        { "hebraico": "גָּזָ֑לוּ", "transliteral": "gā-zā-lû", "traducao_palavra": "arrebataram" },
        { "hebraico": "וַיֵּלְכ֗וּ", "transliteral": "way-yê-lə-ḵû", "traducao_palavra": "e foram-se" },
