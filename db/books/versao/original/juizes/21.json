        { "hebraico": "וַיֵּצְא֣וּ", "transliteral": "way-yê-ṣə-ʾû", "traducao_palavra": "e saíram" },
        { "hebraico": "מִשָּׁ֔ם", "transliteral": "miš-šām", "traducao_palavra": "dali" },
        { "hebraico": "אִ֖ישׁ", "transliteral": "ʾîš", "traducao_palavra": "cada um" },
        { "hebraico": "לְנַחֲלָתֹֽו׃", "transliteral": "lə-na-ḥă-lā-tô", "traducao_palavra": "para sua herança" }
