        { "hebraico": "בֵּֽית־אֵ֔ל", "transliteral": "bêṯ-ʾēl", "traducao_palavra": "à casa de Deus [Betel]" },
        { "hebraico": "וַיֵּ֣שְׁבוּ", "transliteral": "way-yê-šə-ḇû", "traducao_palavra": "e sentaram-se/ficaram" },
        { "hebraico": "שָׁ֔ם", "transliteral": "šām", "traducao_palavra": "ali" },
        { "hebraico": "עַד־", "transliteral": "ʿaḏ-", "traducao_palavra": "até" },
