        { "hebraico": "אַתֶּם֙", "transliteral": "ʾat-tem", "traducao_palavra": "vós" },
        { "hebraico": "נְתַתֶּ֣ם", "transliteral": "nə-ṯat-tem", "traducao_palavra": "destes" },
