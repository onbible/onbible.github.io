    "22": {
      "traducao_completa": "E será que, quando seus pais ou seus irmãos vierem a queixar-se a nós, nós lhes diremos: Por amor de nós tende compaixão deles, pois na guerra não tomamos mulheres para cada um deles; e vós não lhas destes, pois se o fizésseis agora, seríeis culpados.",
      "palavras": [
        { "hebraico": "וְהָיָ֡ה", "transliteral": "wə-hā-yā", "traducao_palavra": "e será" },
        { "hebraico": "כִּֽי־יָבֹ֨אוּ", "transliteral": "kî-yā-ḇō-ʾû", "traducao_palavra": "que quando vierem" },
        { "hebraico": "אֲבֹותָ֥ם ׀", "transliteral": "ʾă-ḇô-ṯām", "traducao_palavra": "seus pais" },
