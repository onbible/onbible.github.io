        { "hebraico": "מִשָּׁ֤ם", "transliteral": "miš-šām", "traducao_palavra": "dali" },
        { "hebraico": "בְּנֵֽי־יִשְׂרָאֵל֙", "transliteral": "ḇə-nê-yiś-rā-ʾēl", "traducao_palavra": "os filhos de Israel" },
