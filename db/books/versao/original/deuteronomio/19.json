        { "hebraico": "יָבֹ֨א", "transliteral": "yā-ḇō", "traducao_palavra": "entrar" },
        { "hebraico": "אֶת־רֵעֵ֥הוּ", "transliteral": "ʾeṯ-rē-ʿē-hû", "traducao_palavra": "com seu próximo" },
