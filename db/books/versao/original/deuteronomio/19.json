        { "hebraico": "אֱלֹהֶ֙יךָ֙", "transliteral": "ʾĕ-lō-he-ḵā", "traducao_palavra": "teu Deus" },
        { "hebraico": "אֶת־הַגֹּויִ֔ם", "transliteral": "ʾeṯ-hag-gô-yim", "traducao_palavra": "as nações" },
        { "hebraico": "אֲשֶׁר֙", "transliteral": "ʾă-šer", "traducao_palavra": "que" },
        { "hebraico": "יְהוָ֣ה", "transliteral": "YHWH", "traducao_palavra": "YHWH" },
