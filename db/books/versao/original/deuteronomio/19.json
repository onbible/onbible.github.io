        { "hebraico": "וָמֵ֔ת", "transliteral": "wā-mēṯ", "traducao_palavra": "e morra" },
        { "hebraico": "וְנָ֕ס", "transliteral": "wə-nās", "traducao_palavra": "e fuja" },
