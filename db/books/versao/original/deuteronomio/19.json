    "11": {
      "traducao_completa": "Mas, havendo alguém que odeia a seu próximo, e lhe arma ciladas, e se levanta contra ele, e o fere mortalmente, de sorte que morra, e se acolha a alguma destas cidades,",
      "palavras": [
        { "hebraico": "וְכִֽי־יִהְיֶ֥ה", "transliteral": "wə-ḵî-yih-yeh", "traducao_palavra": "e se houver" },
