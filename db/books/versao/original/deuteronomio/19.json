  "versiculos": {
    "1": {
      "traducao_completa": "Quando YHWH teu Deus tiver destruído as nações cuja terra YHWH teu Deus te dá, e tu as possuíres e morares nas suas cidades e nas suas casas,",
      "palavras": [
