        { "hebraico": "נֹתֵ֥ן", "transliteral": "nō-ṯên", "traducao_palavra": "dá" },
        { "hebraico": "לְךָ֖", "transliteral": "lə-ḵā", "traducao_palavra": "a ti" },
        { "hebraico": "אֶת־אַרְצָ֑ם", "transliteral": "ʾeṯ-ʾar-ṣām", "traducao_palavra": "a terra delas" },
        { "hebraico": "וִֽירִשְׁתָּ֕ם", "transliteral": "wî-riš-tām", "traducao_palavra": "e as herdares" },
        { "hebraico": "וְיָשַׁבְתָּ֥", "transliteral": "wə-yā-šaḇ-tā", "traducao_palavra": "e habitares" },
