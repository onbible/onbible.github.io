        { "hebraico": "וָחָ֑י", "transliteral": "wā-ḥāy", "traducao_palavra": "e viver" },
        { "hebraico": "אֲשֶׁ֨ר", "transliteral": "ʾă-šer", "traducao_palavra": "que" },
