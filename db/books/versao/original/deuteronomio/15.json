        { "hebraico": "וַֽיִּפְדְּךָ֖", "transliteral": "way-yip̄-də-ḵā", "traducao_palavra": "e resgatou-te" },
        { "hebraico": "יְהוָ֣ה", "transliteral": "YHWH", "traducao_palavra": "YHWH" },
        { "hebraico": "אֱלֹהֶ֑יךָ", "transliteral": "ʾĕ-lō-he-ḵā", "traducao_palavra": "teu Deus" },
