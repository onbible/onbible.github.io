        { "hebraico": "יְהוָ֧ה", "transliteral": "YHWH", "traducao_palavra": "YHWH" },
        { "hebraico": "אֱלֹהֶ֛יךָ", "transliteral": "ʾĕ-lō-he-ḵā", "traducao_palavra": "teu Deus" },
        { "hebraico": "תֹאכֲלֶ֥נּוּ", "transliteral": "tō-ḵă-len-nû", "traducao_palavra": "o comerás" },
        { "hebraico": "שָׁנָ֥ה", "transliteral": "šā-nā", "traducao_palavra": "ano" },
