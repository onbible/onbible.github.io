        { "hebraico": "כַּצְּבִ֖י", "transliteral": "kaṣ-ṣə-ḇî", "traducao_palavra": "como o corço" },
        { "hebraico": "וְכָאַיָּֽל׃", "transliteral": "wə-ḵā-ʾay-yāl", "traducao_palavra": "e o veado" }
