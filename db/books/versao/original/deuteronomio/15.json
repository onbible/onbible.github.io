      ]
    },
    "13": {
      "traducao_completa": "E, quando o despedires forro de ti, não o despedirás vazio;",
      "palavras": [
        { "hebraico": "וְכִֽי־תְשַׁלְּחֶ֥נּוּ", "transliteral": "wə-ḵî-ṯə-šal-lə-ḥen-nû", "traducao_palavra": "e quando despedires ele" },
        { "hebraico": "חָפְשִׁ֖י", "transliteral": "ḥā-p̄ə-šî", "traducao_palavra": "livre" },
        { "hebraico": "מֵֽעִמָּ֑ךְ", "transliteral": "mê-ʿim-māḵ", "traducao_palavra": "de ti" },
