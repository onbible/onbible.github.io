        { "hebraico": "מִצֹּ֣אנְךָ֔", "transliteral": "miṣ-ṣō-nə-ḵā", "traducao_palavra": "do teu rebanho" },
        { "hebraico": "וּמִֽגָּרְנְךָ֖", "transliteral": "ū-mig-gār-nə-ḵā", "traducao_palavra": "e da tua eira" },
        { "hebraico": "וּמִיִּקְבֶ֑ךָ", "transliteral": "ū-miy-yiq-ḇe-ḵā", "traducao_palavra": "e do teu lagar" },
