      "palavras": [
        { "hebraico": "כָּל־הַבְּכֹ֗ור", "transliteral": "kāl-hab-bə-ḵôr", "traducao_palavra": "todo primogênito" },
        { "hebraico": "אֲשֶׁ֨ר", "transliteral": "ʾă-šer", "traducao_palavra": "que" },
        { "hebraico": "יִוָּלֵ֤ד", "transliteral": "yiw-wā-lēḏ", "traducao_palavra": "nascer" },
        { "hebraico": "בִּבְקָרְךָ֙", "transliteral": "biḇ-qār-ə-ḵā", "traducao_palavra": "em teu gado" },
