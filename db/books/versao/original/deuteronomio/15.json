    },
    "22": {
      "traducao_completa": "Dentro das tuas portas o comerás; o imundo e o limpo o comerão juntamente, como o corço ou o veado.",
      "palavras": [
        { "hebraico": "בִּשְׁעָרֶ֖יךָ", "transliteral": "biš-ʿā-rey-ḵā", "traducao_palavra": "em tuas portas" },
        { "hebraico": "תֹּאכֲלֶ֑נּוּ", "transliteral": "tō-ḵă-len-nû", "traducao_palavra": "o comerás" },
        { "hebraico": "הַטָּמֵ֤א", "transliteral": "ha-ṭā-mē", "traducao_palavra": "o imundo" },
        { "hebraico": "וְהַטָּהֹור֙", "transliteral": "wə-ha-ṭā-hôr", "traducao_palavra": "e o limpo" },
