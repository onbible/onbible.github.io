        { "hebraico": "הַזָּכָ֖ר", "transliteral": "haz-zā-ḵār", "traducao_palavra": "o macho" },
        { "hebraico": "תַּקְדִּ֖ישׁ", "transliteral": "taq-dîš", "traducao_palavra": "santificarás" },
        { "hebraico": "לַיהוָ֣ה", "transliteral": "lay-YHWH", "traducao_palavra": "para YHWH" },
        { "hebraico": "אֱלֹהֶ֑יךָ", "transliteral": "ʾĕ-lō-he-ḵā", "traducao_palavra": "teu Deus" },
        { "hebraico": "לֹ֤א", "transliteral": "lō", "traducao_palavra": "não" },
        { "hebraico": "תַעֲבֹד֙", "transliteral": "ta-ʿă-ḇōḏ", "traducao_palavra": "trabalharás" },
        { "hebraico": "בִּבְכֹ֣ר", "transliteral": "biḇ-ḵōr", "traducao_palavra": "com primogênito de" },
