        { "hebraico": "וְנָתַתָּ֤ה", "transliteral": "wə-nā-ṯat-tā", "traducao_palavra": "e porás/passarás" },
        { "hebraico": "בְאָזְנֹו֙", "transliteral": "ḇə-ʾā-zə-nô", "traducao_palavra": "em sua orelha" },
        { "hebraico": "וּבַדֶּ֔לֶת", "transliteral": "ū-ḇad-de-leṯ", "traducao_palavra": "e na porta" },
        { "hebraico": "וְהָיָ֥ה", "transliteral": "wə-hā-yā", "traducao_palavra": "e será" },
