        { "hebraico": "אֱלֹהֶ֖יךָ", "transliteral": "ʾĕ-lō-he-ḵā", "traducao_palavra": "teu Deus" },
        { "hebraico": "תִּתֶּן־לֹֽו׃", "transliteral": "tit-ten-lô", "traducao_palavra": "darás a ele" }
      ]
