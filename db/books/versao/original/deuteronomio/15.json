      ]
    },
    "12": {
      "traducao_completa": "Quando teu irmão hebreu ou irmã hebreia se vender a ti, seis anos te servirá, mas no sétimo ano o despedirás forro de ti.",
      "palavras": [
        { "hebraico": "כִּֽי־יִמָּכֵ֨ר", "transliteral": "kî-yimmā-ḵēr", "traducao_palavra": "quando for vendido" },
        { "hebraico": "לְךָ֜", "transliteral": "lə-ḵā", "traducao_palavra": "a ti" },
        { "hebraico": "אָחִ֣יךָ", "transliteral": "ʾā-ḥî-ḵā", "traducao_palavra": "teu irmão" },
        { "hebraico": "הָעִבְרִ֗י", "transliteral": "hā-ʿiḇ-rî", "traducao_palavra": "o hebreu" },
        { "hebraico": "אֹ֚ו", "transliteral": "ʾô", "traducao_palavra": "ou" },
        { "hebraico": "הָעִבְרִיָּ֔ה", "transliteral": "hā-ʿiḇ-riy-yā", "traducao_palavra": "a hebreia" },
        { "hebraico": "וַעֲבָֽדְךָ֖", "transliteral": "wa-ʿă-ḇā-ḏə-ḵā", "traducao_palavra": "e servirá a ti" },
        { "hebraico": "שֵׁ֣שׁ", "transliteral": "šēš", "traducao_palavra": "seis" },
        { "hebraico": "שָׁנִ֑ים", "transliteral": "šā-nîm", "traducao_palavra": "anos" },
        { "hebraico": "וּבַשָּׁנָה֙", "transliteral": "ū-ḇaš-šā-nā", "traducao_palavra": "e no ano" },
        { "hebraico": "הַשְּׁבִיעִ֔ת", "transliteral": "haš-šə-ḇî-ʿîṯ", "traducao_palavra": "sétimo" },
        { "hebraico": "תְּשַׁלְּחֶ֥נּוּ", "transliteral": "tə-šal-lə-ḥen-nû", "traducao_palavra": "despedirás ele" },
