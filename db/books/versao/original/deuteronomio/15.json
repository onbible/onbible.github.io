        { "hebraico": "וְהָיָ֥ה", "transliteral": "wə-hā-yā", "traducao_palavra": "e haja" },
        { "hebraico": "בְךָ֖", "transliteral": "ḇə-ḵā", "traducao_palavra": "em ti" },
