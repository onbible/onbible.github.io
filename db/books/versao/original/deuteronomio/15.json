        { "hebraico": "אֵצֵ֖א", "transliteral": "ʾê-ṣē", "traducao_palavra": "sairei" },
        { "hebraico": "מֵעִמָּ֑ךְ", "transliteral": "mê-ʿim-māḵ", "traducao_palavra": "de ti" },
        { "hebraico": "כִּ֤י", "transliteral": "kî", "traducao_palavra": "porque" },
        { "hebraico": "אֲהֵֽבְךָ֙", "transliteral": "ʾă-hê-ḇə-ḵā", "traducao_palavra": "ama-te" },
