        { "hebraico": "פָּ֠תֹחַ", "transliteral": "pā-ṯō-aḥ", "traducao_palavra": "abrindo" },
        { "hebraico": "תִּפְתַּ֨ח", "transliteral": "tip̄-taḥ", "traducao_palavra": "abrirás" },
        { "hebraico": "אֶת־יָדְךָ֧", "transliteral": "ʾeṯ-yā-ḏə-ḵā", "traducao_palavra": "tua mão" },
        { "hebraico": "לְאָחִ֛יךָ", "transliteral": "lə-ʾā-ḥî-ḵā", "traducao_palavra": "para teu irmão" },
