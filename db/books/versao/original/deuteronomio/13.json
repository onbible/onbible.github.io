        { "hebraico": "הַזֹּּאת", "transliteral": "haz-zōṯ", "traducao_palavra": "esta" },
        { "hebraico": "בְּקִרְבֶּֽךָ׃", "transliteral": "bə-qir-be-ḵā", "traducao_palavra": "no teu meio" }
