        { "hebraico": "אַפֹּ֗ו", "transliteral": "ʾap-pô", "traducao_palavra": "sua ira" },
        { "hebraico": "וְנָֽתַן־לְךָ֥", "transliteral": "wə-nā-ṯan-lə-ḵā", "traducao_palavra": "e te dê/faça" },
        { "hebraico": "רַחֲמִ֛ים", "transliteral": "ra-ḥă-mîm", "traducao_palavra": "misericórdia" },
        { "hebraico": "וְרִֽחַמְךָ֥", "transliteral": "wə-ri-ḥam-ḵā", "traducao_palavra": "e tenha piedade de ti" },
