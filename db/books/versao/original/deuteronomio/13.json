    "17": {
      "traducao_completa": "E nada do anátema se pegará à tua mão, para que YHWH se aparte do ardor da sua ira, e te faça misericórdia, e tenha piedade de ti, e te multiplique, como jurou a teus pais,",
      "palavras": [
        { "hebraico": "וְלֹֽא־יִדְבַּ֨ק", "transliteral": "wə-lō-yiḏ-baq", "traducao_palavra": "e não se pegará" },
        { "hebraico": "בְּיָדְךָ֤", "transliteral": "bə-yā-ḏə-ḵā", "traducao_palavra": "à tua mão" },
