        { "hebraico": "וְנָתַ֥ן", "transliteral": "wə-nā-ṯan", "traducao_palavra": "e te der/puser" },
        { "hebraico": "אֵלֶ֛יךָ", "transliteral": "ʾē-le-ḵā", "traducao_palavra": "a ti" },
