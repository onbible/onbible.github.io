    "8": {
      "traducao_completa": "Sê misericordioso para com o teu povo Israel, que tu resgataste, ó YHWH, e não ponhas o sangue inocente no meio do teu povo Israel. E aquela culpa do sangue lhes será perdoada.",
      "palavras": [
        { "hebraico": "כַּפֵּר֩", "transliteral": "kap-pēr", "traducao_palavra": "expia/perdoa" },
        { "hebraico": "לְעַמְּךָ֨", "transliteral": "lə-ʿam-mə-ḵā", "traducao_palavra": "teu povo" },
        { "hebraico": "יִשְׂרָאֵ֜ל", "transliteral": "yiś-rā-ʾēl", "traducao_palavra": "Israel" },
