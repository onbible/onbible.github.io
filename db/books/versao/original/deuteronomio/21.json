        { "hebraico": "אֵיתָ֔ן", "transliteral": "ʾê-ṯān", "traducao_palavra": "perene/áspero" },
        { "hebraico": "אֲשֶׁר֙", "transliteral": "ʾă-šer", "traducao_palavra": "que" },
