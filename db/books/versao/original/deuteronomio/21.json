    "11": {
      "traducao_completa": "E tu vires entre os cativos uma mulher formosa à vista, e a desejares, e a quiseres tomar por mulher,",
      "palavras": [
        { "hebraico": "וְרָאִיתָ֙", "transliteral": "wə-rā-ʾî-ṯā", "traducao_palavra": "e vires" },
        { "hebraico": "בַּשִּׁבְיָ֔ה", "transliteral": "baš-šiḇ-yā", "traducao_palavra": "no cativeiro" },
        { "hebraico": "אֵ֖שֶׁת", "transliteral": "ʾē-šeṯ", "traducao_palavra": "mulher de" },
        { "hebraico": "יְפַת־תֹּ֑אַר", "transliteral": "yə-p̄aṯ-tō-ʾar", "traducao_palavra": "bela forma" },
        { "hebraico": "וְחָשַׁקְתָּ֣", "transliteral": "wə-ḥā-šaq-tā", "traducao_palavra": "e a desejares" },
        { "hebraico": "בָ֔הּ", "transliteral": "ḇāh", "traducao_palavra": " nela" },
        { "hebraico": "וְלָקַחְתָּ֥", "transliteral": "wə-lā-qaḥ-tā", "traducao_palavra": "e tomares" },
        { "hebraico": "לְךָ֖", "transliteral": "lə-ḵā", "traducao_palavra": "para ti" },
        { "hebraico": "לְאִשָּֽׁה׃", "transliteral": "lə-ʾiš-šā", "traducao_palavra": "por mulher" }
      ]
    },
    "12": {
      "traducao_completa": "Então a trarás para dentro da tua casa; e ela rapará a sua cabeça e cortará as suas unhas,",
      "palavras": [
        { "hebraico": "וַהֲבֵאתָ֖הּ", "transliteral": "wa-hă-ḇê-ṯāh", "traducao_palavra": "e a trarás" },
        { "hebraico": "אֶל־תֹּ֣וךְ", "transliteral": "ʾel-tôḵ", "traducao_palavra": "para o meio de" },
        { "hebraico": "בֵּיתֶ֑ךָ", "transliteral": "bê-ṯe-ḵā", "traducao_palavra": "tua casa" },
        { "hebraico": "וְגִלְּחָה֙", "transliteral": "wə-ḡil-lə-ḥā", "traducao_palavra": "e rapará" },
        { "hebraico": "אֶת־רֹאשָׁ֔הּ", "transliteral": "ʾeṯ-rō-šāh", "traducao_palavra": "a sua cabeça" },
        { "hebraico": "וְעָשְׂתָה֙", "transliteral": "wə-ʿā-śə-ṯā", "traducao_palavra": "e fará/tratará" },
        { "hebraico": "אֶת־צִפָּרְנֶֽיהָ׃", "transliteral": "ʾeṯ-ṣip-pār-ney-hā", "traducao_palavra": "as unhas dela" }
      ]
    },
    "13": {
      "traducao_completa": "E despirá o vestido do seu cativeiro, e se assentará na tua casa, e chorará a seu pai e a sua mãe um mês inteiro; e depois chegarás a ela, e tu serás seu marido, e ela tua mulher.",
      "palavras": [
        { "hebraico": "וְהֵסִירָה֩", "transliteral": "wə-hê-śî-rā", "traducao_palavra": "e removerá" },
        { "hebraico": "אֶת־שִׂמְלַ֨ת", "transliteral": "ʾeṯ-śim-laṯ", "traducao_palavra": "a roupa de" },
        { "hebraico": "שִׁבְיָהּ֮", "transliteral": "šiḇ-yāh", "traducao_palavra": "seu cativeiro" },
        { "hebraico": "מֵעָלֶיהָ֒", "transliteral": "mê-ʿā-ley-hā", "traducao_palavra": "de sobre ela" },
        { "hebraico": "וְיָשְׁבָה֙", "transliteral": "wə-yā-šə-ḇā", "traducao_palavra": "e habitará" },
        { "hebraico": "בְּבֵיתֶ֔ךָ", "transliteral": "bə-ḇê-ṯe-ḵā", "traducao_palavra": "em tua casa" },
        { "hebraico": "וּבָכְתָה֙", "transliteral": "ū-ḇā-ḵə-ṯā", "traducao_palavra": "e chorará por" },
        { "hebraico": "אֶת־אָבִ֣יהָ", "transliteral": "ʾeṯ-ʾā-ḇî-hā", "traducao_palavra": "seu pai" },
        { "hebraico": "וְאֶת־אִמָּ֔הּ", "transliteral": "wə-ʾeṯ-ʾim-māh", "traducao_palavra": "e sua mãe" },
        { "hebraico": "יֶ֖רַח", "transliteral": "ye-raḥ", "traducao_palavra": "um mês de" },
        { "hebraico": "יָמִ֑ים", "transliteral": "yā-mîm", "traducao_palavra": "dias" },
        { "hebraico": "וְאַחַר־כֵּן֙", "transliteral": "wə-ʾa-ḥar-kên", "traducao_palavra": "e depois de assim" },
        { "hebraico": "תָּבֹ֣וא", "transliteral": "tā-ḇô", "traducao_palavra": "chegarás" },
        { "hebraico": "אֵלֶיהָ", "transliteral": "ʾē-ley-hā", "traducao_palavra": "a ela" },
        { "hebraico": "וּבְעַלְתָּ֔הּ", "transliteral": "ū-ḇə-ʿal-tāh", "traducao_palavra": "e serás marido dela" },
        { "hebraico": "וְהָיְתָ֥ה", "transliteral": "wə-hā-yə-ṯā", "traducao_palavra": "e ela será" },
        { "hebraico": "לְךָ֖", "transliteral": "lə-ḵā", "traducao_palavra": "tua" },
        { "hebraico": "לְאִשָּֽׁה׃", "transliteral": "lə-ʾiš-šā", "traducao_palavra": "por mulher" }
      ]
    },
    "14": {
      "traducao_completa": "E será que, se não te agradares dela, a deixarás ir à sua vontade; mas de modo nenhum a venderás por dinheiro, nem a tratarás como escrava, pois a humilhaste.",
      "palavras": [
        { "hebraico": "וְהָיָה֩", "transliteral": "wə-hā-yā", "traducao_palavra": "e será [que]" },
        { "hebraico": "אִם־לֹ֨א", "transliteral": "ʾim-lō", "traducao_palavra": "se não" },
        { "hebraico": "חָפַ֜צְתָּ", "transliteral": "ḥā-p̄aṣ-tā", "traducao_palavra": "agradares" },
        { "hebraico": "בָּ֗הּ", "transliteral": "bāh", "traducao_palavra": "nela" },
        { "hebraico": "וְשִׁלַּחְתָּהּ֙", "transliteral": "wə-šil-laḥ-tāh", "traducao_palavra": "então a deixarás" },
        { "hebraico": "לְנַפְשָׁ֔הּ", "transliteral": "lə-nap̄-šāh", "traducao_palavra": "pela sua vontade/alma" },
        { "hebraico": "וּמָכֹ֥ר", "transliteral": "ū-mā-ḵōr", "traducao_palavra": "vender" },
        { "hebraico": "לֹא־תִמְכְּרֶ֖נָּה", "transliteral": "lō-ṯim-kə-ren-nā", "traducao_palavra": "não a venderás" },
        { "hebraico": "בַּכָּ֑סֶף", "transliteral": "bak-kā-sep̄", "traducao_palavra": "por dinheiro" },
        { "hebraico": "לֹא־תִתְעַמֵּ֣ר", "transliteral": "lō-ṯiṯ-ʿam-mēr", "traducao_palavra": "não a tratarás como escrava/mercadoria" },
        { "hebraico": "בָּ֔הּ", "transliteral": "bāh", "traducao_palavra": " nela" },
        { "hebraico": "תַּ֖חַת", "transliteral": "ta-ḥaṯ", "traducao_palavra": "visto que" },
        { "hebraico": "אֲשֶׁ֥ר", "transliteral": "ʾă-šer", "traducao_palavra": "[que]" },
        { "hebraico": "עִנִּיתָֽהּ׃", "transliteral": "ʿin-nî-ṯāh", "traducao_palavra": "a humilhaste" }
      ]
    },
    "15": {
      "traducao_completa": "Quando um homem tiver duas mulheres, uma a quem ama e outra a quem odeia, e a amada e a odiada lhe derem filhos, e o filho primogênito for da odiada,",
      "palavras": [
        { "hebraico": "כִּֽי־תִהְיֶ֨יןָ", "transliteral": "kî-ṯih-yê-nā", "traducao_palavra": "quando houver" },
        { "hebraico": "לְאִ֜ישׁ", "transliteral": "lə-ʾîš", "traducao_palavra": "a um homem" },
        { "hebraico": "שְׁתֵּ֣י", "transliteral": "šə-tê", "traducao_palavra": "duas" },
        { "hebraico": "נָשִׁ֗ים", "transliteral": "nā-šîm", "traducao_palavra": "mulheres" },
        { "hebraico": "הָאַחַ֤ת", "transliteral": "hā-ʾa-ḥaṯ", "traducao_palavra": "uma" },
        { "hebraico": "אֲהוּבָה֙", "transliteral": "ʾă-hû-ḇā", "traducao_palavra": "amada" },
        { "hebraico": "וְהָאַחַ֣ת", "transliteral": "wə-hā-ʾa-ḥaṯ", "traducao_palavra": "e a outra" },
        { "hebraico": "שְׂנוּאָ֔ה", "transliteral": "śə-nû-ʾā", "traducao_palavra": "odiada" },
        { "hebraico": "וְיָֽלְדוּ־לֹ֣ו", "transliteral": "wə-yā-lə-ḏû-lô", "traducao_palavra": "e derem filhos a ele" },
        { "hebraico": "בָנִ֔ים", "transliteral": "ḇā-nîm", "traducao_palavra": "filhos" },
        { "hebraico": "הָאֲהוּבָ֖ה", "transliteral": "hā-ʾă-hû-ḇā", "traducao_palavra": "a amada" },
        { "hebraico": "וְהַשְּׂנוּאָ֑ה", "transliteral": "wə-haś-śə-nû-ʾā", "traducao_palavra": "e a odiada" },
        { "hebraico": "וְהָיָה֙", "transliteral": "wə-hā-yā", "traducao_palavra": "e se for" },
        { "hebraico": "הַבֵּ֣ן", "transliteral": "hab-bên", "traducao_palavra": "o filho" },
        { "hebraico": "הַבְּכֹ֔ור", "transliteral": "hab-bə-ḵôr", "traducao_palavra": "primogênito" },
        { "hebraico": "לַשְּׂנִיאָֽה׃", "transliteral": "laś-śə-nî-ʾā", "traducao_palavra": "da odiada" }
      ]
    },
    "16": {
      "traducao_completa": "Será que, no dia em que fizer herdar a seus filhos o que tiver, não poderá dar a primogenitura ao filho da amada, preferindo-o ao filho da odiada, que é o primogênito.",
      "palavras": [
        { "hebraico": "וְהָיָ֗ה", "transliteral": "wə-hā-yā", "traducao_palavra": "e será [que]" },
        { "hebraico": "בְּיֹום֙", "transliteral": "bə-yôm", "traducao_palavra": "no dia de" },
        { "hebraico": "הַנְחִילֹ֣ו", "transliteral": "han-ḥî-lô", "traducao_palavra": "fazer ele herdar" },
        { "hebraico": "אֶת־בָּנָ֔יו", "transliteral": "ʾeṯ-bā-nāyw", "traducao_palavra": "seus filhos" },
        { "hebraico": "אֵ֥ת", "transliteral": "ʾêṯ", "traducao_palavra": "[objeto]" },
        { "hebraico": "אֲשֶׁר־יִהְיֶ֖ה", "transliteral": "ʾă-šer-yih-yeh", "traducao_palavra": "o que tiver" },
        { "hebraico": "לֹ֑ו", "transliteral": "lô", "traducao_palavra": "ele" },
        { "hebraico": "לֹ֣א", "transliteral": "lō", "traducao_palavra": "não" },
        { "hebraico": "יוּכַ֗ל", "transliteral": "yû-ḵal", "traducao_palavra": "poderá" },
        { "hebraico": "לְבַכֵּר֙", "transliteral": "lə-ḇak-kēr", "traducao_palavra": "tratar como primogênito" },
        { "hebraico": "אֶת־בֶּן־הָאֲהוּבָ֔ה", "transliteral": "ʾeṯ-ben-hā-ʾă-hû-ḇā", "traducao_palavra": "o filho da amada" },
        { "hebraico": "עַל־פְּנֵ֥י", "transliteral": "ʿal-pə-nê", "traducao_palavra": "em face de" },
        { "hebraico": "בֶן־הַשְּׂנוּאָ֖ה", "transliteral": "ben-haś-śə-nû-ʾā", "traducao_palavra": "filho da odiada" },
        { "hebraico": "הַבְּכֹֽר׃", "transliteral": "hab-bə-ḵōr", "traducao_palavra": "[que é] o primogênito" }
      ]
    },
    "17": {
      "traducao_completa": "Mas ao filho da odiada reconhecerá por primogênito, dando-lhe dobrada porção de tudo quanto tiver; porquanto ele é o princípio da sua força, o direito da primogenitura é dele.",
      "palavras": [
        { "hebraico": "כִּ֠י", "transliteral": "kî", "traducao_palavra": "mas" },
        { "hebraico": "אֶת־הַבְּכֹ֨ר", "transliteral": "ʾeṯ-hab-bə-ḵōr", "traducao_palavra": "o primogênito" },
        { "hebraico": "בֶּן־הַשְּׂנוּאָ֜ה", "transliteral": "ben-haś-śə-nû-ʾā", "traducao_palavra": "filho da odiada" },
        { "hebraico": "יַכִּ֗יר", "transliteral": "yak-kîr", "traducao_palavra": "reconhecerá" },
        { "hebraico": "לָ֤תֶת", "transliteral": "lā-ṯeṯ", "traducao_palavra": "para dar" },
        { "hebraico": "לֹו֙", "transliteral": "lô", "traducao_palavra": "a ele" },
        { "hebraico": "פִּ֣י", "transliteral": "pî", "traducao_palavra": "porção de" },
        { "hebraico": "שְׁנַ֔יִם", "transliteral": "šə-na-yim", "traducao_palavra": "dois [dobrada]" },
        { "hebraico": "בְּכֹ֥ל", "transliteral": "bə-ḵōl", "traducao_palavra": "em tudo" },
        { "hebraico": "אֲשֶׁר־יִמָּצֵ֖א", "transliteral": "ʾă-šer-yimmā-ṣē", "traducao_palavra": "que se achar" },
        { "hebraico": "לֹ֑ו", "transliteral": "lô", "traducao_palavra": "lhe/com ele" },
        { "hebraico": "כִּי־הוּא֙", "transliteral": "kî-hû", "traducao_palavra": "pois ele [é]" },
        { "hebraico": "רֵאשִׁ֣ית", "transliteral": "rē-šîṯ", "traducao_palavra": "o princípio de" },
        { "hebraico": "אֹנֹ֔ו", "transliteral": "ʾō-nô", "traducao_palavra": "sua força/vigor" },
        { "hebraico": "לֹ֖ו", "transliteral": "lô", "traducao_palavra": "dele [é]" },
        { "hebraico": "מִשְׁפַּ֥ט", "transliteral": "miš-paṭ", "traducao_palavra": "o direito de" },
        { "hebraico": "הַבְּכֹרָֽה׃", "transliteral": "hab-bə-ḵō-rā", "traducao_palavra": "primogenitura" }
      ]
    },
    "18": {
      "traducao_completa": "Quando alguém tiver um filho contumaz e rebelde, que não obedeça à voz de seu pai nem à voz de sua mãe, e, castigando-o eles, lhes não dê ouvidos,",
      "palavras": [
        { "hebraico": "כִּֽי־יִהְיֶ֣ה", "transliteral": "kî-yih-yeh", "traducao_palavra": "quando houver" },
        { "hebraico": "לְאִ֗ישׁ", "transliteral": "lə-ʾîš", "traducao_palavra": "a um homem" },
        { "hebraico": "בֵּ֚ן", "transliteral": "bên", "traducao_palavra": "filho" },
        { "hebraico": "סֹורֵ֣ר", "transliteral": "śô-rēr", "traducao_palavra": "contumaz/obstinado" },
        { "hebraico": "וּמֹורֶ֔ה", "transliteral": "ū-mô-reh", "traducao_palavra": "e rebelde" },
        { "hebraico": "אֵינֶ֣נּוּ", "transliteral": "ʾê-nen-nû", "traducao_palavra": "[que] não" },
        { "hebraico": "שֹׁמֵ֔עַ", "transliteral": "šō-mê-aʿ", "traducao_palavra": "ouve/obedece" },
        { "hebraico": "בְּקֹ֥ול", "transliteral": "bə-qôl", "traducao_palavra": "à voz de" },
        { "hebraico": "אָבִ֖יו", "transliteral": "ʾā-ḇîw", "traducao_palavra": "seu pai" },
        { "hebraico": "וּבְקֹ֣ול", "transliteral": "ū-ḇə-qôl", "traducao_palavra": "e à voz de" },
        { "hebraico": "אִמֹּ֑ו", "transliteral": "ʾim-mô", "traducao_palavra": "sua mãe" },
        { "hebraico": "וְיִסְּר֣וּ", "transliteral": "wə-yis-śə-rû", "traducao_palavra": "e o castigarem" },
        { "hebraico": "אֹתֹ֔ו", "transliteral": "ʾō-ṯô", "traducao_palavra": "ele" },
        { "hebraico": "וְלֹ֥א", "transliteral": "wə-lō", "traducao_palavra": "e não" },
        { "hebraico": "יִשְׁמַ֖ע", "transliteral": "yiš-maʿ", "traducao_palavra": "ouvir" },
        { "hebraico": "אֲלֵיהֶֽם׃", "transliteral": "ʾă-lê-hem", "traducao_palavra": "a eles" }
      ]
    },
    "19": {
      "traducao_completa": "Então seu pai e sua mãe pegarão nele, e o levarão aos anciãos da sua cidade, e à porta do seu lugar;",
      "palavras": [
        { "hebraico": "וְתָ֥פְשׂוּ", "transliteral": "wə-ṯā-p̄ə-śû", "traducao_palavra": "e pegarão" },
        { "hebraico": "בֹ֖ו", "transliteral": "bô", "traducao_palavra": "nele" },
        { "hebraico": "אָבִ֣יו", "transliteral": "ʾā-ḇîw", "traducao_palavra": "seu pai" },
        { "hebraico": "וְאִמֹּ֑ו", "transliteral": "wə-ʾim-mô", "traducao_palavra": "e sua mãe" },
        { "hebraico": "וְהֹוצִ֧יאוּ", "transliteral": "wə-hô-ṣî-ʾû", "traducao_palavra": "e levarão" },
        { "hebraico": "אֹתֹ֛ו", "transliteral": "ʾō-ṯô", "traducao_palavra": "ele" },
        { "hebraico": "אֶל־זִקְנֵ֥י", "transliteral": "ʾel-ziq-nê", "traducao_palavra": "aos anciãos de" },
        { "hebraico": "עִירֹ֖ו", "transliteral": "ʿî-rô", "traducao_palavra": "sua cidade" },
        { "hebraico": "וְאֶל־שַׁ֥עַר", "transliteral": "wə-ʾel-ša-ʿar", "traducao_palavra": "e à porta de" },
        { "hebraico": "מְקֹמֹֽו׃", "transliteral": "mə-qō-mô", "traducao_palavra": "seu lugar" }
      ]
    },
    "20": {
      "traducao_completa": "E dirão aos anciãos da sua cidade: Este nosso filho é contumaz e rebelde, não dá ouvidos à nossa voz; é um comilão e um beberrão.",
      "palavras": [
        { "hebraico": "וְאָמְר֞וּ", "transliteral": "wə-ʾā-mə-rû", "traducao_palavra": "e dirão" },
        { "hebraico": "אֶל־זִקְנֵ֣י", "transliteral": "ʾel-ziq-nê", "traducao_palavra": "aos anciãos de" },
        { "hebraico": "עִירֹו֒", "transliteral": "ʿî-rô", "traducao_palavra": "sua cidade" },
        { "hebraico": "בְּנֵ֤נוּ", "transliteral": "bə-nê-nū", "traducao_palavra": "nosso filho" },
        { "hebraico": "זֶה֙", "transliteral": "zeh", "traducao_palavra": "este" },
        { "hebraico": "סֹורֵ֣ר", "transliteral": "śô-rēr", "traducao_palavra": "contumaz" },
