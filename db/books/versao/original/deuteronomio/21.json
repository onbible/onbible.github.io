        { "hebraico": "הָעִ֤יר", "transliteral": "hā-ʿîr", "traducao_palavra": "a cidade" },
        { "hebraico": "הַהִוא֙", "transliteral": "ha-hî", "traducao_palavra": "aquela" },
        { "hebraico": "עֶגְלַ֣ת", "transliteral": "ʿeḡ-laṯ", "traducao_palavra": "uma novilha de" },
        { "hebraico": "בָּקָ֔ר", "transliteral": "bā-qār", "traducao_palavra": "gado/manada" },
        { "hebraico": "אֲשֶׁ֤ר", "transliteral": "ʾă-šer", "traducao_palavra": "que" },
        { "hebraico": "לֹא־עֻבַּ֣ד", "transliteral": "lō-ʿub-baḏ", "traducao_palavra": "não foi trabalhada" },
        { "hebraico": "בָּ֔הּ", "transliteral": "bāh", "traducao_palavra": "com ela" },
        { "hebraico": "אֲשֶׁ֥ר", "transliteral": "ʾă-šer", "traducao_palavra": "que" },
        { "hebraico": "לֹא־מָשְׁכָ֖ה", "transliteral": "lō-mā-šə-ḵā", "traducao_palavra": "não puxou" },
        { "hebraico": "בְּעֹֽל׃", "transliteral": "bə-ʿōl", "traducao_palavra": "em jugo" }
      ]
    },
    "4": {
      "traducao_completa": "E os anciãos daquela cidade levarão a novilha a um vale áspero, que não se lavrou nem semeou; e ali degolarão a novilha no vale.",
