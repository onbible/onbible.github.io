        { "hebraico": "בְּשֵׁ֣ם", "transliteral": "bə-šēm", "traducao_palavra": "no nome de" },
        { "hebraico": "יְהוָ֔ה", "transliteral": "YHWH", "traducao_palavra": "YHWH" },
        { "hebraico": "וְעַל־פִּיהֶם֙", "transliteral": "wə-ʿal-pî-hem", "traducao_palavra": "e conforme a boca deles" },
