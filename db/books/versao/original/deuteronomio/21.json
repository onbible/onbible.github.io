{
  "livro": "Deuteronômio - דְּבָרִים - Devarim",
  "capítulo": 21,
  "titulos": {},
  "versiculos": {
    "1": {
      "traducao_completa": "Se na terra que YHWH teu Deus te dá para a possuíres, for achado algum morto caído no campo, sem que se saiba quem o matou,",
      "palavras": [
        { "hebraico": "כִּ֚י", "transliteral": "kî", "traducao_palavra": "quando/se" },
        { "hebraico": "יִמָּצֵ֣א", "transliteral": "yimmā-ṣē", "traducao_palavra": "for achado" },
        { "hebraico": "חָלָ֔ל", "transliteral": "ḥā-lāl", "traducao_palavra": "morto/ferido" },
        { "hebraico": "בָּאֲדָמָ֕ה", "transliteral": "bā-ʾă-ḏā-mā", "traducao_palavra": "na terra" },
        { "hebraico": "אֲשֶׁ֤ר", "transliteral": "ʾă-šer", "traducao_palavra": "que" },
        { "hebraico": "יְהוָ֣ה", "transliteral": "YHWH", "traducao_palavra": "YHWH" },
        { "hebraico": "אֱלֹהֶ֔יךָ", "transliteral": "ʾĕ-lō-he-ḵā", "traducao_palavra": "teu Deus" },
        { "hebraico": "נֹתֵ֥ן", "transliteral": "nō-ṯên", "traducao_palavra": "dá" },
        { "hebraico": "לְךָ֖", "transliteral": "lə-ḵā", "traducao_palavra": "a ti" },
        { "hebraico": "לְרִשְׁתָּ֑הּ", "transliteral": "lə-riš-tāh", "traducao_palavra": "para possuí-la" },
        { "hebraico": "נֹפֵ֖ל", "transliteral": "nō-p̄ēl", "traducao_palavra": "caído" },
        { "hebraico": "בַּשָּׂדֶ֑ה", "transliteral": "baś-śā-ḏeh", "traducao_palavra": "no campo" },
        { "hebraico": "לֹ֥א", "transliteral": "lō", "traducao_palavra": "não" },
        { "hebraico": "נֹודַ֖ע", "transliteral": "nô-ḏaʿ", "traducao_palavra": "se souber/for conhecido" },
        { "hebraico": "מִ֥י", "transliteral": "mî", "traducao_palavra": "quem" },
        { "hebraico": "הִכָּֽהוּ׃", "transliteral": "hik-kā-hû", "traducao_palavra": "o matou/feriu" }
      ]
    },
    "2": {
      "traducao_completa": "Então sairão os teus anciãos e os teus juízes, e medirão a distância até as cidades que estiverem ao redor do morto.",
      "palavras": [
        { "hebraico": "וְיָצְא֥וּ", "transliteral": "wə-yā-ṣə-ʾû", "traducao_palavra": "então sairão" },
        { "hebraico": "זְקֵנֶ֖יךָ", "transliteral": "zə-qē-ney-ḵā", "traducao_palavra": "teus anciãos" },
        { "hebraico": "וְשֹׁפְטֶ֑יךָ", "transliteral": "wə-šō-p̄ə-ṭey-ḵā", "traducao_palavra": "e teus juízes" },
        { "hebraico": "וּמָדְד֕וּ", "transliteral": "ū-mā-ḏə-ḏû", "traducao_palavra": "e medirão" },
        { "hebraico": "אֶל־הֶעָרִ֖ים", "transliteral": "ʾel-he-ʿā-rîm", "traducao_palavra": "até as cidades" },
        { "hebraico": "אֲשֶׁ֥ר", "transliteral": "ʾă-šer", "traducao_palavra": "que" },
        { "hebraico": "סְבִיבֹ֥ת", "transliteral": "śə-ḇî-ḇōṯ", "traducao_palavra": "ao redor de" },
        { "hebraico": "הֶחָלָֽל׃", "transliteral": "he-ḥā-lāl", "traducao_palavra": "o morto" }
      ]
    },
    "3": {
      "traducao_completa": "E será que a cidade mais próxima do morto, os anciãos daquela cidade tomarão uma novilha da manada, que não tenha trabalhado nem puxado sob o jugo;",
