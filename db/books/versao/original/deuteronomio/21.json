        { "hebraico": "כָּל־אַנְשֵׁ֨י", "transliteral": "kāl-ʾan-šê", "traducao_palavra": "todos homens de" },
        { "hebraico": "עִירֹ֤ו", "transliteral": "ʿî-rô", "traducao_palavra": "sua cidade" },
