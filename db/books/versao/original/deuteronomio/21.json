        { "hebraico": "יְהוָ֗ה", "transliteral": "YHWH", "traducao_palavra": "YHWH" },
        { "hebraico": "וְאַל־תִּתֵּן֙", "transliteral": "wə-ʾal-tit-tên", "traducao_palavra": "e não ponhas" },
