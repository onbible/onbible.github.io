        { "hebraico": "עַמְּךָ֣", "transliteral": "ʿam-mə-ḵā", "traducao_palavra": "teu povo" },
        { "hebraico": "יִשְׂרָאֵ֑ל", "transliteral": "yiś-rā-ʾēl", "traducao_palavra": "Israel" },
        { "hebraico": "וְנִכַּפֵּ֥ר", "transliteral": "wə-nik-kap-pēr", "traducao_palavra": "e será expiado" },
