        { "hebraico": "בַנָּֽחַל׃", "transliteral": "ban-nā-ḥal", "traducao_palavra": "no vale" }
      ]
    },
    "7": {
      "traducao_completa": "E responderão, e dirão: As nossas mãos não derramaram este sangue, nem os nossos olhos o viram.",
      "palavras": [
        { "hebraico": "וְעָנ֖וּ", "transliteral": "wə-ʿā-nû", "traducao_palavra": "e responderão" },
        { "hebraico": "וְאָמְר֑וּ", "transliteral": "wə-ʾā-mə-rû", "traducao_palavra": "e dirão" },
