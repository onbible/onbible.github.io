    "5": {
      "traducao_completa": "Então se achegarão os sacerdotes, filhos de Levi; pois YHWH teu Deus os escolheu para o servirem, e para abençoarem em nome de YHWH; e por sua palavra se decidirá toda a demanda e toda a ferida;",
      "palavras": [
        { "hebraico": "וְנִגְּשׁ֣וּ", "transliteral": "wə-nig-gə-šû", "traducao_palavra": "e se aproximarão" },
        { "hebraico": "הַכֹּהֲנִים֮", "transliteral": "hak-kō-hă-nîm", "traducao_palavra": "os sacerdotes" },
        { "hebraico": "בְּנֵ֣י", "transliteral": "bə-nê", "traducao_palavra": "filhos de" },
        { "hebraico": "לֵוִי֒", "transliteral": "lê-wî", "traducao_palavra": "Levi" },
        { "hebraico": "כִּ֣י", "transliteral": "kî", "traducao_palavra": "pois" },
