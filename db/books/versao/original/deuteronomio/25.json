{
  "livro": "Deuteronômio - דְּבָרִים - Devarim",
  "capítulo": 25,
  "titulos": {},
  "versiculos": {
    "1": {
      "traducao_completa": "Quando houver contenda entre alguns homens, e vierem a juízo para que os julguem, justificarão ao justo e condenarão ao ímpio.",
      "palavras": [
        { "hebraico": "כִּֽי־יִהְיֶ֥ה", "transliteral": "kî-yih-yeh", "traducao_palavra": "quando houver" },
        { "hebraico": "רִ֛יב", "transliteral": "rîḇ", "traducao_palavra": "contenda/demanda" },
        { "hebraico": "בֵּ֥ין", "transliteral": "bên", "traducao_palavra": "entre" },
        { "hebraico": "אֲנָשִׁ֖ים", "transliteral": "ʾă-nā-šîm", "traducao_palavra": "homens" },
        { "hebraico": "וְנִגְּשׁ֣וּ", "transliteral": "wə-nig-gə-šû", "traducao_palavra": "e se aproximarem" },
        { "hebraico": "אֶל־הַמִּשְׁפָּ֑ט", "transliteral": "ʾel-ham-miš-pāṭ", "traducao_palavra": "ao juízo" },
        { "hebraico": "וּשְׁפָט֔וּם", "transliteral": "ū-šə-p̄ā-ṭûm", "traducao_palavra": "e os julgarão" },
        { "hebraico": "וְהִצְדִּ֙יקוּ֙", "transliteral": "wə-hiṣ-dî-qû", "traducao_palavra": "e justificarão" },
        { "hebraico": "אֶת־הַצַּדִּ֔יק", "transliteral": "ʾeṯ-haṣ-ṣad-dîq", "traducao_palavra": "ao justo" },
        { "hebraico": "וְהִרְשִׁ֖יעוּ", "transliteral": "wə-hir-šî-ʿû", "traducao_palavra": "e condenarão" },
        { "hebraico": "אֶת־הָרָשָֽׁע׃", "transliteral": "ʾeṯ-hā-rā-šāʿ", "traducao_palavra": "ao ímpio/culpado" }
      ]
    },
    "2": {
      "traducao_completa": "E será que, se o ímpio for digno de açoites, o juiz o fará deitar e o fará açoitar diante de si, segundo a sua culpa, por certo número.",
      "palavras": [
        { "hebraico": "וְהָיָה", "transliteral": "wə-hā-yā", "traducao_palavra": "e será" },
        { "hebraico": "אִם־בִּ֥ן", "transliteral": "ʾim-bin", "traducao_palavra": "se [for] filho de" },
        { "hebraico": "הַכֹּ֖ות", "transliteral": "hak-kôṯ", "traducao_palavra": "açoite/golpe" },
        { "hebraico": "הָרָשָׁ֑ע", "transliteral": "hā-rā-šāʿ", "traducao_palavra": "o ímpio" },
        { "hebraico": "וְהִפִּילֹ֣ו", "transliteral": "wə-hip-pî-lô", "traducao_palavra": "e fará ele cair/deitar" },
        { "hebraico": "הַשֹּׁפֵ֗ט", "transliteral": "haš-šō-p̄ēṭ", "traducao_palavra": "o juiz" },
        { "hebraico": "וְהִכָּ֧הוּ", "transliteral": "wə-hik-kā-hû", "traducao_palavra": "e o açoitará" },
        { "hebraico": "לְפָנָ֛יו", "transliteral": "lə-p̄ā-nāyw", "traducao_palavra": "diante dele" },
        { "hebraico": "כְּדֵ֥י", "transliteral": "kə-ḏê", "traducao_palavra": "conforme" },
        { "hebraico": "רִשְׁעָתֹ֖ו", "transliteral": "riš-ʿā-ṯô", "traducao_palavra": "sua culpa" },
        { "hebraico": "בְּמִסְפָּֽר׃", "transliteral": "bə-mis-pār", "traducao_palavra": "por número" }
      ]
    },
    "3": {
      "traducao_completa": "Quarenta açoites lhe poderá dar, não mais; para que porventura, se lhe der mais do que estes, teu irmão não fique envilecido aos teus olhos.",
      "palavras": [
        { "hebraico": "אַרְבָּעִ֥ים", "transliteral": "ʾar-bā-ʿîm", "traducao_palavra": "quarenta" },
        { "hebraico": "יַכֶּ֖נּוּ", "transliteral": "yak-ken-nû", "traducao_palavra": "açoitará ele" },
        { "hebraico": "לֹ֣א", "transliteral": "lō", "traducao_palavra": "não" },
        { "hebraico": "יֹסִ֑יף", "transliteral": "yō-śîp̄", "traducao_palavra": "acrescentará" },
        { "hebraico": "פֶּן־יֹסִ֨יף", "transliteral": "pen-yō-śîp̄", "traducao_palavra": "para que não acrescente" },
        { "hebraico": "לְהַכֹּתֹ֧ו", "transliteral": "lə-hak-kō-ṯô", "traducao_palavra": "a feri-lo" },
        { "hebraico": "עַל־אֵ֛לֶּה", "transliteral": "ʿal-ʾēl-leh", "traducao_palavra": "além destes" },
        { "hebraico": "מַכָּ֥ה", "transliteral": "mak-kā", "traducao_palavra": "açoite" },
        { "hebraico": "רַבָּ֖ה", "transliteral": "rab-bā", "traducao_palavra": "muito/excessivo" },
        { "hebraico": "וְנִקְלָ֥ה", "transliteral": "wə-niq-lā", "traducao_palavra": "e seja humilhado/envilecido" },
        { "hebraico": "אָחִ֖יךָ", "transliteral": "ʾā-ḥî-ḵā", "traducao_palavra": "teu irmão" },
        { "hebraico": "לְעֵינֶֽיךָ׃", "transliteral": "lə-ʿê-ne-ḵā", "traducao_palavra": "em teus olhos" }
      ]
    },
    "4": {
      "traducao_completa": "Não atarás a boca ao boi quando estiver trilhando.",
      "palavras": [
        { "hebraico": "לֹא־תַחְסֹ֥ם", "transliteral": "lō-ṯaḥ-śōm", "traducao_palavra": "não amordassarás" },
        { "hebraico": "שֹׁ֖ור", "transliteral": "šôr", "traducao_palavra": "boi" },
        { "hebraico": "בְּדִישֹֽׁו׃", "transliteral": "bə-ḏî-šô", "traducao_palavra": "em seu trilhar" }
      ]
    },
    "5": {
      "traducao_completa": "Quando alguns irmãos habitarem juntos, e um deles morrer e não tiver filho, a mulher do morto não se casará fora com homem estranho; seu cunhado entrará a ela e a tomará por mulher, e fará o dever de cunhado para com ela.",
      "palavras": [
        { "hebraico": "כִּֽי־יֵשְׁב֨וּ", "transliteral": "kî-yē-šə-ḇû", "traducao_palavra": "quando habitarem" },
        { "hebraico": "אַחִ֜ים", "transliteral": "ʾa-ḥîm", "traducao_palavra": "irmãos" },
        { "hebraico": "יַחְדָּ֗ו", "transliteral": "yaḥ-dāw", "traducao_palavra": "juntamente" },
        { "hebraico": "וּמֵ֨ת", "transliteral": "ū-mēṯ", "traducao_palavra": "e morrer" },
        { "hebraico": "אַחַ֤ד", "transliteral": "ʾa-ḥaḏ", "traducao_palavra": "um" },
        { "hebraico": "מֵהֶם֙", "transliteral": "mê-hem", "traducao_palavra": "deles" },
        { "hebraico": "וּבֵ֣ן", "transliteral": "ū-ḇēn", "traducao_palavra": "e filho" },
        { "hebraico": "אֵֽין־לֹ֔ו", "transliteral": "ʾên-lô", "traducao_palavra": "não tiver ele" },
        { "hebraico": "לֹֽא־תִהְיֶ֧ה", "transliteral": "lō-ṯih-yeh", "traducao_palavra": "não será" },
        { "hebraico": "אֵֽשֶׁת־הַמֵּ֛ת", "transliteral": "ʾē-šeṯ-ham-mêṯ", "traducao_palavra": "mulher do morto" },
        { "hebraico": "הַח֖וּצָה", "transliteral": "ha-ḥû-ṣā", "traducao_palavra": "fora" },
        { "hebraico": "לְאִ֣ישׁ", "transliteral": "lə-ʾîš", "traducao_palavra": "a homem" },
        { "hebraico": "זָ֑ר", "transliteral": "zār", "traducao_palavra": "estranho" },
        { "hebraico": "יְבָמָהּ֙", "transliteral": "yə-ḇā-māh", "traducao_palavra": "seu cunhado" },
        { "hebraico": "יָבֹ֣א", "transliteral": "yā-ḇō", "traducao_palavra": "virá" },
        { "hebraico": "עָלֶ֔יהָ", "transliteral": "ʿā-le-hā", "traducao_palavra": "a ela" },
        { "hebraico": "וּלְקָחָ֥הּ", "transliteral": "ū-lə-qā-ḥāh", "traducao_palavra": "e a tomará" },
        { "hebraico": "לֹו֙", "transliteral": "lô", "traducao_palavra": "para si" },
        { "hebraico": "לְאִשָּׁ֔ה", "transliteral": "lə-ʾiš-šā", "traducao_palavra": "por mulher" },
        { "hebraico": "וְיִבְּמָֽהּ׃", "transliteral": "wə-yib-bə-māh", "traducao_palavra": "e fará o dever de levirato" }
      ]
    },
    "6": {
      "traducao_completa": "E será que o primogênito que ela der à luz sucederá no nome de seu irmão falecido, para que o seu nome não se apague de Israel.",
      "palavras": [
        { "hebraico": "וְהָיָ֗ה", "transliteral": "wə-hā-yā", "traducao_palavra": "e será" },
        { "hebraico": "הַבְּכֹור֙", "transliteral": "hab-bə-ḵôr", "traducao_palavra": "o primogênito" },
        { "hebraico": "אֲשֶׁ֣ר", "transliteral": "ʾă-šer", "traducao_palavra": "que" },
        { "hebraico": "תֵּלֵ֔ד", "transliteral": "tē-lēḏ", "traducao_palavra": "ela der à luz" },
        { "hebraico": "יָק֕וּם", "transliteral": "yā-qûm", "traducao_palavra": "se levantará/sucederá" },
        { "hebraico": "עַל־שֵׁ֥ם", "transliteral": "ʿal-šēm", "traducao_palavra": "no nome de" },
        { "hebraico": "אָחִ֖יו", "transliteral": "ʾā-ḥîw", "traducao_palavra": "seu irmão" },
        { "hebraico": "הַמֵּ֑ת", "transliteral": "ham-mêṯ", "traducao_palavra": "o morto" },
        { "hebraico": "וְלֹֽא־יִמָּחֶ֥ה", "transliteral": "wə-lō-yimmā-ḥeh", "traducao_palavra": "para que não seja apagado" },
        { "hebraico": "שְׁמֹ֖ו", "transliteral": "šə-mô", "traducao_palavra": "o nome dele" },
        { "hebraico": "מִיִּשְׂרָאֵֽל׃", "transliteral": "mi-yiś-rā-ʾēl", "traducao_palavra": "de Israel" }
      ]
    },
    "7": {
      "traducao_completa": "Porém, se o homem não quiser tomar sua cunhada, subirá sua cunhada à porta, aos anciãos, e dirá: Meu cunhado recusa suscitar a seu irmão nome em Israel; não quer cumprir para comigo o dever de cunhado.",
      "palavras": [
        { "hebraico": "וְאִם־לֹ֨א", "transliteral": "wə-ʾim-lō", "traducao_palavra": "e se não" },
        { "hebraico": "יַחְפֹּ֣ץ", "transliteral": "yaḥ-pōṣ", "traducao_palavra": "quiser" },
        { "hebraico": "הָאִ֔ישׁ", "transliteral": "hā-ʾîš", "traducao_palavra": "o homem" },
        { "hebraico": "לָקַ֖חַת", "transliteral": "lā-qa-ḥaṯ", "traducao_palavra": "tomar" },
        { "hebraico": "אֶת־יְבִמְתֹּ֑ו", "transliteral": "ʾeṯ-yə-ḇim-tô", "traducao_palavra": "sua cunhada" },
        { "hebraico": "וְעָלְתָ֨ה", "transliteral": "wə-ʿā-lə-ṯā", "traducao_palavra": "então subirá" },
        { "hebraico": "יְבִמְתֹּ֤ו", "transliteral": "yə-ḇim-tô", "traducao_palavra": "sua cunhada" },
        { "hebraico": "הַשַּׁ֙עְרָה֙", "transliteral": "ha-ša-ʿə-rā", "traducao_palavra": "à porta" },
        { "hebraico": "אֶל־הַזְּקֵנִ֔ים", "transliteral": "ʾel-haz-zə-qē-nîm", "traducao_palavra": "aos anciãos" },
        { "hebraico": "וְאָמְרָ֗ה", "transliteral": "wə-ʾā-mə-rā", "traducao_palavra": "e dirá" },
        { "hebraico": "מֵאֵ֨ן", "transliteral": "mē-ʾēn", "traducao_palavra": "recusa" },
        { "hebraico": "יְבָמִ֜י", "transliteral": "yə-ḇā-mî", "traducao_palavra": "meu cunhado" },
        { "hebraico": "לְהָקִ֨ים", "transliteral": "lə-hā-qîm", "traducao_palavra": "suscitar" },
        { "hebraico": "לְאָחִ֧יו", "transliteral": "lə-ʾā-ḥîw", "traducao_palavra": "a seu irmão" },
        { "hebraico": "שֵׁם֙", "transliteral": "šēm", "traducao_palavra": "nome" },
        { "hebraico": "בְּיִשְׂרָאֵ֔ל", "transliteral": "bə-yiś-rā-ʾēl", "traducao_palavra": "em Israel" },
        { "hebraico": "לֹ֥א", "transliteral": "lō", "traducao_palavra": "não" },
        { "hebraico": "אָבָ֖ה", "transliteral": "ʾā-ḇā", "traducao_palavra": "quis" },
        { "hebraico": "יַבְּמִֽי׃", "transliteral": "yab-bə-mî", "traducao_palavra": "cumprir dever de cunhado" }
      ]
    },
    "8": {
      "traducao_completa": "Então os anciãos da sua cidade o chamarão e falarão com ele; e, se ele persistir e disser: Não quero tomá-la;",
      "palavras": [
        { "hebraico": "וְקָרְאוּ־לֹ֥ו", "transliteral": "wə-qā-rə-ʾû-lô", "traducao_palavra": "e chamarão ele" },
        { "hebraico": "זִקְנֵי־עִירֹ֖ו", "transliteral": "ziq-nê-ʿî-rô", "traducao_palavra": "anciãos da cidade dele" },
        { "hebraico": "וְדִבְּר֣וּ", "transliteral": "wə-ḏib-bə-rû", "traducao_palavra": "e falarão" },
        { "hebraico": "אֵלָ֑יו", "transliteral": "ʾē-lāyw", "traducao_palavra": "a ele" },
        { "hebraico": "וְעָמַ֣ד", "transliteral": "wə-ʿā-maḏ", "traducao_palavra": "e se parar/persistir" },
        { "hebraico": "וְאָמַ֔ר", "transliteral": "wə-ʾā-mar", "traducao_palavra": "e disser" },
        { "hebraico": "לֹ֥א", "transliteral": "lō", "traducao_palavra": "não" },
        { "hebraico": "חָפַ֖צְתִּי", "transliteral": "ḥā-p̄aṣ-tî", "traducao_palavra": "quiser" },
        { "hebraico": "לְקַחְתָּֽהּ׃", "transliteral": "lə-qaḥ-tāh", "traducao_palavra": "tomá-la" }
      ]
    },
    "9": {
      "traducao_completa": "Então sua cunhada se chegará a ele aos olhos dos anciãos, e lhe descalçará o sapato do pé, e lhe cuspirá no rosto, e responderá, dizendo: Assim se fará ao homem que não edificar a casa de seu irmão.",
      "palavras": [
        { "hebraico": "וְנִגְּשָׁ֨ה", "transliteral": "wə-nig-gə-šā", "traducao_palavra": "e chegará" },
        { "hebraico": "יְבִמְתֹּ֣ו", "transliteral": "yə-ḇim-tô", "traducao_palavra": "sua cunhada" },
        { "hebraico": "אֵלָיו֮", "transliteral": "ʾē-lāyw", "traducao_palavra": "a ele" },
        { "hebraico": "לְעֵינֵ֣י", "transliteral": "lə-ʿê-nê", "traducao_palavra": "aos olhos de" },
        { "hebraico": "הַזְּקֵנִים֒", "transliteral": "haz-zə-qê-nîm", "traducao_palavra": "os anciãos" },
        { "hebraico": "וְחָלְצָ֥ה", "transliteral": "wə-ḥā-lə-ṣā", "traducao_palavra": "e descalçará" },
        { "hebraico": "נַעֲלֹ֛ו", "transliteral": "na-ʿă-lô", "traducao_palavra": "seu sapato" },
        { "hebraico": "מֵעַ֥ל", "transliteral": "mê-ʿal", "traducao_palavra": "de sobre" },
        { "hebraico": "רַגְלֹ֖ו", "transliteral": "raḡ-lô", "traducao_palavra": "seu pé" },
        { "hebraico": "וְיָרְקָ֣ה", "transliteral": "wə-yā-rə-qā", "traducao_palavra": "e cuspirá" },
        { "hebraico": "בְּפָנָ֑יו", "transliteral": "bə-p̄ā-nāyw", "traducao_palavra": "em sua face" },
        { "hebraico": "וְעָנְתָה֙", "transliteral": "wə-ʿā-nə-ṯā", "traducao_palavra": "e responderá" },
        { "hebraico": "וְאָמְרָ֔ה", "transliteral": "wə-ʾā-mə-rā", "traducao_palavra": "e dirá" },
        { "hebraico": "כָּ֚כָה", "transliteral": "kā-ḵā", "traducao_palavra": "assim" },
        { "hebraico": "יֵעָשֶׂ֣ה", "transliteral": "yē-ʿā-śeh", "traducao_palavra": "se fará" },
        { "hebraico": "לָאִ֔ישׁ", "transliteral": "lā-ʾîš", "traducao_palavra": "ao homem" },
        { "hebraico": "אֲשֶׁ֥ר", "transliteral": "ʾă-šer", "traducao_palavra": "que" },
        { "hebraico": "לֹא־יִבְנֶ֖ה", "transliteral": "lō-yiḇ-neh", "traducao_palavra": "não edificar" },
        { "hebraico": "אֶת־בֵּ֥ית", "transliteral": "ʾeṯ-bêṯ", "traducao_palavra": "a casa de" },
        { "hebraico": "אָחִֽיו׃", "transliteral": "ʾā-ḥîw", "traducao_palavra": "seu irmão" }
      ]
    },
    "10": {
      "traducao_completa": "E o seu nome se chamará em Israel: A casa do descalçado.",
      "palavras": [
        { "hebraico": "וְנִקְרָ֥א", "transliteral": "wə-niq-rā", "traducao_palavra": "e se chamará" },
        { "hebraico": "שְׁמֹ֖ו", "transliteral": "šə-mô", "traducao_palavra": "o nome dele" },
        { "hebraico": "בְּיִשְׂרָאֵ֑ל", "transliteral": "bə-yiś-rā-ʾēl", "traducao_palavra": "em Israel" },
        { "hebraico": "בֵּ֖ית", "transliteral": "bêṯ", "traducao_palavra": "casa de" },
        { "hebraico": "חֲל֥וּץ", "transliteral": "ḥă-lûṣ", "traducao_palavra": "descalçado de" },
        { "hebraico": "הַנָּֽעַל׃", "transliteral": "han-nā-ʿal", "traducao_palavra": "o sapato" }
      ]
    },
    "11": {
      "traducao_completa": "Quando pelejarem dois homens, um contra o outro, e a mulher de um se chegar para livrar o seu marido da mão do que o fere, e ela estender a sua mão, e lhe pegar pelas suas partes vergonhosas,",
      "palavras": [
        { "hebraico": "כִּֽי־יִנָּצ֨וּ", "transliteral": "kî-yinnā-ṣû", "traducao_palavra": "quando pelejarem" },
        { "hebraico": "אֲנָשִׁ֤ים", "transliteral": "ʾă-nā-šîm", "traducao_palavra": "homens" },
