        { "hebraico": "מְיַסְּרֶֽךָּ׃", "transliteral": "mə-yas-sə-re-kā", "traducao_palavra": "disciplina-te" }
      ]
    },
    "6": {
      "traducao_completa": "E guarda os mandamentos de YHWH teu Deus, para andares nos seus caminhos e para o temeres.",
