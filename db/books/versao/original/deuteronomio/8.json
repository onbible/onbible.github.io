        { "hebraico": "בָצֵ֑קָה", "transliteral": "ḇā-ṣê-qā", "traducao_palavra": "se inchou" },
        { "hebraico": "זֶ֖ה", "transliteral": "zeh", "traducao_palavra": "estes" },
        { "hebraico": "אַרְבָּעִ֥ים", "transliteral": "ʾar-bā-ʿîm", "traducao_palavra": "quarenta" },
        { "hebraico": "שָׁנָֽה׃", "transliteral": "šā-nā", "traducao_palavra": "anos" }
      ]
    },
