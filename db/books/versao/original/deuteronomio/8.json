        { "hebraico": "וּרְבִיתֶם֮", "transliteral": "ū-rə-ḇî-ṯem", "traducao_palavra": "e vos multipliqueis" },
        { "hebraico": "וּבָאתֶם֙", "transliteral": "ū-ḇā-ṯem", "traducao_palavra": "e entreis" },
        { "hebraico": "וִֽירִשְׁתֶּ֣ם", "transliteral": "wî-riš-tem", "traducao_palavra": "e possuais" },
