        { "hebraico": "אָנֹכִ֧י", "transliteral": "ʾā-nō-ḵî", "traducao_palavra": "eu" },
        { "hebraico": "מְצַוְּךָ֛", "transliteral": "mə-ṣaw-wə-ḵā", "traducao_palavra": "ordeno a ti" },
