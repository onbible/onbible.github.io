        { "hebraico": "וְיָדַעְתָּ֖", "transliteral": "wə-yā-ḏaʿ-tā", "traducao_palavra": "e saberás/sabe" },
        { "hebraico": "עִם־לְבָבֶ֑ךָ", "transliteral": "ʿim-lə-ḇā-ḇe-ḵā", "traducao_palavra": "com teu coração" },
        { "hebraico": "כִּ֗י", "transliteral": "kî", "traducao_palavra": "que" },
