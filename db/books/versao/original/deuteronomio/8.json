        { "hebraico": "אֶת־כָּל־הַדֶּ֗רֶךְ", "transliteral": "ʾeṯ-kāl-had-de-reḵ", "traducao_palavra": "de todo o caminho" },
        { "hebraico": "אֲשֶׁ֨ר", "transliteral": "ʾă-šer", "traducao_palavra": "pelo qual" },
