  "versiculos": {
    "1": {
      "traducao_completa": "Todo o mandamento que hoje vos ordeno cuidareis de cumprir, para que vivais, e vos multipliqueis, e entreis, e possuais a terra que YHWH jurou a vossos pais.",
      "palavras": [
        { "hebraico": "כָּל־הַמִּצְוָ֗ה", "transliteral": "kāl-ham-miṣ-wā", "traducao_palavra": "todo o mandamento" },
