        { "hebraico": "אֶ֡רֶץ", "transliteral": "ʾe-reṣ", "traducao_palavra": "terra" },
        { "hebraico": "אֲשֶׁר֩", "transliteral": "ʾă-šer", "traducao_palavra": "em que" },
