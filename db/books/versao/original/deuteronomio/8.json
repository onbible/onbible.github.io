        { "hebraico": "לֹ֣א", "transliteral": "lō", "traducao_palavra": "não" },
        { "hebraico": "בָלְתָה֙", "transliteral": "ḇā-lə-ṯā", "traducao_palavra": "se envelheceu" },
        { "hebraico": "מֵעָלֶ֔יךָ", "transliteral": "mê-ʿā-ley-ḵā", "traducao_palavra": "sobre ti" },
