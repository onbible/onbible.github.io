        { "hebraico": "כָּאֵ֖ל", "transliteral": "kā-ʾēl", "traducao_palavra": "como o Deus de" },
        { "hebraico": "יְשֻׁר֑וּן", "transliteral": "yə-šu-rûn", "traducao_palavra": "Jesurum" },
        { "hebraico": "רֹכֵ֤ב", "transliteral": "rō-ḵēḇ", "traducao_palavra": "[que] cavalga" },
        { "hebraico": "שָׁמַ֙יִם֙", "transliteral": "šā-ma-yim", "traducao_palavra": "os céus" },
        { "hebraico": "בְּעֶזְרֶ֔ךָ", "transliteral": "bə-ʿez-re-ḵā", "traducao_palavra": "para tua ajuda" },
        { "hebraico": "וּבְגַאֲוָתֹ֖ו", "transliteral": "ū-ḇə-ḡa-ʾă-wā-ṯô", "traducao_palavra": "e em sua majestade" },
