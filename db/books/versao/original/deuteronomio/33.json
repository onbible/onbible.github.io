        { "hebraico": "רֹבֶ֥צֶת", "transliteral": "rō-ḇe-ṣeṯ", "traducao_palavra": "[que] jaz/repousa" },
        { "hebraico": "תָּֽחַת׃", "transliteral": "tā-ḥaṯ", "traducao_palavra": "embaixo" }
