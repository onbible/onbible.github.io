        { "hebraico": "אָשֵׁ֑ר", "transliteral": "ʾā-šēr", "traducao_palavra": "Aser" },
        { "hebraico": "יְהִ֤י", "transliteral": "yə-hî", "traducao_palavra": "seja" },
