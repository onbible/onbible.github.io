    "25": {
      "traducao_completa": "O teu calçado será de ferro e de bronze; e a tua força será como os teus dias.",
      "palavras": [
        { "hebraico": "בַּרְזֶ֥ל", "transliteral": "bar-zel", "traducao_palavra": "ferro" },
        { "hebraico": "וּנְחֹ֖שֶׁת", "transliteral": "ū-nə-ḥō-šeṯ", "traducao_palavra": "e bronze" },
        { "hebraico": "מִנְעָלֶ֑ךָ", "transliteral": "min-ʿā-le-ḵā", "traducao_palavra": "teu calçado/ferrolho" },
        { "hebraico": "וּכְיָמֶ֖יךָ", "transliteral": "ū-ḵə-yā-mey-ḵā", "traducao_palavra": "e como teus dias" },
        { "hebraico": "דָּבְאֶֽךָ׃", "transliteral": "dā-ḇə-ʾe-ḵā", "traducao_palavra": "tua força/repouso" }
