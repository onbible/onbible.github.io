        { "hebraico": "אֱלֹהֵ֣י", "transliteral": "ʾĕ-lō-hê", "traducao_palavra": "Deus de" },
        { "hebraico": "קֶ֔דֶם", "transliteral": "qe-ḏem", "traducao_palavra": "antiguidade/eterno" },
        { "hebraico": "וּמִתַּ֖חַת", "transliteral": "ū-mit-ta-ḥaṯ", "traducao_palavra": "e por baixo" },
