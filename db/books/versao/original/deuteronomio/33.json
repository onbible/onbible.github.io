        { "hebraico": "הַשְׁמֵֽד׃", "transliteral": "haš-mēḏ", "traducao_palavra": "destrói" }
      ]
    },
    "28": {
      "traducao_completa": "Israel, pois, habitará só, seguro, na terra da fonte de Jacó, em terra de grão e de mosto; e os seus céus gotejarão orvalho.",
      "palavras": [
