        { "hebraico": "וַאֲשֶׁר־חֶ֖רֶב", "transliteral": "wa-ʾă-šer-ḥe-reḇ", "traducao_palavra": "e que [é] a espada de" },
        { "hebraico": "גַּאֲוָתֶ֑ךָ", "transliteral": "ga-ʾă-wā-ṯe-ḵā", "traducao_palavra": "tua excelência/majestade" },
        { "hebraico": "וְיִכָּחֲשׁ֤וּ", "transliteral": "wə-yik-kā-ḥă-šû", "traducao_palavra": "e se sujeitarão/mentirão" },
