        { "hebraico": "עֹולָ֑ם", "transliteral": "ʿô-lām", "traducao_palavra": "eternidade" },
        { "hebraico": "וַיְגָ֧רֶשׁ", "transliteral": "way-ḡā-reš", "traducao_palavra": "e lançou fora" },
        { "hebraico": "מִפָּנֶ֛יךָ", "transliteral": "mip-pā-ney-ḵā", "traducao_palavra": "de diante de ti" },
        { "hebraico": "אֹויֵ֖ב", "transliteral": "ʾô-yēḇ", "traducao_palavra": "[o] inimigo" },
