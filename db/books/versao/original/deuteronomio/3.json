{
  "livro": "Deuteronômio - דְּבָרִים - Devarim",
  "capítulo": 3,
  "titulos": {},
  "versiculos": {
    "1": {
      "traducao_completa": "Então nos voltamos e subimos pelo caminho de Basã; e Ogue, rei de Basã, nos saiu ao encontro, ele e todo o seu povo, à peleja, em Edrei.",
      "palavras": [
        { "hebraico": "וַנֵּ֣פֶן", "transliteral": "wan-nê-p̄en", "traducao_palavra": "então voltamos" },
        { "hebraico": "וַנַּ֔עַל", "transliteral": "wan-na-ʿal", "traducao_palavra": "e subimos" },
        { "hebraico": "דֶּ֖רֶךְ", "transliteral": "de-reḵ", "traducao_palavra": "caminho de" },
        { "hebraico": "הַבָּשָׁ֑ן", "transliteral": "hab-bā-šān", "traducao_palavra": "o Basã" },
        { "hebraico": "וַיֵּצֵ֨א", "transliteral": "way-yê-ṣē", "traducao_palavra": "e saiu" },
        { "hebraico": "עֹ֧וג", "transliteral": "ʿôḡ", "traducao_palavra": "Ogue" },
        { "hebraico": "מֶֽלֶךְ־הַבָּשָׁ֛ן", "transliteral": "me-leḵ-hab-bā-šān", "traducao_palavra": "rei de Basã" },
        { "hebraico": "לִקְרָאתֵ֖נוּ", "transliteral": "liq-rā-ṯê-nū", "traducao_palavra": "ao nosso encontro" },
        { "hebraico": "ה֧וּא", "transliteral": "hû", "traducao_palavra": "ele" },
        { "hebraico": "וְכָל־עַמֹּ֛ו", "transliteral": "wə-ḵāl-ʿam-mô", "traducao_palavra": "e todo o seu povo" },
        { "hebraico": "לַמִּלְחָמָ֖ה", "transliteral": "lam-mil-ḥā-mā", "traducao_palavra": "à peleja" },
        { "hebraico": "אֶדְרֶֽעִי׃", "transliteral": "ʾeḏ-re-ʿî", "traducao_palavra": "em Edrei" }
      ]
    },
    "2": {
      "traducao_completa": "E YHWH me disse: Não o temas, porque nas tuas mãos entreguei a ele, e a todo o seu povo, e a sua terra; e far-lhe-ás como fizeste a Seom, rei dos amorreus, que habitava em Hesbom.",
      "palavras": [
        { "hebraico": "וַיֹּ֨אמֶר", "transliteral": "way-yō-mer", "traducao_palavra": "e disse" },
        { "hebraico": "יְהוָ֤ה", "transliteral": "YHWH", "traducao_palavra": "YHWH" },
        { "hebraico": "אֵלַי֙", "transliteral": "ʾē-lay", "traducao_palavra": "a mim" },
        { "hebraico": "אַל־תִּירָ֣א", "transliteral": "ʾal-tî-rā", "traducao_palavra": "não temas" },
        { "hebraico": "אֹתֹ֔ו", "transliteral": "ʾō-ṯô", "traducao_palavra": "ele" },
