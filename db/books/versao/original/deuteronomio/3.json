        { "hebraico": "מַמְלֶ֥כֶת", "transliteral": "mam-le-ḵeṯ", "traducao_palavra": "reino de" },
        { "hebraico": "עֹ֖וג", "transliteral": "ʿôḡ", "traducao_palavra": "Ogue" },
        { "hebraico": "בַּבָּשָֽׁן׃", "transliteral": "bab-bā-šān", "traducao_palavra": "em Basã" }
      ]
    },
    "11": {
      "traducao_completa": "Porque só Ogue, rei de Basã, ficou do resto dos gigantes; eis que o seu leito, um leito de ferro, não está porventura em Rabá dos filhos de Amom? De nove côvados é o seu comprimento, e de quatro côvados a sua largura, pelo côvado comum de um homem.",
