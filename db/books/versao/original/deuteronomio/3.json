        { "hebraico": "אֶעְבְּרָה־נָּ֗א", "transliteral": "ʾeʿ-bə-rā-nā", "traducao_palavra": "deixa-me passar rogo" },
        { "hebraico": "וְאֶרְאֶה֙", "transliteral": "wə-ʾer-ʾeh", "traducao_palavra": "e veja" },
        { "hebraico": "אֶת־הָאָ֣רֶץ", "transliteral": "ʾeṯ-hā-ʾā-reṣ", "traducao_palavra": "a terra" },
        { "hebraico": "הַטֹּובָ֔ה", "transliteral": "haṭ-ṭô-ḇā", "traducao_palavra": "boa" },
        { "hebraico": "אֲשֶׁ֖ר", "transliteral": "ʾă-šer", "traducao_palavra": "que" },
        { "hebraico": "בְּעֵ֣בֶר", "transliteral": "bə-ʿē-ḇer", "traducao_palavra": "além de" },
        { "hebraico": "הַיַּרְדֵּ֑ן", "transliteral": "hay-yar-dên", "traducao_palavra": "o Jordão" },
        { "hebraico": "הָהָ֥ר", "transliteral": "hā-hār", "traducao_palavra": "montanha" },
        { "hebraico": "הַטֹּ֥וב", "transliteral": "haṭ-ṭôḇ", "traducao_palavra": "boa" },
        { "hebraico": "הַזֶּ֖ה", "transliteral": "haz-zeh", "traducao_palavra": "esta" },
        { "hebraico": "וְהַלְּבָנֹֽון׃", "transliteral": "wə-hal-lə-ḇā-nōn", "traducao_palavra": "e o Líbano" }
      ]
    },
    "26": {
      "traducao_completa": "Porém YHWH indignou-se muito contra mim por causa de vós, e não me ouviu; antes YHWH me disse: Basta; não me fales mais deste assunto.",
      "palavras": [
        { "hebraico": "וַיִּתְעַבֵּ֨ר", "transliteral": "way-yiṯ-ʿab-bēr", "traducao_palavra": "e indignou-se" },
        { "hebraico": "יְהוָ֥ה", "transliteral": "YHWH", "traducao_palavra": "YHWH" },
        { "hebraico": "בִּ֛י", "transliteral": "bî", "traducao_palavra": "contra mim" },
        { "hebraico": "לְמַעַנְכֶ֖ם", "transliteral": "lə-ma-ʿan-ḵem", "traducao_palavra": "por causa de vós" },
