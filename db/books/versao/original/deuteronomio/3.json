    "24": {
      "traducao_completa": "Senhor Deus, tu começaste a mostrar ao teu servo a tua grandeza e a tua forte mão; pois, que Deus há nos céus ou na terra, que possa fazer segundo as tuas obras, e segundo os teus grandes feitos?",
      "palavras": [
        { "hebraico": "אֲדֹנָ֣י", "transliteral": "ʾă-ḏō-nāy", "traducao_palavra": "Senhor" },
        { "hebraico": "יְהוִ֗ה", "transliteral": "YHWH", "traducao_palavra": "YHWH" },
        { "hebraico": "אַתָּ֤ה", "transliteral": "ʾat-tā", "traducao_palavra": "tu" },
        { "hebraico": "הַחִלֹּ֙ותָ֙", "transliteral": "ha-ḥil-lô-ṯā", "traducao_palavra": "começaste" },
        { "hebraico": "לְהַרְאֹ֣ות", "transliteral": "lə-har-ʾôṯ", "traducao_palavra": "a mostrar" },
        { "hebraico": "אֶֽת־עַבְדְּךָ֔", "transliteral": "ʾeṯ-ʿaḇ-də-ḵā", "traducao_palavra": "teu servo" },
        { "hebraico": "אֶת־גָּדְלְךָ֖", "transliteral": "ʾeṯ-gā-ḏə-lə-ḵā", "traducao_palavra": "tua grandeza" },
        { "hebraico": "וְאֶת־יָדְךָ֣", "transliteral": "wə-ʾeṯ-yā-ḏə-ḵā", "traducao_palavra": "e tua mão" },
        { "hebraico": "הַחֲזָקָ֑ה", "transliteral": "ha-ḥă-zā-qā", "traducao_palavra": "forte" },
        { "hebraico": "אֲשֶׁ֤ר", "transliteral": "ʾă-šer", "traducao_palavra": "que" },
        { "hebraico": "מִי־אֵל֙", "transliteral": "mî-ʾēl", "traducao_palavra": "qual Deus?" },
        { "hebraico": "בַּשָּׁמַ֣יִם", "transliteral": "baš-šā-ma-yim", "traducao_palavra": "nos céus" },
        { "hebraico": "וּבָאָ֔רֶץ", "transliteral": "ū-ḇā-ʾā-reṣ", "traducao_palavra": "ou na terra" },
        { "hebraico": "אֲשֶׁר־יַעֲשֶׂ֥ה", "transliteral": "ʾă-šer-ya-ʿă-śeh", "traducao_palavra": "que possa fazer" },
        { "hebraico": "כְמַעֲשֶׂ֖יךָ", "transliteral": "ḵə-ma-ʿă-śe-ḵā", "traducao_palavra": "como tuas obras" },
        { "hebraico": "וְכִגְבוּרֹתֶֽךָ׃", "transliteral": "wə-ḵiḡ-ḇû-rō-ṯe-ḵā", "traducao_palavra": "e como teus feitos de poder" }
      ]
    },
    "25": {
      "traducao_completa": "Rogo-te que me deixes passar, para que veja esta boa terra que está além do Jordão, esta boa montanha e o Líbano.",
