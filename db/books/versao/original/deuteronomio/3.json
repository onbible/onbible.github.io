      ]
    },
    "3": {
      "traducao_completa": "E também YHWH nosso Deus entregou nas nossas mãos a Ogue, rei de Basã, e a todo o seu povo; e o ferimos, até que não lhe ficou sobrevivente algum.",
      "palavras": [
