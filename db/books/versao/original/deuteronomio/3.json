        { "hebraico": "וְאֶת־כָּל־עַמֹּ֕ו", "transliteral": "wə-ʾeṯ-kāl-ʿam-mô", "traducao_palavra": "e todo o seu povo" },
        { "hebraico": "וַנַּכֵּ֕הוּ", "transliteral": "wan-nak-kê-hū", "traducao_palavra": "e ferimo-lo" },
        { "hebraico": "עַד־בִּלְתִּ֥י", "transliteral": "ʿaḏ-bil-tî", "traducao_palavra": "até não" },
        { "hebraico": "הִשְׁאִיר־לֹ֖ו", "transliteral": "hiš-ʾîr-lô", "traducao_palavra": "ficar para ele" },
        { "hebraico": "שָׂרִֽיד׃", "transliteral": "śā-rîḏ", "traducao_palavra": "sobrevivente" }
      ]
    },
    "4": {
      "traducao_completa": "E naquele tempo tomamos todas as suas cidades; nenhuma cidade houve que não lhes tomássemos: sessenta cidades, toda a região de Argobe, o reino de Ogue em Basã.",
