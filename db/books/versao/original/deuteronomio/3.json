        { "hebraico": "כָּל־חֶ֣בֶל", "transliteral": "kāl-ḥe-ḇel", "traducao_palavra": "toda a região de" },
        { "hebraico": "אַרְגֹּ֔ב", "transliteral": "ʾar-gōḇ", "traducao_palavra": "Argobe" },
