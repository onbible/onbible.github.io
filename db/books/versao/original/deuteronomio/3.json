        { "hebraico": "יְהוָ֤ה", "transliteral": "YHWH", "traducao_palavra": "YHWH" },
        { "hebraico": "אֵלַי֙", "transliteral": "ʾē-lay", "traducao_palavra": "a mim" },
        { "hebraico": "רַב־לָ֔ךְ", "transliteral": "raḇ-lāḵ", "traducao_palavra": "basta a ti" },
        { "hebraico": "אַל־תֹּ֥וסֶף", "transliteral": "ʾal-tô-sep̄", "traducao_palavra": "não voltes/acrescentes" },
        { "hebraico": "דַּבֵּ֥ר", "transliteral": "dab-bēr", "traducao_palavra": "a falar" },
        { "hebraico": "אֵלַ֖י", "transliteral": "ʾē-lay", "traducao_palavra": "a mim" },
        { "hebraico": "עֹ֥וד", "transliteral": "ʿôḏ", "traducao_palavra": "mais" },
        { "hebraico": "בַּדָּבָ֥ר", "transliteral": "bad-dā-ḇār", "traducao_palavra": "no assunto/palavra" },
        { "hebraico": "הַזֶּֽה׃", "transliteral": "haz-zeh", "traducao_palavra": "este" }
      ]
    },
    "27": {
      "traducao_completa": "Sobe ao cume de Pisga, e levanta os teus olhos para o ocidente, e para o norte, e para o sul, e para o oriente, e contempla com os teus olhos; porque não passarás este Jordão.",
      "palavras": [
        { "hebraico": "עֲלֵ֣ה׀", "transliteral": "ʿă-lēh", "traducao_palavra": "sobe" },
        { "hebraico": "רֹ֣אשׁ", "transliteral": "rōš", "traducao_palavra": "ao cume de" },
        { "hebraico": "הַפִּסְגָּ֗ה", "transliteral": "hap-pis-gā", "traducao_palavra": "o Pisga" },
        { "hebraico": "וְשָׂ֥א", "transliteral": "wə-śā", "traducao_palavra": "e levanta" },
        { "hebraico": "עֵינֶיךָ֮", "transliteral": "ʿê-ne-ḵā", "traducao_palavra": "teus olhos" },
        { "hebraico": "יָ֣מָּה", "transliteral": "yām-mā", "traducao_palavra": "para o ocidente/mar" },
        { "hebraico": "וְצָפֹ֧נָה", "transliteral": "wə-ṣā-p̄ō-nā", "traducao_palavra": "e para o norte" },
        { "hebraico": "וְתֵימָ֛נָה", "transliteral": "wə-ṯê-mā-nā", "traducao_palavra": "e para o sul" },
        { "hebraico": "וּמִזְרָ֖חָה", "transliteral": "ū-miz-rā-ḥā", "traducao_palavra": "e para o oriente" },
        { "hebraico": "וּרְאֵ֣ה", "transliteral": "ū-rə-ʾēh", "traducao_palavra": "e contempla" },
        { "hebraico": "בְעֵינֶ֑יךָ", "transliteral": "ḇə-ʿê-ne-ḵā", "traducao_palavra": "com teus olhos" },
        { "hebraico": "כִּי־לֹ֥א", "transliteral": "kî-lō", "traducao_palavra": "porque não" },
        { "hebraico": "תַעֲבֹ֖ר", "transliteral": "ṯa-ʿă-ḇōr", "traducao_palavra": "passarás" },
        { "hebraico": "אֶת־הַיַּרְדֵּ֥ן", "transliteral": "ʾeṯ-hay-yar-dên", "traducao_palavra": "o Jordão" },
        { "hebraico": "הַזֶּֽה׃", "transliteral": "haz-zeh", "traducao_palavra": "este" }
      ]
    },
    "28": {
      "traducao_completa": "Manda, pois, a Josué, e anima-o, e fortalece-o; porque ele passará adiante deste povo, e ele lhes fará herdar a terra que verás.",
      "palavras": [
        { "hebraico": "וְצַ֥ו", "transliteral": "wə-ṣaw", "traducao_palavra": "e manda" },
        { "hebraico": "אֶת־יְהֹושֻׁ֖עַ", "transliteral": "ʾeṯ-yə-hô-šu-aʿ", "traducao_palavra": "a Josué" },
        { "hebraico": "וְחַזְּקֵ֣הוּ", "transliteral": "wə-ḥaz-zə-qê-hū", "traducao_palavra": "e anima-o" },
        { "hebraico": "וְאַמְּצֵ֑הוּ", "transliteral": "wə-ʾam-mə-ṣê-hū", "traducao_palavra": "e fortalece-o" },
        { "hebraico": "כִּי־ה֣וּא", "transliteral": "kî-hû", "traducao_palavra": "porque ele" },
        { "hebraico": "יַעֲבֹ֗ר", "transliteral": "ya-ʿă-ḇōr", "traducao_palavra": "passará" },
        { "hebraico": "לִפְנֵי֙", "transliteral": "lip̄-nê", "traducao_palavra": "diante de" },
        { "hebraico": "הָעָ֣ם", "transliteral": "hā-ʿam", "traducao_palavra": "o povo" },
        { "hebraico": "הַזֶּ֔ה", "transliteral": "haz-zeh", "traducao_palavra": "este" },
