        { "hebraico": "אֹותֹ֛ו", "transliteral": "ʾō-ṯô", "traducao_palavra": "ele" },
        { "hebraico": "וְאֶת־כָל־עַמֹּ֖ו", "transliteral": "wə-ʾeṯ-kāl-ʿam-mô", "traducao_palavra": "e todo o seu povo" },
        { "hebraico": "וְאֶת־אַרְצֹ֑ו", "transliteral": "wə-ʾeṯ-ʾar-ṣô", "traducao_palavra": "e a sua terra" },
        { "hebraico": "וְעָשִׂ֣יתָ", "transliteral": "wə-ʿā-śî-ṯā", "traducao_palavra": "e farás" },
        { "hebraico": "לֹּ֔ו", "transliteral": "llô", "traducao_palavra": "a ele" },
