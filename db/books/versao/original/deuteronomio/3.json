    "7": {
      "traducao_completa": "Porém todo o gado e o despojo das cidades tomamos para nós por presa.",
      "palavras": [
        { "hebraico": "וְכָל־הַבְּהֵמָ֛ה", "transliteral": "wə-ḵāl-hab-bə-hē-mā", "traducao_palavra": "e todo o gado" },
