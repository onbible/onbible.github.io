        { "hebraico": "יִקְרְאוּ־לֹ֥ו", "transliteral": "yiq-rə-ʾû-lô", "traducao_palavra": "chamavam-no" },
        { "hebraico": "שְׂנִֽיר׃", "transliteral": "śə-nîr", "traducao_palavra": "Senir" }
      ]
    },
    "10": {
      "traducao_completa": "Todas as cidades da planície, e todo o Gileade, e todo o Basã até Salca e Edrei, cidades do reino de Ogue em Basã.",
      "palavras": [
        { "hebraico": "כֹּ֣ל׀", "transliteral": "kōl", "traducao_palavra": "todas" },
        { "hebraico": "עָרֵ֣י", "transliteral": "ʿā-rê", "traducao_palavra": "cidades de" },
        { "hebraico": "הַמִּישֹׁ֗ר", "transliteral": "ham-mî-šōr", "traducao_palavra": "a planície" },
        { "hebraico": "וְכָל־הַגִּלְעָד֙", "transliteral": "wə-ḵāl-hag-gil-ʿāḏ", "traducao_palavra": "e todo o Gileade" },
        { "hebraico": "וְכָל־הַבָּשָׁ֔ן", "transliteral": "wə-ḵāl-hab-bā-šān", "traducao_palavra": "e todo o Basã" },
        { "hebraico": "עַד־סַלְכָ֖ה", "transliteral": "ʿaḏ-sal-ḵā", "traducao_palavra": "até Salca" },
        { "hebraico": "וְאֶדְרֶ֑עִי", "transliteral": "wə-ʾeḏ-re-ʿî", "traducao_palavra": "e Edrei" },
