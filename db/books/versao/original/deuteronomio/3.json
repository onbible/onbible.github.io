        { "hebraico": "מְאֹֽד׃", "transliteral": "mə-ʾōḏ", "traducao_palavra": "muito" }
      ]
    },
    "6": {
      "traducao_completa": "E destruímo-las totalmente, como fizemos a Seom, rei de Hesbom, destruindo totalmente cada cidade, homens, mulheres e crianças.",
      "palavras": [
        { "hebraico": "וַנַּחֲרֵ֣ם", "transliteral": "wan-na-ḥă-rêm", "traducao_palavra": "e as destruímos totalmente" },
        { "hebraico": "אֹותָ֔ם", "transliteral": "ʾô-ṯām", "traducao_palavra": "elas" },
        { "hebraico": "כַּאֲשֶׁ֣ר", "transliteral": "ka-ʾă-šer", "traducao_palavra": "como" },
        { "hebraico": "עָשִׂ֔ינוּ", "transliteral": "ʿā-śî-nū", "traducao_palavra": "fizemos" },
        { "hebraico": "לְסִיחֹ֖ן", "transliteral": "lə-sî-ḥōn", "traducao_palavra": "a Seom" },
        { "hebraico": "מֶ֣לֶךְ", "transliteral": "me-leḵ", "traducao_palavra": "rei de" },
        { "hebraico": "חֶשְׁבֹּ֑ון", "transliteral": "ḥeš-bōn", "traducao_palavra": "Hesbom" },
        { "hebraico": "הַחֲרֵם֙", "transliteral": "ha-ḥă-rêm", "traducao_palavra": "destruindo totalmente" },
        { "hebraico": "כָּל־עִ֣יר", "transliteral": "kāl-ʿîr", "traducao_palavra": "cada cidade" },
        { "hebraico": "מְתִ֔ם", "transliteral": "mə-ṯim", "traducao_palavra": "homens" },
        { "hebraico": "הַנָּשִׁ֖ים", "transliteral": "han-nā-šîm", "traducao_palavra": "as mulheres" },
