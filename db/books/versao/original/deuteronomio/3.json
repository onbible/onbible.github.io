        { "hebraico": "עָשִׂ֗יתָ", "transliteral": "ʿā-śî-ṯā", "traducao_palavra": "fizeste" },
        { "hebraico": "לְסִיחֹן֙", "transliteral": "lə-sî-ḥōn", "traducao_palavra": "a Seom" },
        { "hebraico": "מֶ֣לֶךְ", "transliteral": "me-leḵ", "traducao_palavra": "rei de" },
        { "hebraico": "הָאֱמֹרִ֔י", "transliteral": "hā-ʾĕ-mō-rî", "traducao_palavra": "os amorreus" },
        { "hebraico": "אֲשֶׁ֥ר", "transliteral": "ʾă-šer", "traducao_palavra": "que" },
