        { "hebraico": "מִנַּ֥חַל", "transliteral": "min-na-ḥal", "traducao_palavra": "desde ribeiro de" },
        { "hebraico": "אַרְנֹ֖ן", "transliteral": "ʾar-nōn", "traducao_palavra": "Arnom" },
        { "hebraico": "עַד־הַ֥ר", "transliteral": "ʿaḏ-har", "traducao_palavra": "até monte" },
        { "hebraico": "חֶרְמֹֽון׃", "transliteral": "ḥer-mōn", "traducao_palavra": "Hermom" }
      ]
    },
    "9": {
      "traducao_completa": "(Os sidônios chamam a Hermom, Siriom; porém os amorreus o chamam Senir);",
      "palavras": [
        { "hebraico": "צִידֹנִ֛ים", "transliteral": "ṣî-ḏō-nîm", "traducao_palavra": "sidônios" },
        { "hebraico": "יִקְרְא֥וּ", "transliteral": "yiq-rə-ʾû", "traducao_palavra": "chamavam" },
        { "hebraico": "לְחֶרְמֹ֖ון", "transliteral": "lə-ḥer-mōn", "traducao_palavra": "a Hermom" },
        { "hebraico": "שִׂרְיֹ֑ן", "transliteral": "śir-yōn", "traducao_palavra": "Siriom" },
