        { "hebraico": "בֵּיתֶ֖ךָ", "transliteral": "bê-ṯe-ḵā", "traducao_palavra": "tua casa" },
        { "hebraico": "וּבִשְׁעָרֶֽיךָ׃", "transliteral": "ū-ḇiš-ʿā-re-ḵā", "traducao_palavra": "e em tuas portas" }
