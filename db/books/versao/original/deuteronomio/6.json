        { "hebraico": "כָּל־טוּב֮", "transliteral": "kāl-ṭûḇ", "traducao_palavra": "todo o bem" },
        { "hebraico": "אֲשֶׁ֣ר", "transliteral": "ʾă-šer", "traducao_palavra": "que" },
