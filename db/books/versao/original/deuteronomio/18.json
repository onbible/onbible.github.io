        { "hebraico": "בְּקֶ֣רֶב", "transliteral": "bə-qe-reḇ", "traducao_palavra": "no meio de" },
        { "hebraico": "אֶחָ֑יו", "transliteral": "ʾe-ḥāyw", "traducao_palavra": "seus irmãos" },
