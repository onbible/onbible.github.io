        { "hebraico": "לַכֹּהֲנִ֣ים", "transliteral": "lak-kō-hă-nîm", "traducao_palavra": "para os sacerdotes" },
        { "hebraico": "הַלְוִיִּם֮", "transliteral": "hal-wiy-yim", "traducao_palavra": "os levitas" },
        { "hebraico": "כָּל־שֵׁ֣בֶט", "transliteral": "kāl-šē-ḇeṭ", "traducao_palavra": "toda a tribo de" },
        { "hebraico": "לֵוִי֒", "transliteral": "lē-wî", "traducao_palavra": "Levi" },
        { "hebraico": "חֵ֧לֶק", "transliteral": "ḥē-leq", "traducao_palavra": "parte" },
