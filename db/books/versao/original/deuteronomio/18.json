      ]
    },
    "11": {
      "traducao_completa": "Nem encantador de encantamentos, nem quem consulte a um espírito adivinhador, nem mágico, nem quem consulte os mortos;",
      "palavras": [
        { "hebraico": "וְחֹבֵ֖ר", "transliteral": "wə-ḥō-ḇēr", "traducao_palavra": "e encantador de" },
