        { "hebraico": "נַפְשֹׁ֔ו", "transliteral": "nap̄-šô", "traducao_palavra": "sua alma" },
        { "hebraico": "אֶל־הַמָּקֹ֖ום", "transliteral": "ʾel-ham-mā-qôm", "traducao_palavra": "ao lugar" },
        { "hebraico": "אֲשֶׁר־יִבְחַ֥ר", "transliteral": "ʾă-šer-yiḇ-ḥar", "traducao_palavra": "que escolher" },
