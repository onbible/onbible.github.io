        { "hebraico": "אִשֵּׁ֧י", "transliteral": "ʾiš-šê", "traducao_palavra": "ofertas queimadas de" },
        { "hebraico": "יְהוָ֛ה", "transliteral": "YHWH", "traducao_palavra": "YHWH" },
        { "hebraico": "וְנַחֲלָתֹ֖ו", "transliteral": "wə-na-ḥă-lā-ṯô", "traducao_palavra": "e herança dele" },
