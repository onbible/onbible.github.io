    "10": {
      "traducao_completa": "Não se achará entre ti quem faça passar pelo fogo o seu filho ou a sua filha, nem adivinhador, nem prognosticador, nem agoureiro, nem feiticeiro,",
      "palavras": [
        { "hebraico": "לֹֽא־יִמָּצֵ֣א", "transliteral": "lō-yimmā-ṣē", "traducao_palavra": "não se achará" },
        { "hebraico": "בְךָ֔", "transliteral": "ḇə-ḵā", "traducao_palavra": "em ti" },
        { "hebraico": "מַעֲבִ֥יר", "transliteral": "ma-ʿă-ḇîr", "traducao_palavra": "quem faça passar" },
        { "hebraico": "בְּנֹֽו־וּבִתֹּ֖ו", "transliteral": "bə-nô-ū-ḇit-tô", "traducao_palavra": "seu filho e sua filha" },
