        { "hebraico": "שָׁ֖ם", "transliteral": "šām", "traducao_palavra": "ali" },
        { "hebraico": "לִפְנֵ֥י", "transliteral": "lip̄-nê", "traducao_palavra": "perante" },
        { "hebraico": "יְהוָֽה׃", "transliteral": "YHWH", "traducao_palavra": "YHWH" }
      ]
