        { "hebraico": "דְּגָנְךָ֥", "transliteral": "də-ḡā-nə-ḵā", "traducao_palavra": "teu grão" },
        { "hebraico": "תִּֽירֹשְׁךָ֖", "transliteral": "ṯî-rō-šə-ḵā", "traducao_palavra": "teu mosto" },
        { "hebraico": "וְיִצְהָרֶ֑ךָ", "transliteral": "wə-yiṣ-hā-re-ḵā", "traducao_palavra": "e teu azeite" },
