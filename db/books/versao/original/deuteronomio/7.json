      ]
    },
    "8": {
      "traducao_completa": "Mas, porque YHWH vos amava, e para guardar o juramento que jurara a vossos pais, YHWH vos tirou com mão forte e vos resgatou da casa da servidão, da mão de Faraó, rei do Egito.",
      "palavras": [
        { "hebraico": "כִּ֚י", "transliteral": "kî", "traducao_palavra": "mas" },
        { "hebraico": "מֵֽאַהֲבַ֨ת", "transliteral": "mê-ʾa-hă-ḇaṯ", "traducao_palavra": "pelo amor de" },
        { "hebraico": "יְהוָ֜ה", "transliteral": "YHWH", "traducao_palavra": "YHWH" },
