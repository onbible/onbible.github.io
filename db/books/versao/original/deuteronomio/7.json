    },
    "7": {
      "traducao_completa": "YHWH não tomou prazer em vós, nem vos escolheu, porque fôsseis mais numerosos do que todos os outros povos, pois vós éreis o menor de todos os povos;",
      "palavras": [
        { "hebraico": "לֹ֣א", "transliteral": "lō", "traducao_palavra": "não" },
        { "hebraico": "מֵֽרֻבְּכֶ֞ם", "transliteral": "mê-rub-bə-ḵem", "traducao_palavra": "pela vossa multidão" },
        { "hebraico": "מִכָּל־הָעַמִּ֗ים", "transliteral": "mik-kāl-hā-ʿam-mîm", "traducao_palavra": "mais do que todos os povos" },
