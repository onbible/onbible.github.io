        { "hebraico": "תַּחֲרִים֙", "transliteral": "ta-ḥă-rîm", "traducao_palavra": "as destruirás" },
        { "hebraico": "אֹתָ֔ם", "transliteral": "ʾō-ṯām", "traducao_palavra": "elas" },
        { "hebraico": "לֹא־תִכְרֹ֥ת", "transliteral": "lō-ṯiḵ-rōṯ", "traducao_palavra": "não farás/cortarás" },
        { "hebraico": "לָהֶ֛ם", "transliteral": "lā-hem", "traducao_palavra": "com elas" },
        { "hebraico": "בְּרִ֖ית", "transliteral": "bə-rîṯ", "traducao_palavra": "aliança" },
        { "hebraico": "וְלֹ֥א", "transliteral": "wə-lō", "traducao_palavra": "e não" },
        { "hebraico": "תְחָנֵּֽם׃", "transliteral": "ṯə-ḥān-nêm", "traducao_palavra": "terás piedade delas" }
