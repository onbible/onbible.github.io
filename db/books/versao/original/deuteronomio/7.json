        { "hebraico": "וְהִשְׁמִידְךָ֖", "transliteral": "wə-hiš-mî-ḏə-ḵā", "traducao_palavra": "e destruiria-te" },
        { "hebraico": "מַהֵֽר׃", "transliteral": "ma-hēr", "traducao_palavra": "depressa" }
      ]
    },
    "5": {
      "traducao_completa": "Mas assim lhes fareis: Derrubareis os seus altares, quebrareis as suas estátuas, e cortareis os seus bosques, e queimareis a fogo as suas imagens esculpidas.",
      "palavras": [
        { "hebraico": "כִּֽי־אִם־כֹּ֤ה", "transliteral": "kî-ʾim-kōh", "traducao_palavra": "mas assim" },
