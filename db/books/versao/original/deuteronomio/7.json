        { "hebraico": "אֲחֵרִ֑ים", "transliteral": "ʾă-ḥê-rîm", "traducao_palavra": "outros" },
        { "hebraico": "וְחָרָ֤ה", "transliteral": "wə-ḥā-rā", "traducao_palavra": "e se acenderia" },
        { "hebraico": "אַף־יְהוָה֙", "transliteral": "ʾap̄-YHWH", "traducao_palavra": "a ira de YHWH" },
