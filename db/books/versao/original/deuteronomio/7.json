    "9": {
      "traducao_completa": "Saberás, pois, que YHWH teu Deus, ele é Deus, o Deus fiel, que guarda a aliança e a misericórdia até mil gerações aos que o amam e guardam os seus mandamentos;",
      "palavras": [
        { "hebraico": "וְיָדַעְתָּ֔", "transliteral": "wə-yā-ḏaʿ-tā", "traducao_palavra": "e saberás" },
