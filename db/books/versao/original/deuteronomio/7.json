        { "hebraico": "וְאֶת־הַחֶ֔סֶד", "transliteral": "wə-ʾeṯ-ha-ḥe-seḏ", "traducao_palavra": "e a misericórdia" },
        { "hebraico": "אֲשֶׁ֥ר", "transliteral": "ʾă-šer", "traducao_palavra": "que" },
