      ]
    },
    "17": {
      "traducao_completa": "Se disseres no teu coração: Estas nações são mais numerosas do que eu; como as poderei expulsar?",
      "palavras": [
        { "hebraico": "כִּ֤י", "transliteral": "kî", "traducao_palavra": "se" },
        { "hebraico": "תֹאמַר֙", "transliteral": "ṯō-mar", "traducao_palavra": "disseres" },
        { "hebraico": "בִּלְבָבְךָ֔", "transliteral": "bil-ḇā-ḇə-ḵā", "traducao_palavra": "em teu coração" },
        { "hebraico": "רַבִּ֥ים", "transliteral": "rab-bîm", "traducao_palavra": "mais numerosos" },
        { "hebraico": "הַגֹּויִ֥ם", "transliteral": "hag-gô-yim", "traducao_palavra": "estas nações" },
        { "hebraico": "הָאֵ֖לֶּה", "transliteral": "hā-ʾēl-leh", "traducao_palavra": "estas" },
        { "hebraico": "מִמֶּ֑נִּי", "transliteral": "mim-men-nî", "traducao_palavra": "do que eu" },
        { "hebraico": "אֵיכָ֥ה", "transliteral": "ʾê-ḵā", "traducao_palavra": "como?" },
        { "hebraico": "אוּכַ֖ל", "transliteral": "ʾû-ḵal", "traducao_palavra": "poderei" },
        { "hebraico": "לְהֹורִישָֽׁם׃", "transliteral": "lə-hô-rî-šām", "traducao_palavra": "expulsá-los" }
      ]
    },
    "18": {
      "traducao_completa": "Delas não tenhas medo; lembra-te bem do que YHWH teu Deus fez a Faraó e a todos os egípcios;",
      "palavras": [
        { "hebraico": "לֹ֥א", "transliteral": "lō", "traducao_palavra": "não" },
        { "hebraico": "תִירָ֖א", "transliteral": "tî-rā", "traducao_palavra": "tenhas medo" },
        { "hebraico": "מֵהֶ֑ם", "transliteral": "mê-hem", "traducao_palavra": "deles" },
        { "hebraico": "זָכֹ֣ר", "transliteral": "zā-ḵōr", "traducao_palavra": "lembrar" },
        { "hebraico": "תִּזְכֹּ֗ר", "transliteral": "tiz-kōr", "traducao_palavra": "lembrar-te-ás" },
        { "hebraico": "אֵ֤ת", "transliteral": "ʾêṯ", "traducao_palavra": "[objeto]" },
        { "hebraico": "אֲשֶׁר־עָשָׂה֙", "transliteral": "ʾă-šer-ʿā-śā", "traducao_palavra": "o que fez" },
        { "hebraico": "יְהוָ֣ה", "transliteral": "YHWH", "traducao_palavra": "YHWH" },
