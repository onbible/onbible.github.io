        { "hebraico": "לָהֶ֔ם", "transliteral": "lā-hem", "traducao_palavra": "a eles" },
        { "hebraico": "מִזְבְּחֹתֵיהֶ֣ם", "transliteral": "miz-bə-ḥō-ṯê-hem", "traducao_palavra": "seus altares" },
        { "hebraico": "תִּתֹּ֔צוּ", "transliteral": "tit-tō-ṣû", "traducao_palavra": "derrubareis" },
        { "hebraico": "וּמַצֵּבֹתָ֖ם", "transliteral": "ū-maṣ-ṣê-ḇō-ṯām", "traducao_palavra": "e suas estátuas" },
        { "hebraico": "תְּשַׁבֵּ֑רוּ", "transliteral": "tə-šab-bê-rû", "traducao_palavra": "quebrareis" },
        { "hebraico": "וַאֲשֵֽׁירֵיהֶם֙", "transliteral": "wa-ʾă-šê-rê-hem", "traducao_palavra": "e seus bosques/postes de Asera" },
        { "hebraico": "תְּגַדֵּע֔וּ", "transliteral": "tə-ḡad-dê-ʿû", "traducao_palavra": "cortareis" },
        { "hebraico": "וּפְסִילֵיהֶ֖ם", "transliteral": "ū-p̄ə-śî-lê-hem", "traducao_palavra": "e suas imagens esculpidas" },
        { "hebraico": "תִּשְׂרְפ֥וּן", "transliteral": "tiś-rə-p̄ûn", "traducao_palavra": "queimareis" },
        { "hebraico": "בָּאֵֽשׁ׃", "transliteral": "bā-ʾēš", "traducao_palavra": "em fogo" }
