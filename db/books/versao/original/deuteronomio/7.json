        { "hebraico": "אֲשֶׁר־נִשְׁבַּ֥ע", "transliteral": "ʾă-šer-niš-baʿ", "traducao_palavra": "que jurou" },
        { "hebraico": "לַאֲבֹתֶ֖יךָ", "transliteral": "la-ʾă-ḇō-ṯe-ḵā", "traducao_palavra": "a teus pais" },
        { "hebraico": "לָ֥תֶת", "transliteral": "lā-ṯeṯ", "traducao_palavra": "para dar" },
        { "hebraico": "לָֽךְ׃", "transliteral": "lāḵ", "traducao_palavra": "a ti" }
      ]
    },
    "14": {
      "traducao_completa": "Bendito serás mais do que todos os povos; não haverá estéril entre ti, seja homem ou mulher, nem entre o teu gado.",
      "palavras": [
        { "hebraico": "בָּר֥וּךְ", "transliteral": "bā-rûḵ", "traducao_palavra": "bendito" },
        { "hebraico": "תִּהְיֶ֖ה", "transliteral": "tih-yeh", "traducao_palavra": "serás" },
        { "hebraico": "מִכָּל־הָעַמִּ֑ים", "transliteral": "mik-kāl-hā-ʿam-mîm", "traducao_palavra": "mais do que todos os povos" },
        { "hebraico": "לֹא־יִהְיֶ֨ה", "transliteral": "lō-yih-yeh", "traducao_palavra": "não haverá" },
        { "hebraico": "בְךָ֥", "transliteral": "ḇə-ḵā", "traducao_palavra": "em ti" },
        { "hebraico": "עָקָ֛ר", "transliteral": "ʿā-qār", "traducao_palavra": "estéril [macho]" },
        { "hebraico": "וַעֲקָרָ֖ה", "transliteral": "wa-ʿă-qā-rā", "traducao_palavra": "e estéril [fêmea]" },
        { "hebraico": "וּבִבְהֶמְתֶּֽךָ׃", "transliteral": "ū-ḇiḇ-hem-te-ḵā", "traducao_palavra": "e em teu gado" }
      ]
    },
    "15": {
      "traducao_completa": "E YHWH desviará de ti toda a enfermidade; e nenhuma das más doenças dos egípcios, que bem conheces, porá sobre ti, mas as porá sobre todos os que te odeiam.",
      "palavras": [
        { "hebraico": "וְהֵסִ֧יר", "transliteral": "wə-hê-śîr", "traducao_palavra": "e desviará/removerá" },
        { "hebraico": "יְהוָ֛ה", "transliteral": "YHWH", "traducao_palavra": "YHWH" },
        { "hebraico": "מִמְּךָ֖", "transliteral": "mim-mə-ḵā", "traducao_palavra": "de ti" },
        { "hebraico": "כָּל־חֹ֑לִי", "transliteral": "kāl-ḥō-lî", "traducao_palavra": "toda enfermidade" },
        { "hebraico": "וְכָל־מַדְוֵי֩", "transliteral": "wə-ḵāl-maḏ-wê", "traducao_palavra": "e todas as doenças de" },
        { "hebraico": "מִצְרַ֨יִם", "transliteral": "miṣ-ra-yim", "traducao_palavra": "Egito" },
        { "hebraico": "הָרָעִ֜ים", "transliteral": "hā-rā-ʿîm", "traducao_palavra": "as más" },
        { "hebraico": "אֲשֶׁ֣ר", "transliteral": "ʾă-šer", "traducao_palavra": "que" },
        { "hebraico": "יָדַ֗עְתָּ", "transliteral": "yā-ḏaʿ-tā", "traducao_palavra": "conheces" },
        { "hebraico": "לֹ֤א", "transliteral": "lō", "traducao_palavra": "não" },
        { "hebraico": "יְשִׂימָם֙", "transliteral": "yə-śî-mām", "traducao_palavra": "as porá" },
        { "hebraico": "בָּ֔ךְ", "transliteral": "bāḵ", "traducao_palavra": "em ti" },
        { "hebraico": "וּנְתָנָ֖ם", "transliteral": "ū-nə-ṯā-nām", "traducao_palavra": "mas as porá/dará" },
        { "hebraico": "בְּכָל־שֹׂנְאֶֽיךָ׃", "transliteral": "bə-ḵāl-śō-nə-ʾe-ḵā", "traducao_palavra": "em todos os que te odeiam" }
      ]
    },
    "16": {
      "traducao_completa": "Consumirás, pois, a todos os povos que YHWH teu Deus te der; o teu olho não terá piedade deles, e não servirás a seus deuses, pois isso te seria por laço.",
      "palavras": [
        { "hebraico": "וְאָכַלְתָּ֣", "transliteral": "wə-ʾā-ḵal-tā", "traducao_palavra": "e consumirás/comerás" },
