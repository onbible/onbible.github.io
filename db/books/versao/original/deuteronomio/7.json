  "versiculos": {
    "1": {
      "traducao_completa": "Quando YHWH teu Deus te introduzir na terra, a qual passas a possuir, e tiver lançado fora muitas nações de diante de ti, os heteus, e os girgaseus, e os amorreus, e os cananeus, e os ferezeus, e os heveus, e os jebuseus, sete nações mais numerosas e mais poderosas do que tu;",
      "palavras": [
        { "hebraico": "כִּ֤י", "transliteral": "kî", "traducao_palavra": "quando" },
        { "hebraico": "יְבִיאֲךָ֙", "transliteral": "yə-ḇî-ʾă-ḵā", "traducao_palavra": "introduzir-te" },
        { "hebraico": "יְהוָ֣ה", "transliteral": "YHWH", "traducao_palavra": "YHWH" },
        { "hebraico": "אֱלֹהֶ֔יךָ", "transliteral": "ʾĕ-lō-he-ḵā", "traducao_palavra": "teu Deus" },
        { "hebraico": "אֶל־הָאָ֕רֶץ", "transliteral": "ʾel-hā-ʾā-reṣ", "traducao_palavra": "à terra" },
        { "hebraico": "אֲשֶׁר־אַתָּ֥ה", "transliteral": "ʾă-šer-ʾat-tā", "traducao_palavra": "que tu" },
        { "hebraico": "בָא־שָׁ֖מָּה", "transliteral": "ḇā-šām-mā", "traducao_palavra": "entras ali" },
        { "hebraico": "לְרִשְׁתָּ֑הּ", "transliteral": "lə-riš-tāh", "traducao_palavra": "para possuí-la" },
        { "hebraico": "וְנָשַׁ֣ל", "transliteral": "wə-nā-šal", "traducao_palavra": "e lançar fora" },
        { "hebraico": "גֹּויִם־רַבִּ֣ים", "transliteral": "gô-yim-rab-bîm", "traducao_palavra": "nações muitas" },
        { "hebraico": "מִפָּנֶ֡יךָ", "transliteral": "mip-pā-ne-ḵā", "traducao_palavra": "de diante de ti" },
        { "hebraico": "הַֽחִתִּ֣י", "transliteral": "ha-ḥit-tî", "traducao_palavra": "o heteu" },
        { "hebraico": "וְהַגִּרְגָּשִׁ֣י", "transliteral": "wə-hag-gir-gā-šî", "traducao_palavra": "e o girgaseu" },
        { "hebraico": "וְהָאֱמֹרִ֣י", "transliteral": "wə-hā-ʾĕ-mō-rî", "traducao_palavra": "e o amorreu" },
        { "hebraico": "וְהַכְּנַעֲנִ֣י", "transliteral": "wə-hak-kə-na-ʿă-nî", "traducao_palavra": "e o cananeu" },
        { "hebraico": "וְהַפְּרִזִּי֙", "transliteral": "wə-hap-pə-riz-zî", "traducao_palavra": "e o ferezeu" },
        { "hebraico": "וְהַחִוִּ֣י", "transliteral": "wə-ha-ḥiw-wî", "traducao_palavra": "e o heveu" },
        { "hebraico": "וְהַיְבוּסִ֔י", "transliteral": "wə-hay-ḇû-śî", "traducao_palavra": "e o jebuseu" },
        { "hebraico": "שֶׁ֣בַע", "transliteral": "še-ḇaʿ", "traducao_palavra": "sete" },
        { "hebraico": "גֹּויִ֔ם", "transliteral": "gô-yim", "traducao_palavra": "nações" },
        { "hebraico": "רַבִּ֥ים", "transliteral": "rab-bîm", "traducao_palavra": "numerosas" },
        { "hebraico": "וַעֲצוּמִ֖ים", "transliteral": "wa-ʿă-ṣû-mîm", "traducao_palavra": "e poderosas" },
        { "hebraico": "מִמֶּֽךָּ׃", "transliteral": "mim-mek-kā", "traducao_palavra": "do que tu" }
      ]
    },
    "2": {
      "traducao_completa": "E quando YHWH teu Deus as tiver entregue diante de ti, e as ferires, totalmente as destruirás; não farás com elas aliança, nem terás piedade delas;",
      "palavras": [
        { "hebraico": "וּנְתָנָ֞ם", "transliteral": "ū-nə-ṯā-nām", "traducao_palavra": "e as tiver entregue" },
        { "hebraico": "יְהוָ֧ה", "transliteral": "YHWH", "traducao_palavra": "YHWH" },
        { "hebraico": "אֱלֹהֶ֛יךָ", "transliteral": "ʾĕ-lō-he-ḵā", "traducao_palavra": "teu Deus" },
        { "hebraico": "לְפָנֶ֖יךָ", "transliteral": "lə-p̄ā-ne-ḵā", "traducao_palavra": "diante de ti" },
        { "hebraico": "וְהִכִּיתָ֑ם", "transliteral": "wə-hik-kî-ṯām", "traducao_palavra": "e as ferires" },
