        { "hebraico": "אֱלֹהֶ֜יךָ", "transliteral": "ʾĕ-lō-he-ḵā", "traducao_palavra": "teu Deus" },
        { "hebraico": "נֹתֵ֣ן", "transliteral": "nō-ṯên", "traducao_palavra": "está dando" },
        { "hebraico": "לָ֔ךְ", "transliteral": "lāḵ", "traducao_palavra": "a ti" },
        { "hebraico": "לֹא־תָחֹ֥וס", "transliteral": "lō-ṯā-ḥôs", "traducao_palavra": "não poupará/terá piedade" },
        { "hebraico": "עֵינְךָ֖", "transliteral": "ʿên-ə-ḵā", "traducao_palavra": "teu olho" },
        { "hebraico": "עֲלֵיהֶ֑ם", "transliteral": "ʿă-lê-hem", "traducao_palavra": "deles" },
        { "hebraico": "וְלֹא־תַעֲבֹד֙", "transliteral": "wə-lō-ṯa-ʿă-ḇōḏ", "traducao_palavra": "e não servirás" },
        { "hebraico": "אֶת־אֱלֹ֣הֵיהֶ֔ם", "transliteral": "ʾeṯ-ʾĕ-lō-hê-hem", "traducao_palavra": "os deuses deles" },
