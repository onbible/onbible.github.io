        { "hebraico": "לְשֹׂנְאָ֛יו", "transliteral": "lə-śō-nə-ʾāw", "traducao_palavra": "aos que o odeiam" },
        { "hebraico": "אֶל־פָּנָ֖יו", "transliteral": "ʾel-pā-nāw", "traducao_palavra": "no seu rosto" },
        { "hebraico": "לְהַאֲבִידֹ֑ו", "transliteral": "lə-ha-ʾă-ḇî-ḏô", "traducao_palavra": "para fazê-lo perecer" },
        { "hebraico": "לֹ֤א", "transliteral": "lō", "traducao_palavra": "não" },
        { "hebraico": "יְאַחֵר֙", "transliteral": "yə-ʾa-ḥēr", "traducao_palavra": "retardará/será tardio" },
        { "hebraico": "לְשֹׂ֣נְאֹ֔ו", "transliteral": "lə-śō-nə-ʾô", "traducao_palavra": "para o que o odeia" },
        { "hebraico": "אֶל־פָּנָ֖יו", "transliteral": "ʾel-pā-nāw", "traducao_palavra": "em seu rosto" },
        { "hebraico": "יְשַׁלֶּם־לֹֽו׃", "transliteral": "yə-šal-lem-lô", "traducao_palavra": "pagará a ele" }
      ]
    },
    "11": {
      "traducao_completa": "Guarda, pois, os mandamentos, e os estatutos, e os juízos que hoje te mando cumprir.",
      "palavras": [
        { "hebraico": "וְשָׁמַרְתָּ֨", "transliteral": "wə-šā-mar-tā", "traducao_palavra": "e guardarás" },
        { "hebraico": "אֶת־הַמִּצְוָ֜ה", "transliteral": "ʾeṯ-ha-miṣ-wā", "traducao_palavra": "o mandamento" },
        { "hebraico": "וְאֶת־הַחֻקִּ֣ים", "transliteral": "wə-ʾeṯ-ha-ḥuq-qîm", "traducao_palavra": "e os estatutos" },
        { "hebraico": "וְאֶת־הַמִּשְׁפָּטִ֗ים", "transliteral": "wə-ʾeṯ-ham-miš-pā-ṭîm", "traducao_palavra": "e os juízos" },
        { "hebraico": "אֲשֶׁ֨ר", "transliteral": "ʾă-šer", "traducao_palavra": "que" },
        { "hebraico": "אָנֹכִ֧י", "transliteral": "ʾā-nō-ḵî", "traducao_palavra": "eu" },
        { "hebraico": "מְצַוְּךָ֛", "transliteral": "mə-ṣaw-wə-ḵā", "traducao_palavra": "ordeno a ti" },
        { "hebraico": "הַיֹּ֖ום", "transliteral": "hay-yôm", "traducao_palavra": "hoje" },
        { "hebraico": "לַעֲשֹׂותָֽם׃", "transliteral": "la-ʿă-śō-ṯām", "traducao_palavra": "para cumpri-los" }
      ]
    },
    "12": {
      "traducao_completa": "Será, pois, que, se ouvirdes estes juízos, e os guardardes e cumprirdes, YHWH teu Deus te guardará a aliança e a misericórdia que jurou a teus pais;",
      "palavras": [
        { "hebraico": "וְהָיָ֣ה", "transliteral": "wə-hā-yā", "traducao_palavra": "e será" },
        { "hebraico": "עֵ֣קֶב", "transliteral": "ʿê-qeḇ", "traducao_palavra": "em consequência de/se" },
        { "hebraico": "תִּשְׁמְע֗וּן", "transliteral": "tiš-mə-ʿûn", "traducao_palavra": "ouvirdes" },
        { "hebraico": "אֵ֤ת", "transliteral": "ʾêṯ", "traducao_palavra": "[objeto]" },
        { "hebraico": "הַמִּשְׁפָּטִ֣ים", "transliteral": "ham-miš-pā-ṭîm", "traducao_palavra": "os juízos" },
        { "hebraico": "הָאֵ֔לֶּה", "transliteral": "hā-ʾēl-leh", "traducao_palavra": "estes" },
        { "hebraico": "וּשְׁמַרְתֶּ֥ם", "transliteral": "ū-šə-mar-tem", "traducao_palavra": "e guardardes" },
        { "hebraico": "וַעֲשִׂיתֶ֖ם", "transliteral": "wa-ʿă-śî-ṯem", "traducao_palavra": "e fizerdes" },
        { "hebraico": "אֹתָ֑ם", "transliteral": "ʾō-ṯām", "traducao_palavra": "eles" },
        { "hebraico": "וְשָׁמַר֩", "transliteral": "wə-šā-mar", "traducao_palavra": "e guardará" },
        { "hebraico": "יְהוָ֨ה", "transliteral": "YHWH", "traducao_palavra": "YHWH" },
        { "hebraico": "אֱלֹהֶ֜יךָ", "transliteral": "ʾĕ-lō-he-ḵā", "traducao_palavra": "teu Deus" },
