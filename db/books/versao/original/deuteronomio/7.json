    },
    "3": {
      "traducao_completa": "Nem te aparentarás com elas; não darás tua filha a seu filho, e não tomarás sua filha para teu filho;",
      "palavras": [
        { "hebraico": "וְלֹ֥א", "transliteral": "wə-lō", "traducao_palavra": "e não" },
        { "hebraico": "תִתְחַתֵּ֖ן", "transliteral": "tiṯ-ḥat-tên", "traducao_palavra": "te aparentarás/casarás" },
        { "hebraico": "בָּ֑ם", "transliteral": "bām", "traducao_palavra": "com elas" },
        { "hebraico": "בִּתְּךָ֙", "transliteral": "bit-tə-ḵā", "traducao_palavra": "tua filha" },
        { "hebraico": "לֹא־תִתֵּ֣ן", "transliteral": "lō-ṯit-tên", "traducao_palavra": "não darás" },
        { "hebraico": "לִבְנֹ֔ו", "transliteral": "liḇ-nô", "traducao_palavra": "a seu filho" },
        { "hebraico": "וּבִתֹּ֖ו", "transliteral": "ū- village-it-tô", "traducao_palavra": "e a filha dele" },
        { "hebraico": "לֹא־תִקַּ֥ח", "transliteral": "lō-ṯiq-qaḥ", "traducao_palavra": "não tomarás" },
        { "hebraico": "לִבְנֶֽךָ׃", "transliteral": "liḇ-ne-ḵā", "traducao_palavra": "para teu filho" }
      ]
    },
    "4": {
      "traducao_completa": "Pois elas fariam desviar teus filhos de mim, para que servissem a outros deuses; e a ira de YHWH se acenderia contra vós, e depressa vos destruiria.",
      "palavras": [
        { "hebraico": "כִּֽי־יָסִ֤יר", "transliteral": "kî-yā-śîr", "traducao_palavra": "pois fariam desviar" },
        { "hebraico": "אֶת־בִּנְךָ֙", "transliteral": "ʾeṯ-bin-ḵā", "traducao_palavra": "teu filho" },
        { "hebraico": "מֵֽאַחֲרַ֔י", "transliteral": "mê-ʾa-ḥă-ray", "traducao_palavra": "de após mim" },
        { "hebraico": "וְעָבְד֖וּ", "transliteral": "wə-ʿā-ḇə-ḏû", "traducao_palavra": "e serviriam" },
