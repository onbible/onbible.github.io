        { "hebraico": "לַאֲבֹתֶֽיךָ׃", "transliteral": "la-ʾă-ḇō-ṯe-ḵā", "traducao_palavra": "a teus pais" }
      ]
    },
    "13": {
      "traducao_completa": "E amar-te-á, abençoar-te-á e te fará multiplicar; abençoará o fruto do teu ventre, e o fruto da tua terra, o teu grão, e o teu mosto, e o teu azeite, e a criação das tuas vacas, e o rebanho das tuas ovelhas, na terra que jurou a teus pais dar-te.",
      "palavras": [
        { "hebraico": "וַאֲהֵבְךָ֙", "transliteral": "wa-ʾă-hê-ḇə-ḵā", "traducao_palavra": "e amar-te-á" },
        { "hebraico": "וּבֵֽרַכְךָ֣", "transliteral": "ū-ḇê-raḵ-ḵā", "traducao_palavra": "e abençoar-te-á" },
        { "hebraico": "וְהִרְבֶּ֔ךָ", "transliteral": "wə-hir-be-ḵā", "traducao_palavra": "e te multiplicará" },
        { "hebraico": "וּבֵרַ֣ךְ", "transliteral": "ū-ḇê-raḵ", "traducao_palavra": "e abençoará" },
        { "hebraico": "פְּרִֽי־בִטְנְךָ֣", "transliteral": "pə-rî-ḇiṭ-nə-ḵā", "traducao_palavra": "o fruto do teu ventre" },
        { "hebraico": "וּפְרִֽי־אַ֠דְמָתֶךָ", "transliteral": "ū-p̄ə-rî-ʾaḏ-mā-ṯe-ḵā", "traducao_palavra": "e o fruto da tua terra" },
        { "hebraico": "דְּגָ֨נְךָ֜", "transliteral": "də-ḡā-nə-ḵā", "traducao_palavra": "teu grão" },
        { "hebraico": "וְתִירֹֽשְׁךָ֣", "transliteral": "wə-ṯî-rō-šə-ḵā", "traducao_palavra": "e teu mosto" },
        { "hebraico": "וְיִצְהָרֶ֗ךָ", "transliteral": "wə-yiṣ-hā-re-ḵā", "traducao_palavra": "e teu azeite" },
        { "hebraico": "שְׁגַר־אֲלָפֶ֙יךָ֙", "transliteral": "šə-ḡar-ʾă-lā-p̄e-ḵā", "traducao_palavra": "criação das tuas vacas" },
        { "hebraico": "וְעַשְׁתְּרֹ֣ת", "transliteral": "wə-ʿaš-tə-rōṯ", "traducao_palavra": "e rebanho de" },
        { "hebraico": "צֹאנֶ֔ךָ", "transliteral": "ṣō-ne-ḵā", "traducao_palavra": "tuas ovelhas" },
