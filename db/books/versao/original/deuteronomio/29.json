        { "hebraico": "הַבְּרִ֜ית", "transliteral": "hab-bə-rîṯ", "traducao_palavra": "a aliança" },
        { "hebraico": "אֲשֶׁר־צִוָּ֧ה", "transliteral": "ʾă-šer-ṣiw-wā", "traducao_palavra": "que ordenou" },
