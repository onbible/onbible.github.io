        { "hebraico": "לְעֵינֵיכֶם֙", "transliteral": "lə-ʿê-nê-ḵem", "traducao_palavra": "perante vossos olhos" },
        { "hebraico": "בְּאֶ֣רֶץ", "transliteral": "bə-ʾe-reṣ", "traducao_palavra": "na terra de" },
