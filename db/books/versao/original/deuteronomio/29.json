    "7": {
      "traducao_completa": "Chegando vós, pois, a este lugar, Seom, rei de Hesbom, e Ogue, rei de Basã, nos saíram ao encontro à peleja, e nós os ferimos;",
      "palavras": [
        { "hebraico": "וַתָּבֹ֖אוּ", "transliteral": "wat-tā-ḇō-ʾû", "traducao_palavra": "e viestes/chegastes" },
        { "hebraico": "אֶל־הַמָּקֹ֥ום", "transliteral": "ʾel-ham-mā-qôm", "traducao_palavra": "a este lugar" },
        { "hebraico": "הַזֶּ֑ה", "transliteral": "haz-zeh", "traducao_palavra": "[este]" },
        { "hebraico": "וַיֵּצֵ֣א", "transliteral": "way-yē-ṣē", "traducao_palavra": "e saiu" },
        { "hebraico": "סִיחֹ֣ן", "transliteral": "śî-ḥōn", "traducao_palavra": "Seom" },
        { "hebraico": "מֶֽלֶךְ־חֶ֠שְׁבֹּון", "transliteral": "me-leḵ-ḥeš-bôn", "traducao_palavra": "rei de Hesbom" },
        { "hebraico": "וְעֹ֨וג", "transliteral": "wə-ʿôḡ", "traducao_palavra": "e Ogue" },
        { "hebraico": "מֶֽלֶךְ־הַבָּשָׁ֧ן", "transliteral": "me-leḵ-hab-bā-šān", "traducao_palavra": "rei de Basã" },
        { "hebraico": "לִקְרָאתֵ֛נוּ", "transliteral": "liq-rā-ṯê-nū", "traducao_palavra": "ao nosso encontro" },
        { "hebraico": "לַמִּלְחָמָ֖ה", "transliteral": "lam-mil-ḥā-mā", "traducao_palavra": "para a guerra" },
        { "hebraico": "וַנַּכֵּֽם׃", "transliteral": "wan-nak-kēm", "traducao_palavra": "e ferimo-los" }
      ]
    },
    "8": {
      "traducao_completa": "E tomamos a sua terra e a demos por herança aos rubenitas, e aos gaditas, e à meia tribo dos manassitas.",
      "palavras": [
        { "hebraico": "וַנִּקַּח֙", "transliteral": "wan-niq-qaḥ", "traducao_palavra": "e tomamos" },
        { "hebraico": "אֶת־אַרְצָ֔ם", "transliteral": "ʾeṯ-ʾar-ṣām", "traducao_palavra": "a terra deles" },
        { "hebraico": "וַנִּתְּנָ֣הּ", "transliteral": "wan-nit-tə-nāh", "traducao_palavra": "e demo-la" },
        { "hebraico": "לְנַחֲלָ֔ה", "transliteral": "lə-na-ḥă-lā", "traducao_palavra": "por herança" },
        { "hebraico": "לָרֽאוּבֵנִ֖י", "transliteral": "lā-rə-ʾū-ḇê-nî", "traducao_palavra": "aos rubenitas" },
        { "hebraico": "וְלַגָּדִ֑י", "transliteral": "wə-lag-gā-ḏî", "traducao_palavra": "e aos gaditas" },
        { "hebraico": "וְלַחֲצִ֖י", "transliteral": "wə-la-ḥă-ṣî", "traducao_palavra": "e à metade de" },
        { "hebraico": "שֵׁ֥בֶט", "transliteral": "šē-ḇeṭ", "traducao_palavra": "tribo de" },
        { "hebraico": "הַֽמְנַשִּֽׁי׃", "transliteral": "ham-naš-śî", "traducao_palavra": "os manassitas" }
      ]
    },
    "9": {
      "traducao_completa": "Guardai, pois, as palavras desta aliança e cumpri-as, para que prospereis em tudo quanto fizerdes.",
      "palavras": [
        { "hebraico": "וּשְׁמַרְתֶּ֗ם", "transliteral": "ū-šə-mar-tem", "traducao_palavra": "e guardareis" },
        { "hebraico": "אֶת־דִּבְרֵי֙", "transliteral": "ʾeṯ-diḇ-rê", "traducao_palavra": "as palavras de" },
        { "hebraico": "הַבְּרִ֣ית", "transliteral": "hab-bə-rîṯ", "traducao_palavra": "a aliança" },
        { "hebraico": "הַזֹּּאת", "transliteral": "haz-zōṯ", "traducao_palavra": "esta" },
        { "hebraico": "וַעֲשִׂיתֶ֣ם", "transliteral": "wa-ʿă-śî-ṯem", "traducao_palavra": "e fareis/cumprireis" },
        { "hebraico": "אֹתָ֔ם", "transliteral": "ʾō-ṯām", "traducao_palavra": "elas" },
        { "hebraico": "לְמַ֣עַן", "transliteral": "lə-ma-ʿan", "traducao_palavra": "para que" },
        { "hebraico": "תַּשְׂכִּ֔ילוּ", "transliteral": "taś-kî-lû", "traducao_palavra": "prospereis/entendais" },
        { "hebraico": "אֵ֖ת", "transliteral": "ʾēṯ", "traducao_palavra": "[objeto]" },
        { "hebraico": "כָּל־אֲשֶׁ֥ר", "transliteral": "kāl-ʾă-šer", "traducao_palavra": "tudo quanto" },
        { "hebraico": "תַּעֲשֽׂוּן׃", "transliteral": "ta-ʿă-śûn", "traducao_palavra": "fizerdes" }
      ]
    },
    "10": {
      "traducao_completa": "Vós todos estais hoje perante YHWH vosso Deus; os vossos cabeças, as vossas tribos, os vossos anciãos e os vossos oficiais, com todos os homens de Israel,",
      "palavras": [
        { "hebraico": "אַתֶּ֨ם", "transliteral": "ʾat-tem", "traducao_palavra": "vós" },
        { "hebraico": "נִצָּבִ֥ים", "transliteral": "niṣ-ṣā-ḇîm", "traducao_palavra": "estais postos/apresentados" },
        { "hebraico": "הַיֹּ֛ום", "transliteral": "hay-yôm", "traducao_palavra": "hoje" },
        { "hebraico": "כֻּלְּכֶ֖ם", "transliteral": "kul-lə-ḵem", "traducao_palavra": "todos vós" },
        { "hebraico": "לִפְנֵ֥י", "transliteral": "lip̄-nê", "traducao_palavra": "perante" },
        { "hebraico": "יְהוָ֥ה", "transliteral": "YHWH", "traducao_palavra": "YHWH" },
        { "hebraico": "אֱלֹהֵיכֶ֑ם", "transliteral": "ʾĕ-lō-hê-ḵem", "traducao_palavra": "vosso Deus" },
        { "hebraico": "רָאשֵׁיכֶ֣ם", "transliteral": "rā-šê-ḵem", "traducao_palavra": "vossos cabeças" },
        { "hebraico": "שִׁבְטֵיכֶ֔ם", "transliteral": "šiḇ-ṭê-ḵem", "traducao_palavra": "vossas tribos" },
        { "hebraico": "זִקְנֵיכֶם֙", "transliteral": "ziq-nê-ḵem", "traducao_palavra": "vossos anciãos" },
        { "hebraico": "וְשֹׁטְרֵיכֶ֔ם", "transliteral": "wə-šō-ṭə-rê-ḵem", "traducao_palavra": "e vossos oficiais" },
        { "hebraico": "כֹּ֖ל", "transliteral": "kōl", "traducao_palavra": "todo" },
        { "hebraico": "אִ֥ישׁ", "transliteral": "ʾîš", "traducao_palavra": "homem de" },
        { "hebraico": "יִשְׂרָאֵֽל׃", "transliteral": "yiś-rā-ʾēl", "traducao_palavra": "Israel" }
      ]
    },
    "11": {
      "traducao_completa": "Vossos meninos, vossas mulheres, e o estrangeiro que está no meio do teu arraial; desde o rachador da tua lenha até ao tirador da tua água;",
      "palavras": [
