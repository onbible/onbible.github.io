        { "hebraico": "אֲשֶׁ֥ר", "transliteral": "ʾă-šer", "traducao_palavra": "que" },
        { "hebraico": "רָא֖וּ", "transliteral": "rā-ʾû", "traducao_palavra": "viram" },
        { "hebraico": "עֵינֶ֑יךָ", "transliteral": "ʿê-ne-ḵā", "traducao_palavra": "teus olhos" },
        { "hebraico": "הָאֹתֹ֧ת", "transliteral": "hā-ʾō-ṯōṯ", "traducao_palavra": "os sinais" },
        { "hebraico": "וְהַמֹּופְתִ֥ים", "transliteral": "wə-ham-mô-p̄ə-ṯîm", "traducao_palavra": "e os prodígios" },
        { "hebraico": "הַגְּדֹלִ֖ים", "transliteral": "hag-gə-ḏō-lîm", "traducao_palavra": "grandes" },
