      ]
    },
    "2": {
      "traducao_completa": "Chamou, pois, Moisés a todo o Israel, e disse-lhes: Vistes tudo quanto YHWH fez perante vossos olhos, na terra do Egito, a Faraó, e a todos os seus servos, e a toda a sua terra;",
      "palavras": [
        { "hebraico": "וַיִּקְרָ֥א", "transliteral": "way-yiq-rā", "traducao_palavra": "e chamou" },
        { "hebraico": "מֹשֶׁ֛ה", "transliteral": "mō-šeh", "traducao_palavra": "Moisés" },
        { "hebraico": "אֶל־כָּל־יִשְׂרָאֵ֖ל", "transliteral": "ʾel-kāl-yiś-rā-ʾēl", "traducao_palavra": "a todo o Israel" },
        { "hebraico": "וַיֹּ֣אמֶר", "transliteral": "way-yō-mer", "traducao_palavra": "e disse" },
        { "hebraico": "אֲלֵהֶ֑ם", "transliteral": "ʾă-lê-hem", "traducao_palavra": "a eles" },
        { "hebraico": "אַתֶּ֣ם", "transliteral": "ʾat-tem", "traducao_palavra": "vós" },
        { "hebraico": "רְאִיתֶ֗ם", "transliteral": "rə-ʾî-ṯem", "traducao_palavra": "vistes" },
