        { "hebraico": "מֹואָ֑ב", "transliteral": "mô-ʾāḇ", "traducao_palavra": "Moabe" },
        { "hebraico": "מִלְּבַ֣ד", "transliteral": "mil-lə-ḇaḏ", "traducao_palavra": "além de" },
        { "hebraico": "הַבְּרִ֔ית", "transliteral": "hab-bə-rîṯ", "traducao_palavra": "a aliança" },
