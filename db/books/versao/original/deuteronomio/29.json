        { "hebraico": "לֶ֚חֶם", "transliteral": "le-ḥem", "traducao_palavra": "pão" },
        { "hebraico": "לֹ֣א", "transliteral": "lō", "traducao_palavra": "não" },
        { "hebraico": "אֲכַלְתֶּ֔ם", "transliteral": "ʾă-ḵal-tem", "traducao_palavra": "comestes" },
