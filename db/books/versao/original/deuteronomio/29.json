    "5": {
      "traducao_completa": "E quarenta anos vos fiz andar pelo deserto; não se envelheceram sobre vós as vossas vestes, e nem se envelheceu o teu sapato no teu pé.",
      "palavras": [
        { "hebraico": "וָאֹולֵ֨ךְ", "transliteral": "wā-ʾô-lēḵ", "traducao_palavra": "e fiz andar" },
        { "hebraico": "אֶתְכֶ֥ם", "transliteral": "ʾeṯ-ḵem", "traducao_palavra": "vós" },
        { "hebraico": "אַרְבָּעִ֛ים", "transliteral": "ʾar-bā-ʿîm", "traducao_palavra": "quarenta" },
        { "hebraico": "שָׁנָ֖ה", "transliteral": "šā-nā", "traducao_palavra": "anos" },
        { "hebraico": "בַּמִּדְבָּ֑ר", "transliteral": "bam-miḏ-bār", "traducao_palavra": "no deserto" },
        { "hebraico": "לֹא־בָל֤וּ", "transliteral": "lō-ḇā-lû", "traducao_palavra": "não se envelheceram" },
        { "hebraico": "שַׂלְמֹֽתֵיכֶם֙", "transliteral": "śal-mō-ṯê-ḵem", "traducao_palavra": "vossas vestes" },
        { "hebraico": "מֵעֲלֵיכֶ֔ם", "transliteral": "mê-ʿă-lê-ḵem", "traducao_palavra": "de sobre vós" },
        { "hebraico": "וְנַֽעַלְךָ֥", "transliteral": "wə-na-ʿal-ḵā", "traducao_palavra": "e teu sapato" },
        { "hebraico": "לֹֽא־בָלְתָ֖ה", "transliteral": "lō-ḇā-lə-ṯā", "traducao_palavra": "não se envelheceu" },
        { "hebraico": "עַל־רַגְלֶֽךָ׃", "transliteral": "ʿal-raḡ-le-ḵā", "traducao_palavra": "sobre teu pé" }
      ]
    },
    "6": {
      "traducao_completa": "Pão não comestes, e vinho e bebida forte não bebestes; para que soubésseis que eu sou YHWH vosso Deus.",
