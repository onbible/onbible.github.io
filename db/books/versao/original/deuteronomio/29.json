        { "hebraico": "וּלְכָל־עֲבָדָ֖יו", "transliteral": "ū-lə-ḵāl-ʿă-ḇā-ḏāyw", "traducao_palavra": "e a todos os seus servos" },
        { "hebraico": "וּלְכָל־אַרְצֹֽו׃", "transliteral": "ū-lə-ḵāl-ʾar-ṣô", "traducao_palavra": "e a toda a terra dele" }
      ]
    },
    "3": {
      "traducao_completa": "As grandes provas que os teus olhos viram, os sinais e aqueles grandes prodígios;",
      "palavras": [
        { "hebraico": "הַמַּסֹּות֙", "transliteral": "ham-mas-śôṯ", "traducao_palavra": "as provas" },
