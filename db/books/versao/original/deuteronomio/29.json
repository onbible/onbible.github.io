      ]
    },
    "4": {
      "traducao_completa": "E não vos deu YHWH coração para entender, nem olhos para ver, nem ouvidos para ouvir, até ao dia de hoje.",
      "palavras": [
        { "hebraico": "וְלֹא־נָתַן֩", "transliteral": "wə-lō-nā-ṯan", "traducao_palavra": "e não deu" },
        { "hebraico": "יְהוָ֨ה", "transliteral": "YHWH", "traducao_palavra": "YHWH" },
        { "hebraico": "לָכֶ֥ם", "transliteral": "lā-ḵem", "traducao_palavra": "a vós" },
        { "hebraico": "לֵב֙", "transliteral": "lēḇ", "traducao_palavra": "coração" },
        { "hebraico": "לָדַ֔עַת", "transliteral": "lā-ḏa-ʿaṯ", "traducao_palavra": "para saber/entender" },
