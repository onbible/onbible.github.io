        { "hebraico": "לַגֵּר֙", "transliteral": "lag-gēr", "traducao_palavra": "para o estrangeiro" },
        { "hebraico": "לַיָּתֹ֣ום", "transliteral": "lay-yā-ṯôm", "traducao_palavra": "para o órfão" },
