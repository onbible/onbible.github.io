        { "hebraico": "אִ֛ישׁ", "transliteral": "ʾîš", "traducao_palavra": "um homem" },
        { "hebraico": "אִשָּׁ֖ה", "transliteral": "ʾiš-šā", "traducao_palavra": "mulher" },
        { "hebraico": "וּבְעָלָ֑הּ", "transliteral": "û-ḇə-ʿā-lāh", "traducao_palavra": "e se casar com ela" },
