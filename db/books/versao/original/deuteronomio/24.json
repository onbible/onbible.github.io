        { "hebraico": "עֶרְוַ֣ת", "transliteral": "ʿer-waṯ", "traducao_palavra": "nudez/fealdade de" },
        { "hebraico": "דָּבָ֔ר", "transliteral": "dā-ḇār", "traducao_palavra": "coisa" },
        { "hebraico": "וְכָ֨תַב", "transliteral": "wə-ḵā-ṯaḇ", "traducao_palavra": "e escreverá" },
