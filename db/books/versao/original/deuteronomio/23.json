    },
    "11": {
      "traducao_completa": "E será que, ao declinar da tarde, se lavará em água; e, posto o sol, entrará no meio do arraial.",
      "palavras": [
        { "hebraico": "וְהָיָ֥ה", "transliteral": "wə-hā-yā", "traducao_palavra": "e será" },
        { "hebraico": "לִפְנֹות־עֶ֖רֶב", "transliteral": "lip̄-nôṯ-ʿe-reḇ", "traducao_palavra": "ao virar/declinar da tarde" },
        { "hebraico": "יִרְחַ֣ץ", "transliteral": "yir-ḥaṣ", "traducao_palavra": "lavará" },
        { "hebraico": "בַּמָּ֑יִם", "transliteral": "bam-mā-yim", "traducao_palavra": "em água" },
