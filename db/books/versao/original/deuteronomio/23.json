      ]
    },
    "12": {
      "traducao_completa": "Também terás um lugar fora do arraial, para onde sairás.",
      "palavras": [
        { "hebraico": "וְיָ֛ד", "transliteral": "wə-yāḏ", "traducao_palavra": "e um lugar/mão" },
