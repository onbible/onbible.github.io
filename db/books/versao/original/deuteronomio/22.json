        { "hebraico": "כִּֽי־יִמָּצֵ֨א", "transliteral": "kî-yimmā-ṣē", "traducao_palavra": "quando for achado" },
        { "hebraico": "אִ֜ישׁ", "transliteral": "ʾîš", "traducao_palavra": "um homem" },
        { "hebraico": "שֹׁכֵ֣ב׀", "transliteral": "šō-ḵēḇ", "traducao_palavra": "deitado" },
