        { "hebraico": "וּמֵ֨תוּ֙", "transliteral": "ū-mē-ṯû", "traducao_palavra": "e morrerão" },
        { "hebraico": "גַּם־שְׁנֵיהֶ֔ם", "transliteral": "gam-šə-nê-hem", "traducao_palavra": "também ambos" },
        { "hebraico": "הָאִ֛ישׁ", "transliteral": "hā-ʾîš", "traducao_palavra": "o homem" },
        { "hebraico": "הַשֹּׁכֵ֥ב", "transliteral": "haš-šō-ḵēḇ", "traducao_palavra": "o deitado" },
        { "hebraico": "עִם־הָאִשָּׁ֖ה", "transliteral": "ʿim-hā-ʾiš-šā", "traducao_palavra": "com a mulher" },
        { "hebraico": "וְהָאִשָּׁ֑ה", "transliteral": "wə-hā-ʾiš-šā", "traducao_palavra": "e a mulher" },
        { "hebraico": "וּבִעַרְתָּ֥", "transliteral": "ū-ḇi-ʿar-tā", "traducao_palavra": "e tirarás" },
        { "hebraico": "הָרָ֖ע", "transliteral": "hā-rā", "traducao_palavra": "o mal" },
        { "hebraico": "מִיִּשְׂרָאֵֽל׃", "transliteral": "mi-yiś-rā-ʾēl", "traducao_palavra": "de Israel" }
      ]
    },
    "23": {
      "traducao_completa": "Quando houver moça virgem, desposada com marido, e um homem a achar na cidade, e se deitar com ela,",
      "palavras": [
        { "hebraico": "כִּ֤י", "transliteral": "kî", "traducao_palavra": "quando" },
        { "hebraico": "יִהְיֶה֙", "transliteral": "yih-yeh", "traducao_palavra": "houver" },
        { "hebraico": "נַעֲרָ֣ה", "transliteral": "na-ʿă-rā", "traducao_palavra": "moça" },
        { "hebraico": "בְתוּלָ֔ה", "transliteral": "ḇə-ṯû-lā", "traducao_palavra": "virgem" },
        { "hebraico": "מְאֹרָשָׂ֖ה", "transliteral": "mə-ʾō-rā-śā", "traducao_palavra": "desposada/comprometida" },
        { "hebraico": "לְאִ֑ישׁ", "transliteral": "lə-ʾîš", "traducao_palavra": "a um homem" },
        { "hebraico": "וּמְצָאָ֥הּ", "transliteral": "ū-mə-ṣā-ʾāh", "traducao_palavra": "e achar ela" },
        { "hebraico": "אִ֛ישׁ", "transliteral": "ʾîš", "traducao_palavra": "um homem" },
        { "hebraico": "בָּעִ֖יר", "transliteral": "bā-ʿîr", "traducao_palavra": "na cidade" },
        { "hebraico": "וְשָׁכַ֥ב", "transliteral": "wə-šā-ḵaḇ", "traducao_palavra": "e deitar" },
        { "hebraico": "עִמָּֽהּ׃", "transliteral": "ʿim-māh", "traducao_palavra": "com ela" }
      ]
    },
    "24": {
      "traducao_completa": "Então trareis a ambos à porta daquela cidade, e os apedrejareis com pedras, até que morram; a moça, porquanto não gritou na cidade, e o homem, porquanto humilhou a mulher do seu próximo; assim tirarás o mal do meio de ti.",
      "palavras": [
        { "hebraico": "וְהֹוצֵאתֶ֨ם", "transliteral": "wə-hô-ṣê-ṯem", "traducao_palavra": "e trareis" },
        { "hebraico": "אֶת־שְׁנֵיהֶ֜ם", "transliteral": "ʾeṯ-šə-nê-hem", "traducao_palavra": "ambos eles" },
        { "hebraico": "אֶל־שַׁ֣עַר", "transliteral": "ʾel-ša-ʿar", "traducao_palavra": "à porta de" },
        { "hebraico": "הָעִ֣יר", "transliteral": "hā-ʿîr", "traducao_palavra": "a cidade" },
        { "hebraico": "הַהִ֗וא", "transliteral": "ha-hî", "traducao_palavra": "aquela" },
        { "hebraico": "וּסְקַלְתֶּ֨ם", "transliteral": "ū-śə-qal-tem", "traducao_palavra": "e apedrejareis" },
        { "hebraico": "אֹתָ֥ם", "transliteral": "ʾō-ṯām", "traducao_palavra": "eles" },
        { "hebraico": "בָּאֲבָנִים֮", "transliteral": "bā-ʾă-ḇā-nîm", "traducao_palavra": "com pedras" },
        { "hebraico": "וָמֵתוּ֒", "transliteral": "wā-mê-ṯû", "traducao_palavra": "e morrerão" },
        { "hebraico": "אֶת־הַנַּעֲרָה֙", "transliteral": "ʾeṯ-han-na-ʿă-rā", "traducao_palavra": "a moça" },
        { "hebraico": "עַל־דְּבַ֣ר", "transliteral": "ʿal-də-ḇar", "traducao_palavra": "pela razão/palavra" },
        { "hebraico": "אֲשֶׁ֣ר", "transliteral": "ʾă-šer", "traducao_palavra": "que" },
        { "hebraico": "לֹא־צָעֲקָ֣ה", "transliteral": "lō-ṣā-ʿă-qā", "traducao_palavra": "não gritou" },
        { "hebraico": "בָעִ֔יר", "transliteral": "bā-ʿîr", "traducao_palavra": "na cidade" },
        { "hebraico": "וְאֶת־הָאִ֔ישׁ", "transliteral": "wə-ʾeṯ-hā-ʾîš", "traducao_palavra": "e o homem" },
        { "hebraico": "עַל־דְּבַ֥ר", "transliteral": "ʿal-də-ḇar", "traducao_palavra": "pela razão" },
        { "hebraico": "אֲשֶׁר־עִנָּ֖ה", "transliteral": "ʾă-šer-ʿin-nā", "traducao_palavra": "que humilhou" },
        { "hebraico": "אֶת־אֵ֣שֶׁת", "transliteral": "ʾeṯ-ʾê-šeṯ", "traducao_palavra": "mulher de" },
        { "hebraico": "רֵעֵ֑הוּ", "transliteral": "rê-ʿē-hū", "traducao_palavra": "seu próximo" },
        { "hebraico": "וּבִעַרְתָּ֥", "transliteral": "ū-ḇi-ʿar-tā", "traducao_palavra": "e tirarás" },
        { "hebraico": "הָרָ֖e", "transliteral": "hā-rā", "traducao_palavra": "o mal" },
        { "hebraico": "מִקִּרְבֶּֽךָ׃", "transliteral": "miq-qir-be-ḵā", "traducao_palavra": "do teu meio" }
      ]
    },
    "25": {
      "traducao_completa": "Mas se algum homem no campo achar uma moça desposada, e o homem a forçar, e se deitar com ela, então morrerá só o homem que se deitou com ela;",
      "palavras": [
        { "hebraico": "וְאִֽם־בַּשָּׂדֶ֞ה", "transliteral": "wə-ʾim-baś-śā-ḏeh", "traducao_palavra": "e se no campo" },
        { "hebraico": "יִמְצָ֣א", "transliteral": "yim-ṣā", "traducao_palavra": "achar" },
        { "hebraico": "הָאִ֗ישׁ", "transliteral": "hā-ʾîš", "traducao_palavra": "o homem" },
        { "hebraico": "אֶת־הַנַּעֲרָה֙", "transliteral": "ʾeṯ-han-na-ʿă-rā", "traducao_palavra": "a moça" },
        { "hebraico": "הַמְאֹרָשָׂ֔ה", "transliteral": "ham-ʾō-rā-śā", "traducao_palavra": "desposada" },
        { "hebraico": "וְהֶחֱזִֽיק־בָּ֥הּ", "transliteral": "wə-he-ḥĕ-zîq-bāh", "traducao_palavra": "e a forçar/segurar" },
        { "hebraico": "הָאִ֖ישׁ", "transliteral": "hā-ʾîš", "traducao_palavra": "o homem" },
        { "hebraico": "וְשָׁכַ֣ב", "transliteral": "wə-šā-ḵaḇ", "traducao_palavra": "e deitar" },
        { "hebraico": "עִמָּ֑הּ", "transliteral": "ʿim-māh", "traducao_palavra": "com ela" },
        { "hebraico": "וּמֵ֣ת", "transliteral": "ū-mēṯ", "traducao_palavra": "e morrerá" },
        { "hebraico": "הָאִ֥ישׁ", "transliteral": "hā-ʾîš", "traducao_palavra": "o homem" },
        { "hebraico": "אֲשֶׁר־שָׁכַ֥ב", "transliteral": "ʾă-šer-šā-ḵaḇ", "traducao_palavra": "que se deitou" },
        { "hebraico": "עִמָּ֖הּ", "transliteral": "ʿim-māh", "traducao_palavra": "com ela" },
        { "hebraico": "לְבַדֹּֽו׃", "transliteral": "lə-base-dô", "traducao_palavra": "sozinho" }
      ]
    },
    "26": {
      "traducao_completa": "E à moça não farás nada; a moça não tem pecado digno de morte; pois, como o homem que se levanta contra o seu próximo e lhe tira a vida, assim é este negócio.",
      "palavras": [
        { "hebraico": "וְלַנַּעֲרָה֙", "transliteral": "wə-lan-na-ʿă-rā", "traducao_palavra": "e à moça" },
        { "hebraico": "לֹא־תַעֲשֶׂ֣ה", "transliteral": "lō-ṯa-ʿă-śeh", "traducao_palavra": "não farás" },
        { "hebraico": "דָּבָ֔ר", "transliteral": "dā-ḇār", "traducao_palavra": "coisa/nada" },
        { "hebraico": "אֵ֥ין", "transliteral": "ʾên", "traducao_palavra": "não tem" },
        { "hebraico": "לַנַּעֲרָ֖ה", "transliteral": "lan-na-ʿă-rā", "traducao_palavra": "a moça" },
        { "hebraico": "חֵ֣טְא", "transliteral": "ḥē-ṭə-ʾ", "traducao_palavra": "pecado" },
        { "hebraico": "מָ֑וֶת", "transliteral": "mā-weṯ", "traducao_palavra": "[de] morte" },
        { "hebraico": "כִּ֡י", "transliteral": "kî", "traducao_palavra": "pois" },
        { "hebraico": "כַּאֲשֶׁר֩", "transliteral": "ka-ʾă-šer", "traducao_palavra": "como" },
        { "hebraico": "יָק֨וּם", "transliteral": "yā-qûm", "traducao_palavra": "se levanta" },
        { "hebraico": "אִ֜ישׁ", "transliteral": "ʾîš", "traducao_palavra": "um homem" },
        { "hebraico": "עַל־רֵעֵ֙הוּ֙", "transliteral": "ʿal-rē-ʿē-hû", "traducao_palavra": "contra seu próximo" },
        { "hebraico": "וּרְצָחֹ֣ו", "transliteral": "ū-rə-ṣā-ḥô", "traducao_palavra": "e o mata" },
        { "hebraico": "נֶ֔פֶשׁ", "transliteral": "ne-p̄eš", "traducao_palavra": "[na] alma/vida" },
        { "hebraico": "כֵּ֖ן", "transliteral": "kên", "traducao_palavra": "assim" },
        { "hebraico": "הַדָּבָ֥ר", "transliteral": "had-dā-ḇār", "traducao_palavra": "o negócio/palavra" },
        { "hebraico": "הַזֶּֽה׃", "transliteral": "haz-zeh", "traducao_palavra": "esta" }
      ]
    },
    "27": {
      "traducao_completa": "Pois a achou no campo; a moça desposada gritou, e não houve quem a livrasse.",
      "palavras": [
        { "hebraico": "כִּ֥י", "transliteral": "kî", "traducao_palavra": "pois" },
        { "hebraico": "בַשָּׂדֶ֖ה", "transliteral": "baś-śā-ḏeh", "traducao_palavra": "no campo" },
        { "hebraico": "מְצָאָ֑הּ", "transliteral": "mə-ṣā-ʾāh", "traducao_palavra": "achou-a" },
        { "hebraico": "צָעֲקָ֗ה", "transliteral": "ṣā-ʿă-qā", "traducao_palavra": "gritou" },
        { "hebraico": "הַנַּעֲרָה֙", "transliteral": "han-na-ʿă-rā", "traducao_palavra": "a moça" },
        { "hebraico": "הַמְאֹרָשָׂ֔ה", "transliteral": "ham-ʾō-rā-śā", "traducao_palavra": "desposada" },
        { "hebraico": "וְאֵ֥ין", "transliteral": "wə-ʾên", "traducao_palavra": "e não houve" },
        { "hebraico": "מֹושִׁ֖יעַ", "transliteral": "mô-šî-aʿ", "traducao_palavra": "salvador/quem livrasse" },
        { "hebraico": "לָֽהּ׃", "transliteral": "lāh", "traducao_palavra": "a ela" }
      ]
    },
    "28": {
      "traducao_completa": "Quando um homem achar moça virgem, que não for desposada, e pegar nela, e se deitar com ela, e forem achados,",
      "palavras": [
        { "hebraico": "כִּֽי־יִמְצָ֣א", "transliteral": "kî-yim-ṣā", "traducao_palavra": "quando achar" },
        { "hebraico": "אִ֗ישׁ", "transliteral": "ʾîš", "traducao_palavra": "um homem" },
        { "hebraico": "נַעֲרָ֤ה", "transliteral": "na-ʿă-rā", "traducao_palavra": "uma moça" },
        { "hebraico": "בְתוּלָה֙", "transliteral": "ḇə-ṯû-lā", "traducao_palavra": "virgem" },
        { "hebraico": "אֲשֶׁ֣ר", "transliteral": "ʾă-šer", "traducao_palavra": "que" },
        { "hebraico": "לֹא־אֹרָ֔שָׂה", "transliteral": "lō-ʾō-rā-śā", "traducao_palavra": "não foi desposada" },
        { "hebraico": "וּתְפָשָׂ֖הּ", "transliteral": "ū-ṯə-p̄ā-śāh", "traducao_palavra": "e pegar nela" },
        { "hebraico": "וְשָׁכַ֣ב", "transliteral": "wə-šā-ḵaḇ", "traducao_palavra": "e deitar" },
        { "hebraico": "עִמָּ֑הּ", "transliteral": "ʿim-māh", "traducao_palavra": "com ela" },
        { "hebraico": "וְנִמְצָֽאוּ׃", "transliteral": "wə-nim-ṣā-ʾû", "traducao_palavra": "e forem achados" }
      ]
    },
    "29": {
      "traducao_completa": "Então o homem que se deitou com ela dará ao pai da moça cinquenta siclos de prata; e ela ficará sendo sua mulher, porquanto a humilhou; não a poderá despedir em todos os seus dias.",
      "palavras": [
        { "hebraico": "וְנָתַ֨ן", "transliteral": "wə-nā-ṯan", "traducao_palavra": "e dará" },
        { "hebraico": "הָאִ֜ישׁ", "transliteral": "hā-ʾîš", "traducao_palavra": "o homem" },
        { "hebraico": "הַשֹּׁכֵ֣ב", "transliteral": "haš-šō-ḵēḇ", "traducao_palavra": "o que deitou" },
        { "hebraico": "עִמָּהּ֮", "transliteral": "ʿim-māh", "traducao_palavra": "com ela" },
        { "hebraico": "לַאֲבִ֣י", "transliteral": "la-ʾă-ḇî", "traducao_palavra": "ao pai de" },
        { "hebraico": "הַנַּעֲרָה֒", "transliteral": "han-na-ʿă-rā", "traducao_palavra": "a moça" },
        { "hebraico": "חֲמִשִּׁ֖ים", "transliteral": "ḥă-miš-śîm", "traducao_palavra": "cinquenta" },
        { "hebraico": "כָּ֑סֶף", "transliteral": "kā-sep̄", "traducao_palavra": "[siclos de] prata" },
        { "hebraico": "וְלֹו־תִהְיֶ֣ה", "transliteral": "wə-lô-ṯih-yeh", "traducao_palavra": "e será para ele" },
        { "hebraico": "לְאִשָּׁ֗ה", "transliteral": "lə-ʾiš-šā", "traducao_palavra": "por mulher" },
        { "hebraico": "תַּ֚חַת", "transliteral": "ta-ḥaṯ", "traducao_palavra": "porque/visto que" },
        { "hebraico": "אֲשֶׁ֣ר", "transliteral": "ʾă-šer", "traducao_palavra": "[que]" },
        { "hebraico": "עִנָּ֔הּ", "transliteral": "ʿin-nāh", "traducao_palavra": "humilhou-a" },
        { "hebraico": "לֹא־יוּכַ֥ל", "transliteral": "lō-yû-ḵal", "traducao_palavra": "não poderá" },
        { "hebraico": "שַׁלְּחָ֖הּ", "transliteral": "šal-lə-ḥāh", "traducao_palavra": "despedi-la" },
        { "hebraico": "כָּל־יָמָֽיו׃", "transliteral": "kāl-yā-māyw", "traducao_palavra": "todos os seus dias" }
      ]
    },
    "30": {
      "traducao_completa": "Nenhum homem tomará a mulher de seu pai, nem levantará a cobertura de seu pai.",
      "palavras": [
        { "hebraico": "לֹא־יִקַּ֥ח", "transliteral": "lō-yiq-qaḥ", "traducao_palavra": "não tomará" },
        { "hebraico": "אִ֖ישׁ", "transliteral": "ʾîš", "traducao_palavra": "homem" },
        { "hebraico": "אֶת־אֵ֣שֶׁת", "transliteral": "ʾeṯ-ʾê-šeṯ", "traducao_palavra": "a mulher de" },
        { "hebraico": "אָבִ֑יו", "transliteral": "ʾā-ḇîw", "traducao_palavra": "seu pai" },
        { "hebraico": "וְלֹ֥א", "transliteral": "wə-lō", "traducao_palavra": "e não" },
