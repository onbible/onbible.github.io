        { "hebraico": "קָרֹ֥וב", "transliteral": "qā-rôḇ", "traducao_palavra": "perto" },
        { "hebraico": "אָחִ֛יךָ", "transliteral": "ʾā-ḥî-ḵā", "traducao_palavra": "teu irmão" },
        { "hebraico": "אֵלֶ֖יךָ", "transliteral": "ʾê-le-ḵā", "traducao_palavra": "de ti" },
        { "hebraico": "וְלֹ֣א", "transliteral": "wə-lō", "traducao_palavra": "e não" },
        { "hebraico": "יְדַעְתֹּ֑ו", "transliteral": "yə-ḏa-ʿtô", "traducao_palavra": "conheceres ele" },
        { "hebraico": "וַאֲסַפְתֹּו֙", "transliteral": "wa-ʾă-sap̄-tô", "traducao_palavra": "recolhê-lo-ás" },
        { "hebraico": "אֶל־תֹּ֣וךְ", "transliteral": "ʾel-tôḵ", "traducao_palavra": "para o meio de" },
        { "hebraico": "בֵּיתֶ֔ךָ", "transliteral": "bê-ṯe-ḵā", "traducao_palavra": "tua casa" },
        { "hebraico": "וְהָיָ֣ה", "transliteral": "wə-hā-yā", "traducao_palavra": "e estará" },
        { "hebraico": "עִמְּךָ֗", "transliteral": "ʿim-mə-ḵā", "traducao_palavra": "contigo" },
        { "hebraico": "עַ֣ד", "transliteral": "ʿaḏ", "traducao_palavra": "até" },
        { "hebraico": "דְּרֹ֥שׁ", "transliteral": "də-rōš", "traducao_palavra": "[o] buscar" },
        { "hebraico": "אָחִ֛יךָ", "transliteral": "ʾā-ḥî-ḵā", "traducao_palavra": "teu irmão" },
        { "hebraico": "אֹתֹ֖ו", "transliteral": "ʾō-ṯô", "traducao_palavra": "ele" },
        { "hebraico": "וַהֲשֵׁבֹתֹ֥ו", "transliteral": "wa-hă-šê-ḇō-ṯô", "traducao_palavra": "e lho restituirás" },
        { "hebraico": "לֹֽו׃", "transliteral": "lô", "traducao_palavra": "a ele" }
      ]
    },
    "3": {
      "traducao_completa": "E assim farás com o seu jumento, e assim farás com a sua roupa; e assim farás com toda a coisa perdida de teu irmão, que se lhe perder, e tu a achares; não te poderás desviar.",
      "palavras": [
        { "hebraico": "וְכֵ֧ן", "transliteral": "wə-ḵên", "traducao_palavra": "e assim" },
        { "hebraico": "תַּעֲשֶׂ֣ה", "transliteral": "ta-ʿă-śeh", "traducao_palavra": "farás" },
        { "hebraico": "לַחֲמֹרֹ֗ו", "transliteral": "la-ḥă-mō-rô", "traducao_palavra": "ao jumento dele" },
        { "hebraico": "וְכֵ֣ן", "transliteral": "wə-ḵên", "traducao_palavra": "e assim" },
        { "hebraico": "תַּעֲשֶׂה֮", "transliteral": "ta-ʿă-śeh", "traducao_palavra": "farás" },
        { "hebraico": "לְשִׂמְלָתֹו֒", "transliteral": "lə-śim-lā-ṯô", "traducao_palavra": "à roupa dele" },
        { "hebraico": "וְכֵ֣ן", "transliteral": "wə-ḵên", "traducao_palavra": "e assim" },
        { "hebraico": "תַּעֲשֶׂה֮", "transliteral": "ta-ʿă-śeh", "traducao_palavra": "farás" },
        { "hebraico": "לְכָל־אֲבֵדַ֣ת", "transliteral": "lə-ḵāl-ʾă-ḇê-ḏaṯ", "traducao_palavra": "com toda a perda de" },
        { "hebraico": "אָחִ֪יךָ", "transliteral": "ʾā-ḥî-ḵā", "traducao_palavra": "teu irmão" },
        { "hebraico": "אֲשֶׁר־תֹּאבַ֥ד", "transliteral": "ʾă-šer-tō-ḇaḏ", "traducao_palavra": "que se perder" },
        { "hebraico": "מִמֶּ֛נּוּ", "transliteral": "mim-men-nū", "traducao_palavra": "dele" },
        { "hebraico": "וּמְצָאתָ֖הּ", "transliteral": "ū-mə-ṣā-ṯāh", "traducao_palavra": "e tu a achares" },
        { "hebraico": "לֹ֥א", "transliteral": "lō", "traducao_palavra": "não" },
