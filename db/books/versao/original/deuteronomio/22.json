        { "hebraico": "בֵיצִים֒", "transliteral": "ḇê-ṣîm", "traducao_palavra": "ovos" },
        { "hebraico": "וְהָאֵ֤ם", "transliteral": "wə-hā-ʾēm", "traducao_palavra": "e a mãe" },
        { "hebraico": "רֹבֶ֙צֶת֙", "transliteral": "rō-ḇe-ṣeṯ", "traducao_palavra": "deitada/posta" },
        { "hebraico": "עַל־הָֽאֶפְרֹחִ֔ים", "transliteral": "ʿal-hā-ʾep̄-rō-ḥîm", "traducao_palavra": "sobre os passarinhos" },
        { "hebraico": "אֹ֖ו", "transliteral": "ʾô", "traducao_palavra": "ou" },
