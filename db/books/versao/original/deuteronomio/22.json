        { "hebraico": "עִמֹּֽו׃", "transliteral": "ʿim-mô", "traducao_palavra": "com ele" }
      ]
    },
    "5": {
      "traducao_completa": "Não haverá traje de homem na mulher, e não vestirá o homem veste de mulher; porque qualquer que faz isto, abominação é a YHWH teu Deus.",
      "palavras": [
        { "hebraico": "לֹא־יִהְיֶ֤ה", "transliteral": "lō-yih-yeh", "traducao_palavra": "não haverá" },
        { "hebraico": "כְלִי־גֶ֙בֶר֙", "transliteral": "ḵəlî-ḡe-ḇer", "traducao_palavra": "traje/objeto de homem" },
        { "hebraico": "עַל־אִשָּׁ֔ה", "transliteral": "ʿal-ʾiš-šā", "traducao_palavra": "sobre mulher" },
        { "hebraico": "וְלֹא־יִלְבַּ֥שׁ", "transliteral": "wə-lō-yil-baš", "traducao_palavra": "e não vestirá" },
        { "hebraico": "גֶּ֖בֶר", "transliteral": "ge-ḇer", "traducao_palavra": "[o] homem" },
        { "hebraico": "שִׂמְלַ֣ת", "transliteral": "śim-laṯ", "traducao_palavra": "veste de" },
        { "hebraico": "אִשָּׁ֑ה", "transliteral": "ʾiš-šā", "traducao_palavra": "mulher" },
        { "hebraico": "כִּ֧י", "transliteral": "kî", "traducao_palavra": "porque" },
        { "hebraico": "תֹועֲבַ֛ת", "transliteral": "ṯô-ʿă-ḇaṯ", "traducao_palavra": "[é] abominação de" },
        { "hebraico": "יְהוָ֥ה", "transliteral": "YHWH", "traducao_palavra": "YHWH" },
        { "hebraico": "אֱלֹהֶ֖יךָ", "transliteral": "ʾĕ-lō-he-ḵā", "traducao_palavra": "teu Deus" },
        { "hebraico": "כָּל־עֹ֥שֵׂה", "transliteral": "kāl-ʿō-śēh", "traducao_palavra": "todo o que faz" },
        { "hebraico": "אֵֽלֶּה׃", "transliteral": "ʾēl-leh", "traducao_palavra": "estas [coisas]" }
      ]
