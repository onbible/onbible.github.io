{
  "livro": "Deuteronômio - דְּבָרִים - Devarim",
  "capítulo": 22,
  "titulos": {},
  "versiculos": {
    "1": {
      "traducao_completa": "Não verás o boi de teu irmão, ou a sua ovelha, desgarrados, e te desviarás deles; certamente os reconduzirás a teu irmão.",
      "palavras": [
        { "hebraico": "לֹא־תִרְאֶה֩", "transliteral": "lō-ṯir-ʾeh", "traducao_palavra": "não verás" },
        { "hebraico": "אֶת־שֹׁ֨ור", "transliteral": "ʾeṯ-šôr", "traducao_palavra": "o boi de" },
        { "hebraico": "אָחִ֜יךָ", "transliteral": "ʾā-ḥî-ḵā", "traducao_palavra": "teu irmão" },
        { "hebraico": "אֹ֤ו", "transliteral": "ʾô", "traducao_palavra": "ou" },
        { "hebraico": "אֶת־שְׂיֹו֙", "transliteral": "ʾeṯ-śê-yô", "traducao_palavra": "sua ovelha" },
        { "hebraico": "נִדָּחִ֔ים", "transliteral": "nid-dā-ḥîm", "traducao_palavra": "desgarrados" },
        { "hebraico": "וְהִתְעַלַּמְתָּ֖", "transliteral": "wə-hiṯ-ʿal-lam-tā", "traducao_palavra": "e te esconderás/desviarás" },
        { "hebraico": "מֵהֶ֑ם", "transliteral": "mê-hem", "traducao_palavra": "deles" },
        { "hebraico": "הָשֵׁ֥ב", "transliteral": "hā-šēḇ", "traducao_palavra": "retornando" },
        { "hebraico": "תְּשִׁיבֵ֖ם", "transliteral": "tə-šî-ḇēm", "traducao_palavra": "certamente os reconduzirás" },
        { "hebraico": "לְאָחִֽיךָ׃", "transliteral": "lə-ʾā-ḥî-ḵā", "traducao_palavra": "a teu irmão" }
      ]
    },
    "2": {
      "traducao_completa": "E se teu irmão não estiver perto de ti, ou tu não o conheceres, recolhê-los-ás na tua casa, e estarão contigo até que teu irmão os busque, e lhos restituirás.",
      "palavras": [
