    "6": {
      "traducao_completa": "Quando encontrares pelo caminho um ninho de ave em alguma árvore, ou no chão, com passarinhos ou ovos, e a mãe posta sobre os passarinhos ou sobre os ovos, não tomarás a mãe com os filhos;",
      "palavras": [
        { "hebraico": "כִּ֣י", "transliteral": "kî", "traducao_palavra": "quando" },
        { "hebraico": "יִקָּרֵ֨א", "transliteral": "yiq-qā-rē", "traducao_palavra": "se encontrar" },
        { "hebraico": "קַן־צִפֹּ֨ור", "transliteral": "qan-ṣip-pôr", "traducao_palavra": "ninho de ave" },
        { "hebraico": "לְפָנֶ֜יךָ", "transliteral": "lə-p̄ā-ne-ḵā", "traducao_palavra": "diante de ti" },
        { "hebraico": "בַּדֶּ֗רֶךְ", "transliteral": "bad-de-reḵ", "traducao_palavra": "no caminho" },
        { "hebraico": "בְּכָל־עֵץ֮", "transliteral": "bə-ḵāl-ʿēṣ", "traducao_palavra": "em toda árvore" },
        { "hebraico": "אֹ֣ו", "transliteral": "ʾô", "traducao_palavra": "ou" },
        { "hebraico": "עַל־הָאָרֶץ֒", "transliteral": "ʿal-hā-ʾā-reṣ", "traducao_palavra": "sobre a terra" },
        { "hebraico": "אֶפְרֹחִים֮", "transliteral": "ʾep̄-rō-ḥîm", "traducao_palavra": "pintinhos/passarinhos" },
