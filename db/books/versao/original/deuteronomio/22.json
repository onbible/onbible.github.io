      ]
    },
    "8": {
      "traducao_completa": "Quando edificares casa nova, farás um parapeito no teu telhado, para que não ponhas sangue na tua casa, se alguém de lá cair.",
      "palavras": [
        { "hebraico": "כִּ֤י", "transliteral": "kî", "traducao_palavra": "quando" },
        { "hebraico": "תִבְנֶה֙", "transliteral": "ṯiḇ-neh", "traducao_palavra": "edificares" },
        { "hebraico": "בַּ֣יִת", "transliteral": "ba-yiṯ", "traducao_palavra": "casa" },
        { "hebraico": "חָדָ֔שׁ", "transliteral": "ḥā-ḏāš", "traducao_palavra": "nova" },
        { "hebraico": "וְעָשִׂ֥יתָ", "transliteral": "wə-ʿā-śî-ṯā", "traducao_palavra": "e farás" },
        { "hebraico": "מַעֲקֶ֖ה", "transliteral": "ma-ʿă-qeh", "traducao_palavra": "um parapeito/mureta" },
        { "hebraico": "לְגַגֶּ֑ךָ", "transliteral": "lə-ḡag-ge-ḵā", "traducao_palavra": "para o teu telhado" },
        { "hebraico": "וְלֹֽא־תָשִׂ֤ים", "transliteral": "wə-lō-ṯā-śîm", "traducao_palavra": "e não porás" },
        { "hebraico": "דָּמִים֙", "transliteral": "dā-mîm", "traducao_palavra": "sangues/culpa de sangue" },
        { "hebraico": "בְּבֵיתֶ֔ךָ", "transliteral": "bə-ḇê-ṯe-ḵā", "traducao_palavra": "em tua casa" },
        { "hebraico": "כִּֽי־יִפֹּ֥ל", "transliteral": "kî-yip-pōl", "traducao_palavra": "se cair" },
        { "hebraico": "הַנֹּפֵ֖ל", "transliteral": "han-nō-p̄ēl", "traducao_palavra": "o que cai" },
        { "hebraico": "מִמֶּֽנּוּ׃", "transliteral": "mim-men-nū", "traducao_palavra": "dele" }
      ]
    },
    "9": {
      "traducao_completa": "Não semearás a tua vinha com sementes diversas, para que não se corrompa o fruto da semente que semeares e o produto da vinha.",
      "palavras": [
        { "hebraico": "לֹא־תִזְרַ֥ע", "transliteral": "lō-ṯiz-raʿ", "traducao_palavra": "não semearás" },
        { "hebraico": "כַּרְמְךָ֖", "transliteral": "kar-mə-ḵā", "traducao_palavra": "tua vinha" },
        { "hebraico": "כִּלְאָ֑יִם", "transliteral": "kil-ʾay-im", "traducao_palavra": "[com] mistura/duas espécies" },
        { "hebraico": "פֶּן־תִּקְדַּ֗שׁ", "transliteral": "pen-tiq-daš", "traducao_palavra": "para que não seja consagrado/corrompido" },
        { "hebraico": "הַמְלֵאָ֤ה", "transliteral": "ham-lê-ʾā", "traducao_palavra": "a plenitude de" },
        { "hebraico": "הַזֶּ֙רַע֙", "transliteral": "haz-ze-raʿ", "traducao_palavra": "a semente" },
        { "hebraico": "אֲשֶׁ֣ר", "transliteral": "ʾă-šer", "traducao_palavra": "que" },
        { "hebraico": "תִּזְרָ֔ע", "transliteral": "tiz-rāʿ", "traducao_palavra": "semearás" },
        { "hebraico": "וּתְבוּאַ֖ת", "transliteral": "ū-ṯə-ḇû-ʾaṯ", "traducao_palavra": "e o produto de" },
        { "hebraico": "הַכָּֽרֶם׃", "transliteral": "hak-kā-rem", "traducao_palavra": "a vinha" }
      ]
    },
    "10": {
      "traducao_completa": "Não lavrarás com boi e jumento juntamente.",
      "palavras": [
        { "hebraico": "לֹא־תַחֲרֹ֥שׁ", "transliteral": "lō-ṯa-ḥă-rōš", "traducao_palavra": "não lavrarás" },
        { "hebraico": "בְּשֹׁור־וּבַחֲמֹ֖ר", "transliteral": "bə-šôr-ū-ḇa-ḥă-mōr", "traducao_palavra": "com boi e jumento" },
        { "hebraico": "יַחְדָּֽו׃", "transliteral": "yaḥ-dāw", "traducao_palavra": "juntamente" }
      ]
    },
    "11": {
      "traducao_completa": "Não vestirás roupa de diversos estofos, de lã e linho juntamente.",
