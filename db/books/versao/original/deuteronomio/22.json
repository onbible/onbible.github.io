        { "hebraico": "הָאֵ֖ם", "transliteral": "hā-ʾēm", "traducao_palavra": "a mãe" },
        { "hebraico": "עַל־הַבָּנִֽים׃", "transliteral": "ʿal-hab-bā-nîm", "traducao_palavra": "com os filhos" }
      ]
    },
    "7": {
      "traducao_completa": "Deixando, deixarás ir a mãe, e os filhos tomarás para ti; para que bem te suceda, e prolongues os teus dias.",
      "palavras": [
        { "hebraico": "שַׁלֵּ֤חַ", "transliteral": "šal-lē-aḥ", "traducao_palavra": "soltando" },
        { "hebraico": "תְּשַׁלַּח֙", "transliteral": "tə-šal-laḥ", "traducao_palavra": "soltarás" },
        { "hebraico": "אֶת־הָאֵ֔ם", "transliteral": "ʾeṯ-hā-ʾēm", "traducao_palavra": "a mãe" },
        { "hebraico": "וְאֶת־הַבָּנִ֖ים", "transliteral": "wə-ʾeṯ-hab-bā-nîm", "traducao_palavra": "e os filhos" },
        { "hebraico": "תִּֽקַּח־לָ֑ךְ", "transliteral": "tiq-qaḥ-lāḵ", "traducao_palavra": "tomarás para ti" },
        { "hebraico": "לְמַ֤עַן׀", "transliteral": "lə-ma-ʿan", "traducao_palavra": "para que" },
        { "hebraico": "יִיטַ֣ב", "transliteral": "yî-ṭaḇ", "traducao_palavra": "bem vá" },
