        { "hebraico": "בְּיָדֶ֑ךָ", "transliteral": "bə-yā-ḏe-ḵā", "traducao_palavra": "na tua mão" },
        { "hebraico": "וְהִכִּיתָ֥", "transliteral": "wə-hik-kî-ṯā", "traducao_palavra": "e ferirás" },
        { "hebraico": "אֶת־כָּל־זְכוּרָ֖הּ", "transliteral": "ʾeṯ-kāl-zə-ḵû-rāh", "traducao_palavra": "a todo o macho/varão dela" },
        { "hebraico": "לְפִי־חָֽרֶב׃", "transliteral": "lə-p̄î-ḥā-reḇ", "traducao_palavra": "ao fio da espada" }
      ]
    },
    "14": {
      "traducao_completa": "Salvo as mulheres, e os meninos, e o gado, e tudo o que houver na cidade, todo o seu despojo tomarás para ti; e comerás o despojo dos teus inimigos, que YHWH teu Deus te deu.",
      "palavras": [
