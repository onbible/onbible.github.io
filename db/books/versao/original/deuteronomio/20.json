        { "hebraico": "הַנָּשִׁ֣ים", "transliteral": "han-nā-šîm", "traducao_palavra": "as mulheres" },
        { "hebraico": "וְהַטַּף֩", "transliteral": "wə-ha-ṭap̄", "traducao_palavra": "e as crianças/meninos" },
        { "hebraico": "וְהַבְּהֵמָ֨ה", "transliteral": "wə-hab-bə-hē-mā", "traducao_palavra": "e o gado" },
