{
  "livro": "Deuteronômio - דְּבָרִים - Devarim",
  "capítulo": 20,
  "titulos": {},
  "versiculos": {
    "1": {
      "traducao_completa": "Quando saíres à peleja contra os teus inimigos, e vires cavalos, e carros, e povo maior em número do que tu, não os temerás; pois YHWH teu Deus, que te tirou da terra do Egito, está contigo.",
      "palavras": [
        { "hebraico": "כִּֽי־תֵצֵ֨א", "transliteral": "kî-ṯē-ṣē", "traducao_palavra": "quando saíres" },
        { "hebraico": "לַמִּלְחָמָ֜ה", "transliteral": "lam-mil-ḥā-mā", "traducao_palavra": "para a guerra" },
        { "hebraico": "עַל־אֹיְבֶ֗יךָ", "transliteral": "ʿal-ʾō-yə-ḇe-ḵā", "traducao_palavra": "contra teus inimigos" },
        { "hebraico": "וְרָאִ֜יתָ", "transliteral": "wə-rā-ʾî-ṯā", "traducao_palavra": "e vires" },
        { "hebraico": "ס֤וּס", "transliteral": "śûs", "traducao_palavra": "cavalo" },
        { "hebraico": "וָרֶ֙כֶב֙", "transliteral": "wā-re-ḵeḇ", "traducao_palavra": "e carro" },
        { "hebraico": "עַ֚ם", "transliteral": "ʿam", "traducao_palavra": "povo" },
        { "hebraico": "רַ֣ב", "transliteral": "rab", "traducao_palavra": "numeroso" },
        { "hebraico": "מִמְּךָ֔", "transliteral": "mim-mə-ḵā", "traducao_palavra": "mais que tu" },
        { "hebraico": "לֹ֥א", "transliteral": "lō", "traducao_palavra": "não" },
        { "hebraico": "תִירָ֖א", "transliteral": "ṯî-rā", "traducao_palavra": "temerás" },
        { "hebraico": "מֵהֶ֑ם", "transliteral": "mê-hem", "traducao_palavra": "deles" },
        { "hebraico": "כִּֽי־יְהוָ֤ה", "transliteral": "kî-YHWH", "traducao_palavra": "pois YHWH" },
        { "hebraico": "אֱלֹהֶ֙יךָ֙", "transliteral": "ʾĕ-lō-he-ḵā", "traducao_palavra": "teu Deus" },
        { "hebraico": "עִמָּ֔ךְ", "transliteral": "ʿim-māḵ", "traducao_palavra": "[está] contigo" },
        { "hebraico": "הַמַּֽעֲלְךָ֖", "transliteral": "ham-ma-ʿă-lə-ḵā", "traducao_palavra": "quem te fez subir" },
        { "hebraico": "מֵאֶ֥רֶץ", "transliteral": "mê-ʾe-reṣ", "traducao_palavra": "da terra de" },
        { "hebraico": "מִצְרָֽיִם׃", "transliteral": "miṣ-rā-yim", "traducao_palavra": "Egito" }
      ]
    },
    "2": {
      "traducao_completa": "E será que, quando vos chegardes à peleja, o sacerdote se chegará e falará ao povo,",
      "palavras": [
        { "hebraico": "וְהָיָ֕ה", "transliteral": "wə-hā-yā", "traducao_palavra": "e será" },
        { "hebraico": "כְּקָרָבְכֶ֖ם", "transliteral": "kə-qā-rā-ḇə-ḵem", "traducao_palavra": "ao vos aproximardes" },
        { "hebraico": "אֶל־הַמִּלְחָמָ֑ה", "transliteral": "ʾel-ham-mil-ḥā-mā", "traducao_palavra": "da peleja" },
        { "hebraico": "וְנִגַּ֥שׁ", "transliteral": "wə-nig-gaš", "traducao_palavra": "e se aproximará" },
        { "hebraico": "הַכֹּהֵ֖ן", "transliteral": "hak-kō-hên", "traducao_palavra": "o sacerdote" },
        { "hebraico": "וְדִבֶּ֥ר", "transliteral": "wə-ḏib-ber", "traducao_palavra": "e falará" },
        { "hebraico": "אֶל־הָעָֽם׃", "transliteral": "ʾel-hā-ʿām", "traducao_palavra": "ao povo" }
      ]
    },
    "3": {
      "traducao_completa": "E dir-lhes-á: Ouve, ó Israel, vós hoje vos achegais à peleja contra os vossos inimigos; não se amoleça o vosso coração; não temais, nem tremais, nem vos aterrorizeis diante deles,",
      "palavras": [
        { "hebraico": "וְאָמַ֣ר", "transliteral": "wə-ʾā-mar", "traducao_palavra": "e dirá" },
        { "hebraico": "אֲלֵהֶ֗ם", "transliteral": "ʾă-lê-hem", "traducao_palavra": "a eles" },
        { "hebraico": "שְׁמַ֣ע", "transliteral": "šə-maʿ", "traducao_palavra": "ouve" },
        { "hebraico": "יִשְׂרָאֵ֔ל", "transliteral": "yiś-rā-ʾēl", "traducao_palavra": "Israel" },
        { "hebraico": "אַתֶּ֨ם", "transliteral": "ʾat-tem", "traducao_palavra": "vós" },
        { "hebraico": "קְרֵבִ֥ים", "transliteral": "qə-rē-ḇîm", "traducao_palavra": "estais aproximando" },
        { "hebraico": "הַיֹּ֖ום", "transliteral": "hay-yôm", "traducao_palavra": "hoje" },
        { "hebraico": "לַמִּלְחָמָ֥ה", "transliteral": "lam-mil-ḥā-mā", "traducao_palavra": "para a peleja" },
        { "hebraico": "עַל־אֹיְבֵיכֶ֑ם", "transliteral": "ʿal-ʾō-yə-ḇê-ḵem", "traducao_palavra": "contra vossos inimigos" },
        { "hebraico": "אַל־יֵרַ֣ךְ", "transliteral": "ʾal-yē-raḵ", "traducao_palavra": "não amoleça" },
        { "hebraico": "לְבַבְכֶ֗ם", "transliteral": "lə-ḇaḇ-ḵem", "traducao_palavra": "vosso coração" },
        { "hebraico": "אַל־תִּֽירְא֧וּ", "transliteral": "ʾal-tî-rə-ʾû", "traducao_palavra": "não temais" },
        { "hebraico": "וְאַל־תַּחְפְּז֛וּ", "transliteral": "wə-ʾal-taḥ-pə-zû", "traducao_palavra": "e não vos apresseis/tremais" },
        { "hebraico": "וְאַל־תַּעַרְצ֖וּ", "transliteral": "wə-ʾal-ta-ʿar-ṣû", "traducao_palavra": "e não vos aterrorizeis" },
        { "hebraico": "מִפְּנֵיהֶֽם׃", "transliteral": "mip-pə-nê-hem", "traducao_palavra": "diante das faces deles" }
      ]
    },
    "4": {
      "traducao_completa": "Pois YHWH vosso Deus é o que vai convosco, a pelejar por vós contra os vossos inimigos, para vos salvar.",
      "palavras": [
        { "hebraico": "כִּ֚י", "transliteral": "kî", "traducao_palavra": "pois" },
        { "hebraico": "יְהוָ֣ה", "transliteral": "YHWH", "traducao_palavra": "YHWH" },
        { "hebraico": "אֱלֹהֵיכֶ֔ם", "transliteral": "ʾĕ-lō-hê-ḵem", "traducao_palavra": "vosso Deus" },
        { "hebraico": "הַהֹלֵ֖ךְ", "transliteral": "ha-hō-lēḵ", "traducao_palavra": "[é] o que vai" },
        { "hebraico": "עִמָּכֶ֑ם", "transliteral": "ʿim-mā-ḵem", "traducao_palavra": "convosco" },
        { "hebraico": "לְהִלָּחֵ֥ם", "transliteral": "lə-hil-lā-ḥēm", "traducao_palavra": "para pelejar" },
        { "hebraico": "לָכֶ֛ם", "transliteral": "lā-ḵem", "traducao_palavra": "por vós" },
        { "hebraico": "עִם־אֹיְבֵיכֶ֖ם", "transliteral": "ʿim-ʾō-yə-ḇê-ḵem", "traducao_palavra": "com vossos inimigos" },
        { "hebraico": "לְהֹושִׁ֥יעַ", "transliteral": "lə-hô-šî-aʿ", "traducao_palavra": "para salvar" },
        { "hebraico": "אֶתְכֶֽם׃", "transliteral": "ʾeṯ-ḵem", "traducao_palavra": "vós" }
      ]
    },
    "5": {
      "traducao_completa": "Então os oficiais falarão ao povo, dizendo: Qual é o homem que edificou casa nova e ainda não a consagrou? Vá, e torne-se à sua casa, para que porventura não morra na peleja e outro a consagre.",
      "palavras": [
        { "hebraico": "וְדִבְּר֣וּ", "transliteral": "wə-ḏib-bə-rû", "traducao_palavra": "e falarão" },
        { "hebraico": "הַשֹּֽׁטְרִים֮", "transliteral": "haš-šō-ṭə-rîm", "traducao_palavra": "os oficiais" },
        { "hebraico": "אֶל־הָעָ֣ם", "transliteral": "ʾel-hā-ʿām", "traducao_palavra": "ao povo" },
        { "hebraico": "לֵאמֹר֒", "transliteral": "lê-mōr", "traducao_palavra": "dizendo" },
        { "hebraico": "מִֽי־הָאִ֤ישׁ", "transliteral": "mî-hā-ʾîš", "traducao_palavra": "quem [é] o homem?" },
        { "hebraico": "אֲשֶׁר֩", "transliteral": "ʾă-šer", "traducao_palavra": "que" },
        { "hebraico": "בָּנָ֨ה", "transliteral": "bā-nā", "traducao_palavra": "edificou" },
        { "hebraico": "בַיִת־חָדָ֜שׁ", "transliteral": "ba-yiṯ-ḥā-ḏāš", "traducao_palavra": "casa nova" },
        { "hebraico": "וְלֹ֣א", "transliteral": "wə-lō", "traducao_palavra": "e não" },
        { "hebraico": "חֲנָכֹ֗ו", "transliteral": "ḥă-nā-ḵô", "traducao_palavra": "a consagrou" },
        { "hebraico": "יֵלֵךְ֙", "transliteral": "yē-lēḵ", "traducao_palavra": "vá" },
        { "hebraico": "וְיָשֹׁ֣ב", "transliteral": "wə-yā-šōḇ", "traducao_palavra": "e retorne" },
        { "hebraico": "לְבֵיתֹו", "transliteral": "lə-ḇê-ṯô", "traducao_palavra": "à sua casa" },
        { "hebraico": "פֶּן־יָמוּת֙", "transliteral": "pen-yā-mûṯ", "traducao_palavra": "para que não morra" },
        { "hebraico": "בַּמִּלְחָמָ֔ה", "transliteral": "bam-mil-ḥā-mā", "traducao_palavra": "na guerra" },
        { "hebraico": "וְאִ֥ישׁ", "transliteral": "wə-ʾîš", "traducao_palavra": "e homem" },
        { "hebraico": "אַחֵ֖ר", "transliteral": "ʾa-ḥēr", "traducao_palavra": "outro" },
        { "hebraico": "יַחְנְכֶֽנּוּ׃", "transliteral": "yaḥ-nə-ḵen-nû", "traducao_palavra": "a consagre" }
      ]
    },
    "6": {
      "traducao_completa": "E qual é o homem que plantou uma vinha e ainda não a desfrutou? Vá, e torne-se à sua casa, para que porventura não morra na peleja e outro a desfrute.",
      "palavras": [
        { "hebraico": "וּמִֽי־הָאִ֞ישׁ", "transliteral": "ū-mî-hā-ʾîš", "traducao_palavra": "e quem [é] o homem?" },
        { "hebraico": "אֲשֶׁר־נָטַ֥ע", "transliteral": "ʾă-šer-nā-ṭaʿ", "traducao_palavra": "que plantou" },
        { "hebraico": "כֶּ֙רֶם֙", "transliteral": "ke-rem", "traducao_palavra": "vinha" },
        { "hebraico": "וְלֹ֣א", "transliteral": "wə-lō", "traducao_palavra": "e não" },
        { "hebraico": "חִלְּלֹ֔ו", "transliteral": "ḥil-lə-lô", "traducao_palavra": "a desfrutou/profanou" },
        { "hebraico": "יֵלֵךְ֙", "transliteral": "yē-lēḵ", "traducao_palavra": "vá" },
        { "hebraico": "וְיָשֹׁ֣ב", "transliteral": "wə-yā-šōḇ", "traducao_palavra": "e retorne" },
        { "hebraico": "לְבֵיתֹו", "transliteral": "lə-ḇê-ṯô", "traducao_palavra": "à sua casa" },
        { "hebraico": "פֶּן־יָמוּת֙", "transliteral": "pen-yā-mûṯ", "traducao_palavra": "para que não morra" },
        { "hebraico": "בַּמִּלְחָמָ֔ה", "transliteral": "bam-mil-ḥā-mā", "traducao_palavra": "na guerra" },
        { "hebraico": "וְאִ֥ישׁ", "transliteral": "wə-ʾîš", "traducao_palavra": "e homem" },
        { "hebraico": "אַחֵ֖ר", "transliteral": "ʾa-ḥēr", "traducao_palavra": "outro" },
        { "hebraico": "יְחַלְּלֶֽנּוּ׃", "transliteral": "yə-ḥal-lə-len-nû", "traducao_palavra": "a desfrute" }
      ]
    },
    "7": {
      "traducao_completa": "E qual é o homem que se desposou com uma mulher e ainda não a recebeu? Vá, e torne-se à sua casa, para que porventura não morra na peleja e outro homem a receba.",
      "palavras": [
        { "hebraico": "וּמִֽי־הָאִ֞ישׁ", "transliteral": "ū-mî-hā-ʾîš", "traducao_palavra": "e quem [é] o homem?" },
