        { "hebraico": "לָֽךְ׃", "transliteral": "lāḵ", "traducao_palavra": "a ti" }
      ]
    },
    "15": {
      "traducao_completa": "Assim farás a todas as cidades que estiverem muito longe de ti, que não forem das cidades destas nações.",
      "palavras": [
        { "hebraico": "כֵּ֤ן", "transliteral": "kên", "traducao_palavra": "assim" },
        { "hebraico": "תַּעֲשֶׂה֙", "transliteral": "ta-ʿă-śeh", "traducao_palavra": "farás" },
        { "hebraico": "לְכָל־הֶעָרִ֔ים", "transliteral": "lə-ḵāl-he-ʿā-rîm", "traducao_palavra": "a todas as cidades" },
        { "hebraico": "הָרְחֹקֹ֥ת", "transliteral": "hā-rə-ḥō-qōṯ", "traducao_palavra": "as distantes" },
        { "hebraico": "מִמְּךָ֖", "transliteral": "mim-mə-ḵā", "traducao_palavra": "de ti" },
        { "hebraico": "מְאֹ֑ד", "transliteral": "mə-ʾōḏ", "traducao_palavra": "muito" },
        { "hebraico": "אֲשֶׁ֥ר", "transliteral": "ʾă-šer", "traducao_palavra": "que" },
        { "hebraico": "לֹא־מֵעָרֵֽי־הַגֹּויִם־הָאֵ֥לֶּה", "transliteral": "lō-mē-ʿā-rê-hag-gô-yim-hā-ʾēl-leh", "traducao_palavra": "não [são] das cidades destas nações" },
