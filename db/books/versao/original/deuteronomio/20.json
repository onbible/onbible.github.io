        { "hebraico": "לְבֵיתֹו", "transliteral": "lə-ḇê-ṯô", "traducao_palavra": "à sua casa" },
        { "hebraico": "פֶּן־יָמוּת֙", "transliteral": "pen-yā-mûṯ", "traducao_palavra": "para que não morra" },
        { "hebraico": "בַּמִּלְחָמָ֔ה", "transliteral": "bam-mil-ḥā-mā", "traducao_palavra": "na guerra" },
        { "hebraico": "וְאִ֥ישׁ", "transliteral": "wə-ʾîš", "traducao_palavra": "e homem" },
        { "hebraico": "אַחֵ֖ר", "transliteral": "ʾa-ḥēr", "traducao_palavra": "outro" },
        { "hebraico": "יִקָּחֶֽנָּה׃", "transliteral": "yiq-qā-ḥen-nā", "traducao_palavra": "tome-a" }
      ]
    },
    "8": {
      "traducao_completa": "E continuarão os oficiais a falar ao povo, dizendo: Qual é o homem medroso e de coração tímido? Vá, e torne-se à sua casa, para que o coração de seus irmãos se não derreta como o seu coração.",
      "palavras": [
        { "hebraico": "וְיָסְפ֣וּ", "transliteral": "wə-yā-sə-p̄û", "traducao_palavra": "e continuarão" },
        { "hebraico": "הַשֹּׁטְרִים֮", "transliteral": "haš-šō-ṭə-rîm", "traducao_palavra": "os oficiais" },
        { "hebraico": "לְדַבֵּ֣ר", "transliteral": "lə-ḏab-bêr", "traducao_palavra": "a falar" },
        { "hebraico": "אֶל־הָעָם֒", "transliteral": "ʾel-hā-ʿām", "traducao_palavra": "ao povo" },
