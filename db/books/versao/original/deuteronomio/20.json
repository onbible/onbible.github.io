    },
    "17": {
      "traducao_completa": "Antes, totalmente os destruirás: aos heteus, e aos amorreus, e aos cananeus, e aos ferezeus, e aos heveus, e aos jebuseus, como te ordenou YHWH teu Deus.",
      "palavras": [
        { "hebraico": "כִּֽי־הַחֲרֵ֣ם", "transliteral": "kî-ha-ḥă-rēm", "traducao_palavra": "pois destruindo totalmente" },
