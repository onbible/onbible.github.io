        { "hebraico": "צִוְּךָ֖", "transliteral": "ṣiw-wə-ḵā", "traducao_palavra": "ordenou a ti" },
        { "hebraico": "יְהוָ֥ה", "transliteral": "YHWH", "traducao_palavra": "YHWH" },
        { "hebraico": "אֱלֹהֶֽיךָ׃", "transliteral": "ʾĕ-lō-he-ḵā", "traducao_palavra": "teu Deus" }
      ]
    },
    "18": {
      "traducao_completa": "Para que não vos ensinem a fazer conforme a todas as suas abominações, que fizeram a seus deuses, e pequeis contra YHWH vosso Deus.",
      "palavras": [
        { "hebraico": "לְמַ֗עַן", "transliteral": "lə-ma-ʿan", "traducao_palavra": "para que" },
        { "hebraico": "אֲשֶׁ֨ר", "transliteral": "ʾă-šer", "traducao_palavra": "[que]" },
        { "hebraico": "לֹֽא־יְלַמְּד֤וּ", "transliteral": "lō-yə-lam-mə-ḏû", "traducao_palavra": "não ensinem" },
        { "hebraico": "אֶתְכֶם֙", "transliteral": "ʾeṯ-ḵem", "traducao_palavra": "vós" },
        { "hebraico": "לַעֲשֹׂ֔ות", "transliteral": "la-ʿă-śôṯ", "traducao_palavra": "a fazer" },
        { "hebraico": "כְּכֹ֕ל", "transliteral": "kə-ḵōl", "traducao_palavra": "conforme todas" },
        { "hebraico": "תֹּועֲבֹתָ֔ם", "transliteral": "ṯô-ʿă-ḇō-ṯām", "traducao_palavra": "abominações deles" },
        { "hebraico": "אֲשֶׁ֥ר", "transliteral": "ʾă-šer", "traducao_palavra": "que" },
        { "hebraico": "עָשׂ֖וּ", "transliteral": "ʿā-śû", "traducao_palavra": "fizeram" },
        { "hebraico": "לֵאלֹהֵיהֶ֑ם", "transliteral": "lê-lō-hê-hem", "traducao_palavra": "para os deuses deles" },
        { "hebraico": "וַחֲטָאתֶ֖ם", "transliteral": "wa-ḥă-ṭā-ṯem", "traducao_palavra": "e pequeis" },
        { "hebraico": "לַיהוָ֥ה", "transliteral": "lay-YHWH", "traducao_palavra": "contra YHWH" },
        { "hebraico": "אֱלֹהֵיכֶֽם׃", "transliteral": "ʾĕ-lō-hê-ḵem", "traducao_palavra": "vosso Deus" }
      ]
    },
    "19": {
      "traducao_completa": "Quando sitiares uma cidade por muitos dias, pelejando contra ela para a tomar, não destruirás o seu arvoredo, metendo nela o machado, porque dela comerás; pois não a cortarás (pois a árvore do campo é o mantimento do homem), para que sirva de baluarte para ti.",
      "palavras": [
        { "hebraico": "כִּֽי־תָצ֣וּר", "transliteral": "kî-ṯā-ṣûr", "traducao_palavra": "quando sitiares" },
        { "hebraico": "אֶל־עִיר֩", "transliteral": "ʾel-ʿîr", "traducao_palavra": "uma cidade" },
        { "hebraico": "יָמִ֨ים", "transliteral": "yā-mîm", "traducao_palavra": "dias" },
        { "hebraico": "רַבִּ֜ים", "transliteral": "rab-bîm", "traducao_palavra": "muitos" },
        { "hebraico": "לְֽהִלָּחֵ֧ם", "transliteral": "lə-hil-lā-ḥēm", "traducao_palavra": "para pelejar" },
        { "hebraico": "עָלֶ֣יהָ", "transliteral": "ʿā-ley-hā", "traducao_palavra": "contra ela" },
        { "hebraico": "לְתָפְשָׂ֗הּ", "transliteral": "lə-ṯā-p̄ə-śāh", "traducao_palavra": "para capturá-la" },
        { "hebraico": "לֹֽא־תַשְׁחִ֤ית", "transliteral": "lō-ṯaš-ḥîṯ", "traducao_palavra": "não destruirás" },
        { "hebraico": "אֶת־עֵצָהּ֙", "transliteral": "ʾeṯ-ʿê-ṣāh", "traducao_palavra": "o seu arvoredo" },
        { "hebraico": "לִנְדֹּ֤חַ", "transliteral": "lin-dō-aḥ", "traducao_palavra": "a forçar/meter" },
        { "hebraico": "עָלָיו֙", "transliteral": "ʿā-lāyw", "traducao_palavra": "nele" },
        { "hebraico": "גַּרְזֶ֔ן", "transliteral": "gar-zen", "traducao_palavra": "machado" },
        { "hebraico": "כִּ֚י", "transliteral": "kî", "traducao_palavra": "pois" },
        { "hebraico": "מִמֶּ֣נּוּ", "transliteral": "mim-men-nû", "traducao_palavra": "dele" },
        { "hebraico": "תֹאכֵ֔ל", "transliteral": "ṯō-ḵēl", "traducao_palavra": "comerás" },
        { "hebraico": "וְאֹתֹ֖ו", "transliteral": "wə-ʾō-ṯô", "traducao_palavra": "e ele" },
        { "hebraico": "לֹ֥א", "transliteral": "lō", "traducao_palavra": "não" },
        { "hebraico": "תִכְרֹ֑ת", "transliteral": "tiḵ-rōṯ", "traducao_palavra": "cortarás" },
        { "hebraico": "כִּ֤י", "transliteral": "kî", "traducao_palavra": "pois" },
        { "hebraico": "הָאָדָם֙", "transliteral": "hā-ʾā-ḏām", "traducao_palavra": "o homem" },
        { "hebraico": "עֵ֣ץ", "transliteral": "ʿēṣ", "traducao_palavra": "[é] árvore de" },
        { "hebraico": "הַשָּׂדֶ֔ה", "transliteral": "haś-śā-ḏeh", "traducao_palavra": "o campo" },
        { "hebraico": "לָבֹ֥א", "transliteral": "lā-ḇō", "traducao_palavra": "para vir" },
        { "hebraico": "מִפָּנֶ֖יךָ", "transliteral": "mip-pā-ne-ḵā", "traducao_palavra": "de diante de ti" },
        { "hebraico": "בַּמָּצֹֽור׃", "transliteral": "bam-mā-ṣôr", "traducao_palavra": "no cerco" }
      ]
    },
    "20": {
      "traducao_completa": "Mas as árvores que souberes que não são árvores de comer, essas destruirás e cortarás; e contra a cidade que guerrear contra ti edificarás baluartes, até que ela seja derrubada.",
