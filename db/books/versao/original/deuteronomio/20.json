        { "hebraico": "עִמָּ֔ךְ", "transliteral": "ʿim-māḵ", "traducao_palavra": "contigo" },
        { "hebraico": "וְעָשְׂתָ֥ה", "transliteral": "wə-ʿā-śə-ṯā", "traducao_palavra": "e fizer" },
