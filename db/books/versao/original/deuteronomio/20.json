    },
    "9": {
      "traducao_completa": "E sucederá que, quando os oficiais acabarem de falar ao povo, então designarão os capitães dos exércitos para a frente do povo.",
      "palavras": [
        { "hebraico": "וְהָיָה֙", "transliteral": "wə-hā-yā", "traducao_palavra": "e será" },
        { "hebraico": "כְּכַלֹּ֣ת", "transliteral": "kə-ḵal-lōṯ", "traducao_palavra": "quando acabarem" },
        { "hebraico": "הַשֹּׁטְרִ֔ים", "transliteral": "haš-šō-ṭə-rîm", "traducao_palavra": "os oficiais" },
        { "hebraico": "לְדַבֵּ֖ר", "transliteral": "lə-ḏab-bêr", "traducao_palavra": "a falar" },
        { "hebraico": "אֶל־הָעָ֑ם", "transliteral": "ʾel-hā-ʿām", "traducao_palavra": "ao povo" },
        { "hebraico": "וּפָ֥קְדוּ", "transliteral": "ū-p̄ā-qə-ḏû", "traducao_palavra": "então designarão" },
        { "hebraico": "שָׂרֵ֥י", "transliteral": "śā-rê", "traducao_palavra": "capitães de" },
