        { "hebraico": "יִהְי֥וּ", "transliteral": "yih-yû", "traducao_palavra": "serão" },
        { "hebraico": "לְךָ֛", "transliteral": "lə-ḵā", "traducao_palavra": "para ti" },
        { "hebraico": "לָמַ֖ס", "transliteral": "lā-mas", "traducao_palavra": "como tributários/serviço forçado" },
        { "hebraico": "וַעֲבָדֽוּךָ׃", "transliteral": "wa-ʿă-ḇā-ḏû-ḵā", "traducao_palavra": "e te servirão" }
