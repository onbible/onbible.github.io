        { "hebraico": "אֲשֶׁ֨ר", "transliteral": "ʾă-šer", "traducao_palavra": "que" },
        { "hebraico": "יִהְיֶ֥ה", "transliteral": "yih-yeh", "traducao_palavra": "houver" },
        { "hebraico": "בָעִ֛יר", "transliteral": "ḇā-ʿîr", "traducao_palavra": "na cidade" },
        { "hebraico": "כָּל־שְׁלָלָ֖הּ", "transliteral": "kāl-šə-lā-lāh", "traducao_palavra": "todo o despojo dela" },
        { "hebraico": "תָּבֹ֣ז", "transliteral": "tā-ḇōz", "traducao_palavra": "saquearás/tomarás" },
        { "hebraico": "לָ֑ךְ", "transliteral": "lāḵ", "traducao_palavra": "para ti" },
        { "hebraico": "וְאָֽכַלְתָּ֙", "transliteral": "wə-ʾā-ḵal-tā", "traducao_palavra": "e comerás" },
        { "hebraico": "אֶת־שְׁלַ֣ל", "transliteral": "ʾeṯ-šə-lal", "traducao_palavra": "o despojo de" },
