        { "hebraico": "וְלֹ֥א", "transliteral": "wə-lō", "traducao_palavra": "e não" },
        { "hebraico": "לְקָחָ֑הּ", "transliteral": "lə-qā-ḥāh", "traducao_palavra": "tomou-a" },
        { "hebraico": "יֵלֵךְ֙", "transliteral": "yē-lēḵ", "traducao_palavra": "vá" },
