        { "hebraico": "הַכְּנַעֲנִ֥י", "transliteral": "hak-kə-na-ʿă-nî", "traducao_palavra": "o cananeu" },
        { "hebraico": "וְהַפְּרִזִּ֖י", "transliteral": "wə-hap-pə-riz-zî", "traducao_palavra": "e o ferezeu" },
        { "hebraico": "הַחִוִּ֣י", "transliteral": "ha-ḥiw-wî", "traducao_palavra": "o heveu" },
        { "hebraico": "וְהַיְבוּסִ֑י", "transliteral": "wə-hay-ḇû-śî", "traducao_palavra": "e o jebuseu" },
