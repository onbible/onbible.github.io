        { "hebraico": "הָעָֽם׃", "transliteral": "hā-ʿām", "traducao_palavra": "o povo" }
      ]
    },
    "10": {
      "traducao_completa": "Quando te achegares a alguma cidade para combatê-la, apregoar-lhe-ás a paz.",
      "palavras": [
        { "hebraico": "כִּֽי־תִקְרַ֣ב", "transliteral": "kî-ṯiq-raḇ", "traducao_palavra": "quando te aproximares" },
        { "hebraico": "אֶל־עִ֔יר", "transliteral": "ʾel-ʿîr", "traducao_palavra": "de uma cidade" },
        { "hebraico": "לְהִלָּחֵ֖ם", "transliteral": "lə-hil-lā-ḥēm", "traducao_palavra": "para combater" },
        { "hebraico": "עָלֶ֑יהָ", "transliteral": "ʿā-ley-hā", "traducao_palavra": "contra ela" },
        { "hebraico": "וְקָרָ֥אתָ", "transliteral": "wə-qā-rā-ṯā", "traducao_palavra": "e proclamarás/chamarás" },
        { "hebraico": "אֵלֶ֖יהָ", "transliteral": "ʾē-ley-hā", "traducao_palavra": "a ela" },
        { "hebraico": "לְשָׁלֹֽום׃", "transliteral": "lə-šā-lôm", "traducao_palavra": "a paz" }
      ]
    },
    "11": {
      "traducao_completa": "E será que, se ela te responder paz, e te abrir as portas, todo o povo que se achar nela te será tributário e te servirá.",
