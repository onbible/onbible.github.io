        { "hebraico": "וְאֶת־הָאַרְנֶ֜בֶת", "transliteral": "wə-ʾeṯ-hā-ʾar-ne-ḇeṯ", "traducao_palavra": "e a lebre" },
        { "hebraico": "וְאֶת־הַשָּׁפָ֗ן", "transliteral": "wə-ʾeṯ-haš-šā-p̄ān", "traducao_palavra": "e o coelho/hirax" },
