    "26": {
      "traducao_completa": "E aquele dinheiro darás por tudo o que deseja a tua alma, por vacas, e por ovelhas, e por vinho, e por bebida forte, e por tudo o que te pedir a tua alma; e ali comerás perante YHWH teu Deus, e te alegrarás, tu e a tua casa;",
      "palavras": [
        { "hebraico": "וְנָתַתָּ֨ה", "transliteral": "wə-nā-ṯat-tā", "traducao_palavra": "e darás" },
        { "hebraico": "הַכֶּ֜סֶף", "transliteral": "hak-ke-sep̄", "traducao_palavra": "o dinheiro" },
        { "hebraico": "בְּכֹ֣ל", "transliteral": "bə-ḵōl", "traducao_palavra": "por tudo" },
        { "hebraico": "אֲשֶׁר־תְּאַוֶּ֣ה", "transliteral": "ʾă-šer-tə-ʾaw-weh", "traducao_palavra": "que desejar" },
