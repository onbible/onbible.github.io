        { "hebraico": "אֶת־זֶה֙", "transliteral": "ʾeṯ-zeh", "traducao_palavra": "este" },
        { "hebraico": "תֹּאכְל֔וּ", "transliteral": "ṯō-ḵə-lû", "traducao_palavra": "comereis" },
        { "hebraico": "מִכֹּ֥ל", "transliteral": "mik-kōl", "traducao_palavra": "de tudo" },
        { "hebraico": "אֲשֶׁ֖ר", "transliteral": "ʾă-šer", "traducao_palavra": "que [há]" },
