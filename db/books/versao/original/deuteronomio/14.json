        { "hebraico": "שָׁם֒", "transliteral": "šām", "traducao_palavra": "ali" },
        { "hebraico": "מַעְשַׂ֤ר", "transliteral": "ma-ʿśar", "traducao_palavra": "o dízimo de" },
        { "hebraico": "דְּגָֽנְךָ֙", "transliteral": "də-ḡā-ne-ḵā", "traducao_palavra": "teu grão" },
        { "hebraico": "תִּירֹשְׁךָ֣", "transliteral": "ṯî-rō-šə-ḵā", "traducao_palavra": "teu mosto" },
