    "11": {
      "traducao_completa": "Toda a ave limpa comereis.",
      "palavras": [
        { "hebraico": "כָּל־צִפֹּ֥ור", "transliteral": "kāl-ṣip-pôr", "traducao_palavra": "toda ave" },
