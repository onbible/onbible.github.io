    "10": {
      "traducao_completa": "Mas tudo o que não tiver barbatanas nem escamas não comereis; imundo vos será.",
      "palavras": [
        { "hebraico": "וְכֹ֨ל", "transliteral": "wə-ḵōl", "traducao_palavra": "e tudo" },
