{
  "livro": "Deuteronômio - דְּבָרִים - Devarim",
  "capítulo": 14,
  "titulos": {},
  "versiculos": {
    "1": {
      "traducao_completa": "Filhos sois de YHWH vosso Deus; não vos cortareis a vós mesmos, nem fareis calva entre vossos olhos por causa de algum morto.",
      "palavras": [
        { "hebraico": "בָּנִ֣ים", "transliteral": "bā-nîm", "traducao_palavra": "filhos" },
        { "hebraico": "אַתֶּ֔ם", "transliteral": "ʾat-tem", "traducao_palavra": "sois vós" },
        { "hebraico": "לַיהוָ֖ה", "transliteral": "lay-YHWH", "traducao_palavra": "de YHWH" },
        { "hebraico": "אֱלֹהֵיכֶ֑ם", "transliteral": "ʾĕ-lō-hê-ḵem", "traducao_palavra": "vosso Deus" },
        { "hebraico": "לֹ֣א", "transliteral": "lō", "traducao_palavra": "não" },
        { "hebraico": "תִתְגֹּֽדְד֗וּ", "transliteral": "tiṯ-gō-ḏə-ḏû", "traducao_palavra": "vos cortareis" },
        { "hebraico": "וְלֹא־תָשִׂ֧ימוּ", "transliteral": "wə-lō-ṯā-śî-mû", "traducao_palavra": "e não fareis" },
        { "hebraico": "קָרְחָ֛ה", "transliteral": "qār-ḥā", "traducao_palavra": "calva" },
        { "hebraico": "בֵּ֥ין", "transliteral": "bên", "traducao_palavra": "entre" },
        { "hebraico": "עֵינֵיכֶ֖ם", "transliteral": "ʿê-nê-ḵem", "traducao_palavra": "vossos olhos" },
        { "hebraico": "לָמֵֽת׃", "transliteral": "lā-mēṯ", "traducao_palavra": "pelo morto" }
      ]
    },
    "2": {
      "traducao_completa": "Porque és povo santo a YHWH teu Deus; e YHWH te escolheu de todos os povos que há sobre a face da terra, para lhe seres o seu povo próprio.",
      "palavras": [
        { "hebraico": "כִּ֣י", "transliteral": "kî", "traducao_palavra": "porque" },
        { "hebraico": "עַ֤ם", "transliteral": "ʿam", "traducao_palavra": "[um] povo" },
        { "hebraico": "קָדֹושׁ֙", "transliteral": "qā-ḏôš", "traducao_palavra": "santo" },
        { "hebraico": "אַתָּ֔ה", "transliteral": "ʾat-tā", "traducao_palavra": "és tu" },
        { "hebraico": "לַיהוָ֖ה", "transliteral": "lay-YHWH", "traducao_palavra": "para YHWH" },
        { "hebraico": "אֱלֹהֶ֑יךָ", "transliteral": "ʾĕ-lō-he-ḵā", "traducao_palavra": "teu Deus" },
        { "hebraico": "וּבְךָ֞", "transliteral": "ū-ḇə-ḵā", "traducao_palavra": "e em ti" },
        { "hebraico": "בָּחַ֣ר", "transliteral": "bā-ḥar", "traducao_palavra": "escolheu" },
        { "hebraico": "יְהוָ֗ה", "transliteral": "YHWH", "traducao_palavra": "YHWH" },
        { "hebraico": "לִהְיֹ֥ות", "transliteral": "li-hə-yôṯ", "traducao_palavra": "para ser" },
        { "hebraico": "לֹו֙", "transliteral": "lô", "traducao_palavra": "dele" },
        { "hebraico": "לְעַ֣ם", "transliteral": "lə-ʿam", "traducao_palavra": "povo de" },
        { "hebraico": "סְגֻלָּ֔ה", "transliteral": "śə-ḡul-lā", "traducao_palavra": "propriedade/tesouro" },
        { "hebraico": "מִכֹּל֙", "transliteral": "mik-kōl", "traducao_palavra": "de todos" },
        { "hebraico": "הָֽעַמִּ֔ים", "transliteral": "hā-ʿam-mîm", "traducao_palavra": "os povos" },
