    "12": {
      "traducao_completa": "Mas estas são as que não comereis: a águia, o quebra-ossos e a águia marinha,",
      "palavras": [
        { "hebraico": "וְזֶ֕ה", "transliteral": "wə-zeh", "traducao_palavra": "e estas [são]" },
