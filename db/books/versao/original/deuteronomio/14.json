      ]
    },
    "3": {
      "traducao_completa": "Nenhuma coisa abominável comereis.",
      "palavras": [
        { "hebraico": "לֹ֥א", "transliteral": "lō", "traducao_palavra": "não" },
        { "hebraico": "תֹאכַ֖ל", "transliteral": "ṯō-ḵal", "traducao_palavra": "comereis" },
