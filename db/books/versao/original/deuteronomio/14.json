        { "hebraico": "לֹ֣א", "transliteral": "lō", "traducao_palavra": "não" },
        { "hebraico": "הִפְרִ֔יסוּ", "transliteral": "hip̄-rî-śû", "traducao_palavra": "dividiram" },
