        { "hebraico": "תֹאכֵ֔לוּ", "transliteral": "ṯō-ḵê-lû", "traducao_palavra": "comereis" },
        { "hebraico": "וּבְנִבְלָתָ֖ם", "transliteral": "ū-ḇə-niḇ-lā-ṯām", "traducao_palavra": "e em seu cadáver" },
