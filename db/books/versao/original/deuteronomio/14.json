      "traducao_completa": "O veado, o corço, o búfalo, a cabra montês, o antílope, a ovelha montês e o gamo.",
      "palavras": [
        { "hebraico": "אַיָּ֥ל", "transliteral": "ʾay-yāl", "traducao_palavra": "veado" },
        { "hebraico": "וּצְבִ֖י", "transliteral": "ū-ṣə-ḇî", "traducao_palavra": "e corço" },
