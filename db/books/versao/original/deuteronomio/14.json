        { "hebraico": "תֹּאכֵ֑לוּ", "transliteral": "ṯō-ḵê-lû", "traducao_palavra": "comereis" },
        { "hebraico": "שֹׁ֕ור", "transliteral": "šôr", "traducao_palavra": "boi" },
