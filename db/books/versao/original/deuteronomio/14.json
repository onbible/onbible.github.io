        { "hebraico": "תֹּאכֵֽלוּ׃", "transliteral": "tō-ḵē-lû", "traducao_palavra": "comereis" }
      ]
    },
    "7": {
      "traducao_completa": "Porém estes não comereis, dos que ruminam, ou dos que têm unha fendida: o camelo, a lebre e o coelho, porque ruminam, mas não têm a unha fendida; imundos vos serão.",
      "palavras": [
        { "hebraico": "אַ֣ךְ", "transliteral": "ʾaḵ", "traducao_palavra": "porém" },
        { "hebraico": "אֶת־זֶ֞ה", "transliteral": "ʾeṯ-zeh", "traducao_palavra": "[objeto] este" },
        { "hebraico": "לֹ֤א", "transliteral": "lō", "traducao_palavra": "não" },
        { "hebraico": "תֹאכְלוּ֙", "transliteral": "ṯō-ḵə-lû", "traducao_palavra": "comereis" },
        { "hebraico": "מִמַּעֲלֵ֣י", "transliteral": "mim-ma-ʿă-lê", "traducao_palavra": "dos que sobem" },
