      ]
    },
    "4": {
      "traducao_completa": "Estes são os animais que comereis: o boi, a ovelha e a cabra.",
      "palavras": [
        { "hebraico": "זֹ֥את", "transliteral": "zōṯ", "traducao_palavra": "estes [são]" },
