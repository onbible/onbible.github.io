    "6": {
      "traducao_completa": "Pelo depoimento de duas ou três testemunhas, morrerá o que houver de morrer; pelo depoimento de uma só testemunha não morrerá.",
      "palavras": [
        { "hebraico": "עַל־פִּ֣י׀", "transliteral": "ʿal-pî", "traducao_palavra": "pela boca de/conforme" },
