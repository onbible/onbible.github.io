        { "hebraico": "בָּאַחֲרֹנָ֑ה", "transliteral": "bā-ʾa-ḥă-rō-nā", "traducao_palavra": "por último" },
        { "hebraico": "וּבִֽעַרְתָּ֥", "transliteral": "ū-ḇi-ʿar-tā", "traducao_palavra": "e tirarás/queimarás" },
        { "hebraico": "הָרָ֖ע", "transliteral": "hā-rā", "traducao_palavra": "o mal" },
        { "hebraico": "מִקִּרְבֶּֽךָ׃", "transliteral": "miq-qir-be-ḵā", "traducao_palavra": "do teu meio" }
      ]
    },
    "8": {
      "traducao_completa": "Quando alguma causa te for difícil demais em juízo, entre sangue e sangue, entre demanda e demanda, entre ferida e ferida, causas de controvérsia nas tuas portas, então te levantarás e subirás ao lugar que escolher YHWH teu Deus;",
      "palavras": [
        { "hebraico": "כִּ֣י", "transliteral": "kî", "traducao_palavra": "quando" },
        { "hebraico": "יִפָּלֵא֩", "transliteral": "yippā-lē", "traducao_palavra": "for difícil/maravilhoso" },
        { "hebraico": "מִמְּךָ֙", "transliteral": "mim-mə-ḵā", "traducao_palavra": "de ti" },
        { "hebraico": "דָבָ֜ר", "transliteral": "dā-ḇār", "traducao_palavra": "causa/coisa" },
        { "hebraico": "לַמִּשְׁפָּ֗ט", "transliteral": "lam-miš-pāṭ", "traducao_palavra": "para o juízo" },
        { "hebraico": "בֵּין־דָּ֨ם׀", "transliteral": "bên-dām", "traducao_palavra": "entre sangue" },
        { "hebraico": "לְדָ֜ם", "transliteral": "lə-ḏām", "traducao_palavra": "e sangue" },
        { "hebraico": "בֵּין־דִּ֣ין", "transliteral": "bên-dîn", "traducao_palavra": "entre demanda/lei" },
        { "hebraico": "לְדִ֗ין", "transliteral": "lə-ḏîn", "traducao_palavra": "e demanda" },
