{
  "livro": "Deuteronômio - דְּבָרִים - Devarim",
  "capítulo": 17,
  "titulos": {},
  "versiculos": {
    "1": {
      "traducao_completa": "Não sacrificarás a YHWH teu Deus boi ou ovelha em que haja defeito ou qualquer coisa má; pois é abominação a YHWH teu Deus.",
      "palavras": [
        { "hebraico": "לֹא־תִזְבַּח֩", "transliteral": "lō-ṯiz-baḥ", "traducao_palavra": "não sacrificarás" },
        { "hebraico": "לַיהוָ֨ה", "transliteral": "lay-YHWH", "traducao_palavra": "para YHWH" },
        { "hebraico": "אֱלֹהֶ֜יךָ", "transliteral": "ʾĕ-lō-he-ḵā", "traducao_palavra": "teu Deus" },
        { "hebraico": "שֹׁ֣ור", "transliteral": "šôr", "traducao_palavra": "boi" },
        { "hebraico": "וָשֶׂ֗ה", "transliteral": "wā-śeh", "traducao_palavra": "e ovelha/cordeiro" },
