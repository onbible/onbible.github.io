        { "hebraico": "דָּבָ֣ר", "transliteral": "dā-ḇār", "traducao_palavra": "coisa" },
        { "hebraico": "רָ֑ע", "transliteral": "rā", "traducao_palavra": "má" },
        { "hebraico": "כִּ֧י", "transliteral": "kî", "traducao_palavra": "pois" },
        { "hebraico": "תֹועֲבַ֛ת", "transliteral": "ṯô-ʿă-ḇaṯ", "traducao_palavra": "[é] abominação de" },
        { "hebraico": "יְהוָ֥ה", "transliteral": "YHWH", "traducao_palavra": "YHWH" },
        { "hebraico": "אֱלֹהֶ֖יךָ", "transliteral": "ʾĕ-lō-he-ḵā", "traducao_palavra": "teu Deus" },
        { "hebraico": "הֽוּא׃", "transliteral": "hû", "traducao_palavra": "ele/é" }
      ]
    },
    "2": {
      "traducao_completa": "Quando no meio de ti, em alguma das tuas portas que YHWH teu Deus te dá, se achar homem ou mulher que fizer o que é mau aos olhos de YHWH teu Deus, transgredindo a sua aliança,",
      "palavras": [
        { "hebraico": "כִּֽי־יִמָּצֵ֤א", "transliteral": "kî-yimmā-ṣē", "traducao_palavra": "quando for achado" },
        { "hebraico": "בְקִרְבְּךָ֙", "transliteral": "ḇə-qir-bə-ḵā", "traducao_palavra": "no teu meio" },
        { "hebraico": "בְּאַחַ֣ד", "transliteral": "bə-ʾa-ḥaḏ", "traducao_palavra": "em uma de" },
        { "hebraico": "שְׁעָרֶ֔יךָ", "transliteral": "šə-ʿā-re-ḵā", "traducao_palavra": "tuas portas" },
        { "hebraico": "אֲשֶׁר־יְהוָ֥ה", "transliteral": "ʾă-šer-YHWH", "traducao_palavra": "que YHWH" },
        { "hebraico": "אֱלֹהֶ֖יךָ", "transliteral": "ʾĕ-lō-he-ḵā", "traducao_palavra": "teu Deus" },
        { "hebraico": "נֹתֵ֣ן", "transliteral": "nō-ṯên", "traducao_palavra": "dá" },
        { "hebraico": "לָ֑ךְ", "transliteral": "lāḵ", "traducao_palavra": "a ti" },
        { "hebraico": "אִ֣ישׁ", "transliteral": "ʾîš", "traducao_palavra": "homem" },
        { "hebraico": "אֹו־אִשָּׁ֗ה", "transliteral": "ʾô-ʾiš-šā", "traducao_palavra": "ou mulher" },
        { "hebraico": "אֲשֶׁ֨ר", "transliteral": "ʾă-šer", "traducao_palavra": "que" },
        { "hebraico": "יַעֲשֶׂ֧ה", "transliteral": "ya-ʿă-śeh", "traducao_palavra": "fizer" },
        { "hebraico": "אֶת־הָרַ֛ע", "transliteral": "ʾeṯ-hā-raʿ", "traducao_palavra": "o mal" },
        { "hebraico": "בְּעֵינֵ֥י", "transliteral": "bə-ʿê-nê", "traducao_palavra": "aos olhos de" },
        { "hebraico": "יְהוָֽה־אֱלֹהֶ֖יךָ", "transliteral": "YHWH-ʾĕ-lō-he-ḵā", "traducao_palavra": "YHWH teu Deus" },
        { "hebraico": "לַעֲבֹ֥ר", "transliteral": "la-ʿă-ḇōr", "traducao_palavra": "para transgredir" },
        { "hebraico": "בְּרִיתֹֽו׃", "transliteral": "bə-rî-ṯô", "traducao_palavra": "sua aliança" }
      ]
    },
    "3": {
      "traducao_completa": "E que for e servir a outros deuses, e se encurvar a eles, ou ao sol, ou à lua, ou a todo o exército do céu, o que eu não ordenei,",
      "palavras": [
