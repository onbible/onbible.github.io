      ]
    },
    "4": {
      "traducao_completa": "E te for denunciado, e o ouvires, então bem inquirirás; e eis que, sendo verdade e certo que se fez tal abominação em Israel,",
      "palavras": [
        { "hebraico": "וְהֻגַּד־לְךָ֖", "transliteral": "wə-hug-gaḏ-lə-ḵā", "traducao_palavra": "e for denunciado a ti" },
        { "hebraico": "וְשָׁמָ֑עְתָּ", "transliteral": "wə-šā-mā-ʿatā", "traducao_palavra": "e ouvires" },
        { "hebraico": "וְדָרַשְׁתָּ֣", "transliteral": "wə-ḏā-raš-tā", "traducao_palavra": "então inquirirás" },
        { "hebraico": "הֵיטֵ֔ב", "transliteral": "hê-ṭēḇ", "traducao_palavra": "bem" },
        { "hebraico": "וְהִנֵּ֤ה", "transliteral": "wə-hin-nē", "traducao_palavra": "e eis" },
        { "hebraico": "אֱמֶת֙", "transliteral": "ʾĕ-meṯ", "traducao_palavra": "[que é] verdade" },
        { "hebraico": "נָכֹ֣ון", "transliteral": "nā-ḵôn", "traducao_palavra": "certo" },
        { "hebraico": "הַדָּבָ֔ר", "transliteral": "had-dā-ḇar", "traducao_palavra": "a coisa/fato" },
        { "hebraico": "נֶעֶשְׂתָה֙", "transliteral": "ne-ʿeś-ṯā", "traducao_palavra": "se fez" },
        { "hebraico": "הַתֹּועֵבָ֥ה", "transliteral": "hat-tô-ʿē-ḇā", "traducao_palavra": "a abominação" },
        { "hebraico": "הַזֹּּאת", "transliteral": "haz-zōṯ", "traducao_palavra": "esta" },
        { "hebraico": "בְּיִשְׂרָאֵֽל׃", "transliteral": "bə-yiś-rā-ʾēl", "traducao_palavra": "em Israel" }
      ]
    },
    "5": {
      "traducao_completa": "Então levarás o homem ou a mulher que fez este mal às tuas portas, e apedrejarás o homem ou a mulher, até que morram.",
      "palavras": [
        { "hebraico": "וְהֹוצֵאתָ֣", "transliteral": "wə-hô-ṣê-ṯā", "traducao_palavra": "e tirarás/levarás" },
        { "hebraico": "אֶת־הָאִ֣ישׁ", "transliteral": "ʾeṯ-hā-ʾîš", "traducao_palavra": "o homem" },
        { "hebraico": "הַה֡וּא", "transliteral": "ha-hû", "traducao_palavra": "aquele" },
        { "hebraico": "אֹו֩", "transliteral": "ʾô", "traducao_palavra": "ou" },
        { "hebraico": "אֶת־הָאִשָּׁ֨ה", "transliteral": "ʾeṯ-hā-ʾiš-šā", "traducao_palavra": "a mulher" },
        { "hebraico": "הַהִ֜וא", "transliteral": "ha-hî", "traducao_palavra": "aquela" },
        { "hebraico": "אֲשֶׁ֣ר", "transliteral": "ʾă-šer", "traducao_palavra": "que" },
        { "hebraico": "עָ֠שׂוּ", "transliteral": "ʿā-śû", "traducao_palavra": "fizeram" },
        { "hebraico": "אֶת־הַדָּבָ֨ר", "transliteral": "ʾeṯ-had-dā-ḇār", "traducao_palavra": "a coisa" },
        { "hebraico": "הָרַ֤ע", "transliteral": "hā-raʿ", "traducao_palavra": "má" },
        { "hebraico": "הַזֶּה֙", "transliteral": "haz-zeh", "traducao_palavra": "esta" },
        { "hebraico": "אֶל־שְׁעָרֶ֔יךָ", "transliteral": "ʾel-šə-ʿā-re-ḵā", "traducao_palavra": "às tuas portas" },
        { "hebraico": "אֶת־הָאִ֖ישׁ", "transliteral": "ʾeṯ-hā-ʾîš", "traducao_palavra": "o homem" },
        { "hebraico": "אֹ֣ו", "transliteral": "ʾô", "traducao_palavra": "ou" },
        { "hebraico": "אֶת־הָאִשָּׁ֑ה", "transliteral": "ʾeṯ-hā-ʾiš-šā", "traducao_palavra": "a mulher" },
        { "hebraico": "וּסְקַלְתָּ֥ם", "transliteral": "ū-śə-qal-tām", "traducao_palavra": "e apedrejarás eles" },
        { "hebraico": "בָּאֲבָנִ֖ים", "transliteral": "bā-ʾă-ḇā-nîm", "traducao_palavra": "com pedras" },
        { "hebraico": "וָמֵֽתוּ׃", "transliteral": "wā-mê-ṯû", "traducao_palavra": "e morrerão" }
