        { "hebraico": "בִּשְׁעָרֶ֑יךָ", "transliteral": "biš-ʿā-re-ḵā", "traducao_palavra": "em tuas portas" },
        { "hebraico": "וְקַמְתָּ֣", "transliteral": "wə-qam-tā", "traducao_palavra": "e te levantarás" },
