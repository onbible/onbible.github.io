        { "hebraico": "וַֽיַּעֲבֹד֙", "transliteral": "way-ya-ʿă-ḇōḏ", "traducao_palavra": "e servir" },
        { "hebraico": "אֱלֹהִ֣ים", "transliteral": "ʾĕ-lō-hîm", "traducao_palavra": "deuses" },
        { "hebraico": "אֲחֵרִ֔ים", "transliteral": "ʾă-ḥê-rîm", "traducao_palavra": "outros" },
        { "hebraico": "וַיִּשְׁתַּ֖חוּ", "transliteral": "way-yiš-ta-ḥû", "traducao_palavra": "e se encurvar" },
        { "hebraico": "לָהֶ֑ם", "transliteral": "lā-hem", "traducao_palavra": "a eles" },
        { "hebraico": "וְלַשֶּׁ֣מֶשׁ", "transliteral": "wə-laš-še-meš", "traducao_palavra": "e ao sol" },
        { "hebraico": "אֹ֣ו", "transliteral": "ʾô", "traducao_palavra": "ou" },
        { "hebraico": "לַיָּרֵ֗חַ", "transliteral": "lay-yā-rē-aḥ", "traducao_palavra": "à lua" },
        { "hebraico": "אֹ֛ו", "transliteral": "ʾô", "traducao_palavra": "ou" },
        { "hebraico": "לְכָל־צְבָ֥א", "transliteral": "lə-ḵāl-ṣə-ḇā", "traducao_palavra": "a todo exército de" },
        { "hebraico": "הַשָּׁמַ֖יִם", "transliteral": "haš-šā-ma-yim", "traducao_palavra": "os céus" },
        { "hebraico": "אֲשֶׁ֥ר", "transliteral": "ʾă-šer", "traducao_palavra": "que" },
