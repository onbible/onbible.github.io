        { "hebraico": "עֵדִ֗ים", "transliteral": "ʿē-ḏîm", "traducao_palavra": "testemunhas" },
        { "hebraico": "אֹ֛ו", "transliteral": "ʾô", "traducao_palavra": "ou" },
        { "hebraico": "שְׁלֹשָׁ֥ה", "transliteral": "šə-lō-šā", "traducao_palavra": "três" },
        { "hebraico": "עֵדִ֖ים", "transliteral": "ʿē-ḏîm", "traducao_palavra": "testemunhas" },
        { "hebraico": "יוּמַ֣ת", "transliteral": "yû-maṯ", "traducao_palavra": "morrerá" },
        { "hebraico": "הַמֵּ֑ת", "transliteral": "ham-mêṯ", "traducao_palavra": "o que morre" },
        { "hebraico": "לֹ֣א", "transliteral": "lō", "traducao_palavra": "não" },
