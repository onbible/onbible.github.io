    "9": {
      "traducao_completa": "E virás aos sacerdotes levitas, e ao juiz que houver naqueles dias, e inquirirás, e eles te anunciarão a sentença do juízo.",
      "palavras": [
        { "hebraico": "וּבָאתָ֗", "transliteral": "ū-ḇā-ṯā", "traducao_palavra": "e virás" },
        { "hebraico": "אֶל־הַכֹּהֲנִים֙", "transliteral": "ʾel-hak-kō-hă-nîm", "traducao_palavra": "aos sacerdotes" },
        { "hebraico": "הַלְוִיִּ֔ם", "transliteral": "hal-wiy-yim", "traducao_palavra": "os levitas" },
