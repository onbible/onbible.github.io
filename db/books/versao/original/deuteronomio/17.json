        { "hebraico": "נֶ֨גַע֙", "transliteral": "ne-ḡaʿ", "traducao_palavra": "ferida" },
        { "hebraico": "לָנֶ֔גַע", "transliteral": "lā-ne-ḡaʿ", "traducao_palavra": "e ferida" },
        { "hebraico": "דִּבְרֵ֥י", "transliteral": "diḇ-rê", "traducao_palavra": "questões/palavras de" },
