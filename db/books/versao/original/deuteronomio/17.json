    "7": {
      "traducao_completa": "As mãos das testemunhas serão as primeiras contra ele, para o matar; e depois as mãos de todo o povo; assim tirarás o mal do meio de ti.",
      "palavras": [
        { "hebraico": "יַ֣ד", "transliteral": "yaḏ", "traducao_palavra": "a mão de" },
        { "hebraico": "הָעֵדִים֮", "transliteral": "hā-ʿē-ḏîm", "traducao_palavra": "as testemunhas" },
        { "hebraico": "תִּֽהְיֶה־בֹּ֣ו", "transliteral": "tih-yeh-bô", "traducao_palavra": "será contra ele" },
        { "hebraico": "בָרִאשֹׁנָה֮", "transliteral": "ḇā-ri-šō-nā", "traducao_palavra": "primeira" },
        { "hebraico": "לַהֲמִיתֹו֒", "transliteral": "la-hă-mî-ṯô", "traducao_palavra": "para matá-lo" },
