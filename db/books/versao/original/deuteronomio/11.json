        { "hebraico": "לְאֹות֙", "transliteral": "lə-ʾôṯ", "traducao_palavra": "por sinal" },
        { "hebraico": "עַל־יֶדְכֶ֔ם", "transliteral": "ʿal-yeḏ-ḵem", "traducao_palavra": "sobre vossa mão" },
        { "hebraico": "וְהָי֥וּ", "transliteral": "wə-hā-yû", "traducao_palavra": "e serão" },
        { "hebraico": "לְטֹוטָפֹ֖ת", "transliteral": "lə-ṭô-ṭā-p̄ōṯ", "traducao_palavra": "por frontais" },
        { "hebraico": "בֵּ֥ין", "transliteral": "bên", "traducao_palavra": "entre" },
