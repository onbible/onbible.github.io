      ]
    },
    "19": {
      "traducao_completa": "E ensiná-las-eis a vossos filhos, falando delas assentado em tua casa, e andando pelo caminho, e ao deitar-te, e ao levantar-te;",
      "palavras": [
        { "hebraico": "וְלִמַּדְתֶּ֥ם", "transliteral": "wə-lim-maḏ-tem", "traducao_palavra": "e as ensinareis" },
        { "hebraico": "אֹתָ֛ם", "transliteral": "ʾō-ṯām", "traducao_palavra": "elas" },
        { "hebraico": "אֶת־בְּנֵיכֶ֖ם", "transliteral": "ʾeṯ-bə-nê-ḵem", "traducao_palavra": "a vossos filhos" },
        { "hebraico": "לְדַבֵּ֣ר", "transliteral": "lə-ḏab-bēr", "traducao_palavra": "para falar" },
