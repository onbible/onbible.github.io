        { "hebraico": "לָהֶֽם׃", "transliteral": "lā-hem", "traducao_palavra": "a eles" }
      ]
    },
    "17": {
      "traducao_completa": "E a ira de YHWH se acenda contra vós, e feche ele os céus, e não haja chuva, e a terra não dê o seu fruto; e cedo pereçais da boa terra que YHWH vos dá.",
