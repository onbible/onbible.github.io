        { "hebraico": "מְצַוֶּ֥ה", "transliteral": "mə-ṣaw-weh", "traducao_palavra": "ordeno" },
        { "hebraico": "אֶתְכֶ֖ם", "transliteral": "ʾeṯ-ḵem", "traducao_palavra": "a vós" },
        { "hebraico": "הַיֹּ֑ום", "transliteral": "hay-yôm", "traducao_palavra": "hoje" },
        { "hebraico": "לְאַהֲבָ֞ה", "transliteral": "lə-ʾa-hă-ḇā", "traducao_palavra": "para amar" },
        { "hebraico": "אֶת־יְהוָ֤ה", "transliteral": "ʾeṯ-YHWH", "traducao_palavra": "a YHWH" },
        { "hebraico": "אֱלֹהֵיכֶם֙", "transliteral": "ʾĕ-lō-hê-ḵem", "traducao_palavra": "vosso Deus" },
        { "hebraico": "וּלְעָבְדֹ֔ו", "transliteral": "ū-lə-ʿā-ḇə-ḏô", "traducao_palavra": "e para servi-lo" },
        { "hebraico": "בְּכָל־לְבַבְכֶ֖ם", "transliteral": "bə-ḵāl-lə-ḇaḇ-ḵem", "traducao_palavra": "com todo vosso coração" },
