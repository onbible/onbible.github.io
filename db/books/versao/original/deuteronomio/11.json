        { "hebraico": "בְּשָׂדְךָ֖", "transliteral": "bə-śā-ḏə-ḵā", "traducao_palavra": "no teu campo" },
        { "hebraico": "לִבְהֶמְתֶּ֑ךָ", "transliteral": "liḇ-hem-te-ḵā", "traducao_palavra": "para teu gado" },
        { "hebraico": "וְאָכַלְתָּ֖", "transliteral": "wə-ʾā-ḵal-tā", "traducao_palavra": "e comerás" },
        { "hebraico": "וְשָׂבָֽעְתָּ׃", "transliteral": "wə-śā-ḇā-ʿătā", "traducao_palavra": "e te fartarás" }
      ]
