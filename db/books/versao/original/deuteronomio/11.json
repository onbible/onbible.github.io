    "18": {
      "traducao_completa": "Ponde, pois, estas minhas palavras no vosso coração e na vossa alma, e atai-as por sinal na vossa mão, para que estejam por frontais entre os vossos olhos.",
      "palavras": [
        { "hebraico": "וְשַׂמְתֶּם֙", "transliteral": "wə-śam-tem", "traducao_palavra": "e poreis" },
        { "hebraico": "אֶת־דְּבָרַ֣י", "transliteral": "ʾeṯ-də-ḇā-ray", "traducao_palavra": "as minhas palavras" },
        { "hebraico": "אֵ֔לֶּה", "transliteral": "ʾēl-leh", "traducao_palavra": "estas" },
        { "hebraico": "עַל־לְבַבְכֶ֖ם", "transliteral": "ʿal-lə-ḇaḇ-ḵem", "traducao_palavra": "sobre vosso coração" },
        { "hebraico": "וְעַֽל־נַפְשְׁכֶ֑ם", "transliteral": "wə-ʿal-nap̄-šə-ḵem", "traducao_palavra": "e sobre vossa alma" },
        { "hebraico": "וּקְשַׁרְתֶּ֨ם", "transliteral": "ū-qə-šar-tem", "traducao_palavra": "e as atareis" },
