        { "hebraico": "וְחֻקֹּתָ֧יו", "transliteral": "wə-ḥuq-qō-ṯāw", "traducao_palavra": "e seus estatutos" },
        { "hebraico": "וּמִשְׁפָּטָ֛יו", "transliteral": "ū-miš-pā-ṭāw", "traducao_palavra": "e seus juízos" },
