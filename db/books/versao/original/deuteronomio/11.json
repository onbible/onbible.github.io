        { "hebraico": "וְיִצְהָרֶֽךָ׃", "transliteral": "wə-yiṣ-hā-re-ḵā", "traducao_palavra": "e teu azeite" }
      ]
    },
    "15": {
      "traducao_completa": "E darei erva no teu campo para o teu gado, e comerás, e fartar-te-ás.",
