        { "hebraico": "אִם־שָׁמֹ֤עַ", "transliteral": "ʾim-šā-mō-aʿ", "traducao_palavra": "se ouvirdes" },
        { "hebraico": "תִּשְׁמְעוּ֙", "transliteral": "tiš-mə-ʿû", "traducao_palavra": "diligentemente" },
        { "hebraico": "אֶל־מִצְוֺתַ֔י", "transliteral": "ʾel-miṣ-wō-ṯay", "traducao_palavra": "meus mandamentos" },
