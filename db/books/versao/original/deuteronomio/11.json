        { "hebraico": "אֱלֹהֵיכֶ֑ם", "transliteral": "ʾĕ-lō-hê-ḵem", "traducao_palavra": "vosso Deus" },
        { "hebraico": "אֶת־גָּדְלֹ֕ו", "transliteral": "ʾeṯ-gā-ḏə-lô", "traducao_palavra": "sua grandeza" },
