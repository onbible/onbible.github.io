        { "hebraico": "אֶת־יְבוּלָ֑הּ", "transliteral": "ʾeṯ-yə-ḇû-lāh", "traducao_palavra": "o seu fruto" },
        { "hebraico": "וַאֲבַדְתֶּ֣ם", "transliteral": "wa-ʾă-ḇaḏ-tem", "traducao_palavra": "e pereçais" },
