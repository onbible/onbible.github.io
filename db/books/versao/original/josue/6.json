        { "hebraico": "הָעָם֙", "transliteral": "hā-ʿām", "traducao_palavra": "o povo" },
        { "hebraico": "תְּרוּעָ֣ה", "transliteral": "tə-rû-ʿā", "traducao_palavra": "brado" },
