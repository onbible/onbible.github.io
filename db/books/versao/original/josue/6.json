        { "hebraico": "וְהֹוצִ֨יאוּ", "transliteral": "wə-hô-ṣî-ʾû", "traducao_palavra": "e tirai" },
        { "hebraico": "מִשָּׁ֤ם", "transliteral": "miš-šām", "traducao_palavra": "de lá" },
        { "hebraico": "אֶת־הָאִשָּׁה֙", "transliteral": "ʾeṯ-hā-ʾiš-šā", "traducao_palavra": "a mulher" },
