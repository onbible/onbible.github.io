        { "hebraico": "הִשָּֽׁבְעוּ־נָ֥א", "transliteral": "hiš-šā-ḇə-ʿû-nā", "traducao_palavra": "jurai-me peço" },
        { "hebraico": "לִי֙", "transliteral": "lî", "traducao_palavra": "a mim" },
        { "hebraico": "בַּיהוָ֔ה", "transliteral": "bay-YHWH", "traducao_palavra": "por YHWH" },
