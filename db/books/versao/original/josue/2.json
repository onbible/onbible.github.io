        { "hebraico": "חֶ֥סֶד", "transliteral": "ḥe-seḏ", "traducao_palavra": "[com] misericórdia" },
        { "hebraico": "וֶאֱמֶֽת׃", "transliteral": "we-ʾĕ-meṯ", "traducao_palavra": "e fidelidade/verdade" }
      ]
    },
