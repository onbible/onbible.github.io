    "19": {
      "traducao_completa": "E será que qualquer que sair fora das portas da tua casa, o seu sangue será sobre a sua cabeça, e nós seremos inocentes; mas qualquer que estiver contigo em casa, o seu sangue será sobre a nossa cabeça, se alguma mão lhe tocar.",
      "palavras": [
        { "hebraico": "וְהָיָ֡ה", "transliteral": "wə-hā-yā", "traducao_palavra": "e será [que]" },
        { "hebraico": "כָּל־אֲשֶׁר־יֵצֵא֩", "transliteral": "kāl-ʾă-šer-yē-ṣē", "traducao_palavra": "todo aquele que sair" },
        { "hebraico": "מִדַּלְתֵ֨י", "transliteral": "mid-dal-ṯê", "traducao_palavra": "das portas de" },
        { "hebraico": "בֵיתֵ֜ךְ", "transliteral": "bê-ṯêḵ", "traducao_palavra": "tua casa" },
        { "hebraico": "הַח֗וּצָה", "transliteral": "ha-ḥû-ṣā", "traducao_palavra": "para fora" },
        { "hebraico": "דָּמֹ֧ו", "transliteral": "dā-mô", "traducao_palavra": "sangue dele" },
