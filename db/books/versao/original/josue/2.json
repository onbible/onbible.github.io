        { "hebraico": "בֵּית־אִשָּׁ֥ה", "transliteral": "bêṯ-ʾiš-šā", "traducao_palavra": "casa de mulher" },
        { "hebraico": "זֹונָ֛ה", "transliteral": "zô-nā", "traducao_palavra": "prostituta" },
        { "hebraico": "וּשְׁמָ֥הּ", "transliteral": "û-šə-māh", "traducao_palavra": "e nome dela" },
