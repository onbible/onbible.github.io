    "23": {
      "traducao_completa": "Assim voltaram os dois homens, e desceram do monte, e passaram, e chegaram a Josué, filho de Num, e contaram-lhe tudo quanto lhes acontecera.",
      "palavras": [
        { "hebraico": "וַיָּשֻׁ֜בוּ", "transliteral": "way-yā-šu-ḇû", "traducao_palavra": "e voltaram" },
        { "hebraico": "שְׁנֵ֣י", "transliteral": "šə-nê", "traducao_palavra": "os dois" },
        { "hebraico": "הָאֲנָשִׁ֗ים", "transliteral": "hā-ʾă-nā-šîm", "traducao_palavra": "homens" },
        { "hebraico": "וַיֵּרְד֧וּ", "transliteral": "way-yē-rə-ḏû", "traducao_palavra": "e desceram" },
        { "hebraico": "מֵֽהָהָר֮", "transliteral": "mē-hā-hār", "traducao_palavra": "do monte" },
        { "hebraico": "וַיַּעַבְרוּ֒", "transliteral": "way-ya-ʿaḇ-rû", "traducao_palavra": "e passaram [o rio]" },
        { "hebraico": "וַיָּבֹ֙אוּ֙", "transliteral": "way-yā-ḇō-ʾû", "traducao_palavra": "e vieram/chegaram" },
        { "hebraico": "אֶל־יְהֹושֻׁ֣עַ", "transliteral": "ʾel-yə-hô-šu-aʿ", "traducao_palavra": "a Josué" },
        { "hebraico": "בִּן־נ֔וּן", "transliteral": "bin-nûn", "traducao_palavra": "filho de Num" },
        { "hebraico": "וַיְסַפְּרוּ־לֹ֔ו", "transliteral": "way-sap-pə-rû-lô", "traducao_palavra": "e contaram a ele" },
        { "hebraico": "אֵ֥ת", "transliteral": "ʾēṯ", "traducao_palavra": "[objeto]" },
        { "hebraico": "כָּל־הַמֹּצְאֹ֖ות", "transliteral": "kāl-ham-mō-ṣə-ʾôṯ", "traducao_palavra": "tudo quanto encontraram" },
