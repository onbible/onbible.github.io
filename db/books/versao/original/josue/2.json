    },
    "16": {
      "traducao_completa": "E disse-lhes: Ide-vos ao monte, para que porventura os perseguidores vos não encontrem; e escondei-vos ali três dias, até que voltem os perseguidores, e depois ide pelo vosso caminho.",
      "palavras": [
        { "hebraico": "וַתֹּ֤אמֶר", "transliteral": "wat-tō-mer", "traducao_palavra": "e disse" },
        { "hebraico": "לָהֶם֙", "transliteral": "lā-hem", "traducao_palavra": "a eles" },
        { "hebraico": "הָהָ֣רָה", "transliteral": "hā-hā-rā", "traducao_palavra": "ao monte" },
        { "hebraico": "לֵּ֔כוּ", "transliteral": "llê-ḵû", "traducao_palavra": "ide" },
