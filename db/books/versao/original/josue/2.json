    "7": {
      "traducao_completa": "E foram-se aqueles homens após eles pelo caminho do Jordão, até aos vaus; e fechou-se a porta, depois que saíram os que iam após eles.",
      "palavras": [
        { "hebraico": "וְהָאֲנָשִׁ֗ים", "transliteral": "wə-hā-ʾă-nā-šîm", "traducao_palavra": "e os homens" },
