        { "hebraico": "בְּאִ֖ישׁ", "transliteral": "bə-ʾîš", "traducao_palavra": "em homem" },
        { "hebraico": "מִפְּנֵיכֶ֑ם", "transliteral": "mip-pə-nê-ḵem", "traducao_palavra": "por causa de vossa presença" },
