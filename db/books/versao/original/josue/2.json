        { "hebraico": "כָּל־בֵּ֣ית", "transliteral": "kāl-bêṯ", "traducao_palavra": "toda casa de" },
        { "hebraico": "אָבִ֔יךְ", "transliteral": "ʾā-ḇîḵ", "traducao_palavra": "teu pai" },
