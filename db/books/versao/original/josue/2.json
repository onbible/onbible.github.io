        { "hebraico": "לָכֶ֖ם", "transliteral": "lā-ḵem", "traducao_palavra": "para vós" },
        { "hebraico": "אֶת־הָאָ֑רֶץ", "transliteral": "ʾeṯ-hā-ʾā-reṣ", "traducao_palavra": "a terra" },
        { "hebraico": "וְכִֽי־נָפְלָ֤ה", "transliteral": "wə-ḵî-nā-p̄ə-lā", "traducao_palavra": "e que caiu" },
