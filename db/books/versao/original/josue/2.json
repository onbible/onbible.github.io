        { "hebraico": "וְהִיא֙", "transliteral": "wə-hî", "traducao_palavra": "e ela" },
        { "hebraico": "עָלְתָ֣ה", "transliteral": "ʿā-lə-ṯā", "traducao_palavra": "subiu" },
