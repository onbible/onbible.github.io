        { "hebraico": "כָּל־אֲשֶׁ֣ר", "transliteral": "kāl-ʾă-šer", "traducao_palavra": "tudo quanto" },
        { "hebraico": "לָהֶ֑ם", "transliteral": "lā-hem", "traducao_palavra": "[pertence] a eles" },
        { "hebraico": "וְהִצַּלְתֶּ֥ם", "transliteral": "wə-hiṣ-ṣal-tem", "traducao_palavra": "e livrareis" },
        { "hebraico": "אֶת־נַפְשֹׁתֵינוּ", "transliteral": "ʾeṯ-nap̄-šō-ṯê-nū", "traducao_palavra": "nossas almas" },
        { "hebraico": "מִמָּֽוֶת׃", "transliteral": "mim-mā-weṯ", "traducao_palavra": "da morte" }
      ]
    },
    "14": {
      "traducao_completa": "Então aqueles homens responderam-lhe: A nossa vida responderá pela vossa, se não denunciardes este nosso negócio; e será que, dando-nos YHWH esta terra, usaremos contigo de misericórdia e de fidelidade.",
