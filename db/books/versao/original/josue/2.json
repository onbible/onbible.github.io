        { "hebraico": "אֶל־יְהֹושֻׁ֔עַ", "transliteral": "ʾel-yə-hô-šu-aʿ", "traducao_palavra": "a Josué" },
        { "hebraico": "כִּֽי־נָתַ֧ן", "transliteral": "kî-nā-ṯan", "traducao_palavra": "que entregou" },
        { "hebraico": "יְהוָ֛ה", "transliteral": "YHWH", "traducao_palavra": "YHWH" },
        { "hebraico": "בְּיָדֵ֖נוּ", "transliteral": "bə-yā-ḏê-nū", "traducao_palavra": "em nossas mãos" },
        { "hebraico": "אֶת־כָּל־הָאָ֑רֶץ", "transliteral": "ʾeṯ-kāl-hā-ʾā-reṣ", "traducao_palavra": "toda a terra" },
        { "hebraico": "וְגַם־נָמֹ֛גוּ", "transliteral": "wə-ḡam-nā-mō-ḡû", "traducao_palavra": "e também desmaiaram" },
        { "hebraico": "כָּל־יֹשְׁבֵ֥י", "transliteral": "kāl-yō-šə-ḇê", "traducao_palavra": "todos moradores de" },
        { "hebraico": "הָאָ֖רֶץ", "transliteral": "hā-ʾā-reṣ", "traducao_palavra": "a terra" },
        { "hebraico": "מִפָּנֵֽינוּ׃", "transliteral": "mip-pā-nê-nū", "traducao_palavra": "de diante de nós" }
