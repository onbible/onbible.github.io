        { "hebraico": "עִמָּכֶ֖ם", "transliteral": "ʿim-mā-ḵem", "traducao_palavra": "convosco" },
        { "hebraico": "חָ֑סֶד", "transliteral": "ḥā-seḏ", "traducao_palavra": "bondade/misericórdia" },
        { "hebraico": "וַעֲשִׂיתֶ֨ם", "transliteral": "wa-ʿă-śî-ṯem", "traducao_palavra": "e usareis/fareis" },
        { "hebraico": "גַּם־אַתֶּ֜ם", "transliteral": "gam-ʾat-tem", "traducao_palavra": "também vós" },
        { "hebraico": "עִם־בֵּ֣ית", "transliteral": "ʿim-bêṯ", "traducao_palavra": "com a casa de" },
        { "hebraico": "אָבִ֗י", "transliteral": "ʾā-ḇî", "traducao_palavra": "meu pai" },
        { "hebraico": "חֶ֕סֶד", "transliteral": "ḥe-seḏ", "traducao_palavra": "bondade" },
        { "hebraico": "וּנְתַתֶּ֥ם", "transliteral": "ū-nə-ṯat-tem", "traducao_palavra": "e dareis" },
