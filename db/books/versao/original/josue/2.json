      "palavras": [
        { "hebraico": "וַיֹּאמְר֥וּ", "transliteral": "way-yō-mə-rû", "traducao_palavra": "e disseram" },
        { "hebraico": "אֵלֶ֖יהָ", "transliteral": "ʾē-le-hā", "traducao_palavra": "a ela" },
        { "hebraico": "הָאֲנָשִׁ֑ים", "transliteral": "hā-ʾă-nā-šîm", "traducao_palavra": "os homens" },
        { "hebraico": "נְקִיִּ֣ם", "transliteral": "nə-qî-yim", "traducao_palavra": "isentos/limpos" },
        { "hebraico": "אֲנַ֔חְנוּ", "transliteral": "ʾă-naḥ-nū", "traducao_palavra": "nós [seremos]" },
        { "hebraico": "מִשְּׁבֻעָתֵ֥ךְ", "transliteral": "miš-šə-ḇu-ʿā-ṯêḵ", "traducao_palavra": "deste teu juramento" },
        { "hebraico": "הַזֶּ֖ה", "transliteral": "haz-zeh", "traducao_palavra": "este" },
        { "hebraico": "אֲשֶׁ֥ר", "transliteral": "ʾă-šer", "traducao_palavra": "que" },
        { "hebraico": "הִשְׁבַּעְתָּֽנוּ׃", "transliteral": "hiš-ba-ʿtā-nū", "traducao_palavra": "fizeste-nos jurar" }
      ]
    },
    "18": {
      "traducao_completa": "Eis que, quando nós entrarmos na terra, atarás este cordão de fio de escarlate à janela por onde nos fizeste descer; e recolherás em tua casa a teu pai, e a tua mãe, e a teus irmãos, e a toda a família de teu pai.",
      "palavras": [
        { "hebraico": "הִנֵּ֛ה", "transliteral": "hin-nē", "traducao_palavra": "eis" },
        { "hebraico": "אֲנַ֥חְנוּ", "transliteral": "ʾă-naḥ-nū", "traducao_palavra": "nós" },
        { "hebraico": "בָאִ֖ים", "transliteral": "ḇā-ʾîm", "traducao_palavra": "entrando/viremos" },
        { "hebraico": "בָּאָ֑רֶץ", "transliteral": "bā-ʾā-reṣ", "traducao_palavra": "na terra" },
