        { "hebraico": "אֱמֶֽת׃", "transliteral": "ʾĕ-meṯ", "traducao_palavra": "verdadeiro/certo" }
      ]
    },
    "13": {
      "traducao_completa": "E que conservareis a vida a meu pai e a minha mãe, como também a meus irmãos e a minhas irmãs, com tudo o que têm, e que livrareis as nossas almas da morte.",
      "palavras": [
