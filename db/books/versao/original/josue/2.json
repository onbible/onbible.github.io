      ]
    },
    "9": {
      "traducao_completa": "E disse aos homens: Bem sei que YHWH vos deu esta terra, e que o pavor de vós caiu sobre nós, e que todos os moradores da terra estão desmaiados diante de vós.",
      "palavras": [
        { "hebraico": "וַתֹּ֙אמֶר֙", "transliteral": "wat-tō-mer", "traducao_palavra": "e disse" },
        { "hebraico": "אֶל־הָ֣אֲנָשִׁ֔ים", "transliteral": "ʾel-hā-ʾă-nā-šîm", "traducao_palavra": "aos homens" },
