        { "hebraico": "אֲשֶׁ֨ר", "transliteral": "ʾă-šer", "traducao_palavra": "que" },
        { "hebraico": "יִהְיֶ֤ה", "transliteral": "yih-yeh", "traducao_palavra": "estiver" },
