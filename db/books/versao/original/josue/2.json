        { "hebraico": "הַיַּרְדֵּ֖ן", "transliteral": "hay-yar-dên", "traducao_palavra": "o Jordão" },
        { "hebraico": "עַ֣ל", "transliteral": "ʿal", "traducao_palavra": "até" },
        { "hebraico": "הַֽמַּעְבְּרֹ֑ות", "transliteral": "ham-ma-ʿə-bə-rôṯ", "traducao_palavra": "os vaus" },
        { "hebraico": "וְהַשַּׁ֣עַר", "transliteral": "wə-haš-ša-ʿar", "traducao_palavra": "e a porta" },
