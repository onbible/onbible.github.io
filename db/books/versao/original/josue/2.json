    "20": {
      "traducao_completa": "E se tu denunciares este nosso negócio, seremos desobrigados do teu juramento que nos fizeste jurar.",
      "palavras": [
        { "hebraico": "וְאִם־תַּגִּ֖ידִי", "transliteral": "wə-ʾim-taḡ-gî-ḏî", "traducao_palavra": "e se declarares/denunciares" },
        { "hebraico": "אֶת־דְּבָרֵ֣נוּ", "transliteral": "ʾeṯ-də-ḇā-rē-nū", "traducao_palavra": "negócio nosso" },
        { "hebraico": "זֶ֑ה", "transliteral": "zeh", "traducao_palavra": "este" },
