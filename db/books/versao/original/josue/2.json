    "21": {
      "traducao_completa": "E ela disse: Conforme as vossas palavras, assim seja. Então os despediu; e eles se foram; e ela atou o cordão de escarlate à janela.",
      "palavras": [
        { "hebraico": "וַתֹּ֥אמֶר", "transliteral": "wat-tō-mer", "traducao_palavra": "e disse" },
        { "hebraico": "כְּדִבְרֵיכֶ֖ם", "transliteral": "kə-ḏiḇ-rê-ḵem", "traducao_palavra": "conforme vossas palavras" },
        { "hebraico": "כֶּן־ה֑וּא", "transliteral": "ken-hû", "traducao_palavra": "assim seja ele" },
        { "hebraico": "וַֽתְּשַׁלְּחֵם֙", "transliteral": "wat-tə-šal-lə-ḥêm", "traducao_palavra": "e despediu eles" },
        { "hebraico": "וַיֵּלֵ֔כוּ", "transliteral": "way-yē-lê-ḵû", "traducao_palavra": "e foram-se" },
        { "hebraico": "וַתִּקְשֹׁ֛ר", "transliteral": "wat-tiq-šōr", "traducao_palavra": "e atou" },
        { "hebraico": "אֶת־תִּקְוַ֥ת", "transliteral": "ʾeṯ-tiq-waṯ", "traducao_palavra": "o cordão de" },
        { "hebraico": "הַשָּׁנִ֖י", "transliteral": "haš-šā-nî", "traducao_palavra": "escarlate" },
        { "hebraico": "בַּחַלֹּֽון׃", "transliteral": "ba-ḥal-lôn", "traducao_palavra": "na janela" }
      ]
    },
    "22": {
      "traducao_completa": "Foram-se, pois, e chegaram ao monte, e ficaram ali três dias, até que voltaram os perseguidores; porque os perseguidores os buscaram por todo o caminho, porém não os acharam.",
      "palavras": [
        { "hebraico": "וַיֵּלְכוּ֙", "transliteral": "way-yē-lə-ḵû", "traducao_palavra": "e foram" },
        { "hebraico": "וַיָּבֹ֣אוּ", "transliteral": "way-yā-ḇō-ʾû", "traducao_palavra": "e chegaram" },
        { "hebraico": "הָהָ֔רָה", "transliteral": "hā-hā-rā", "traducao_palavra": "ao monte" },
        { "hebraico": "וַיֵּ֥שְׁבוּ", "transliteral": "way-yê-šə-ḇû", "traducao_palavra": "e ficaram" },
        { "hebraico": "שָׁ֖ם", "transliteral": "šām", "traducao_palavra": "ali" },
        { "hebraico": "שְׁלֹ֣שֶׁת", "transliteral": "šə-lō-šeṯ", "traducao_palavra": "três" },
        { "hebraico": "יָמִ֑ים", "transliteral": "yā-mîm", "traducao_palavra": "dias" },
        { "hebraico": "עַד־שָׁ֣בוּ", "transliteral": "ʿaḏ-šā-ḇû", "traducao_palavra": "até voltarem" },
        { "hebraico": "הָרֹדְפִ֔ים", "transliteral": "hā-rō-ḏə-p̄îm", "traducao_palavra": "os perseguidores" },
        { "hebraico": "וַיְבַקְשׁ֧וּ", "transliteral": "way-ḇaq-šû", "traducao_palavra": "e buscaram" },
        { "hebraico": "הָרֹדְפִ֛ים", "transliteral": "hā-rō-ḏə-p̄îm", "traducao_palavra": "os perseguidores" },
        { "hebraico": "בְּכָל־הַדֶּ֖רֶךְ", "transliteral": "bə-ḵāl-had-de-reḵ", "traducao_palavra": "por todo o caminho" },
