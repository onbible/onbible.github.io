        { "hebraico": "בָכֶ֖ם", "transliteral": "ḇā-ḵem", "traducao_palavra": "vós" },
        { "hebraico": "הָרֹדְפִ֑ים", "transliteral": "hā-rō-ḏə-p̄îm", "traducao_palavra": "os perseguidores" },
        { "hebraico": "וְנֶחְבֵּאתֶ֨ם", "transliteral": "wə-neḥ-bê-ṯem", "traducao_palavra": "e escondei-vos" },
        { "hebraico": "שָׁ֤מָּה", "transliteral": "šām-mā", "traducao_palavra": "ali" },
        { "hebraico": "שְׁלֹ֣שֶׁת", "transliteral": "šə-lō-šeṯ", "traducao_palavra": "três" },
        { "hebraico": "יָמִ֔ים", "transliteral": "yā-mîm", "traducao_palavra": "dias" },
        { "hebraico": "עַ֖ד", "transliteral": "ʿaḏ", "traducao_palavra": "até" },
        { "hebraico": "שֹׁ֣וב", "transliteral": "šôḇ", "traducao_palavra": "o voltar de" },
        { "hebraico": "הָרֹדְפִ֑ים", "transliteral": "hā-rō-ḏə-p̄îm", "traducao_palavra": "os perseguidores" },
