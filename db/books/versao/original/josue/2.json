      ]
    },
    "6": {
      "traducao_completa": "Porém ela os tinha feito subir ao telhado, e os tinha escondido entre as canas do linho, que pusera em ordem sobre o telhado.",
      "palavras": [
        { "hebraico": "וְהִיא֙", "transliteral": "wə-hî", "traducao_palavra": "mas ela" },
