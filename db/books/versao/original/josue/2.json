        { "hebraico": "לָ֣הּ", "transliteral": "lāh", "traducao_palavra": "a ela" },
        { "hebraico": "הָאֲנָשִׁ֗ים", "transliteral": "hā-ʾă-nā-šîm", "traducao_palavra": "os homens" },
        { "hebraico": "נַפְשֵׁ֤נוּ", "transliteral": "nap̄-šē-nū", "traducao_palavra": "nossa alma" },
        { "hebraico": "תַחְתֵּיכֶם֙", "transliteral": "ṯaḥ-tê-ḵem", "traducao_palavra": "em lugar da vossa" },
        { "hebraico": "לָמ֔וּת", "transliteral": "lā-mûṯ", "traducao_palavra": "para morrer" },
        { "hebraico": "אִ֚ם", "transliteral": "ʾim", "traducao_palavra": "se" },
        { "hebraico": "לֹ֣א", "transliteral": "lō", "traducao_palavra": "não" },
        { "hebraico": "תַגִּ֔ידוּ", "transliteral": "taḡ-gî-ḏû", "traducao_palavra": "declarardes/denunciardes" },
        { "hebraico": "אֶת־דְּבָרֵ֖נוּ", "transliteral": "ʾeṯ-də-ḇā-rē-nū", "traducao_palavra": "este nosso negócio" },
        { "hebraico": "זֶ֑ה", "transliteral": "zeh", "traducao_palavra": "este" },
        { "hebraico": "וְהָיָ֗ה", "transliteral": "wə-hā-yā", "traducao_palavra": "e será" },
        { "hebraico": "בְּתֵת־יְהוָ֥ה", "transliteral": "bə-ṯēṯ-YHWH", "traducao_palavra": "ao dar YHWH" },
        { "hebraico": "לָ֙נוּ֙", "transliteral": "lā-nū", "traducao_palavra": "a nós" },
        { "hebraico": "אֶת־הָאָ֔רֶץ", "transliteral": "ʾeṯ-hā-ʾā-reṣ", "traducao_palavra": "a terra" },
        { "hebraico": "וְעָשִׂ֥ינוּ", "transliteral": "wə-ʿā-śî-nū", "traducao_palavra": "e agiremos" },
