        { "hebraico": "הָעֲרָבָ֛ה", "transliteral": "hā-ʿă-rā-ḇā", "traducao_palavra": "a Arabá" },
        { "hebraico": "צָפֹ֑ונָה", "transliteral": "ṣā-p̄ô-nā", "traducao_palavra": "ao norte" },
