        { "hebraico": "ל֑וּזָה", "transliteral": "lû-zā", "traducao_palavra": "para Luz" },
        { "hebraico": "וְעָבַ֥ר", "transliteral": "wə-ʿā-ḇar", "traducao_palavra": "e passou" },
        { "hebraico": "אֶל־גְּב֥וּל", "transliteral": "ʾel-gə-ḇûl", "traducao_palavra": "ao termo de" },
