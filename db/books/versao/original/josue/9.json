        { "hebraico": "כִּֽי־נִשְׁבְּע֨וּ", "transliteral": "kî-niš-bə-ʿû", "traducao_palavra": "porque juraram" },
        { "hebraico": "לָהֶ֜ם", "transliteral": "lā-hem", "traducao_palavra": "a eles" },
