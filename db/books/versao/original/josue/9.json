        { "hebraico": "וַיִּשָּׁבְע֥וּ", "transliteral": "way-yiš-šā-ḇə-ʿû", "traducao_palavra": "e juraram" },
        { "hebraico": "לָהֶ֖ם", "transliteral": "lā-hem", "traducao_palavra": "a eles" },
