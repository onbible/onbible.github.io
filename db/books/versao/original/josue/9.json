        { "hebraico": "אָנַחְנוּ", "transliteral": "ʾā-naḥ-nū", "traducao_palavra": "nós" },
        { "hebraico": "וְעַתָּ֖ה", "transliteral": "wə-ʿat-tā", "traducao_palavra": "e agora" },
        { "hebraico": "כִּרְתוּ־לָ֥נוּ", "transliteral": "kir-ṯû-lā-nū", "traducao_palavra": "fazei conosco" },
        { "hebraico": "בְרִֽית׃", "transliteral": "ḇə-rîṯ", "traducao_palavra": "aliança" }
