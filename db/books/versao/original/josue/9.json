        { "hebraico": "וּלְכ֖וּ", "transliteral": "ū-lə-ḵû", "traducao_palavra": "e ide" },
        { "hebraico": "לִקְרָאתָ֑ם", "transliteral": "li-qə-rā-ṯām", "traducao_palavra": "ao encontro deles" },
