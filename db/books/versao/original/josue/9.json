        { "hebraico": "הַיַּ֙יִן֙", "transliteral": "hay-ya-yin", "traducao_palavra": "o vinho" },
        { "hebraico": "אֲשֶׁר֮", "transliteral": "ʾă-šer", "traducao_palavra": "que" },
