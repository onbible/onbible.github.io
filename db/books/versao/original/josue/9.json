        { "hebraico": "שַׂלְמֹותֵ֙נוּ֙", "transliteral": "śal-mô-ṯê-nū", "traducao_palavra": "nossas roupas" },
        { "hebraico": "וּנְעָלֵ֔ינוּ", "transliteral": "ū-nə-ʿā-lê-nū", "traducao_palavra": "e nossos sapatos" },
