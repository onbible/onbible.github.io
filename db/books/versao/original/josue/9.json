        { "hebraico": "הִצְטַיַּדְנוּ", "transliteral": "hiṣ-ṭay-yaḏ-nū", "traducao_palavra": "abastecemos" },
        { "hebraico": "אֹתֹ֛ו", "transliteral": "ʾō-ṯô", "traducao_palavra": "ele" },
