        { "hebraico": "אֲלֵיכֶם֒", "transliteral": "ʾă-lê-ḵem", "traducao_palavra": "a vós" },
        { "hebraico": "וְעַתָּה֙", "transliteral": "wə-ʿat-tā", "traducao_palavra": "e agora" },
        { "hebraico": "הִנֵּ֣ה", "transliteral": "hin-nē", "traducao_palavra": "eis" },
        { "hebraico": "יָבֵ֔שׁ", "transliteral": "yā-ḇēš", "traducao_palavra": "seco" },
