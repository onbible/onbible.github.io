        { "hebraico": "וְאַתֶּ֗ם", "transliteral": "wə-ʾat-tem", "traducao_palavra": "e vós" },
        { "hebraico": "לֹא־עָ֨מַד", "transliteral": "wə-lō-ʿā-maḏ", "traducao_palavra": "não ficou em pé" },
