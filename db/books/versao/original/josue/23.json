        { "hebraico": "אֱלֹהֵיכֶ֛ם", "transliteral": "ʾĕ-lō-hê-ḵem", "traducao_palavra": "vosso Deus" },
        { "hebraico": "לְכָל־הַגֹּויִ֥ם", "transliteral": "lə-ḵāl-hag-gô-yim", "traducao_palavra": "a todas as nações" },
        { "hebraico": "הָאֵ֖לֶּה", "transliteral": "hā-ʾēl-leh", "traducao_palavra": "estas" },
        { "hebraico": "מִפְּנֵיכֶ֑ם", "transliteral": "mip-pə-nê-ḵem", "traducao_palavra": "por causa de vós" },
        { "hebraico": "כִּ֚י", "transliteral": "kî", "traducao_palavra": "porque" },
        { "hebraico": "יְהוָ֣ה", "transliteral": "YHWH", "traducao_palavra": "YHWH" },
        { "hebraico": "אֱלֹהֵיכֶ֔ם", "transliteral": "ʾĕ-lō-hê-ḵem", "traducao_palavra": "vosso Deus" },
        { "hebraico": "ה֖וּא", "transliteral": "hū", "traducao_palavra": "ele" },
        { "hebraico": "הַנִּלְחָ֥ם", "transliteral": "han-nil-ḥām", "traducao_palavra": "o que pelejou" },
        { "hebraico": "לָכֶֽם׃", "transliteral": "lā-ḵem", "traducao_palavra": "por vós" }
      ]
    },
    "4": {
      "traducao_completa": "Vede que vos reparti por sorte estas nações que restam, para serem herança das vossas tribos, desde o Jordão, com todas as nações que tenho destruído, até ao Mar Grande para o pôr do sol.",
      "palavras": [
        { "hebraico": "רְא֨וּ", "transliteral": "rə-ʾū", "traducao_palavra": "vede" },
        { "hebraico": "הִפַּ֧לְתִּי", "transliteral": "hip-pal-tî", "traducao_palavra": "reparti [fiz cair]" },
        { "hebraico": "לָכֶ֛ם", "transliteral": "lā-ḵem", "traducao_palavra": "para vós" },
        { "hebraico": "אֶת־הַגֹּויִ֧ם", "transliteral": "ʾeṯ-hag-gô-yim", "traducao_palavra": "as nações" },
        { "hebraico": "הַנִּשְׁאָרִ֥ים", "transliteral": "han-niš-ʾā-rîm", "traducao_palavra": "as restantes" },
        { "hebraico": "הָאֵ֖לֶּה", "transliteral": "hā-ʾēl-leh", "traducao_palavra": "estas" },
        { "hebraico": "בְּנַחֲלָ֖ה", "transliteral": "bə-na-ḥă-lā", "traducao_palavra": "em herança" },
