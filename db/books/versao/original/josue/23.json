    "7": {
      "traducao_completa": "Para que não entreis no meio destas nações que ainda restam convosco; e dos nomes de seus deuses não façais menção, nem por eles façais jurar, nem os sirvais, nem a eles vos inclineis.",
      "palavras": [
        { "hebraico": "לְḇִלְתִּי־בֹוא֙", "transliteral": "lə-ḇil-tî-ḇô", "traducao_palavra": "para não entrar" },
        { "hebraico": "בַּגֹּויִ֣ם", "transliteral": "bag-gô-yim", "traducao_palavra": "nas nações" },
        { "hebraico": "הָאֵ֔לֶּה", "transliteral": "hā-ʾēl-leh", "traducao_palavra": "estas" },
        { "hebraico": "הַנִּשְׁאָרִ֥ים", "transliteral": "han-niš-ʾā-rîm", "traducao_palavra": "as restantes" },
        { "hebraico": "הָאֵ֖לֶּה", "transliteral": "hā-ʾēl-leh", "traducao_palavra": "estas" },
        { "hebraico": "אִתְּכֶ֑ם", "transliteral": "ʾit-tə-ḵem", "traducao_palavra": "convosco" },
        { "hebraico": "וּבְשֵׁם־אֱלֹהֵיהֶם֙", "transliteral": "ū-ḇə-šēm-ʾĕ-lō-hê-hem", "traducao_palavra": "e no nome dos seus deuses" },
        { "hebraico": "לֹא־תַזְכִּ֔ירוּ", "transliteral": "lō-ṯaz-kî-rū", "traducao_palavra": "não fareis menção" },
        { "hebraico": "וְלֹ֥א", "transliteral": "wə-lō", "traducao_palavra": "e não" },
        { "hebraico": "תַשְׁבִּ֖יעוּ", "transliteral": "taš-bî-ʿū", "traducao_palavra": "fareis jurar" },
        { "hebraico": "וְלֹ֣א", "transliteral": "wə-lō", "traducao_palavra": "e não" },
        { "hebraico": "תַעַבְד֑וּם", "transliteral": "ta-ʿaḇ-ḏūm", "traducao_palavra": "servireis eles" },
