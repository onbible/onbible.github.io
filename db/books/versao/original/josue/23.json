        { "hebraico": "מִן־הַיַּרְדֵּ֗ן", "transliteral": "min-hay-yar-dēn", "traducao_palavra": "desde o Jordão" },
        { "hebraico": "וְכָל־הַגֹּויִם֙", "transliteral": "wə-ḵāl-hag-gô-yim", "traducao_palavra": "e todas as nações" },
        { "hebraico": "אֲשֶׁ֣ר", "transliteral": "ʾă-šer", "traducao_palavra": "que" },
        { "hebraico": "הִכְרַ֔תִּי", "transliteral": "hiḵ-rat-tî", "traducao_palavra": "destruí" },
        { "hebraico": "וְהַיָּ֥ם", "transliteral": "wə-hay-yām", "traducao_palavra": "e o mar" },
        { "hebraico": "הַגָּדֹ֖ול", "transliteral": "hag-gā-ḏôl", "traducao_palavra": "o grande" },
        { "hebraico": "מְבֹ֥וא", "transliteral": "mə-ḇô", "traducao_palavra": "entrar [pôr]" },
        { "hebraico": "הַשָּֽׁמֶשׁ׃", "transliteral": "haš-šā-meš", "traducao_palavra": "do sol" }
      ]
    },
    "5": {
      "traducao_completa": "E YHWH vosso Deus as impelirá de diante de vós, e as expulsará de diante de vós; e vós possuireis a sua terra, como YHWH vosso Deus vos tem dito.",
      "palavras": [
