        { "hebraico": "וְהֹורִ֥ישׁ", "transliteral": "wə-hô-rîš", "traducao_palavra": "e os desapossará [expulsará]" },
        { "hebraico": "אֹתָ֖ם", "transliteral": "ʾō-ṯām", "traducao_palavra": "eles" },
