        { "hebraico": "הַיֹּ֥ום", "transliteral": "hay-yôm", "traducao_palavra": "o dia" },
        { "hebraico": "הַזֶּֽה׃", "transliteral": "haz-zeh", "traducao_palavra": "este" }
      ]
    },
    "10": {
      "traducao_completa": "Um só homem de vós perseguirá a mil; pois YHWH vosso Deus é quem peleja por vós, como já vos tem dito.",
