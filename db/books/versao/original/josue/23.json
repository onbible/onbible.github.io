        { "hebraico": "אִם־בַּיְהוָ֥ה", "transliteral": "ʾim-bay-YHWH", "traducao_palavra": "se em YHWH [a YHWH]" },
        { "hebraico": "אֱלֹהֵיכֶ֖ם", "transliteral": "ʾĕ-lō-hê-ḵem", "traducao_palavra": "vosso Deus" },
        { "hebraico": "תִּדְבָּ֑קוּ", "transliteral": "tiḏ-bā-qū", "traducao_palavra": "vos apegareis" },
        { "hebraico": "כַּאֲשֶׁ֣ר", "transliteral": "ka-ʾă-šer", "traducao_palavra": "conforme" },
        { "hebraico": "עֲשִׂיתֶ֔ם", "transliteral": "ʿă-śî-ṯem", "traducao_palavra": "fizestes" },
        { "hebraico": "עַ֖ד", "transliteral": "ʿaḏ", "traducao_palavra": "até" },
