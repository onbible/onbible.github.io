        { "hebraico": "מִפְּנֵיכֶ֛ם", "transliteral": "mip-pə-nê-ḵem", "traducao_palavra": "de diante de vós" },
        { "hebraico": "גֹּויִ֖ם", "transliteral": "gô-yim", "traducao_palavra": "nações" },
        { "hebraico": "גְּדֹלִ֣ים", "transliteral": "gə-ḏō-lîm", "traducao_palavra": "grandes" },
