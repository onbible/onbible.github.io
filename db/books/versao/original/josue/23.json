        { "hebraico": "אֱלֹהֵיכֶ֜ם", "transliteral": "ʾĕ-lō-hê-ḵem", "traducao_palavra": "vosso Deus" },
        { "hebraico": "ה֣וּא", "transliteral": "hū", "traducao_palavra": "ele" },
        { "hebraico": "יֶהְדֳּפֵ֤ם", "transliteral": "yeh-do-p̄ēm", "traducao_palavra": "os impelirá" },
