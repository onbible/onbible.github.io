{
  "livro": "Josué - יְהֹושֻׁ֫עַ - Yehoshua",
  "capitulo": 23,
  "titulos": {},
  "versiculos": {
    "1": {
      "traducao_completa": "E sucedeu que, muitos dias depois que YHWH dera repouso a Israel de todos os seus inimigos em redor, e sendo Josué já velho e entrado em dias,",
      "palavras": [
        { "hebraico": "וַיְהִי֙", "transliteral": "way-hî", "traducao_palavra": "e sucedeu" },
        { "hebraico": "מִיָּמִ֣ים", "transliteral": "miy-yā-mîm", "traducao_palavra": "de [muitos] dias" },
        { "hebraico": "רַבִּ֔ים", "transliteral": "rab-bîm", "traducao_palavra": "muitos" },
        { "hebraico": "אַ֠חֲרֵי", "transliteral": "ʾa-ḥă-rê", "traducao_palavra": "depois que" },
        { "hebraico": "אֲשֶׁר־הֵנִ֨יחַ", "transliteral": "ʾă-šer-hē-nî-aḥ", "traducao_palavra": "que deu repouso" },
        { "hebraico": "יְהוָ֧ה", "transliteral": "YHWH", "traducao_palavra": "YHWH" },
        { "hebraico": "לְיִשְׂרָאֵ֛ל", "transliteral": "lə-yiś-rā-ʾēl", "traducao_palavra": "para Israel" },
        { "hebraico": "מִכָּל־אֹיְבֵיהֶ֖ם", "transliteral": "mik-kāl-ʾō-yə-ḇê-hem", "traducao_palavra": "de todos os seus inimigos" },
        { "hebraico": "מִסָּבִ֑יב", "transliteral": "mis-sā-ḇîḇ", "traducao_palavra": "em redor" },
        { "hebraico": "וִיהֹושֻׁ֣עַ", "transliteral": "wî-hō-šu-aʿ", "traducao_palavra": "e Josué" },
        { "hebraico": "זָקֵ֔ן", "transliteral": "zā-qēn", "traducao_palavra": "velho" },
        { "hebraico": "בָּ֖א", "transliteral": "bā", "traducao_palavra": "veio" },
        { "hebraico": "בַּיָּמִֽים׃", "transliteral": "bay-yā-mîm", "traducao_palavra": "nos dias [avançado em dias]" }
      ]
    },
    "2": {
      "traducao_completa": "Chamou Josué a todo o Israel, aos seus anciãos, e aos seus cabeças, e aos seus juízes, e aos seus oficiais, e disse-lhes: Eu já sou velho e entrado em dias,",
      "palavras": [
        { "hebraico": "וַיִּקְרָ֤א", "transliteral": "way-yiq-rā", "traducao_palavra": "e chamou" },
        { "hebraico": "יְהֹושֻׁ֙עַ֙", "transliteral": "yə-hô-šu-aʿ", "traducao_palavra": "Josué" },
        { "hebraico": "לְכָל־יִשְׂרָאֵ֔ל", "transliteral": "lə-ḵāl-yiś-rā-ʾēl", "traducao_palavra": "a todo Israel" },
        { "hebraico": "לִזְקֵנָיו֙", "transliteral": "li-zə-qē-nāw", "traducao_palavra": "aos seus anciãos" },
        { "hebraico": "וּלְרָאשָׁ֔יו", "transliteral": "ū-lə-rā-šāw", "traducao_palavra": "e aos seus cabeças" },
        { "hebraico": "וּלְשֹׁפְטָ֖יו", "transliteral": "ū-lə-šō-p̄ə-ṭāw", "traducao_palavra": "e aos seus juízes" },
        { "hebraico": "וּלְשֹׁטְרָ֑יו", "transliteral": "ū-lə-šō-ṭə-rāw", "traducao_palavra": "e aos seus oficiais" },
        { "hebraico": "וַיֹּ֣אמֶר", "transliteral": "way-yō-mer", "traducao_palavra": "e disse" },
        { "hebraico": "אֲלֵהֶ֔ם", "transliteral": "ʾă-lê-hem", "traducao_palavra": "a eles" },
        { "hebraico": "אֲנִ֣י", "transliteral": "ʾă-nî", "traducao_palavra": "eu" },
        { "hebraico": "זָקַ֔נְתִּי", "transliteral": "zā-qan-tî", "traducao_palavra": "envelheci" },
        { "hebraico": "בָּ֭אתִי", "transliteral": "bā-ṯî", "traducao_palavra": "entrei" },
        { "hebraico": "בַּיָּמִֽים׃", "transliteral": "bay-yā-mîm", "traducao_palavra": "nos dias" }
      ]
    },
    "3": {
      "traducao_completa": "E vós tendes visto tudo quanto YHWH vosso Deus fez a todas estas nações por causa de vós; porque YHWH vosso Deus é o que pelejou por vós.",
      "palavras": [
        { "hebraico": "וְאַתֶּ֣ם", "transliteral": "wə-ʾat-tem", "traducao_palavra": "e vós" },
        { "hebraico": "רְאִיתֶם֮", "transliteral": "rə-ʾî-ṯem", "traducao_palavra": "vistes" },
        { "hebraico": "אֵ֣ת", "transliteral": "ʾēṯ", "traducao_palavra": "o" },
        { "hebraico": "כָּל־אֲשֶׁר֩", "transliteral": "kāl-ʾă-šer", "traducao_palavra": "tudo quanto" },
