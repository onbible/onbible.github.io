        { "hebraico": "תִשְׁתַּחֲו֖וּ", "transliteral": "tiš-ta-ḥă-wū", "traducao_palavra": "vos inclinareis" },
        { "hebraico": "לָהֶֽם׃", "transliteral": "lā-hem", "traducao_palavra": "a eles" }
      ]
