    "6": {
      "traducao_completa": "Esforçai-vos, pois, muito para guardardes e para fazerdes tudo quanto está escrito no livro da lei de Moisés; para que dele não vos aparteis nem para a direita nem para a esquerda;",
      "palavras": [
        { "hebraico": "וַחֲזַקְתֶּ֣ם", "transliteral": "wa-ḥă-zaq-tem", "traducao_palavra": "e esforçai-vos" },
        { "hebraico": "מְאֹ֔ד", "transliteral": "mə-ʾōḏ", "traducao_palavra": "muito" },
        { "hebraico": "לִשְׁמֹ֣ר", "transliteral": "liš-mōr", "traducao_palavra": "para guardar" },
        { "hebraico": "וְלַעֲשֹׂ֔ות", "transliteral": "wə-la-ʿă-śôṯ", "traducao_palavra": "e para fazer" },
        { "hebraico": "אֵ֚ת", "transliteral": "ʾēṯ", "traducao_palavra": "o" },
        { "hebraico": "כָּל־הַכָּת֔וּב", "transliteral": "kāl-hak-kā-ṯūḇ", "traducao_palavra": "tudo o escrito" },
        { "hebraico": "בְּסֵ֖פֶר", "transliteral": "bə-sē-p̄er", "traducao_palavra": "no livro de" },
        { "hebraico": "תֹּורַ֣ת", "transliteral": "tô-raṯ", "traducao_palavra": "lei de" },
        { "hebraico": "מֹשֶׁ֑ה", "transliteral": "mō-šeh", "traducao_palavra": "Moisés" },
        { "hebraico": "לְבִלְתִּ֥י", "transliteral": "lə-ḇil-tî", "traducao_palavra": "para não" },
        { "hebraico": "סוּר־מִמֶּ֖נּוּ", "transliteral": "sūr-mim-men-nū", "traducao_palavra": "apartar dele" },
        { "hebraico": "יָמִ֥ין", "transliteral": "yā-mîn", "traducao_palavra": "direita" },
