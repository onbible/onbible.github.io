        { "hebraico": "אֲשֶׁ֥ר", "transliteral": "ʾă-šer", "traducao_palavra": "que" },
        { "hebraico": "תֵּלֵֽךְ׃", "transliteral": "tê-lēḵ", "traducao_palavra": "andares" }
      ]
