        { "hebraico": "וְהַלְּבָנֹ֨ון", "transliteral": "wə-hal-lə-ḇā-nôn", "traducao_palavra": "e o Líbano" },
        { "hebraico": "הַזֶּ֜ה", "transliteral": "haz-zeh", "traducao_palavra": "este" },
