        { "hebraico": "לַעֲשֹׂ֔ות", "transliteral": "la-ʿă-śôṯ", "traducao_palavra": "em fazer" },
        { "hebraico": "כְּכָל־הַכָּת֖וּב", "transliteral": "kə-ḵāl-hak-kā-ṯûḇ", "traducao_palavra": "conforme tudo o escrito" },
