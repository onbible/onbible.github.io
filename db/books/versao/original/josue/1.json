    "7": {
      "traducao_completa": "Tão-somente esforça-te e tem mui bom ânimo, para teres o cuidado de fazer conforme a toda a lei que meu servo Moisés te ordenou; dela não te desvies, nem para a direita nem para a esquerda, para que prudentemente te conduzas por onde quer que andares.",
      "palavras": [
        { "hebraico": "רַק֩", "transliteral": "raq", "traducao_palavra": "apenas/tão-somente" },
        { "hebraico": "חֲזַ֨ק", "transliteral": "ḥă-zaq", "traducao_palavra": "esforça-te" },
        { "hebraico": "וֶאֱמַ֜ץ", "transliteral": "we-ʾĕ-maṣ", "traducao_palavra": "e sê corajoso" },
        { "hebraico": "מְאֹ֗ד", "transliteral": "mə-ʾōḏ", "traducao_palavra": "muito" },
        { "hebraico": "לִשְׁמֹ֤ר", "transliteral": "liš-mōr", "traducao_palavra": "para guardar" },
