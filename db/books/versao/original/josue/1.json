        { "hebraico": "וֶאֱמָ֔ץ", "transliteral": "we-ʾĕ-māṣ", "traducao_palavra": "e tem bom ânimo" },
        { "hebraico": "אַל־תַּעֲרֹ֖ץ", "transliteral": "ʾal-ta-ʿă-rōṣ", "traducao_palavra": "não te aterrorizes" },
        { "hebraico": "וְאַל־תֵּחָ֑ת", "transliteral": "wə-al-tē-ḥāṯ", "traducao_palavra": "e não te espantes" },
