        { "hebraico": "סֵפֶר", "transliteral": "śē-p̄er", "traducao_palavra": "o livro de" },
        { "hebraico": "הַתֹּורָ֤ה", "transliteral": "hat-tô-rā", "traducao_palavra": "a lei" },
