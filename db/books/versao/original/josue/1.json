        { "hebraico": "הֲלֹ֤וא", "transliteral": "hă-lô", "traducao_palavra": "porventura não?" },
        { "hebraico": "צִוִּיתִ֙יךָ֙", "transliteral": "ṣiw-wî-ṯî-ḵā", "traducao_palavra": "ordenei a ti" },
