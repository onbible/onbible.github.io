    "6": {
      "traducao_completa": "Esforça-te, e tem bom ânimo; porque tu farás a este povo herdar a terra que jurei a seus pais lhes dar.",
      "palavras": [
        { "hebraico": "חֲזַ֖ק", "transliteral": "ḥă-zaq", "traducao_palavra": "sê forte/esforça-te" },
