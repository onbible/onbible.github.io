  "versiculos": {
    "1": {
      "traducao_completa": "Isto, pois, é o que os filhos de Israel tomaram em herança na terra de Canaã, o que Eleazar, o sacerdote, e Josué, filho de Num, e os cabeças dos pais das tribos dos filhos de Israel lhes fizeram repartir,",
      "palavras": [
