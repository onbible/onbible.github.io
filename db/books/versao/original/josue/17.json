        { "hebraico": "הַיֹּשֵׁ֣ב", "transliteral": "hay-yô-šēḇ", "traducao_palavra": "o habitante" },
        { "hebraico": "בְּאֶֽרֶץ־הָעֵ֔מֶק", "transliteral": "bə-ʾe-reṣ-hā-ʿē-meq", "traducao_palavra": "na terra do vale" },
