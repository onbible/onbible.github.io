        { "hebraico": "בָּ֖א", "transliteral": "bā", "traducao_palavra": "entrado" },
        { "hebraico": "בַּיָּמִ֑ים", "transliteral": "bay-yā-mîm", "traducao_palavra": "nos dias" },
