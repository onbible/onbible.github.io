        { "hebraico": "וְהָאָ֧רֶץ", "transliteral": "wə-hā-ʾā-reṣ", "traducao_palavra": "e a terra" },
        { "hebraico": "נִשְׁאֲרָ֛ה", "transliteral": "niš-ʾă-rā", "traducao_palavra": "ficou" },
