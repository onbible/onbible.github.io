        { "hebraico": "חֲמֵ֣שֶׁת", "transliteral": "ḥă-mē-šeṯ", "traducao_palavra": "cinco" },
        { "hebraico": "סַרְנֵ֣י", "transliteral": "sar-nê", "traducao_palavra": "príncipes de" },
