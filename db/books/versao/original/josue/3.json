        { "hebraico": "בַּבֹּ֗קֶר", "transliteral": "bab-bō-qer", "traducao_palavra": "pela manhã" },
        { "hebraico": "וַיִּסְע֣וּ", "transliteral": "way-yis-ʿû", "traducao_palavra": "e partiram" },
