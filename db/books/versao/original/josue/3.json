        { "hebraico": "יָמִ֑ים", "transliteral": "yā-mîm", "traducao_palavra": "dias" },
        { "hebraico": "וַיַּעַבְר֥וּ", "transliteral": "way-ya-ʿaḇ-rû", "traducao_palavra": "e passaram" },
